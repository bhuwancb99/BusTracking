@model BusTracking.Common.DTOs.Dashboard.DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard"; ViewData["Breadcrumb"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Dashboard</h4>
    <span class="text-muted small"><i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</span>
</div>

@if (Model is not null)
{
    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-primary mb-2"><i class="bi bi-bus-front fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.TotalBuses</div>
                    <div class="stat-label text-muted small">Total Buses</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="Bus" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-success mb-2"><i class="bi bi-person-video2 fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.TotalDrivers</div>
                    <div class="stat-label text-muted small">Drivers</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="Driver" asp-action="Index" class="btn btn-sm btn-outline-success">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-warning mb-2"><i class="bi bi-person-badge fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.TotalBusCoordinators</div>
                    <div class="stat-label text-muted small">Coordinators</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="SubAdmin" asp-action="Index" class="btn btn-sm btn-outline-warning">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-info mb-2"><i class="bi bi-people fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.TotalParents</div>
                    <div class="stat-label text-muted small">Parents</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="Parent" asp-action="Index" class="btn btn-sm btn-outline-info">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-secondary mb-2"><i class="bi bi-mortarboard fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.TotalStudents</div>
                    <div class="stat-label text-muted small">Students</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="Student" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-2">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <div class="stat-icon text-danger mb-2"><i class="bi bi-geo-alt fs-1"></i></div>
                    <div class="stat-value fw-bold fs-2">@Model.ActiveTrips</div>
                    <div class="stat-label text-muted small">Active Trips</div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <span class="badge bg-danger-subtle text-danger px-3 py-2">Live</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick actions -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
            <i class="bi bi-lightning me-2 text-warning"></i>Quick Actions
        </div>
        <div class="card-body px-4 pb-4">
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Bus" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-plus-circle me-1"></i>Add Bus</a>
                <a asp-controller="Driver" asp-action="Create" class="btn btn-outline-success"><i class="bi bi-plus-circle me-1"></i>Add Driver</a>
                <a asp-controller="Student" asp-action="Create" class="btn btn-outline-info">   <i class="bi bi-plus-circle me-1"></i>Add Student</a>
                <a asp-controller="Route" asp-action="Create" class="btn btn-outline-secondary"><i class="bi bi-plus-circle me-1"></i>Add Route</a>
                <a asp-controller="Parent" asp-action="Create" class="btn btn-outline-warning"><i class="bi bi-plus-circle me-1"></i>Add Parent</a>
            </div>
        </div>
    </div>
}
