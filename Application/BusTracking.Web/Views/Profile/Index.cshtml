@* Views/Profile/Index.cshtml — UPDATED
   Shared by ALL roles: Driver, Student, Parent, SuperAdmin, Coordinator
   Camera button on avatar → instant upload → avatar updates live
*@
@model BusTracking.Common.DTOs.User.UserProfileDto
@{
    ViewData["Title"] = "My Profile";
    ViewData["Breadcrumb"] = "My Profile";
    var hasPhoto = !string.IsNullOrEmpty(Model?.ProfileImageUrl);
    var initials = Model?.FullName?.ToInitials() ?? "?";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">

                <!-- Banner -->
                <div class="rounded-top" style="background:linear-gradient(135deg,#3d5af1,#e94560);height:100px;"></div>

                <div class="px-4 pb-4">
                    <div class="d-flex align-items-end gap-3 mt-n4 mb-4">

                        <!-- ── Avatar with camera overlay ── -->
                        <div class="position-relative" style="flex-shrink:0;width:72px;height:72px;">
                            @if (hasPhoto)
                            {
                                <img id="profileAvatar"
                                     src="@Model!.ProfileImageUrl"
                                     alt="Profile"
                                     class="rounded-circle border border-3 border-white shadow"
                                     style="width:72px;height:72px;object-fit:cover;" />
                            }
                            else
                            {
                                <div id="profileAvatar"
                                     class="rounded-circle border border-3 border-white shadow bg-white d-flex align-items-center justify-content-center"
                                     style="width:72px;height:72px;font-size:1.6rem;font-weight:700;color:#3d5af1;">
                                    @initials
                                </div>
                            }

                            <!-- Camera button overlay -->
                            <label for="profileFileInput"
                                   class="position-absolute bottom-0 end-0 d-flex align-items-center justify-content-center
                                btn btn-primary rounded-circle shadow-sm"
                                   style="width:26px;height:26px;cursor:pointer;padding:0;"
                                   title="Change profile photo">
                                <i class="bi bi-camera-fill" style="font-size:.7rem;"></i>
                                <input type="file" id="profileFileInput" class="d-none"
                                       accept="image/jpeg,image/png,image/webp"
                                       onchange="uploadMyProfile(this)" />
                            </label>
                        </div>

                        <!-- Name + role -->
                        <div class="pb-1">
                            <h5 class="fw-bold mb-0">@Model?.FullName</h5>
                            <span class="badge bg-primary-subtle text-primary">@Model?.Role</span>
                            <div id="profileImgMsg" class="small mt-1" style="min-height:18px;"></div>
                        </div>

                        <!-- Actions -->
                        <div class="ms-auto d-flex gap-2 pb-1 flex-wrap justify-content-end">
                            @if (hasPhoto)
                            {
                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        onclick="deleteMyProfile()">
                                    <i class="bi bi-trash me-1"></i>Remove Photo
                                </button>
                            }
                            <a asp-action="Edit" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a asp-controller="Auth" asp-action="ChangePassword"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-key me-1"></i>Change Password
                            </a>
                        </div>
                    </div>

                    <table class="table table-borderless">
                        <tr><th class="text-muted small w-35">Email</th><td>@Model?.Email</td></tr>
                        <tr><th class="text-muted small">Phone</th><td>@(Model?.PhoneNumber ?? "–")</td></tr>
                        <tr><th class="text-muted small">Role</th><td>@Model?.Role</td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        const _tok = () => document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // ── Upload own profile photo ──────────────────────────────────────
        async function uploadMyProfile(input) {
            if (!input.files || !input.files[0]) return;
            const msg = document.getElementById('profileImgMsg');
            msg.innerHTML = '<span class="text-muted"><span class="spinner-border spinner-border-sm me-1"></span>Uploading…</span>';

            const fd = new FormData();
            fd.append('file', input.files[0]);

            try {
                const res  = await fetch('/Image/UploadMyProfile', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': _tok() },
                    body: fd
                });
                const json = await res.json();

                if (json.success) {
                    // Swap initials div → real photo (or refresh existing photo)
                    const avatar = document.getElementById('profileAvatar');
                    const newSrc = json.imageUrl + '?v=' + Date.now();

                    if (avatar.tagName === 'IMG') {
                        avatar.src = newSrc;
                    } else {
                        // Replace div with img
                        const img = document.createElement('img');
                        img.id        = 'profileAvatar';
                        img.src       = newSrc;
                        img.alt       = 'Profile';
                        img.className = 'rounded-circle border border-3 border-white shadow';
                        img.style     = 'width:72px;height:72px;object-fit:cover;';
                        avatar.replaceWith(img);
                    }

                    // Also update top-navbar avatar if present
                    updateNavbarAvatar(newSrc);

                    msg.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Photo saved.</span>';
                    setTimeout(() => location.reload(), 900); // reload to show Remove button
                } else {
                    msg.innerHTML = `<span class="text-danger">${json.message}</span>`;
                }
            } catch {
                msg.innerHTML = '<span class="text-danger">Upload failed. Try again.</span>';
            }
            input.value = '';
        }

        // ── Delete own profile photo ──────────────────────────────────────
        async function deleteMyProfile() {
            if (!confirm('Remove your profile photo?')) return;
            const msg = document.getElementById('profileImgMsg');
            msg.innerHTML = '<span class="text-muted">Removing…</span>';
            try {
                const res  = await fetch('/Image/DeleteMyProfile', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': _tok() }
                });
                const json = await res.json();
                if (json.success) location.reload();
                else msg.innerHTML = '<span class="text-danger">Error removing photo.</span>';
            } catch {
                msg.innerHTML = '<span class="text-danger">Error. Try again.</span>';
            }
        }

        // ── Update navbar avatar (if _Layout has an img#navAvatar) ───────
        function updateNavbarAvatar(src) {
            const el = document.getElementById('navAvatar');
            if (el) el.src = src;
        }
    </script>
}
