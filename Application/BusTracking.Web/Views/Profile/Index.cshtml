@* ── Profile/Index.cshtml ─────────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.User.UserProfileDto
@{
    ViewData["Title"] = "My Profile"; ViewData["Breadcrumb"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <!-- Header banner -->
                <div class="rounded-top" style="background:linear-gradient(135deg,#3d5af1,#e94560);height:100px"></div>
                <div class="px-4 pb-4">
                    <div class="d-flex align-items-end gap-3 mt-n4 mb-4">
                        <div class="avatar-xl bg-white rounded-circle border border-3 border-white shadow d-flex align-items-center justify-content-center"
                             style="width:72px;height:72px;font-size:1.8rem;font-weight:700;color:#3d5af1;flex-shrink:0">
                            @Model?.FullName.ToInitials()
                        </div>
                        <div class="pb-1">
                            <h5 class="fw-bold mb-0">@Model?.FullName</h5>
                            <span class="badge bg-primary-subtle text-primary">@Model?.Role</span>
                        </div>
                        <div class="ms-auto d-flex gap-2 pb-1">
                            <a asp-action="Edit" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
                            <a asp-controller="Auth" asp-action="ChangePassword" class="btn btn-outline-secondary btn-sm"><i class="bi bi-key me-1"></i>Change Password</a>
                        </div>
                    </div>

                    <table class="table table-borderless">
                        <tr><th class="text-muted small w-35">Email</th><td>@Model?.Email</td></tr>
                        <tr><th class="text-muted small">Phone</th><td>@(Model?.PhoneNumber ?? "–")</td></tr>
                        <tr><th class="text-muted small">Role</th><td>@Model?.Role</td></tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
