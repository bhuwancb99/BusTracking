@* ── Feedback/Index.cshtml (Admin) ───────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Feedback.FeedbackListDto>
@{
    ViewData["Title"] = "Help & Support"; ViewData["Breadcrumb"] = "Help & Support";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-headset me-2 text-primary"></i>Help & Support</h4>
    <div class="d-flex gap-2">
        @foreach (var status in new[] { "", "Open", "InProgress", "Resolved", "Closed" })
        {
            var label = status == "" ? "All" : status;
            var active = (ViewBag.Status as string ?? "") == status;
            <a asp-action="Index" asp-route-status="@status"
               class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary")">@label</a>
        }
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model?.Items.Count == 0)
        {
            <div class="text-center text-muted py-5"><i class="bi bi-headset fs-1 d-block mb-2"></i>No feedback found.</div>
        }
        else
        {
            @foreach (var f in Model!.Items)
            {
                <div class="p-4 border-bottom">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <span class="badge @(f.Category == "Complaint" ? "bg-danger-subtle text-danger" : "bg-info-subtle text-info") me-2">
                                @f.Category
                            </span>
                            <strong>@f.UserName</strong>
                            <span class="text-muted small ms-2">@f.Email</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            @{
                                var statusCss = f.Status switch
                                {
                                    "Open" => "bg-warning-subtle text-warning",
                                    "InProgress" => "bg-primary-subtle text-primary",
                                    "Resolved" => "bg-success-subtle text-success",
                                    _ => "bg-secondary-subtle text-secondary"
                                };
                            }
                            <span class="badge @statusCss">@f.Status</span>
                            <span class="text-muted small">@f.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                    <p class="mt-2 mb-2 text-muted small">@f.Description</p>
                    @if (f.Status is "Open" or "InProgress")
                    {
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var s in new[] { "InProgress", "Resolved", "Closed" })
                            {
                                <form asp-action="UpdateStatus" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@f.FeedbackId" />
                                    <input type="hidden" name="status" value="@s" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                                        Mark @s
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
    @if (Model is not null && Model.TotalPages > 1)
    {
        <div class="p-3">
            <partial name="_Pagination" model="Model" />
        </div>
    }
</div>
