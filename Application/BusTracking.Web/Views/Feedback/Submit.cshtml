@model BusTracking.Common.DTOs.Feedback.CreateFeedbackDto
@{
    ViewData["Title"] = "Help & Support"; ViewData["Breadcrumb"] = "Help & Support";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-headset me-2 text-primary"></i>Submit Inquiry or Complaint
            </div>
            <div class="card-body p-4">
                @if (TempData["SuccessMessage"] is string msg)
                {
                    <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i>@msg</div>
                }

                <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
                <form asp-action="Submit" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Category" value="Inquiry" id="catInquiry" checked />
                                <label class="form-check-label" for="catInquiry">
                                    <i class="bi bi-question-circle me-1 text-info"></i>Inquiry
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Category" value="Complaint" id="catComplaint" />
                                <label class="form-check-label" for="catComplaint">
                                    <i class="bi bi-exclamation-circle me-1 text-danger"></i>Complaint
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Optional" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="5"
                                      placeholder="Describe your issue or question…"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-send me-1"></i>Submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
