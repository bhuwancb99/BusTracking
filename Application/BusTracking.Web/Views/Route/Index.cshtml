@* ── Route/Index.cshtml ──────────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Route.RouteListDto>
@{
    ViewData["Title"] = "Routes"; ViewData["Breadcrumb"] = "Routes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-map me-2 text-primary"></i>Routes</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Route</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" style="max-width:300px" placeholder="Search route name or code…" />
            <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
            }
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>#</th><th>Route Name</th><th>Code</th><th>Morning</th><th>Evening</th><th>Stops</th><th>Status</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4"><i class="bi bi-map fs-2 d-block mb-2"></i>No routes found.</td></tr>
                    }

                    @foreach (var (r, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td class="fw-semibold">@r.RouteName</td>
                            <td><code class="bg-light px-2 py-1 rounded small">@r.RouteCode</code></td>
                            <td><span class="small"><i class="bi bi-sunrise me-1 text-warning"></i>@(r.MorningTime ?? "–")</span></td>
                            <td><span class="small"><i class="bi bi-sunset me-1 text-secondary"></i>@(r.EveningTime ?? "–")</span></td>
                            <td><span class="badge bg-info-subtle text-info">@r.StopCount stops</span></td>
                            <td><span class="badge @(r.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(r.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@r.RouteId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@r.RouteId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-action="Delete" asp-route-id="@r.RouteId" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete route @r.RouteName?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model" />
    </div>
</div>
