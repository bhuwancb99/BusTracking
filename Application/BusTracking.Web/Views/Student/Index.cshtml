@* ── Student/Index ───────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Student.StudentListDto>
@{
    ViewData["Title"] = "Students"; ViewData["Breadcrumb"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard me-2 text-info"></i>Students</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Student</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" style="max-width:280px" placeholder="Search name or student code…" />
            <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
            }
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>#</th><th>Student Code</th><th>Name</th><th>Class</th><th>Bus</th><th>Stop</th><th>Status</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No students found.</td></tr>
                    }
                    @foreach (var (s, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td><code>@s.StudentCode</code></td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td>@(s.Standard ?? "–")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.BusNumber))
                                {
                                    @s.BusNumber
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </td>
                            <td>@(s.StopName ?? "–")</td>
                            <td><span class="badge @(s.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Availability" asp-route-studentId="@s.StudentId" class="btn btn-sm btn-outline-info me-1" title="Availability"><i class="bi bi-calendar-check"></i></a>
                                <form asp-action="Delete" asp-route-id="@s.StudentId" method="post" class="d-inline" onsubmit="return confirm('Delete this student?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model is not null && Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@ViewBag.Search">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>