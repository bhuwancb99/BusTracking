@* ── Driver/Create.cshtml ─────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Driver.CreateDriverDto
@{
    ViewData["Title"] = "Add Driver"; ViewData["Breadcrumb"] = "Drivers / Add";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-person-plus me-2 text-success"></i>Add New Driver
            </div>
            <div class="card-body p-4">
                <div asp-validation-summary="All" class="alert alert-danger py-2 d-none" id="valSummary"></div>
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Driver full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="driver@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+91 98765 43210" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenseNumber" class="form-label fw-semibold">License Number</label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="DL-1234567890" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenseExpiry" class="form-label fw-semibold">License Expiry Date</label>
                            <input asp-for="LicenseExpiry" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="alert alert-info py-2 mt-3 small">
                        <i class="bi bi-info-circle me-1"></i>
                        A temporary password will be emailed to the driver automatically.
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-success px-4"><i class="bi bi-check2 me-1"></i>Save Driver</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
