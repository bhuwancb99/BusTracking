@model BusTracking.Common.DTOs.Auth.ResetPasswordDto
@{ Layout = null; ViewData["Title"] = "Reset Password"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
<div class="card shadow-lg border-0 p-5" style="width:100%;max-width:420px">
    <div class="text-center mb-4">
        <i class="bi bi-shield-lock text-primary" style="font-size:2.5rem"></i>
        <h4 class="fw-bold mt-2">Set New Password</h4>
    </div>
    <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Token" type="hidden" value="@ViewBag.Token"/>
        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Min 8 characters"/>
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>
        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password"/>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">Reset Password</button>
    </form>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
