@* ── ForgotPassword ─────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Auth.ForgotPasswordDto
@{ Layout = null; ViewData["Title"] = "Forgot Password"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
<div class="card shadow-lg border-0" style="width:100%;max-width:420px">
    <div class="card-body p-5">
        <div class="text-center mb-4">
            <i class="bi bi-key text-primary" style="font-size:2.5rem"></i>
            <h4 class="fw-bold mt-2">Forgot Password?</h4>
            <p class="text-muted small">Enter your email to receive a reset link.</p>
        </div>
        <div asp-validation-summary="All" class="alert alert-danger py-2 d-none"></div>
        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com"/>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2">Send Reset Link</button>
        </form>
        <div class="text-center mt-3">
            <a asp-action="Login" class="small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
