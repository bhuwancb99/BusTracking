@* ── ChangePassword ──────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Auth.ChangePasswordDto
@{ ViewData["Title"] = "Change Password"; ViewData["Breadcrumb"] = "Change Password"; }
<div class="row justify-content-center">
<div class="col-md-6 col-lg-5">
<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
        <i class="bi bi-key me-2 text-primary"></i>Change Password
    </div>
    <div class="card-body p-4">
        <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label fw-semibold">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control"/>
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Min 8 characters"/>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control"/>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
