@* Parent/Dashboard/Index.cshtml *@
@{
    ViewData["Title"] = "Parent Dashboard";
}
<div class="mb-4">
    <h4 class="fw-bold mb-0">Welcome, @User.Identity?.Name?.Split(' ').FirstOrDefault()</h4>
    <p class="text-muted small">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
</div>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <i class="bi bi-geo-alt-fill text-danger fs-1 mb-3"></i>
            <h6 class="fw-semibold">Track Bus</h6>
            <p class="text-muted small">See where your child's bus is right now.</p>
            <a asp-area="Parent" asp-controller="Tracking" asp-action="Track" asp-route-tripId="0"
               class="btn btn-danger btn-sm mt-auto">Open Map</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <i class="bi bi-calendar-check-fill text-info fs-1 mb-3"></i>
            <h6 class="fw-semibold">Manage Availability</h6>
            <p class="text-muted small">Mark leave, holiday or parent pickup days.</p>
            <a asp-area="Parent" asp-controller="Home" asp-action="Availability" asp-route-studentId="0"
               class="btn btn-info btn-sm mt-auto text-white">Manage</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <i class="bi bi-headset text-secondary fs-1 mb-3"></i>
            <h6 class="fw-semibold">Help & Support</h6>
            <p class="text-muted small">Submit an inquiry or complaint.</p>
            <a asp-area="Parent" asp-controller="Feedback" asp-action="Submit"
               class="btn btn-outline-secondary btn-sm mt-auto">Contact Us</a>
        </div>
    </div>
</div>
