@using BusTracking.Common.Helpers
@inject BusTracking.Common.Data.AppDbContext DbContext
@inject BusTracking.Common.Interfaces.ICurrentUserService CurrentUser
@{
    string? schoolName = null;
    string? schoolLogo = null;
    string? userPhoto = null;
    var sId = CurrentUser.SchoolId;
    if (sId.HasValue)
    {
        var school = DbContext.Schools.IgnoreQueryFilters().FirstOrDefault(s => s.SchoolId == sId.Value);
        if (school != null)
        {
            schoolName = school.SchoolName;
            schoolLogo = school.SchoolLogo;
        }
    }
    var uId = CurrentUser.UserId;
    if (uId.HasValue)
    {
        var dbUser = DbContext.Users.IgnoreQueryFilters().FirstOrDefault(u => u.UserId == uId.Value);
        if (dbUser != null)
        {
            userPhoto = dbUser.ProfileImageUrl;
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] – Parent | Bus Tracking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex">
    <nav id="sidebar" class="sidebar d-flex flex-column">
        <div class="sidebar-brand">
            @if (!string.IsNullOrEmpty(schoolLogo))
            {
                <img src="@schoolLogo" alt="School Logo" class="me-2 rounded-circle" style="width: 32px; height: 32px; object-fit: cover;" />
            }
            else
            {
                <i class="bi bi-bus-front-fill me-2"></i>
            }

            @if (!string.IsNullOrEmpty(schoolName))
            {
                <span>@schoolName</span>
            }
            else
            {
                <span>BusTrack <small class="opacity-50">Parent</small></span>
            }
        </div>
        <ul class="sidebar-nav flex-grow-1">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                (string L, string I, string C, string A)[] items =
                [
                    ("Dashboard",     "bi-speedometer2",    "Dashboard","Index"),
                ("Track Bus",     "bi-geo-alt",         "Tracking", "Track"),
                ("Availability",  "bi-calendar-check",  "Home",     "Availability"),
                ("Help & Support","bi-headset",         "Feedback", "Submit"),
            ];
            }
            @foreach (var (l, i, c, a) in items)
            {
                <li class="sidebar-item @(ctrl == c ? "active" : "")">
                    <a class="sidebar-link" asp-area="Parent" asp-controller="@c" asp-action="@a">
                        <i class="bi @i"></i><span>@l</span>
                    </a>
                </li>
            }
        </ul>
        <div class="sidebar-footer">
            <a class="sidebar-link" asp-controller="Profile" asp-action="Index" asp-area="">
                @if (!string.IsNullOrEmpty(userPhoto))
                {
                    <img src="@userPhoto" alt="Profile" class="me-2 rounded-circle border border-secondary" style="width: 22px; height: 22px; object-fit: cover;" />
                }
                else
                {
                    <i class="bi bi-person-circle"></i>
                }
                <span>@User.GetFullName()</span>
            </a>
            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                    <i class="bi bi-box-arrow-left"></i><span>Logout</span>
                </button>
            </form>
        </div>
    </nav>
    <div class="main-wrapper flex-grow-1 d-flex flex-column">
        <header class="top-navbar">
            <button class="sidebar-toggle btn btn-sm btn-link" id="sidebarToggle"><i class="bi bi-list fs-4"></i></button>
            <span class="badge bg-info-subtle text-info ms-1 small">Parent Portal</span>
            <div class="ms-auto">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center gap-1" data-bs-toggle="dropdown">
                        @if (!string.IsNullOrEmpty(userPhoto))
                        {
                            <img src="@userPhoto" alt="Profile" class="rounded-circle border border-secondary" style="width: 18px; height: 18px; object-fit: cover;" />
                        }
                        else
                        {
                            <i class="bi bi-person-circle"></i>
                        }
                        <span>@User.GetFullName()</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index" asp-area=""><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword" asp-area=""><i class="bi bi-key me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-left me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>
        <main class="content-area flex-grow-1 p-4">
            @{
                var alert = BusTracking.Web.Helpers.AlertHelper.FromTempData(TempData);
            }
            @if (alert is not null)
            {
                <div class="alert @alert.CssClass alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi @alert.Icon"></i><span>@alert.Message</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
        <footer class="py-2 px-4 border-top text-muted small text-end">&copy; @DateTime.Now.Year Bus Tracking System</footer>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
