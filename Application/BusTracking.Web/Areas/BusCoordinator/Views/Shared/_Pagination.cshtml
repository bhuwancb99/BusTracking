@* ── _Pagination.cshtml ──────────────────────────────────────────────
   Usage: <partial name="_Pagination" model="Model" />
   Preserves every current query-string parameter (search, status,
   platform, busId, date, etc.) across page links — only "page" changes.
*@
@using BusTracking.Common.Models
@model dynamic

@{
    int currentPage = (int)(Model?.PageNumber ?? 1);
    int totalPages = (int)(Model?.TotalPages ?? 1);
    int totalCount = (int)(Model?.TotalCount ?? 0);
    int pageSize = (int)(Model?.PageSize ?? 10);
    string action = (string)(ViewContext.RouteData.Values["action"] ?? "Index");
    var pageNums = PaginationHelper.GetPageNumbers(currentPage, totalPages);

    // Forward every current query-string value except "page" so filters
    // (search, status, platform, busId, date, ...) survive pagination.
    Func<int, Dictionary<string, string>> routeFor = p =>
    {
        var values = new Dictionary<string, string>();
        foreach (var kv in ViewContext.HttpContext.Request.Query)
        {
            if (string.Equals(kv.Key, "page", StringComparison.OrdinalIgnoreCase)) continue;
            var v = kv.Value.ToString();
            if (!string.IsNullOrEmpty(v)) values[kv.Key] = v;
        }
        values["page"] = p.ToString();
        return values;
    };
}

@if (totalPages > 1)
{
    <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2">
        <small class="text-muted">
            Showing @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, totalCount))
            of <strong>@totalCount</strong> results
        </small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="@action" asp-all-route-data="@routeFor(currentPage - 1)">&laquo;</a>
                </li>
                @foreach (var p in pageNums)
                {
                    if (p is null)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link" asp-action="@action" asp-all-route-data="@routeFor(p.Value)">@p</a>
                        </li>
                    }
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="@action" asp-all-route-data="@routeFor(currentPage + 1)">&raquo;</a>
                </li>
            </ul>
        </nav>
    </div>
}
