@using BusTracking.Common.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] – Coordinator | Bus Tracking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex">

    <!-- ── Sidebar ─────────────────────────────────────────────── -->
    <nav id="sidebar" class="sidebar d-flex flex-column">
        <div class="sidebar-brand">
            <i class="bi bi-bus-front-fill"></i>
            <span>BusTrack <small class="opacity-50">Coord</small></span>
        </div>
        <ul class="sidebar-nav flex-grow-1">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                // Read permission claims — set by cookie at login
                var perms = User.Claims
                    .Where(c => c.Type == "permission")
                    .Select(c => c.Value)
                    .ToHashSet();
                bool Has(string key) => perms.Contains(key);

                // Dashboard always visible
                bool showAppConfig = Has("appconfig.view");
                bool showStandard = Has("standard.view");
                bool showBusType = Has("bustype.view");
                bool showSubAdmins = Has("subadmin.view");
                bool showRoutes = Has("route.view");
                bool showBuses = Has("bus.view");
                bool showDrivers = Has("driver.view");
                bool showParents = Has("parent.view");
                bool showStudents = Has("student.view");
                bool showTrips = Has("trip.view") || Has("trip.manage");
                bool showNotif = Has("notification.manage");
                bool showSupport = Has("helpsupport.view") || Has("helpsupport.manage");
                bool showlogs = Has("logs.view");
            }

            @* Dashboard — always visible *@
            <li class="sidebar-item @(ctrl == "Dashboard" ? "active" : "")">
                <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i><span>Dashboard</span>
                </a>
            </li>

            @* App Config — mirrors SuperAdmin position 2 *@
            @if (showAppConfig)
            {
                <li class="sidebar-item @(ctrl == "AppConfig" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="AppConfig" asp-action="Index">
                        <i class="bi bi-sliders"></i><span>App Config</span>
                    </a>
                </li>
            }

            @* Classes / Standards *@
            @if (showStandard)
            {
                <li class="sidebar-item @(ctrl == "Standard" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Standard" asp-action="Index">
                        <i class="bi bi-bookmark-star"></i><span>Classes/Standards</span>
                    </a>
                </li>
            }

            @* Bus Type — mirrors SuperAdmin position 3 *@
            @if (showBusType)
            {
                <li class="sidebar-item @(ctrl == "BusType" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="BusType" asp-action="Index">
                        <i class="bi-truck-front"></i><span>Bus Types</span>
                    </a>
                </li>
            }

            @* Sub-Admins — mirrors SuperAdmin position 4 *@
            @if (showSubAdmins)
            {
                <li class="sidebar-item @(ctrl == "SubAdmin" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Index">
                        <i class="bi bi-person-badge"></i><span>Sub-Admins</span>
                    </a>
                </li>
            }

            @* Routes *@
            @if (showRoutes)
            {
                <li class="sidebar-item @(ctrl == "Route" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Route" asp-action="Index">
                        <i class="bi bi-map"></i><span>Routes</span>
                    </a>
                </li>
            }

            @* Buses *@
            @if (showBuses)
            {
                <li class="sidebar-item @(ctrl == "Bus" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Bus" asp-action="Index">
                        <i class="bi bi-bus-front"></i><span>Buses</span>
                    </a>
                </li>
            }

            @* Drivers *@
            @if (showDrivers)
            {
                <li class="sidebar-item @(ctrl == "Driver" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Driver" asp-action="Index">
                        <i class="bi bi-person-video2"></i><span>Drivers</span>
                    </a>
                </li>
            }

            @* Parents *@
            @if (showParents)
            {
                <li class="sidebar-item @(ctrl == "Parent" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Parent" asp-action="Index">
                        <i class="bi bi-people"></i><span>Parents</span>
                    </a>
                </li>
            }

            @* Students *@
            @if (showStudents)
            {
                <li class="sidebar-item @(ctrl == "Student" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Student" asp-action="Index">
                        <i class="bi bi-mortarboard"></i><span>Students</span>
                    </a>
                </li>
            }

            @* Trips *@
            @if (showTrips)
            {
                <li class="sidebar-item @(ctrl == "Trip" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Trip" asp-action="Index">
                        <i class="bi bi-signpost-split"></i><span>Trips</span>
                    </a>
                </li>
            }

            @* Notifications *@
            @if (showNotif)
            {
                <li class="sidebar-item @(ctrl == "Notification" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Notification" asp-action="Index">
                        <i class="bi bi-bell"></i><span>Notifications</span>
                    </a>
                </li>
            }

            @* Help & Support *@
            @if (showSupport)
            {
                <li class="sidebar-item @(ctrl == "Feedback" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Feedback" asp-action="Index">
                        <i class="bi bi-headset"></i><span>Help & Support</span>
                    </a>
                </li>
            }

            @* Logger *@
            @if (showlogs)
            {
                <li class="sidebar-item @(ctrl == "Logger" ? "active" : "")">
                    <a class="sidebar-link" asp-area="BusCoordinator" asp-controller="Logger" asp-action="Index">
                        <i class="bi-journal-text"></i><span>System Logs</span>
                    </a>
                </li>
            }
        </ul>

        <div class="sidebar-footer">
            <a class="sidebar-link" asp-controller="Profile" asp-action="Index" asp-area="">
                <i class="bi bi-person-circle"></i>
                <span>@User.GetFullName()</span>
            </a>
            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                    <i class="bi bi-box-arrow-left"></i><span>Logout</span>
                </button>
            </form>
        </div>
    </nav>

    <!-- ── Main ─────────────────────────────────────────────────── -->
    <div class="main-wrapper flex-grow-1 d-flex flex-column">
        <header class="top-navbar">
            <button class="sidebar-toggle btn btn-sm btn-link" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <span class="badge bg-primary-subtle text-primary ms-1 small">Bus Coordinator</span>
            <div class="ms-auto d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>@User.GetFullName()
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" asp-controller="Profile" asp-action="Index" asp-area="">
                                <i class="bi bi-person me-2"></i>Profile
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword" asp-area="">
                                <i class="bi bi-key me-2"></i>Change Password
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bi bi-box-arrow-left me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="content-area flex-grow-1 p-4">
            @{
                var alert = BusTracking.Web.Helpers.AlertHelper.FromTempData(TempData);
            }
            @if (alert is not null)
            {
                <div class="alert @alert.CssClass alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi @alert.Icon"></i>
                    <span>@alert.Message</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

        <footer class="py-2 px-4 border-top text-muted small text-end">
            &copy; @DateTime.Now.Year Bus Tracking System
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
