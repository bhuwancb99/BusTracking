@* Usage: <partial name="_CreatedCredentials" model="createdUserResultDto" /> *@
@model BusTracking.Common.DTOs.User.CreatedUserResultDto
@if (Model is not null)
{
    <div class="card border-success shadow-sm mb-4">
        <div class="card-header bg-success text-white fw-semibold py-2 px-4">
            <i class="bi bi-person-check-fill me-2"></i>Account Created Successfully
        </div>
        <div class="card-body p-4">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    <table class="table table-borderless mb-0 small">
                        <tr>
                            <th class="text-muted" style="width:120px">Full Name</th>
                            <td class="fw-semibold">@Model.FullName</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Email</th>
                            <td>@Model.Email</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Username</th>
                            <td><code class="bg-light px-2 py-1 rounded">@Model.Email</code></td>
                        </tr>
                        <tr>
                            <th class="text-muted">Password</th>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <code class="bg-warning-subtle px-2 py-1 rounded" id="genPassword">@Model.GeneratedPassword</code>
                                    <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1"
                                            onclick="copyPassword()" title="Copy">
                                        <i class="bi bi-clipboard" id="copyIcon"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Email Sent</th>
                            <td>
                                @if (Model.EmailSent)
                                {
                                    <span class="badge bg-success-subtle text-success"><i class="bi bi-check2 me-1"></i>Sent</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary-subtle text-secondary">Not sent</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-md-6 text-center">
                    <div class="p-4 bg-warning-subtle rounded-3">
                        <i class="bi bi-exclamation-triangle-fill text-warning fs-1 d-block mb-2"></i>
                        <p class="small fw-semibold mb-0 text-warning-emphasis">
                            Please share these credentials with the user.<br>
                            The password is shown only once.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        function copyPassword() {
            const pwd  = document.getElementById('genPassword').textContent;
            const icon = document.getElementById('copyIcon');
            navigator.clipboard.writeText(pwd).then(() => {
                icon.className = 'bi bi-clipboard-check';
                setTimeout(() => icon.className = 'bi bi-clipboard', 2000);
            });
        }
    </script>
}
