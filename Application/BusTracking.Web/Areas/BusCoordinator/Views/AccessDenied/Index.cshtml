@using System.Security.Claims
@{
    ViewData["Title"] = "Access Denied";
    var fullName    = User.FindFirstValue("FullName") ?? User.FindFirstValue(ClaimTypes.Name) ?? "Coordinator";
    var requestedPage = ViewBag.RequestedPage as string ?? "this page";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:70vh">
    <div class="text-center" style="max-width:520px">

        
        <div class="position-relative d-inline-flex align-items-center justify-content-center mb-4">
            <div class="rounded-circle position-absolute"
                 style="width:120px;height:120px;background:rgba(255,193,7,.12);animation:pulse 2s infinite"></div>
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:88px;height:88px;background:rgba(255,193,7,.18)">
                <i class="bi bi-shield-lock-fill text-warning" style="font-size:2.8rem"></i>
            </div>
        </div>

        <h2 class="fw-bold mb-2" style="color:#1a202c">Access Denied</h2>

        <p class="mb-1" style="color:#4a5568;font-size:1rem">
            Hi <strong>@fullName</strong>, you don't have permission to access
            <strong>@requestedPage</strong>.
        </p>
        <p class="mb-4" style="color:#718096;font-size:.9rem">
            Please contact your System Administrator to request the required permissions.
        </p>

        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-area="BusCoordinator" asp-controller="Dashboard" asp-action="Index"
               class="btn btn-warning px-4 fw-semibold">
                <i class="bi bi-house me-2"></i>Go to Dashboard
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-2"></i>Go Back
            </button>
        </div>

        <div class="mt-5 p-3 rounded-3 text-start"
             style="background:#fffbeb;border:1px solid #fde68a">
            <div class="d-flex align-items-start gap-2">
                <i class="bi bi-info-circle-fill text-warning mt-1 flex-shrink-0"></i>
                <div style="font-size:.82rem;color:#92400e">
                    <strong>What can I do?</strong><br/>
                    Your System Administrator can assign permissions from
                    <strong>SuperAdmin &rarr; Bus Coordinators &rarr; Edit</strong>.
                    Once updated, log out and log back in for the changes to take effect.
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    @@keyframes pulse {
        0%   { transform: scale(1);   opacity: .7; }
        50%  { transform: scale(1.18); opacity: .3; }
        100% { transform: scale(1);   opacity: .7; }
    }
</style>
