@model BusTracking.Common.DTOs.Route.RouteDetailDto
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Route Details"; ViewData["Breadcrumb"] = "Routes / Details";
    bool canEdit = PermissionHelper.Can(User, "route.edit");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-map me-2 text-primary"></i>@Model?.RouteName</h4>
    <div class="d-flex gap-2">
        @if (canEdit && Model?.Stops.Count > 0)
        {
            <button class="btn btn-success btn-sm" id="btnUpdateOrder"><i class="bi bi-arrow-down-up me-1"></i>Update Order</button>
        }
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model?.RouteId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-4">
    <!-- Route info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">Route Info</div>
            <div class="card-body p-4">
                <table class="table table-borderless mb-0">
                    <tr><th class="text-muted small">Code</th><td><code>@Model?.RouteCode</code></td></tr>
                    <tr><th class="text-muted small">Morning</th><td><i class="bi bi-sunrise text-warning me-1"></i>@(Model?.MorningTime ?? "–")</td></tr>
                    <tr><th class="text-muted small">Evening</th><td><i class="bi bi-sunset text-secondary me-1"></i>@(Model?.EveningTime ?? "–")</td></tr>
                    <tr><th class="text-muted small">Stops</th><td><span class="badge bg-info-subtle text-info">@(Model?.StopCount ?? 0)</span></td></tr>
                    <tr>
                        <th class="text-muted small">Status</th>
                        <td><span class="badge @(Model?.IsActive == true ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(Model?.IsActive == true ? "Active" : "Inactive")</span></td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model?.Description))
                    {
                        <tr><th class="text-muted small">Notes</th><td class="small text-muted">@Model.Description</td></tr>
                    }
                </table>
            </div>
        </div>

        <!-- Add Stop panel -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-pin-map me-2 text-primary"></i>Add Stop</div>
            <div class="card-body p-4">
                <div id="addStopAlert"></div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Stop Name <span class="text-danger">*</span></label>
                    <input type="text" id="stopName" class="form-control form-control-sm" placeholder="e.g. City Park Gate" />
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Morning</label>
                        <input type="time" id="stopMorning" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Evening</label>
                        <input type="time" id="stopEvening" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Latitude</label>
                        <input type="number" step="0.0000001" id="stopLat" class="form-control form-control-sm" placeholder="20.593…" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold small">Longitude</label>
                        <input type="number" step="0.0000001" id="stopLng" class="form-control form-control-sm" placeholder="78.962…" />
                    </div>
                </div>
                <button class="btn btn-primary btn-sm w-100" id="btnAddStop">
                    <i class="bi bi-plus-circle me-1"></i>Add Stop
                </button>
            </div>
        </div>
    </div>

    <!-- Stop timeline -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-signpost-split me-2 text-primary"></i>Stops on this Route</div>
            <div class="card-body p-4">
                @if (Model?.Stops.Count == 0)
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-geo fs-1 d-block mb-2"></i>No stops added yet.
                    </div>
                }
                else
                {
                    <div class="stop-timeline" id="stopList">
                        @foreach (var stop in Model!.Stops)
                        {
                            <div class="stop-item d-flex align-items-start gap-3" id="stop-@stop.StopId">
                                <div class="stop-dot"></div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="fw-semibold">@stop.StopName</span>
                                            <input type="number" min="1"
                                                   class="form-control form-control-sm stop-order-input d-inline-block ms-2"
                                                   style="width:70px"
                                                   data-stop-id="@stop.StopId"
                                                   data-original-order="@stop.StopOrder"
                                                   value="@stop.StopOrder" />
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger py-0 px-2 btn-del-stop"
                                                data-stop-id="@stop.StopId">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                    <div class="d-flex gap-3 mt-1 small text-muted">
                                        @if (stop.MorningTime is not null)
                                        {
                                            <span><i class="bi bi-sunrise me-1 text-warning"></i>@stop.MorningTime</span>
                                        }
                                        @if (stop.EveningTime is not null)
                                        {
                                            <span><i class="bi bi-sunset me-1 text-secondary"></i>@stop.EveningTime</span>
                                        }
                                        @if (stop.Latitude is not null)
                                        {
                                            <span><i class="bi bi-geo-alt me-1 text-danger"></i>@stop.Latitude, @stop.Longitude</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const routeId = @Model?.RouteId;

        document.getElementById('btnAddStop')?.addEventListener('click', async () => {
            const name  = document.getElementById('stopName').value.trim();
            if (!name) {
                busTrack.showToast('Stop name is required.', 'warning'); return;
            }
            const data = {
                routeId,
                stopName:    name,
                morningTime: document.getElementById('stopMorning').value || null,
                eveningTime: document.getElementById('stopEvening').value || null,
                latitude:    parseFloat(document.getElementById('stopLat').value) || null,
                longitude:   parseFloat(document.getElementById('stopLng').value) || null
            };
            const result = await busTrack.post('/BusCoordinator/Route/AddStop', data);
            if (result.success) {
                busTrack.showToast('Stop added. Refreshing…', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                busTrack.showToast(result.message, 'danger');
            }
        });

        document.getElementById('btnUpdateOrder')?.addEventListener('click', async () => {
            const inputs = document.querySelectorAll('.stop-order-input');
            const allValues = [];
            const changed = [];

            inputs.forEach(inp => {
                const original = parseInt(inp.dataset.originalOrder);
                const current  = parseInt(inp.value);
                allValues.push(current);
                if (current !== original) {
                    changed.push({ stopId: parseInt(inp.dataset.stopId), stopOrder: current });
                }
            });

            if (changed.length === 0) {
                busTrack.showToast('You have not changed anything in the order. Please update the order first, then click Update.', 'warning');
                return;
            }

            const hasDuplicates = new Set(allValues).size !== allValues.length;
            if (hasDuplicates) {
                busTrack.showToast('Order numbers must be unique. Please fix duplicate order numbers before updating.', 'warning');
                return;
            }

            const result = await busTrack.post('/BusCoordinator/Route/ReorderStops', {
                routeId,
                stops: Array.from(inputs).map(inp => ({
                    stopId:    parseInt(inp.dataset.stopId),
                    stopOrder: parseInt(inp.value)
                }))
            });

            if (result.success) {
                busTrack.showToast('Stop order updated. Refreshing…', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                busTrack.showToast(result.message, 'danger');
            }
        });

        document.querySelectorAll('.btn-del-stop').forEach(btn => {
            btn.addEventListener('click', async function () {
                if (!confirm('Remove this stop?')) return;
                const stopId = this.dataset.stopId;
                const result = await busTrack.post(`/BusCoordinator/Route/DeleteStop?stopId=${stopId}`, {});
                if (result.success) {
                    document.getElementById(`stop-${stopId}`)?.remove();
                    busTrack.showToast('Stop removed.', 'success');
                } else {
                    busTrack.showToast(result.message, 'danger');
                }
            });
        });
    </script>
}
