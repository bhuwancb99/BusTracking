@model BusTracking.Common.DTOs.Dashboard.DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard";
}
<div class="mb-4"><h4 class="fw-bold mb-0">Coordinator Dashboard</h4><p class="text-muted small">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p></div>
@if (Model is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3"><div class="card stat-card border-0 shadow-sm text-center p-4"><i class="bi bi-bus-front-fill text-primary fs-1 d-block mb-2"></i><div class="fw-bold fs-2">@Model.TotalBuses</div><div class="text-muted small">Buses</div></div></div>
        <div class="col-6 col-md-3"><div class="card stat-card border-0 shadow-sm text-center p-4"><i class="bi bi-mortarboard-fill text-info fs-1 d-block mb-2"></i><div class="fw-bold fs-2">@Model.TotalStudents</div><div class="text-muted small">Students</div></div></div>
        <div class="col-6 col-md-3"><div class="card stat-card border-0 shadow-sm text-center p-4"><i class="bi bi-geo-alt-fill text-danger fs-1 d-block mb-2"></i><div class="fw-bold fs-2">@Model.ActiveTrips</div><div class="text-muted small">Active Trips</div></div></div>
        <div class="col-6 col-md-3"><div class="card stat-card border-0 shadow-sm text-center p-4"><i class="bi bi-people-fill text-success fs-1 d-block mb-2"></i><div class="fw-bold fs-2">@Model.TotalParents</div><div class="text-muted small">Parents</div></div></div>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-lightning-charge me-2 text-warning"></i>Quick Actions</div>
        <div class="card-body px-4 pb-4 d-flex flex-wrap gap-2">
            <a asp-area="BusCoordinator" asp-controller="Trip" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-play-circle me-1"></i>Create Trip</a>
            <a asp-area="BusCoordinator" asp-controller="Trip" asp-action="Index" class="btn btn-outline-info"><i class="bi bi-list me-1"></i>View Trips</a>
            <a asp-area="BusCoordinator" asp-controller="Student" asp-action="Create" class="btn btn-outline-info"><i class="bi bi-plus me-1"></i>Add Student</a>
            <a asp-area="BusCoordinator" asp-controller="Bus" asp-action="Create" class="btn btn-outline-secondary"><i class="bi bi-plus me-1"></i>Add Bus</a>
            <a asp-area="BusCoordinator" asp-controller="Feedback" asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-headset me-1"></i>View Support</a>
        </div>
    </div>
}