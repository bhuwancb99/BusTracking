@* BusCoordinator/Views/Driver/Details.cshtml — UPDATED *@
@model BusTracking.Common.DTOs.Driver.DriverListDto
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Driver Details";
    bool canEdit = PermissionHelper.Can(User, "driver.edit");
    var thumbUrl = Model?.ProfileImageUrl?.Replace("_medium.webp", "_thumb.webp");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-video2 me-2 text-success"></i>Driver Profile</h4>
    <div class="d-flex gap-2">
        @if (canEdit)
        {
            <a asp-area="BusCoordinator" asp-action="Edit" asp-route-id="@Model?.UserId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        }
        <a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

@if (Model is not null)
{
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <!-- ── Profile photo widget ── -->
                        <div class="position-relative d-inline-block mb-3" id="imgWidget_@Model.UserId">
                            @if (!string.IsNullOrEmpty(thumbUrl))
                            {
                                <img id="imgWidget_@(Model.UserId)_preview" src="@thumbUrl" alt="@Model.FullName"
                                     class="rounded-circle border shadow"
                                     style="width:80px;height:80px;object-fit:cover;" />
                            }
                            else
                            {
                                <div id="imgWidget_@(Model.UserId)_preview"
                                     class="rounded-circle border shadow bg-success-subtle text-success d-flex align-items-center justify-content-center mx-auto"
                                     style="width:80px;height:80px;font-size:1.8rem;font-weight:700;">
                                    @Model.FullName.ToInitials()
                                </div>
                            }
                            <label for="imgInput_@Model.UserId"
                                   class="position-absolute bottom-0 end-0 btn btn-sm btn-primary rounded-circle p-1"
                                   style="width:26px;height:26px;line-height:1;cursor:pointer;" title="Change photo">
                                <i class="bi bi-camera-fill" style="font-size:0.7rem;"></i>
                                <input type="file" id="imgInput_@Model.UserId" class="d-none"
                                       accept="image/jpeg,image/png,image/webp"
                                       onchange="uploadUserProfile(@Model.UserId, this, 'imgWidget_@Model.UserId')" />
                            </label>
                        </div>
                        <div id="imgWidget_@(Model.UserId)_msg" class="small mb-2"></div>
                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                        {
                            <button type="button" class="btn btn-sm btn-outline-danger mb-3"
                                    onclick="deleteUserProfile(@Model.UserId, 'imgWidget_@Model.UserId')">
                                <i class="bi bi-trash me-1"></i>Remove Photo
                            </button>
                        }
                        <h5 class="fw-bold mb-1">@Model.FullName</h5>
                        <span class="badge bg-success-subtle text-success me-1">Driver</span>
                        <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                    <table class="table table-borderless small mb-0">
                        <tr><th class="text-muted w-40">Email</th><td>@Model.Email</td></tr>
                        <tr><th class="text-muted">Phone</th><td>@(Model.PhoneNumber ?? "–")</td></tr>
                        <tr><th class="text-muted">License No.</th><td>@(Model.LicenseNumber ?? "–")</td></tr>
                        <tr><th class="text-muted">Expiry</th><td>@(Model.LicenseExpiry ?? "–")</td></tr>
                        <tr>
                            <th class="text-muted">Password</th>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span id="pwdMask" class="font-monospace">••••••••••</span>
                                    <span id="pwdReal" class="font-monospace d-none text-danger small">(Reset in Edit)</span>
                                    <button type="button" class="btn btn-sm btn-link p-0 text-muted" id="btnTogglePwd">
                                        <i class="bi bi-eye" id="pwdEyeIcon"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                    <i class="bi bi-bus-front me-2 text-primary"></i>Assigned Bus
                </div>
                <div class="card-body p-4">
                    @if (Model.BusName is not null)
                    {
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="p-3 bg-primary-subtle rounded-circle"><i class="bi bi-bus-front text-primary fs-4"></i></div>
                            <div>
                                <div class="fw-semibold">@Model.BusName</div>
                                <span class="badge bg-primary-subtle text-primary">@Model.BusNumber</span>
                            </div>
                        </div>
                    }
                    else
                    {

                        <div class="text-center text-muted py-3"><i class="bi bi-bus-front fs-2 d-block mb-2"></i>No bus assigned.</div>
                    }
                    <hr class="my-3" />
                    <div class="fw-semibold small mb-2">Quick Assign Bus</div>
                    <div class="d-flex gap-2">
                        <div class="position-relative flex-grow-1">
                            <input type="text" id="quickBusSearch" class="form-control form-control-sm" placeholder="Type bus name…" autocomplete="off" />
                            <div id="quickBusSug" class="dropdown-menu w-100 shadow-sm"></div>
                        </div>
                        <button class="btn btn-sm btn-primary" id="btnAssignBus"><i class="bi bi-check2"></i> Assign</button>
                        <button class="btn btn-sm btn-outline-danger" id="btnRemoveBus"><i class="bi bi-x"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        const _tok = () => document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        document.getElementById('btnTogglePwd').addEventListener('click', function () {
            const mask = document.getElementById('pwdMask'), real = document.getElementById('pwdReal'), icon = document.getElementById('pwdEyeIcon');
            const hidden = mask.classList.contains('d-none');
            mask.classList.toggle('d-none', !hidden); real.classList.toggle('d-none', hidden);
            icon.className = hidden ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
        async function uploadUserProfile(userId, input, widgetId) {
            if (!input.files || !input.files[0]) return;
            const msg = document.getElementById(widgetId + '_msg');
            msg.innerHTML = '<span class="text-muted">Uploading…</span>';
            const fd = new FormData(); fd.append('file', input.files[0]);
            try {
                const res = await fetch('/Image/UploadUserProfile?userId=' + userId, { method: 'POST', headers: { 'RequestVerificationToken': _tok() }, body: fd });
                const json = await res.json();
                if (json.success) { msg.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Saved.</span>'; setTimeout(() => location.reload(), 800); }
                else { msg.innerHTML = `<span class="text-danger">${json.message}</span>`; }
            } catch { msg.innerHTML = '<span class="text-danger">Upload failed.</span>'; }
            input.value = '';
        }
        async function deleteUserProfile(userId, widgetId) {
            if (!confirm('Remove this profile photo?')) return;
            const msg = document.getElementById(widgetId + '_msg');
            try {
                const res = await fetch('/Image/DeleteUserProfile?userId=' + userId, { method: 'POST', headers: { 'RequestVerificationToken': _tok() } });
                const json = await res.json(); if (json.success) location.reload();
            } catch { msg.innerHTML = '<span class="text-danger">Error.</span>'; }
        }
        const driverUserId = @(Model?.UserId ?? 0);
        let selBusId = null, t;
        document.getElementById('quickBusSearch').addEventListener('input', function () {
            clearTimeout(t); const q = this.value.trim();
            if (q.length < 1) { hideSug(); return; }
            t = setTimeout(() => fetchBuses(q), 250);
        });
        document.addEventListener('click', e => { if (!e.target.closest('#quickBusSearch,#quickBusSug')) hideSug(); });
        async function fetchBuses(q) {
            const data = await (await fetch(`/BusCoordinator/Driver/SearchBuses?q=${encodeURIComponent(q)}`)).json();
            const box = document.getElementById('quickBusSug'); box.innerHTML = '';
            data.forEach(b => { const a = document.createElement('a'); a.className = 'dropdown-item'; a.href = '#'; a.textContent = b.display; a.addEventListener('click', e => { e.preventDefault(); selBusId = b.busId; document.getElementById('quickBusSearch').value = b.display; hideSug(); }); box.appendChild(a); });
            if (data.length) box.classList.add('show');
        }
        function hideSug() { document.getElementById('quickBusSug').classList.remove('show'); }
        document.getElementById('btnAssignBus').addEventListener('click', async () => {
            if (!selBusId) { busTrack.showToast('Select a bus first', 'warning'); return; }
            const res = await fetch('/BusCoordinator/Driver/AssignBus', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _tok() }, body: JSON.stringify({ driverUserId, busId: selBusId }) });
            const data = await res.json(); busTrack.showToast(data.message, data.success ? 'success' : 'danger');
            if (data.success) setTimeout(() => location.reload(), 800);
        });
        document.getElementById('btnRemoveBus').addEventListener('click', async () => {
            if (!confirm('Remove bus assignment?')) return;
            const res = await fetch('/BusCoordinator/Driver/AssignBus', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _tok() }, body: JSON.stringify({ driverUserId, busId: null }) });
            const data = await res.json(); busTrack.showToast(data.message, data.success ? 'success' : 'danger');
            if (data.success) setTimeout(() => location.reload(), 800);
        });
    </script>
}
