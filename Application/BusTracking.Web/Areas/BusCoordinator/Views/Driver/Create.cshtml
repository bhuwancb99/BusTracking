@* ── Driver/Create.cshtml ─────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Driver.CreateDriverDto
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Add Driver";
    if (!PermissionHelper.Can(User, "driver.add")) { Context.Response.Redirect("/BusCoordinator/Driver"); return; }
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-person-plus me-2 text-success"></i>Add New Driver
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="BusCoordinator" asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Driver full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="UserName" class="form-control" placeholder="unique_username" id="usernameInput" autocomplete="off" />
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div id="usernameMsg" class="small mt-1"></div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-muted fw-normal">(Optional)</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="driver@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+91 98765 43210" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenseNumber" class="form-label fw-semibold">License Number</label>
                            <input asp-for="LicenseNumber" class="form-control" placeholder="DL-XXXXXXXXXX" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LicenseExpiry" class="form-label fw-semibold">License Expiry</label>
                            <input asp-for="LicenseExpiry" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Assign Bus (optional)</label>
                            <div class="input-group">
                                <input type="text" id="busSearch" class="form-control" placeholder="Type bus name or number…" autocomplete="off" />
                                <input type="hidden" asp-for="BusId" id="busIdInput" />
                            </div>
                            <div id="busSuggestions" class="dropdown-menu w-100 shadow-sm"></div>
                            <div id="busSelected" class="mt-1"></div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="SendEmail" class="form-check-input" type="checkbox" role="switch" id="sendEmailChk" />
                                <label class="form-check-label" for="sendEmailChk">
                                    <i class="bi bi-envelope me-1"></i>Send welcome email with credentials
                                    <span class="badge bg-secondary-subtle text-secondary ms-1">Optional</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success px-4"><i class="bi bi-check2 me-1"></i>Create Driver</button>
                        <a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Validation summary — show only on error
        const vs = document.getElementById('valSummary');
        if (vs && vs.querySelector('li, span:not(:empty)')) vs.style.display = '';
        document.getElementById('createForm').addEventListener('submit', function() {
            if (vs) vs.style.display = '';
        });

        // Bus autocomplete
        let busTimer;
        document.getElementById('busSearch').addEventListener('input', function() {
            clearTimeout(busTimer);
            const q = this.value.trim();
            if (q.length < 1) { hideSug(); return; }
            busTimer = setTimeout(() => fetchBuses(q), 250);
        });
        document.addEventListener('click', e => { if (!e.target.closest('#busSearch,#busSuggestions')) hideSug(); });

        async function fetchBuses(q) {
            const res  = await fetch(`/BusCoordinator/Driver/SearchBuses?q=${encodeURIComponent(q)}`);
            const data = await res.json();
            const box  = document.getElementById('busSuggestions');
            box.innerHTML = '';
            if (!data.length) { hideSug(); return; }
            data.forEach(b => {
                const item = document.createElement('a');
                item.className = 'dropdown-item'; item.href = '#';
                item.textContent = b.display;
                item.addEventListener('click', e => { e.preventDefault(); selectBus(b); });
                box.appendChild(item);
            });
            box.classList.add('show');
        }
        function selectBus(b) {
            document.getElementById('busIdInput').value = b.busId;
            document.getElementById('busSearch').value  = b.display;
            document.getElementById('busSelected').innerHTML = `<span class="badge bg-primary-subtle text-primary"><i class="bi bi-bus-front me-1"></i>${b.display}</span>`;
            hideSug();
        }
        function hideSug() { document.getElementById('busSuggestions').classList.remove('show'); }
            const res = await fetch(`/Auth/CheckUsername?userName=${encodeURIComponent(val)}`);
            const data = await res.json();
            if (!data.success) {
                showUsernameMsg('<i class="bi bi-x-circle me-1"></i>Username already exists', 'text-danger fw-semibold');
            } else {
                showUsernameMsg('<i class="bi bi-check-circle me-1"></i>Username is available', 'text-success fw-semibold');
            }
        }
        function togglePwd() { const inp = document.getElementById('pwdInput'); const icon = document.getElementById('eyeIcon'); inp.type = inp.type === 'password' ? 'text' : 'password'; icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash'; }
        // ── Username live-check (keyup, min 5 chars, no excludeUserId on create) ──
        const _unInput = document.getElementById('usernameInput');
        const _unMsg   = document.getElementById('usernameMsg');
        let   _unTimer = null;

        _unInput.addEventListener('keyup', () => {
            clearTimeout(_unTimer);
            _unTimer = setTimeout(liveCheckUsername, 350);
        });

        async function liveCheckUsername() {
            const val = _unInput.value.trim();
            _unMsg.innerHTML = '';
            _unMsg.className = 'small mt-1';
            if (val.length === 0) return;
            if (val.length < 5) {
                _unMsg.innerHTML  = '<i class="bi bi-exclamation-circle me-1"></i>Username must have at least 5 characters';
                _unMsg.className  = 'small mt-1 text-danger';
                return;
            }
            try {
                const res  = await fetch(`/Auth/CheckUsername?userName=${encodeURIComponent(val)}`);
                if (!res.ok) return;
                const data = await res.json();
                if (!data.success) {
                    _unMsg.innerHTML = `<i class="bi bi-x-circle me-1"></i>The username <strong>${escHtml(val)}</strong> is already taken`;
                    _unMsg.className = 'small mt-1 text-danger';
                } else {
                    _unMsg.innerHTML = `<i class="bi bi-check-circle me-1"></i><strong>${escHtml(val)}</strong> is available`;
                    _unMsg.className = 'small mt-1 text-success fw-semibold';
                }
            } catch (_) { /* silent */ }
        }
        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
    </script>
}
