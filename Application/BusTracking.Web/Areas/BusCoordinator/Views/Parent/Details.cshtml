@model BusTracking.Common.DTOs.Parent.ParentListDto
@{
    ViewData["Title"] = "Parent Details";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-info"></i>Parent Profile</h4>
    <div class="d-flex gap-2">
        <a asp-area="BusCoordinator" asp-action="Edit" asp-route-id="@Model?.UserId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

@if (Model is not null)
{
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 text-center">
                    <div class="avatar-xl bg-info-subtle text-info mx-auto rounded-circle d-flex align-items-center justify-content-center mb-3"
                         style="width:72px;height:72px;font-size:1.8rem;font-weight:700">
                        @Model.FullName.ToInitials()
                    </div>
                    <h5 class="fw-bold mb-1">@Model.FullName</h5>
                    <span class="badge bg-info-subtle text-info me-1">Parent</span>
                    <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(Model.IsActive ? "Active" : "Inactive")</span>
                    <hr />
                    <table class="table table-borderless small text-start mb-0">
                        <tr><th class="text-muted">Email</th><td>@Model.Email</td></tr>
                        <tr><th class="text-muted">Phone</th><td>@(Model.PhoneNumber ?? "–")</td></tr>
                        <tr><th class="text-muted">Children</th><td><span class="badge bg-secondary-subtle text-secondary">@Model.Students.Count</span></td></tr>
                        <!-- ── PASSWORD ROW ─────────────────────── -->
                        <tr>
                            <th class="text-muted">Password</th>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span id="pwdMask" class="font-monospace">••••••••••</span>
                                    <span id="pwdReal" class="font-monospace d-none text-danger small">(Reset in Edit)</span>
                                    <button type="button" class="btn btn-sm btn-link p-0 text-muted" id="btnTogglePwd">
                                        <i class="bi bi-eye" id="pwdEyeIcon"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                    <i class="bi bi-mortarboard me-2 text-info"></i>Linked Children (@Model.Students.Count)
                </div>
                <div class="card-body p-0">
                    @if (Model.Students.Count == 0)
                    {
                        <div class="text-center text-muted py-5"><i class="bi bi-mortarboard fs-1 d-block mb-2"></i>No students linked yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr><th class="ps-4">Code</th><th>Name</th><th>Class</th><th>Bus</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in Model.Students)
                                    {
                                        <tr>
                                            <td class="ps-4"><code>@s.StudentCode</code></td>
                                            <td class="fw-semibold">@s.FullName</td>
                                            <td class="small text-muted">@(s.Standard ?? "–")</td>
                                            <td>
                                                @if (s.BusNumber is not null)
                                                {
                                                    <div><span class="badge bg-primary-subtle text-primary">@s.BusNumber</span></div>
                                                    @if (s.BusName is not null)
                                                    {
                                                        <div class="text-muted small">@s.BusName</div>
                                                    }
                                                }
                                                else
                                                {

                                                    <span class="text-muted small">–</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // ── Password toggle ───────────────────────────────────────────
        document.getElementById('btnTogglePwd').addEventListener('click', function() {
            const mask = document.getElementById('pwdMask');
            const real = document.getElementById('pwdReal');
            const icon = document.getElementById('pwdEyeIcon');
            const hidden = mask.classList.contains('d-none');
            mask.classList.toggle('d-none', !hidden);
            real.classList.toggle('d-none', hidden);
            icon.className = hidden ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
    </script>
}

