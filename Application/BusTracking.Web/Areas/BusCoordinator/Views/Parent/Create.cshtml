@* ── Parent/Create.cshtml ──────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Parent.CreateParentDto
@{
    ViewData["Title"] = "Add Parent";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-people me-2 text-info"></i>Add New Parent</div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="BusCoordinator" asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Parent full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="parent@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+91 98765 43210" />
                        </div>
                    </div>

                    <!-- Student autocomplete section -->
                    <hr class="my-4" />
                    <div class="fw-semibold mb-2">Link Students</div>
                    <div class="mb-3">
                        <div class="input-group">
                            <input type="text" id="studentSearch" class="form-control" placeholder="Type student name or code to search…" autocomplete="off" />
                            <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
                        </div>
                        <div id="studentSuggestions" class="dropdown-menu w-100 shadow-sm"></div>
                        <small class="text-muted">Select students from the dropdown. Selected students appear below.</small>
                    </div>

                    <div id="selectedStudents" class="d-flex flex-wrap gap-2 mb-3"></div>
                    <div id="studentInputs"></div>

                    <div class="form-check form-switch mt-3">
                        <input asp-for="SendEmail" class="form-check-input" type="checkbox" role="switch" id="sendEmailChk" />
                        <label class="form-check-label" for="sendEmailChk">
                            <i class="bi bi-envelope me-1"></i>Send welcome email with credentials
                            <span class="badge bg-secondary-subtle text-secondary ms-1">Optional</span>
                        </label>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check2 me-1"></i>Create Parent</button>
                        <a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const vs=document.getElementById('valSummary');
        if(vs&&vs.querySelector('li,span:not(:empty)'))vs.style.display='';
        document.getElementById('createForm').addEventListener('submit',()=>{if(vs)vs.style.display='';});

        // Student autocomplete
        const selected = {};
        let t;
        document.getElementById('studentSearch').addEventListener('input',function(){
            clearTimeout(t); const q=this.value.trim();
            if(q.length<1){hideSug();return;}
            t=setTimeout(()=>searchStudents(q),250);
        });
        document.addEventListener('click',e=>{if(!e.target.closest('#studentSearch,#studentSuggestions'))hideSug();});

        async function searchStudents(q){
            const res=await fetch(`/BusCoordinator/Parent/SearchStudents?q=${encodeURIComponent(q)}`);
            const data=await res.json();
            const box=document.getElementById('studentSuggestions');
            box.innerHTML='';
            if(!data.length){const li=document.createElement('div');li.className='dropdown-item text-muted';li.textContent='No students found';box.appendChild(li);box.classList.add('show');return;}
            data.forEach(s=>{
                const a=document.createElement('a');
                a.className='dropdown-item d-flex align-items-center gap-2';a.href='#';
                a.innerHTML=`<code class="small">${s.studentCode}</code><span>${s.fullName}</span>${s.standard?`<span class="badge bg-secondary-subtle text-secondary ms-auto">${s.standard}</span>`:''}`;
                a.addEventListener('click',e=>{e.preventDefault();addStudent(s);document.getElementById('studentSearch').value='';hideSug();});
                box.appendChild(a);
            });
            box.classList.add('show');
        }
        function hideSug(){document.getElementById('studentSuggestions').classList.remove('show');}

        function addStudent(s){
            if(selected[s.studentId])return;
            selected[s.studentId]=s;

            // Badge chip
            const chip=document.createElement('span');
            chip.className='badge bg-info-subtle text-info px-3 py-2 d-flex align-items-center gap-2';
            chip.id=`chip-${s.studentId}`;
            chip.innerHTML=`<i class="bi bi-mortarboard"></i><span>${s.fullName} <code class="bg-transparent">${s.studentCode}</code></span><button type="button" class="btn btn-sm p-0 ms-1 text-danger" onclick="removeStudent(${s.studentId})"><i class="bi bi-x-circle"></i></button>`;
            document.getElementById('selectedStudents').appendChild(chip);

            // Hidden input
            const inp=document.createElement('input');
            inp.type='hidden'; inp.name='StudentCodes'; inp.value=s.studentCode; inp.id=`sinp-${s.studentId}`;
            document.getElementById('studentInputs').appendChild(inp);
        }
        function removeStudent(id){
            delete selected[id];
            document.getElementById(`chip-${id}`)?.remove();
            document.getElementById(`sinp-${id}`)?.remove();
        }
    </script>
}
