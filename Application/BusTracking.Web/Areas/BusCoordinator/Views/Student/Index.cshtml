@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Student.StudentListDto>
@{
    ViewData["Title"] = "Students";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard me-2 text-info"></i>Students</h4>
    <a asp-area="BusCoordinator" asp-controller="Student" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Student</a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-area="BusCoordinator" asp-action="Index" method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" style="max-width:280px" placeholder="Search…" />
            <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>#</th><th>Code</th><th>Name</th><th>Class</th><th>Bus</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No students found.</td></tr>
                    }
                    @foreach (var (s, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td><code>@s.StudentCode</code></td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td>@(s.Standard ?? "–")</td>
                            <td>@(s.BusNumber ?? "–")</td>
                            <td><span class="badge @(s.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                <a asp-area="BusCoordinator" asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model" />
    </div>
</div>
