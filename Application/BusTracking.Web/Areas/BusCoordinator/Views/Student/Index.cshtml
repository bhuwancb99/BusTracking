@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Student.StudentListDto>
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Students";
    bool canAdd    = PermissionHelper.Can(User, "student.add");
    bool canEdit   = PermissionHelper.Can(User, "student.edit");
    bool canDelete = PermissionHelper.Can(User, "student.delete");
    bool canView   = PermissionHelper.Can(User, "student.view");
}

@{
    var created = TempData["CreatedUser"] as string;
    BusTracking.Common.DTOs.User.CreatedUserResultDto? newUser = null;
    if (!string.IsNullOrEmpty(created))
        newUser = System.Text.Json.JsonSerializer.Deserialize<BusTracking.Common.DTOs.User.CreatedUserResultDto>(created);
}

@if (newUser is not null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        @* <h6 class="fw-bold mb-3"><i class="bi bi-check-circle-fill me-2"></i>Student Created Successfully</h6> *@
        <div class="row g-2">
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Full Name</div><div class="fw-semibold">@newUser.FullName</div></div></div>
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Role</div><div><span class="badge bg-info-subtle text-info">@newUser.Role</span></div></div></div>
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Username (Email)</div><div class="fw-semibold">@newUser.Email</div></div></div>
            <div class="col-12">
                <div class="bg-white rounded p-3 border">
                    <div class="text-muted small mb-1">Password</div>
                    <div class="d-flex align-items-center gap-2">
                        <span id="pwdDisplay" class="fw-semibold font-monospace">••••••••••••</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="togglePwd()"><i class="bi bi-eye" id="pwdEye"></i></button>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyPwd()"><i class="bi bi-clipboard"></i> Copy</button>
                    </div>
                    <input type="hidden" id="pwdValue" value="@newUser.PlainPassword" />
                </div>
            </div>
        </div>
        @* <p class="mt-2 mb-0 small text-muted"><i class="bi bi-exclamation-triangle me-1"></i>Save this password now — it won't be shown again.</p> *@
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard me-2 text-info"></i>Students</h4>
    @if (canAdd)
    {
        <a asp-area="BusCoordinator" asp-controller="Student" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Student</a>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-4 d-flex align-items-center gap-4 flex-wrap">
        <span class="fw-semibold small text-muted">Filter:</span>
        <form asp-area="BusCoordinator" asp-action="Index" method="get" class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
            <div class="d-flex gap-3">
                @foreach (var s in new[] { ("Active", "Active"), ("Inactive", "Inactive"), ("", "Both") })
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" name="status" value="@s.Item1" id="st_@s.Item1"
                        @(ViewBag.Status as string == s.Item1 ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label small" for="st_@s.Item1">@s.Item2</label>
                    </div>
                }
            </div>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm ms-auto" style="max-width:260px" placeholder="Search name or code…" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Code</th><th>Name</th>@* <th>Email</th> *@<th>Class</th><th>Bus</th><th>Stop</th><th>Status</th><th class="text-end pe-4">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-5"><i class="bi bi-mortarboard fs-1 d-block mb-2"></i>No students found.</td></tr>
                    }
                    @foreach (var (s, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="ps-3 text-muted small">@i</td>
                            <td><code class="bg-light px-2 py-1 rounded">@s.StudentCode</code></td>
                            <td class="fw-semibold">@s.FullName</td>
                            @* <td class="text-muted small">@s.Email</td> *@
                            <td class="small">@(s.StandardName ?? "–")</td>
                            <td>
                                @if (s.BusNumber is not null)
                                {
                                    <span class="badge bg-primary-subtle text-primary">@s.BusNumber</span>
                                }
                                else
                                {

                                    <span class="text-muted small">–</span>
                                }
                            </td>
                            <td class="small">@(s.StopName ?? "–")</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @(s.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                @if (canView)
                                {
                                    <a asp-area="BusCoordinator" asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                }
                                @if (canEdit)
                                {
                                    <a asp-area="BusCoordinator" asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                    <a asp-area="BusCoordinator" asp-action="Availability" asp-route-studentId="@s.StudentId" class="btn btn-sm btn-outline-secondary me-1" title="Availability"><i class="bi bi-calendar-check"></i></a>
                                }
                                <button class="btn btn-sm @(s.IsActive ? "btn-outline-secondary" : "btn-outline-success") me-1 btn-toggle"
                                        data-id="@s.StudentId" data-url="/BusCoordinator/Student/Toggle">
                                    <i class="bi @(s.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2"><partial name="_Pagination" model="Model" /></div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle').forEach(btn => {
            btn.addEventListener('click', async function() {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const res = await fetch(`${this.dataset.url}?id=${this.dataset.id}`,{method:'POST',headers:{'RequestVerificationToken':token}});
                const data = await res.json();
                busTrack.showToast(data.message, data.success?'success':'danger');
                if (data.success) setTimeout(()=>location.reload(),700);
            });
        });
        function togglePwd(){const el=document.getElementById('pwdDisplay');const val=document.getElementById('pwdValue').value;const ic=document.getElementById('pwdEye');if(el.textContent.includes('•')){el.textContent=val;ic.className='bi bi-eye-slash';}else{el.textContent='••••••••••••';ic.className='bi bi-eye';}}
        function copyPwd(){navigator.clipboard.writeText(document.getElementById('pwdValue').value);busTrack.showToast('Password copied!','success');}
    </script>
}
