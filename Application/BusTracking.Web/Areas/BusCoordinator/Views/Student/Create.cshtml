@model BusTracking.Common.DTOs.Student.CreateStudentDto
@{
    ViewData["Title"] = "Add Student";
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-mortarboard me-2 text-info"></i>Add Student</div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="BusCoordinator" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label><input asp-for="Email" type="email" class="form-control" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="StudentCode" class="form-label fw-semibold">Student Code <span class="text-danger">*</span></label><input asp-for="StudentCode" class="form-control" /><span asp-validation-for="StudentCode" class="text-danger small"></span></div>
                        <div class="col-md-6"><label asp-for="Standard" class="form-label fw-semibold">Class</label><input asp-for="Standard" class="form-control" /></div>
                    </div>
                    <div class="d-flex gap-2 mt-4"><button type="submit" class="btn btn-primary px-4">Save</button><a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a></div>
                </form>
            </div>
        </div>    </div>
    </div>