@model BusTracking.Common.DTOs.SubAdmin.CreateSubAdminDto
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Add Sub-Admin";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-person-plus me-2 text-primary"></i>Add Sub-Admin
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="UserName" class="form-control" placeholder="unique_username" id="usernameInput" autocomplete="off" />
                                <button type="button" class="btn btn-outline-secondary" id="btnCheckUsername" title="Check availability"><i class="bi bi-search"></i></button>
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div id="usernameMsg" class="small mt-1"></div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-muted fw-normal">(Optional)</span></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="SendEmail" id="sendEmail" />
                                <label class="form-check-label" for="sendEmail">Send welcome email with credentials</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <label class="fw-semibold">Assign Permissions</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnSelectAll">Select All</button>
                        </div>
                        @{
                            var allPerms   = ViewBag.AllPermissions as List<(int Id, string ModuleName, string Key, string Description)>
                                             ?? new List<(int, string, string, string)>();
                            var permGroups = allPerms.GroupBy(p => p.ModuleName).OrderBy(g => g.Key);
                        }
                        <div class="row g-3">
                            @foreach (var group in permGroups)
                            {
                                var modKey = group.Key.Replace(" ", "_").Replace("&", "");
                                <div class="col-md-6">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="fw-semibold small text-uppercase text-muted">
                                                @group.Key.Replace("Manage", "")
                                            </span>
                                            <button type="button" class="btn btn-link btn-sm p-0 text-primary btn-module-all"
                                                    data-mod="@modKey">All</button>
                                        </div>
                                        @foreach (var perm in group)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input perm-@modKey" type="checkbox"
                                                       name="PermissionIds" value="@perm.Id" id="perm_@perm.Id" />
                                                <label class="form-check-label small" for="perm_@perm.Id">@perm.Description</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check2 me-1"></i>Create Sub-Admin
                        </button>
                        <a asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Index"
                           class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.btn-module-all').forEach(btn => {
            btn.addEventListener('click', function () {
                const mod = this.dataset.mod;
                const checks = [...document.querySelectorAll(`.perm-${mod}`)];
                const allChecked = checks.every(c => c.checked);
                checks.forEach(c => c.checked = !allChecked);
                this.textContent = allChecked ? 'All' : 'None';
            });
        });
        document.getElementById('btnSelectAll').addEventListener('click', function () {
            const checks = [...document.querySelectorAll('input[name="PermissionIds"]')];
            const allChecked = checks.every(c => c.checked);
            checks.forEach(c => c.checked = !allChecked);
            this.textContent = allChecked ? 'Select All' : 'Deselect All';
        });
        document.getElementById('btnCheckUsername').addEventListener('click', checkUsername);
        document.getElementById('usernameInput').addEventListener('input', () => document.getElementById('usernameMsg').innerHTML = '');
        async function checkUsername() {
            const val = document.getElementById('usernameInput').value.trim();
            if (!val) { showUsernameMsg('Enter a username first.', 'text-muted'); return; }
            const res = await fetch(`/api/auth/check-username?userName=${encodeURIComponent(val)}`);
            const data = await res.json();
            if (!data.success) {
                showUsernameMsg('<i class="bi bi-x-circle me-1"></i>Username already exists', 'text-danger fw-semibold');
            } else {
                showUsernameMsg('<i class="bi bi-check-circle me-1"></i>Username is available', 'text-success fw-semibold');
            }
        }
        function showUsernameMsg(html, cls) { const el = document.getElementById('usernameMsg'); el.innerHTML = html; el.className = 'small mt-1 ' + cls; }
        function togglePwd() { const inp = document.getElementById('pwdInput'); const icon = document.getElementById('eyeIcon'); inp.type = inp.type === 'password' ? 'text' : 'password'; icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash'; }
    </script>
}
