@model BusTracking.Common.DTOs.Common.ApiResponse<BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.SubAdmin.SubAdminListDto>>
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Sub-Admins";
    bool canAdd    = PermissionHelper.Can(User, "subadmin.add");
    bool canEdit   = PermissionHelper.Can(User, "subadmin.edit");
    bool canDelete = PermissionHelper.Can(User, "subadmin.delete");
    var list       = Model?.Data;
}

@{
    var created = TempData["CreatedUser"] as string;
    BusTracking.Common.DTOs.User.CreatedUserResultDto? newUser = null;
    if (!string.IsNullOrEmpty(created))
        newUser = System.Text.Json.JsonSerializer.Deserialize<BusTracking.Common.DTOs.User.CreatedUserResultDto>(created);
}

@if (newUser is not null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4">
        <div class="row g-2">
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Full Name</div><div class="fw-semibold">@newUser.FullName</div></div></div>
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Role</div><div><span class="badge bg-warning-subtle text-warning">@newUser.Role</span></div></div></div>
            <div class="col-md-4"><div class="bg-white rounded p-3 border"><div class="text-muted small mb-1">Email</div><div class="fw-semibold">@newUser.Email</div></div></div>
            <div class="col-12">
                <div class="bg-white rounded p-3 border">
                    <div class="text-muted small mb-1">Password</div>
                    <div class="d-flex align-items-center gap-2">
                        <span id="pwdDisplay" class="fw-semibold font-monospace">••••••••••••</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="togglePwd()"><i class="bi bi-eye" id="pwdEye"></i></button>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyPwd()"><i class="bi bi-clipboard me-1"></i>Copy</button>
                    </div>
                    <input type="hidden" id="pwdValue" value="@newUser.PlainPassword" />
                </div>
            </div>
        </div>
    </div>
}

@if (TempData["SuccessMessage"] is string sm)
{
    <div class="alert alert-success border-0 shadow-sm mb-3">@sm</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-badge me-2 text-warning"></i>Sub-Admins</h4>
    @if (canAdd)
    {
        <a asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Add Sub-Admin
        </a>
    }
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-4 d-flex align-items-center gap-4 flex-wrap">
        <span class="fw-semibold small text-muted">Filter:</span>
        <form asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Index" method="get"
              class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
            <div class="d-flex gap-3">
                @foreach (var s in new[] { ("Active", "Active"), ("Inactive", "Inactive"), ("Both", "Both") })
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" name="status" value="@s.Item1" id="st_@s.Item1"
                               @((ViewBag.Status as string) == s.Item1 ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label small" for="st_@s.Item1">@s.Item2</label>
                    </div>
                }
            </div>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm ms-auto"
                   style="max-width:260px" placeholder="Search name or email…" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Permissions</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (list?.Items?.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-person-badge fs-1 d-block mb-2"></i>No sub-admins found.
                        </td></tr>
                    }
                    @{ int i = ((list?.PageNumber ?? 1) - 1) * (list?.PageSize ?? 10) + 1; }
                    @foreach (var u in list?.Items ?? [])
                    {
                        bool isSelf = u.UserId == (int)(ViewBag.CurrentUserId ?? 0);
                        <tr @(isSelf ? "class=table-light" : "")>
                            <td class="text-muted small">@(i++)</td>
                            <td class="fw-semibold">
                                @u.FullName
                                @if (isSelf)
                                {
                                    <span class="badge bg-warning-subtle text-warning ms-1" style="font-size:.7rem">You</span>
                                }
                            </td>
                            <td class="text-muted small">@u.Email</td>
                            <td class="text-muted small">@u.PhoneNumber</td>
                            <td>
                                <span class="badge bg-info-subtle text-info">@u.Permissions.Count perm(s)</span>
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-2 justify-content-end">
                                    @* View always visible *@
                                    <a asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Details"
                                       asp-route-id="@u.UserId" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @* Edit / Toggle / Delete hidden for own row *@
                                    @if (!isSelf)
                                    {
                                        @if (canEdit)
                                        {
                                            <a asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Edit"
                                               asp-route-id="@u.UserId" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    onclick="toggleStatus(@u.UserId, this)" title="Toggle Active/Inactive">
                                                <i class="bi bi-toggle-@(u.IsActive ? "on text-success" : "off text-danger")"></i>
                                            </button>
                                        }
                                        @if (canDelete)
                                        {
                                            <form asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Delete"
                                                  asp-route-id="@u.UserId" method="post"
                                                  onsubmit="return confirm('Mark this coordinator as inactive?')">
                                                @Html.AntiForgeryToken()
                                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                            </form>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Pagination *@
@if ((list?.TotalPages ?? 0) > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            @for (int p = 1; p <= list!.TotalPages; p++)
            {
                <li class="page-item @(p == list.PageNumber ? "active" : "")">
                    <a class="page-link" asp-area="BusCoordinator" asp-controller="SubAdmin" asp-action="Index"
                       asp-route-page="@p" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status">@p</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
<script>
    function togglePwd() {
        const el = document.getElementById('pwdDisplay');
        const eye = document.getElementById('pwdEye');
        const val = document.getElementById('pwdValue').value;
        if (el.textContent.includes('•')) { el.textContent = val; eye.className = 'bi bi-eye-slash'; }
        else { el.textContent = '••••••••••••'; eye.className = 'bi bi-eye'; }
    }
    function copyPwd() {
        navigator.clipboard.writeText(document.getElementById('pwdValue').value);
    }
    async function toggleStatus(id, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const res = await fetch(`/BusCoordinator/SubAdmin/Toggle?id=${id}`, {
            method: 'POST', headers: { 'RequestVerificationToken': token }
        });
        if (res.ok) location.reload();
    }
</script>
}
