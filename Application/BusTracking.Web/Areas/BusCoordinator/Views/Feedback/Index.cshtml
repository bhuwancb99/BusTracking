@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Feedback.FeedbackListDto>
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Help & Support";
    bool canManageFeedback = PermissionHelper.Can(User, "helpsupport.manage");
}
<div class="mb-4"><h4 class="fw-bold mb-0"><i class="bi bi-headset me-2 text-primary"></i>Help & Support</h4></div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model?.Items.Count == 0)
        {
            <div class="text-center text-muted py-5">No feedback found.</div>
        }
        @foreach (var f in Model?.Items ?? [])
        {
            <div class="p-4 border-bottom">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                    <div><span class="badge @(f.Category == "Complaint" ? "bg-danger-subtle text-danger" : "bg-info-subtle text-info") me-2">@f.Category</span><strong>@f.UserName</strong></div>
                    <span class="badge @(f.Status == "Open" ? "bg-warning-subtle text-warning" : f.Status == "Resolved" ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">@f.Status</span>
                </div>
                <p class="mt-2 mb-2 text-muted small">@f.Description</p>
                @if (canManageFeedback && (f.Status is "Open" or "InProgress"))
                {
                    <div class="d-flex gap-2">
                        @foreach (var s in new[] { "InProgress", "Resolved", "Closed" })
                        {
                            <form asp-area="BusCoordinator" asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@f.FeedbackId" />
                                <input type="hidden" name="status" value="@s" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Mark @s</button>
                            </form>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
