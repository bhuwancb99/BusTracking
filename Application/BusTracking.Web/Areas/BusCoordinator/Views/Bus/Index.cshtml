@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Bus.BusListDto>
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Buses";
    bool canAdd  = PermissionHelper.Can(User, "bus.add");
    bool canEdit = PermissionHelper.Can(User, "bus.edit");
    bool canView = PermissionHelper.Can(User, "bus.view");

    var currentStatus = (ViewBag.Status as string) ?? "Active";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bus-front me-2 text-primary"></i>Buses</h4>
    @if (canAdd)
    {
        <a asp-area="BusCoordinator" asp-controller="Bus" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Bus</a>
    }
</div>
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-4 d-flex align-items-center gap-4 flex-wrap">
        <span class="fw-semibold small text-muted">Filter:</span>
        <form asp-area="BusCoordinator" asp-action="Index" method="get"
              class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
            <div class="d-flex gap-3">
                @foreach (var s in new[] { ("Active", "Active"), ("Inactive", "Inactive"), ("Both", "Both") })
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" name="status"
                               value="@s.Item1" id="bus_st_@s.Item1"
                               @(currentStatus == s.Item1 ? "checked" : "")
                               onchange="this.form.submit()" />
                        <label class="form-check-label small" for="bus_st_@s.Item1">@s.Item2</label>
                    </div>
                }
            </div>
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm ms-auto" style="max-width:280px"
                   placeholder="Search…" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light"><tr><th>#</th><th>Bus Name</th><th>Number</th><th>Route</th><th>Type</th><th>Driver</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No buses found.</td></tr>
                    }
                    @foreach (var (b, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td class="fw-semibold">@b.BusName</td>
                            <td><span class="badge bg-primary-subtle text-primary">@b.BusNumber</span></td>
                            <td>@(b.RouteName ?? "–")</td>
                            <td><span class="badge bg-secondary-subtle text-secondary">@(b.BusTypeName ?? "–")</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(b.DriverName))
                                {
                                    @b.DriverName
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td><span class="badge @(b.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(b.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                @if (canView)
                                {
                                    <a asp-area="BusCoordinator" asp-action="Details" asp-route-id="@b.BusId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                }
                                @if (canEdit)
                                {
                                    <a asp-area="BusCoordinator" asp-action="Edit" asp-route-id="@b.BusId" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil"></i></a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model" />
    </div>
</div>
