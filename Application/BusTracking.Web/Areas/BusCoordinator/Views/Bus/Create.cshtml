@model BusTracking.Common.DTOs.Bus.CreateBusDto
@using BusTracking.Web.Helpers
@{
    ViewData["Title"] = "Add Bus";
    if (!PermissionHelper.Can(User, "bus.add")) { Context.Response.Redirect("/BusCoordinator/Bus"); return; }
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-bus-front me-2 text-primary"></i>Add New Bus
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="BusCoordinator" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="BusName" class="form-label fw-semibold">Bus Name <span class="text-danger">*</span></label>
                            <input asp-for="BusName" class="form-control" placeholder="e.g. Red Falcon" />
                            <span asp-validation-for="BusName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BusNumber" class="form-label fw-semibold">Bus Number <span class="text-danger">*</span></label>
                            <input asp-for="BusNumber" class="form-control" placeholder="e.g. MH-01-AB-1234" />
                            <span asp-validation-for="BusNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Capacity" class="form-label fw-semibold">Capacity (seats)</label>
                            <input asp-for="Capacity" type="number" min="1" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RouteId" class="form-label fw-semibold">
                                Assign Route <span class="text-danger">*</span>
                                <small class="text-muted fw-normal">(required for stops)</small>
                            </label>
                            <select asp-for="RouteId" class="form-select"
                                    asp-items="@(ViewBag.Routes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? [])">
                                <option value="">-- Select Route --</option>
                            </select>
                            <span asp-validation-for="RouteId" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="alert alert-info border-0 py-2 mt-3 small">
                        <i class="bi bi-lightbulb me-1"></i>
                        Assigning a route enables stop selection when assigning students to this bus.
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check2 me-1"></i>Save Bus</button>
                        <a asp-area="BusCoordinator" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

