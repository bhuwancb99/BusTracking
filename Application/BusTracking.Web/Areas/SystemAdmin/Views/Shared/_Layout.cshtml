<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – System Administration</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/sysadmin.css" asp-append-version="true" />
</head>
<body class="sysadmin-body">
    <div class="sysadmin-sidebar">
        <a href="@Url.Action("Index", "Dashboard", new { area = "SystemAdmin" })" class="sysadmin-logo">
            <i class="bi bi-shield-lock-fill"></i>
            <span>System Admin</span>
        </a>

        <ul class="sysadmin-nav-menu">
            <li class="sysadmin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <a href="@Url.Action("Index", "Dashboard", new { area = "SystemAdmin" })">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="sysadmin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "School" ? "active" : "")">
                <a href="@Url.Action("Index", "School", new { area = "SystemAdmin" })">
                    <i class="bi bi-building"></i>
                    <span>Schools</span>
                </a>
            </li>
            <li class="sysadmin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "SuperAdmin" ? "active" : "")">
                <a href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin" })">
                    <i class="bi bi-people"></i>
                    <span>Super Admins</span>
                </a>
            </li>
            <li class="sysadmin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auth" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                <a href="@Url.Action("Profile", "Auth", new { area = "SystemAdmin" })">
                    <i class="bi bi-person-circle"></i>
                    <span>Profile Settings</span>
                </a>
            </li>
            <li class="sysadmin-nav-item mt-5">
                <form id="logoutForm" action="@Url.Action("Logout", "Auth", new { area = "SystemAdmin" })" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <a href="javascript:void(0)" onclick="document.getElementById('logoutForm').submit()" class="text-danger">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>
                </form>
            </li>
        </ul>
    </div>

    <div class="sysadmin-main">
        <div class="container-fluid">
            @if (TempData["SuccessMessage"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: rgba(16, 185, 129, 0.15); color: #10b981;">
                    <i class="bi bi-check-circle-fill me-2"></i>@successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 mb-4" role="alert" style="background-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
