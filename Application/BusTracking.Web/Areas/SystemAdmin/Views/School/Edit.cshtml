@model BusTracking.Common.Entities.School
@{
    ViewData["Title"] = "Edit School";
}

<div class="row">
    <div class="col-md-9 mx-auto">
        <div class="d-flex align-items-center mb-4">
            <a href="@Url.Action("Index", "School", new { area = "SystemAdmin" })" class="btn btn-secondary btn-sm me-3 rounded-circle" style="padding: 0.375rem 0.5rem;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="fw-bold m-0"><i class="bi bi-building-gear text-primary me-2"></i>Edit School</h2>
        </div>

        <div class="premium-card rounded-4 border-0 p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SchoolId" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 border-0 rounded-3 mb-4" style="background-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="SchoolName" class="form-label">School Name</label>
                        <input asp-for="SchoolName" class="form-control" required />
                        <span asp-validation-for="SchoolName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SchoolCode" class="form-label">School Code</label>
                        <input asp-for="SchoolCode" class="form-control" required />
                        <span asp-validation-for="SchoolCode" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PrincipalName" class="form-label">Principal Name</label>
                        <input asp-for="PrincipalName" class="form-control" required />
                        <span asp-validation-for="PrincipalName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label for="logoFile" class="form-label fw-semibold">School Logo</label>
                        <div class="premium-file-upload border border-dashed rounded-3 p-3 text-center position-relative bg-light-subtle" style="cursor: pointer; border-style: dashed !important; border-color: #3d5af1 !important; transition: background-color 0.2s;">
                            <input type="file" id="logoFile" name="logoFile" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" accept="image/*" onchange="previewFile(this, 'logoPreview', 'logoFileName')" />
                            <div class="upload-content">
                                <i class="bi bi-cloud-arrow-up-fill text-primary fs-3 d-block mb-1"></i>
                                <span class="fw-semibold text-secondary d-block" id="logoFileName">Choose new logo...</span>
                                <span class="text-muted small">PNG, JPG or WebP (max. 5MB)</span>
                            </div>
                            <div id="logoPreview" class="mt-2 @(string.IsNullOrEmpty(Model.SchoolLogo) ? "d-none" : "")">
                                <img src="@Model.SchoolLogo" class="rounded border border-secondary" style="height: 50px; max-width: 100%; object-fit: contain;" />
                                @if (!string.IsNullOrEmpty(Model.SchoolLogo))
                                {
                                    <div class="text-secondary small mt-1">Current Active Logo</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                        <input asp-for="ContactNumber" class="form-control" required />
                        <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EmailAddress" class="form-label">Email Address</label>
                        <input asp-for="EmailAddress" type="email" class="form-control" required />
                        <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Website" class="form-label">Website</label>
                        <input asp-for="Website" type="url" class="form-control" placeholder="https://example.com" />
                        <span asp-validation-for="Website" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="SchoolAddress" class="form-label">School Address</label>
                        <textarea asp-for="SchoolAddress" class="form-control" rows="3" required></textarea>
                        <span asp-validation-for="SchoolAddress" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mt-3">
                        <label class="form-label d-block">Status</label>
                        <div class="form-check form-switch pt-1">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch" style="cursor: pointer; width: 45px; height: 22px;">
                            <label class="form-check-label ms-2 text-secondary" for="IsActiveSwitch">Active / Enabled</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4 gap-2">
                    <a href="@Url.Action("Index", "School", new { area = "SystemAdmin" })" class="btn btn-secondary rounded-3">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-3"><i class="bi bi-save me-2"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewFile(input, previewId, nameId) {
            const file = input.files[0];
            const previewDiv = document.getElementById(previewId);
            const nameSpan = document.getElementById(nameId);
            if (file) {
                nameSpan.textContent = file.name;
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewDiv.querySelector('img').src = e.target.result;
                    previewDiv.classList.remove('d-none');
                    // Remove current logo helper text
                    const helper = previewDiv.querySelector('.text-secondary');
                    if (helper) helper.textContent = "New Selected Logo";
                };
                reader.readAsDataURL(file);
            } else {
                nameSpan.textContent = "Choose logo image...";
                previewDiv.classList.add('d-none');
            }
        }
    </script>
}
