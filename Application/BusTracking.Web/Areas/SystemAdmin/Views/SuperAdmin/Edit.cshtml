@model BusTracking.Common.Entities.User
@{
    ViewData["Title"] = "Edit Super Admin";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="d-flex align-items-center mb-4">
            <a href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin" })" class="btn btn-secondary btn-sm me-3 rounded-circle" style="padding: 0.375rem 0.5rem;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h2 class="fw-bold m-0"><i class="bi bi-person-gear text-primary me-2"></i>Edit Super Admin</h2>
        </div>

        <div class="premium-card rounded-4 border-0 p-4">
            <form asp-action="Edit" method="post" id="editAdminForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 border-0 rounded-3 mb-4" style="background-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" required />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="UserName" class="form-label">Username</label>
                        <input asp-for="UserName" class="form-control" id="UserNameInput" required autocomplete="off" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                        <div id="usernameCheckMsg" class="small mt-1"></div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SchoolId" class="form-label">Assign School</label>
                        <select asp-for="SchoolId" asp-items="ViewBag.Schools" class="form-select" required>
                            <option value="">-- Select School --</option>
                        </select>
                        <span asp-validation-for="SchoolId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">Email Address (Optional)</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number (Optional)</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label for="password" class="form-label">Password (Leave blank to keep unchanged)</label>
                        <input type="password" id="password" name="password" class="form-control" placeholder="Enter new password to change" />
                    </div>

                    <div class="col-md-6">
                        <label for="profileImage" class="form-label fw-semibold">Profile Image (Optional)</label>
                        <div class="premium-file-upload border border-dashed rounded-3 p-3 text-center position-relative bg-light-subtle" style="cursor: pointer; border-style: dashed !important; border-color: #3d5af1 !important; transition: background-color 0.2s;">
                            <input type="file" id="profileImage" name="profileImage" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" accept="image/*" onchange="previewFile(this, 'profilePreview', 'profileFileName')" />
                            <div class="upload-content">
                                <i class="bi bi-cloud-arrow-up-fill text-primary fs-3 d-block mb-1"></i>
                                <span class="fw-semibold text-secondary d-block" id="profileFileName">Choose new profile image...</span>
                                <span class="text-muted small">PNG, JPG or WebP (max. 5MB)</span>
                            </div>
                            <div id="profilePreview" class="mt-2 @(string.IsNullOrEmpty(Model.ProfileImageUrl) ? "d-none" : "")">
                                <img src="@Model.ProfileImageUrl" class="rounded-circle border border-secondary" style="height: 50px; width: 50px; object-fit: cover;" />
                                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                                {
                                    <div class="text-secondary small mt-1">Current Active Photo</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mt-3">
                        <label class="form-label d-block">Status</label>
                        <div class="form-check form-switch pt-1">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch" style="cursor: pointer; width: 45px; height: 22px;">
                            <label class="form-check-label ms-2 text-secondary" for="IsActiveSwitch">Active / Enabled</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4 gap-2">
                    <a href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin" })" class="btn btn-secondary rounded-3">Cancel</a>
                    <button type="submit" id="submitBtn" class="btn btn-primary rounded-3"><i class="bi bi-save me-2"></i>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            var timeout = null;
            $('#UserNameInput').on('keyup input', function() {
                var val = $(this).val().trim();
                var currentUserId = '@Model.UserId';
                clearTimeout(timeout);

                if (val.length === 0) {
                    $('#usernameCheckMsg').text('');
                    $('#submitBtn').prop('disabled', false);
                    return;
                }

                timeout = setTimeout(function() {
                    $.ajax({
                        url: '@Url.Action("CheckUsername", "SuperAdmin", new { area = "SystemAdmin" })',
                        type: 'GET',
                        data: { userName: val, excludeUserId: currentUserId },
                        success: function(res) {
                            if (res.success) {
                                $('#usernameCheckMsg').html('<i class="bi bi-check-circle-fill me-1"></i>Username is available').removeClass('text-danger').addClass('text-success');
                                $('#submitBtn').prop('disabled', false);
                            } else {
                                $('#usernameCheckMsg').html('<i class="bi bi-x-circle-fill me-1"></i>' + res.message).removeClass('text-success').addClass('text-danger');
                                $('#submitBtn').prop('disabled', true);
                            }
                        }
                    });
                }, 400);
            });
        });
        function previewFile(input, previewId, nameId) {
            const file = input.files[0];
            const previewDiv = document.getElementById(previewId);
            const nameSpan = document.getElementById(nameId);
            if (file) {
                nameSpan.textContent = file.name;
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewDiv.querySelector('img').src = e.target.result;
                    previewDiv.classList.remove('d-none');
                    const helper = previewDiv.querySelector('.text-secondary');
                    if (helper) helper.textContent = "New Selected Photo";
                };
                reader.readAsDataURL(file);
            } else {
                nameSpan.textContent = "Choose profile image...";
                previewDiv.classList.add('d-none');
            }
        }
    </script>
}
