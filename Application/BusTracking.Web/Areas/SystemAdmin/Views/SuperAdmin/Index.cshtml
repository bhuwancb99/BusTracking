@model List<BusTracking.Common.Entities.User>
@{
    ViewData["Title"] = "Super Admins Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold m-0"><i class="bi bi-people text-primary me-2"></i>Super Admins Management</h2>
    <a href="@Url.Action("Create", "SuperAdmin", new { area = "SystemAdmin" })" class="btn btn-primary rounded-3">
        <i class="bi bi-person-plus-fill me-2"></i>Add Super Admin
    </a>
</div>

<div class="premium-card rounded-4 border-0 p-4 mb-4">
    <form method="get" class="row g-2 align-items-center">
        <div class="col-md-6">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, username or email..." />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100 rounded-3"><i class="bi bi-search me-2"></i>Search</button>
        </div>
        <div class="col-md-3">
            <a href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin" })" class="btn btn-secondary w-100 rounded-3"><i class="bi bi-x-circle me-2"></i>Clear</a>
        </div>
    </form>
</div>

<div class="premium-card rounded-4 border-0 p-0 overflow-hidden">
    <table class="premium-table m-0">
        <thead>
            <tr>
                <th style="width: 80px; text-align: center;">Photo</th>
                <th>Full Name</th>
                <th>Username</th>
                <th>Assigned School</th>
                <th>Email</th>
                <th>Phone</th>
                <th style="width: 120px; text-align: center;">Active</th>
                <th style="width: 180px; text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-center text-secondary py-5">
                        <i class="bi bi-people text-muted" style="font-size: 2.5rem;"></i>
                        <p class="mt-2">No Super Admins found.</p>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-center">
                            @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                            {
                                <img src="@user.ProfileImageUrl" alt="Photo" class="rounded-circle border border-secondary" style="width: 40px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle d-flex align-items-center justify-content-center border border-secondary bg-dark text-secondary" style="width: 40px; height: 40px; font-weight: bold; font-size: 0.85rem; margin: 0 auto;">
                                    @user.FullName.Substring(0, Math.Min(2, user.FullName.Length)).ToUpper()
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@user.FullName</td>
                        <td class="fw-semibold text-primary">@user.UserName</td>
                        <td>@(user.School?.SchoolName ?? "Unassigned")</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td class="text-center">
                            <label class="switch">
                                <input type="checkbox" class="admin-toggle" data-id="@user.UserId" @(user.IsActive ? "checked" : "") />
                                <span class="slider"></span>
                            </label>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1">
                                <a href="@Url.Action("Edit", "SuperAdmin", new { area = "SystemAdmin", id = user.UserId })" class="btn btn-outline-light btn-sm rounded-3">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <button type="button" class="btn btn-outline-warning btn-sm rounded-3 reset-pwd-btn" data-id="@user.UserId" data-name="@user.FullName">
                                    <i class="bi bi-key"></i> Reset
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav class="d-flex justify-content-center mt-4">
        <ul class="pagination gap-1">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-3 bg-secondary text-light border-0" href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin", search = ViewBag.Search, page = ViewBag.CurrentPage - 1 })"><i class="bi bi-chevron-left"></i></a>
            </li>
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                    <a class="page-link rounded-3 border-0 @(ViewBag.CurrentPage == i ? "bg-primary text-light" : "bg-secondary text-secondary")" href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin", search = ViewBag.Search, page = i })">@i</a>
                </li>
            }
            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-3 bg-secondary text-light border-0" href="@Url.Action("Index", "SuperAdmin", new { area = "SystemAdmin", search = ViewBag.Search, page = ViewBag.CurrentPage + 1 })"><i class="bi bi-chevron-right"></i></a>
            </li>
        </ul>
    </nav>
}

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background-color: #1e293b; color: #f8fafc;">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold"><i class="bi bi-key text-warning me-2"></i>Reset Super Admin Password</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="resetUserId" name="id" />
                <div class="modal-body">
                    <p class="text-secondary small mb-3">Resetting password for: <span id="resetAdminName" class="fw-semibold text-light"></span></p>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer border-top border-secondary">
                    <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-3 text-dark fw-semibold">Reset Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Active status switch toggle via Ajax
            $('.admin-toggle').change(function() {
                var adminId = $(this).data('id');
                var token = $('input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '@Url.Action("ToggleActive", "SuperAdmin", new { area = "SystemAdmin" })',
                    type: 'POST',
                    data: { id: adminId, __RequestVerificationToken: token },
                    success: function(res) {
                    },
                    error: function() {
                        alert('An error occurred. Please try again.');
                    }
                });
            });

            // Trigger reset password modal
            $('.reset-pwd-btn').click(function() {
                var adminId = $(this).data('id');
                var adminName = $(this).data('name');
                $('#resetUserId').val(adminId);
                $('#resetAdminName').text(adminName);

                var modal = new bootstrap.Modal(document.getElementById('resetPasswordModal'));
                modal.show();
            });
        });
    </script>
}
