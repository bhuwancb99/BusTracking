@model BusTracking.Common.DTOs.Auth.LoginDto
@{
    Layout = null;
    ViewData["Title"] = "System Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – System Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/sysadmin.css" asp-append-version="true" />
</head>
<body class="sysadmin-body d-flex align-items-center justify-content-center min-vh-100" style="background: radial-gradient(circle at top right, #1e293b 0%, #0f172a 100%) !important;">
    <div class="login-card premium-card border-0 rounded-4" style="width: 100%; max-width: 420px; padding: 3rem;">
        <div class="text-center mb-4">
            <div class="mb-3">
                <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
            </div>
            <h4 class="fw-bold">System Administration</h4>
            <p class="text-secondary small">Manage portal, schools, and credentials</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 border-0 rounded-3" style="background-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
                <div asp-validation-summary="All"></div>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errMsg)
        {
            <div class="alert alert-danger py-2 border-0 rounded-3" style="background-color: rgba(239, 68, 68, 0.15); color: #ef4444;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@errMsg
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" id="username" name="username" class="form-control" placeholder="Enter username" required autofocus />
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2.5 mt-2">Sign In</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
