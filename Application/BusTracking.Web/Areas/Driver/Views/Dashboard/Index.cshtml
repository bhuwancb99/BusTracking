@{
    ViewData["Title"] = "Dashboard";
}

<h3 class="mb-4">Welcome, @User.GetFullName()</h3>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-bus-front text-primary me-2"></i>Quick Links</h5>
                <p class="text-muted">Use the menu to view your assigned bus, route, and start or end today's trip.</p>
                <a asp-area="Driver" asp-controller="Trip" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-signpost-split me-1"></i> Go to My Trip
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-info-circle text-info me-2"></i>How it works</h5>
                <ul class="text-muted ps-3 mb-0">
                    <li>Open <strong>My Trip</strong> to see your bus, route, and today's scheduled trip.</li>
                    <li>Tap <strong>Start Trip</strong> when you begin driving.</li>
                    <li>Mark each stop as <strong>Reached</strong> / <strong>Departed</strong> as you go.</li>
                    <li>Tap <strong>End Trip</strong> once the route is complete.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
