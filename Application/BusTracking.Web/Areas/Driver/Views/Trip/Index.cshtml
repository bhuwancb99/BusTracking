@model BusTracking.Common.DTOs.Driver.DriverMyTripDto
@{
    ViewData["Title"] = "My Trip";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-bus-front me-2 text-primary"></i>My Trip</h4>
        <p class="text-muted small mb-0">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
</div>

@if (Model is null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-bus-front text-muted" style="font-size:3rem"></i>
            <h5 class="mt-3 fw-semibold">No Bus Assigned</h5>
            <p class="text-muted">No bus is currently assigned to you. Please contact your coordinator.</p>
        </div>
    </div>
    return;
}

<div class="row g-4">
    <!-- Bus / Route Info -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <span class="fw-semibold"><i class="bi bi-bus-front me-2 text-primary"></i>Assigned Bus</span>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background:#f8faff">
                    <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width:52px;height:52px">
                        <i class="bi bi-bus-front-fill text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-5">@Model.BusNumber</div>
                        <div class="text-muted small">@Model.BusName</div>
                    </div>
                </div>
                <div class="d-flex flex-column gap-2 small">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted fw-semibold" style="letter-spacing:.04em">ROUTE</span>
                        <span class="fw-semibold">@Model.RouteName</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="text-muted fw-semibold" style="letter-spacing:.04em">BUS ID</span>
                        <span class="fw-semibold">#@Model.BusId</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Trip Card -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <span class="fw-semibold"><i class="bi bi-calendar-check me-2 text-success"></i>Today's Trip</span>
            </div>
            <div class="card-body px-4 pb-4">
                @if (Model.Trip is null)
                {
                    <div class="text-center py-4">
                        <i class="bi bi-calendar-x text-muted" style="font-size:2.5rem"></i>
                        <p class="text-muted mt-3 mb-0">No trip scheduled for today.</p>
                        <small class="text-muted">Your coordinator will assign trips when needed.</small>
                    </div>
                }
                else
                {
                    var trip = Model.Trip;
                    var statusStyle = trip.Status switch
                    {
                        "Scheduled"  => "background:#e8f0fe;color:#1a73e8",
                        "InProgress" => "background:#fef9c3;color:#854d0e",
                        "Completed"  => "background:#e6f4ea;color:#1e8e3e",
                        "Cancelled"  => "background:#fce8e6;color:#c5221f",
                        _            => "background:#f1f3f4;color:#5f6368"
                    };

                    <div class="d-flex flex-column gap-0">
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted fw-semibold small" style="letter-spacing:.04em">TRIP TYPE</span>
                            <span class="fw-semibold">
                                <i class="bi @(trip.TripType == "Morning" ? "bi-sunrise" : "bi-sunset") me-1 text-warning"></i>
                                @trip.TripType
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <span class="text-muted fw-semibold small" style="letter-spacing:.04em">STATUS</span>
                            <span class="badge rounded-pill px-3 py-2 fw-semibold" style="@statusStyle;font-size:.82rem">
                                @trip.Status
                            </span>
                        </div>
                        @if (trip.StartedAt is not null)
                        {
                            <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                                <span class="text-muted fw-semibold small" style="letter-spacing:.04em">STARTED AT</span>
                                <span class="fw-semibold">@trip.StartedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                            </div>
                        }
                        @if (trip.EndedAt is not null)
                        {
                            <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                                <span class="text-muted fw-semibold small" style="letter-spacing:.04em">ENDED AT</span>
                                <span class="fw-semibold">@trip.EndedAt.Value.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</span>
                            </div>
                        }
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex gap-2 flex-wrap mt-4">
                        @if (trip.CanStart)
                        {
                            <form asp-action="Start" asp-route-tripId="@trip.TripId" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success px-4">
                                    <i class="bi bi-play-fill me-1"></i>Start Trip
                                </button>
                            </form>
                        }

                        @if (trip.Status == "InProgress")
                        {
                            <form asp-action="End" asp-route-tripId="@trip.TripId" method="post"
                                  onsubmit="return confirm('End this trip?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger px-4">
                                    <i class="bi bi-stop-fill me-1"></i>End Trip
                                </button>
                            </form>
                        }

                        @if (trip.Status == "InProgress" || trip.Status == "Scheduled")
                        {
                            <a asp-action="Details" asp-route-tripId="@trip.TripId"
                               class="btn btn-outline-primary px-4">
                                <i class="bi bi-signpost-split me-1"></i>Manage Stops
                            </a>
                        }

                        @if (trip.Status == "InProgress" || trip.Status == "Completed")
                        {
                            <a asp-action="Details" asp-route-tripId="@trip.TripId"
                               class="btn btn-outline-secondary px-3">
                                <i class="bi bi-people me-1"></i>Students
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
