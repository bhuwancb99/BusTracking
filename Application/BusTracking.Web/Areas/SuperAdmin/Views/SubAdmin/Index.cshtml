@using System.Security.Claims
@* ── SubAdmin/Index.cshtml ───────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.SubAdmin.SubAdminListDto>
@{
    ViewData["Title"] = "Bus Coordinators"; ViewData["Breadcrumb"] = "Bus Coordinators";

    string? role = string.Empty;
    if (User.Identity?.IsAuthenticated == true)
        role = User?.FindFirstValue(ClaimTypes.Role);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-person-badge me-2 text-warning"></i>Bus Coordinators</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Coordinator</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" style="max-width:300px" placeholder="Search name or email…" />
            <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
            }
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr><th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Permissions</th><th>Status</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-person-badge fs-2 d-block mb-2"></i>No coordinators found.</td></tr>
                    }

                    @foreach (var (sa, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td class="fw-semibold">@sa.FullName</td>
                            <td class="text-muted small">@sa.Email</td>
                            <td>@(sa.PhoneNumber ?? "–")</td>
                            <td style="max-width:240px">
                                @foreach (var p in sa.Permissions.Take(4))
                                {
                                    <span class="badge bg-primary-subtle text-primary me-1 mb-1 small">@p</span>
                                }
                                @if (sa.Permissions.Count > 4)
                                {
                                    <span class="badge bg-secondary-subtle text-secondary small">+@(sa.Permissions.Count - 4) more</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(sa.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @(sa.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@sa.UserId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@sa.UserId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm btn-outline-secondary me-1 btn-toggle"
                                        data-id="@sa.UserId" title="@(sa.IsActive ? "Deactivate" : "Activate")">
                                    <i class="bi @(sa.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                                <form asp-action="Delete" asp-route-id="@sa.UserId" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete coordinator @sa.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id = this.dataset.id;
                const result = await busTrack.post(`/@role/SubAdmin/ToggleActive?id=${id}`, {});
                busTrack.showToast(result.message, result.success ? 'success' : 'danger');
                if (result.success) setTimeout(() => location.reload(), 800);
            });
        });
    </script>
}
