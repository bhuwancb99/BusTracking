@model BusTracking.Common.DTOs.SubAdmin.CreateSubAdminDto
@{
    ViewData["Title"] = "Add Coordinator";
}

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-person-badge me-2 text-warning"></i>Add Bus Coordinator</div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="SuperAdmin" asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Coordinator full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="UserName" class="form-control" placeholder="unique_username" id="usernameInput" autocomplete="off" />
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div id="usernameMsg" class="small mt-1"></div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-muted fw-normal">(Optional)</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="coordinator@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+91 98765 43210" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label fw-semibold">Password <span class="text-muted fw-normal">(leave blank to auto-generate)</span></label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Set password or leave blank" id="pwdInput" autocomplete="new-password" />
                                <button type="button" class="btn btn-outline-secondary" id="togglePwd"><i class="bi bi-eye" id="eyeIcon"></i></button>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-semibold">Assign Permissions</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="btnSelectAll">Select All</button>
                        </div>
                        @{
                            var allPerms = ViewBag.AllPermissions as List<(int Id, string ModuleName, string Key, string Description)>
                                          ?? new List<(int, string, string, string)>();
                            var permGroups = allPerms.GroupBy(p => p.ModuleName).OrderBy(g => g.Key);
                        }
                        <div class="row g-3">
                            @foreach (var group in permGroups)
                            {
                                var modKey = group.Key.Replace(" ", "_").Replace("&", "");
                                <div class="col-md-6">
                                    <div class="border rounded p-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="fw-semibold small text-uppercase text-muted">@group.Key.Replace("Manage", "")</span>
                                            <button type="button" class="btn btn-link btn-sm p-0 text-primary btn-module-all" data-mod="@modKey">All</button>
                                        </div>
                                        @foreach (var perm in group)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input perm-@modKey" type="checkbox"
                                                       name="PermissionIds" value="@perm.Id" id="perm_@perm.Id" />
                                                <label class="form-check-label small" for="perm_@perm.Id">@perm.Description</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="SendEmail" class="form-check-input" type="checkbox" role="switch" id="sendEmailChk" />
                        <label class="form-check-label" for="sendEmailChk">
                            <i class="bi bi-envelope me-1"></i>Send welcome email with credentials
                            <span class="badge bg-secondary-subtle text-secondary ms-1">Requires email</span>
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4"><i class="bi bi-check2 me-1"></i>Create Coordinator</button>
                        <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const vs=document.getElementById('valSummary');
        if(vs&&vs.querySelector('li,span:not(:empty)'))vs.style.display='';
        document.getElementById('createForm').addEventListener('submit',()=>{if(vs)vs.style.display='';});
            document.getElementById('usernameMsg').innerHTML = '';
        });
            const res = await fetch(`/Auth/CheckUsername?userName=${encodeURIComponent(val)}`);
            const data = await res.json();
            if (data.success === false && data.message.includes('already')) {
                showUsernameMsg('<i class="bi bi-x-circle me-1"></i>Username already exists', 'text-danger fw-semibold');
            } else {
                showUsernameMsg('<i class="bi bi-check-circle me-1"></i>Username is available', 'text-success fw-semibold');
            }
        }
            const el = document.getElementById('usernameMsg');
            el.innerHTML = html; el.className = 'small mt-1 ' + cls;
        }

        // Password toggle
        document.getElementById('togglePwd').addEventListener('click', function() {
            const inp = document.getElementById('pwdInput');
            const icon = document.getElementById('eyeIcon');
            inp.type = inp.type === 'password' ? 'text' : 'password';
            icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
        });

        document.querySelectorAll('.btn-module-all').forEach(btn=>{
            btn.addEventListener('click',function(){
                const cls=`.perm-${this.dataset.mod}`;
                const checks=[...document.querySelectorAll(cls)];
                const all=checks.every(c=>c.checked);
                checks.forEach(c=>c.checked=!all);
                this.textContent=all?'All':'None';
            });
        });
        document.getElementById('btnSelectAll').addEventListener('click',function(){
            const checks=[...document.querySelectorAll('input[name="PermissionIds"]')];
            const all=checks.every(c=>c.checked);
            checks.forEach(c=>c.checked=!all);
            this.textContent=all?'Select All':'Deselect All';
        });
        // ── Username live-check (keyup, min 5 chars, no excludeUserId on create) ──
        const _unInput = document.getElementById('usernameInput');
        const _unMsg   = document.getElementById('usernameMsg');
        let   _unTimer = null;

        _unInput.addEventListener('keyup', () => {
            clearTimeout(_unTimer);
            _unTimer = setTimeout(liveCheckUsername, 350);
        });

        async function liveCheckUsername() {
            const val = _unInput.value.trim();
            _unMsg.innerHTML = '';
            _unMsg.className = 'small mt-1';
            if (val.length === 0) return;
            if (val.length < 5) {
                _unMsg.innerHTML  = '<i class="bi bi-exclamation-circle me-1"></i>Username must have at least 5 characters';
                _unMsg.className  = 'small mt-1 text-danger';
                return;
            }
            try {
                const res  = await fetch(`/Auth/CheckUsername?userName=${encodeURIComponent(val)}`);
                if (!res.ok) return;
                const data = await res.json();
                if (!data.success) {
                    _unMsg.innerHTML = `<i class="bi bi-x-circle me-1"></i>The username <strong>${escHtml(val)}</strong> is already taken`;
                    _unMsg.className = 'small mt-1 text-danger';
                } else {
                    _unMsg.innerHTML = `<i class="bi bi-check-circle me-1"></i><strong>${escHtml(val)}</strong> is available`;
                    _unMsg.className = 'small mt-1 text-success fw-semibold';
                }
            } catch (_) { /* silent */ }
        }
        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
    </script>
}
