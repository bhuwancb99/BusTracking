@* ── Route/Create.cshtml ────────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Route.CreateRouteDto
@{
    ViewData["Title"] = "Add Route"; ViewData["Breadcrumb"] = "Routes / Add";
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-map me-2 text-primary"></i>Add New Route</div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="RouteName" class="form-label fw-semibold">Route Name <span class="text-danger">*</span></label>
                            <input asp-for="RouteName" class="form-control" placeholder="e.g. North Zone Route A" />
                            <span asp-validation-for="RouteName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RouteCode" class="form-label fw-semibold">Route Code <span class="text-danger">*</span></label>
                            <input asp-for="RouteCode" class="form-control" placeholder="e.g. NZ-A" />
                            <span asp-validation-for="RouteCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MorningTime" class="form-label fw-semibold"><i class="bi bi-sunrise me-1 text-warning"></i>Morning Departure</label>
                            <input asp-for="MorningTime" type="time" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EveningTime" class="form-label fw-semibold"><i class="bi bi-sunset me-1 text-secondary"></i>Evening Departure</label>
                            <input asp-for="EveningTime" type="time" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description…"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check2 me-1"></i>Save Route</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
