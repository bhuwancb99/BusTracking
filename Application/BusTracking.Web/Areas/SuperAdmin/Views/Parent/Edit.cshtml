@* ── Parent/Edit.cshtml ──────────────────────────────────── *@
@model BusTracking.Common.DTOs.Parent.UpdateParentDto
@{
    ViewData["Title"] = "Edit Parent"; ViewData["Breadcrumb"] = "Parents / Edit";
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-pencil me-2 text-warning"></i>Edit Parent</div>
            <div class="card-body p-4">
                <div asp-validation-summary="All" class="alert alert-danger py-2"></div>
                <form asp-action="Edit" asp-route-id="@ViewBag.ParentId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning px-4">Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

