@* ── _StatusFilter.cshtml ─────────────────────────────────────────────
   Usage: <partial name="_StatusFilter" model='ViewBag.Status as string' />
   Place inside a <form> or standalone — uses GET query string.
*@
@model string?
@{
    var current = Model ?? "Active";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
    var search = ViewContext.HttpContext.Request.Query["search"].ToString();
}
<div class="d-flex align-items-center gap-1 status-filter">
    @foreach (var opt in new[] { ("Active", "Active", "bg-success-subtle text-success"), ("Inactive", "Inactive", "bg-danger-subtle text-danger"), ("", "Both", "bg-secondary-subtle text-secondary") })
    {
        var isActive = current == opt.Item1;
        <a asp-action="@action" asp-route-search="@search" asp-route-status="@opt.Item1"
               class="btn btn-sm @(isActive ? opt.Item3 + " border-0 fw-semibold" : "btn-outline-secondary")">
            @if (opt.Item1 == "Active")
            {
                <i class="bi bi-check-circle me-1"></i>
            }
            @if (opt.Item1 == "Inactive")
            {
                <i class="bi bi-x-circle me-1"></i>
            }
            @if (opt.Item1 == "")
            {
                <i class="bi bi-list me-1"></i>
            }
            @opt.Item2
        </a>
    }
</div>
