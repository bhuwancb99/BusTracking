@using BusTracking.Common.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>@ViewData["Title"] – Super Admin | Bus Tracking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex">

    <!-- ── Sidebar ──────────────────────────────────────────────────── -->
    <nav id="sidebar" class="sidebar d-flex flex-column">
        <div class="sidebar-brand">
            <i class="bi bi-bus-front-fill"></i>
            <span>BusTrack <small class="opacity-50 small">Admin</small></span>
        </div>
        <ul class="sidebar-nav flex-grow-1">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                (string Lbl, string Icon, string C, string A)[] items =
                [
                    ("Dashboard",       "bi-speedometer2",   "Dashboard", "Index"),
                    ("App Config",      "bi-sliders",        "AppConfig", "Index"),
                    ("Classes/Standards","bi-bookmark-star",  "Standard",  "Index"),
                    ("Bus Types",       "bi-truck-front",    "BusType",   "Index"),
                    ("Bus Coordinators","bi-person-badge",   "SubAdmin",  "Index"),
                    ("Routes",          "bi-map",            "Route",     "Index"),
                    ("Buses",           "bi-bus-front",      "Bus",       "Index"),
                    ("Drivers",         "bi-person-video2",  "Driver",    "Index"),
                    ("Parents",         "bi-people",         "Parent",    "Index"),
                    ("Students",        "bi-mortarboard",    "Student",   "Index"),
                    ("Trips",           "bi-signpost-split", "Trip",      "Index"),
                    ("Notifications",   "bi-bell",           "Notification","Index"),
                    ("Help & Support",  "bi-headset",        "Feedback",  "Index"),
                    ("System Logs",     "bi-journal-text",   "Logger",    "Index"),
            ];
            }
            @foreach (var (lbl, icon, c, a) in items)
            {
                <li class="sidebar-item @(ctrl == c ? "active" : "")">
                    <a class="sidebar-link" asp-area="SuperAdmin" asp-controller="@c" asp-action="@a">
                        <i class="bi @icon"></i><span>@lbl</span>
                    </a>
                </li>
            }
        </ul>
        <div class="sidebar-footer">
            <a class="sidebar-link" asp-controller="Profile" asp-action="Index" asp-area="">
                <i class="bi bi-person-circle"></i><span>@User.GetFullName()</span>
            </a>
            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                    <i class="bi bi-box-arrow-left"></i><span>Logout</span>
                </button>
            </form>
        </div>
    </nav>

    <!-- ── Main ──────────────────────────────────────────────────────── -->
    <div class="main-wrapper flex-grow-1 d-flex flex-column">
        <header class="top-navbar">
            <button class="sidebar-toggle btn btn-sm btn-link" id="sidebarToggle"><i class="bi bi-list fs-4"></i></button>
            <span class="badge bg-warning-subtle text-warning ms-1 small">Super Admin</span>
            <div class="ms-auto d-flex align-items-center gap-3">
                <a asp-area="SuperAdmin" asp-controller="Notification" asp-action="Index" class="btn btn-sm btn-outline-secondary position-relative">
                    <i class="bi bi-bell"></i>
                </a>
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>@User.GetFullName()
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index" asp-area=""><i class="bi bi-person me-2"></i>Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword" asp-area=""><i class="bi bi-key me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" asp-area="" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-left me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <main class="content-area flex-grow-1 p-4">
            @{
                var alert = BusTracking.Web.Helpers.AlertHelper.FromTempData(TempData);
            }
            @if (alert is not null)
            {
                <div class="alert @alert.CssClass alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi @alert.Icon"></i><span>@alert.Message</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
        <footer class="py-2 px-4 border-top text-muted small text-end">&copy; @DateTime.Now.Year Bus Tracking System</footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
