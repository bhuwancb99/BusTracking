@* ── Bus/Index ───────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Bus.BusListDto>
@{
    ViewData["Title"] = "Buses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bus-front me-2 text-primary"></i>Buses</h4>
    <a asp-area="SuperAdmin" asp-controller="Bus" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Bus</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-4 d-flex align-items-center gap-4 flex-wrap">
        <span class="fw-semibold small text-muted">Filter:</span>
        <form asp-area="SuperAdmin" asp-action="Index" method="get" class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
            <div class="d-flex gap-3">
                @foreach (var s in new[] { ("Active", "Active"), ("Inactive", "Inactive"), ("Both", "Both") })
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" name="status" value="@s.Item1" id="st_@s.Item1"
                        @((ViewBag.Status as string) == s.Item1 ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label small" for="st_@s.Item1">@s.Item2</label>
                    </div>
                }
            </div>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm ms-auto"
                   style="max-width:260px" placeholder="Search bus name or number…" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-area="SuperAdmin" asp-action="Index" asp-route-status="@ViewBag.Status" class="btn btn-sm btn-outline-danger"><i class="bi bi-x"></i></a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th class="ps-3">#</th><th>Bus Name</th><th>Number</th><th>Route</th><th>Driver</th><th>Capacity</th><th>Students</th><th>Status</th><th class="text-end pe-4">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-5"><i class="bi bi-bus-front fs-1 d-block mb-2"></i>No buses found.</td></tr>
                    }
                    @foreach (var (b, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="ps-3 text-muted small">@i</td>
                            <td class="fw-semibold">@b.BusName</td>
                            <td><span class="badge bg-primary-subtle text-primary px-2">@b.BusNumber</span></td>
                            <td class="small">@(b.RouteName ?? "–")</td>
                            <td>
                                @if (b.DriverName is not null)
                                {
                                    <span class="small"><i class="bi bi-person-video2 me-1 text-success"></i>@b.DriverName</span>
                                }
                                else
                                {

                                    <span class="text-muted small">Unassigned</span>
                                }
                            </td>
                            <td class="small text-center">@(b.Capacity?.ToString() ?? "–")</td>
                            <td class="small text-center">
                                <span class="badge bg-info-subtle text-info">@b.StudentCount</span>
                            </td>
                            <td>
                                <span class="badge @(b.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @(b.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <a asp-area="SuperAdmin" asp-action="Details" asp-route-id="@b.BusId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@b.BusId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <button class="btn btn-sm @(b.IsActive ? "btn-outline-secondary" : "btn-outline-success") me-1 btn-toggle"
                                        data-id="@b.BusId" data-url="/SuperAdmin/Bus/Toggle">
                                    <i class="bi @(b.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                                <form asp-area="SuperAdmin" asp-action="Delete" asp-route-id="@b.BusId" method="post" class="d-inline"
                                      onsubmit="return confirm('Mark bus @b.BusName as inactive?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2"><partial name="_Pagination" model="Model" /></div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle').forEach(btn=>{
            btn.addEventListener('click',async function(){
                const token=document.querySelector('input[name="__RequestVerificationToken"]')?.value||'';
                const res=await fetch(`${this.dataset.url}?id=${this.dataset.id}`,{method:'POST',headers:{'RequestVerificationToken':token}});
                const data=await res.json();busTrack.showToast(data.message,data.success?'success':'danger');
                if(data.success)setTimeout(()=>location.reload(),700);
            });
        });
    </script>
}
