@* ── Bus/Index ───────────────────────────────────────────── *@
@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Bus.BusListDto>
@{ ViewData["Title"] = "Buses"; ViewData["Breadcrumb"] = "Buses"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bus-front me-2 text-primary"></i>Buses</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Bus</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" style="max-width:280px" placeholder="Search bus name or number…"/>
            <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-outline-danger"><i class="bi bi-x"></i></a>
            }
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Bus Name</th>
                        <th>Number</th>
                        <th>Route</th>
                        <th>Driver</th>
                        <th>Capacity</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model?.Items.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No buses found.</td></tr>
                }
                @foreach (var (bus, i) in (Model?.Items ?? []).Select((b, i) => (b, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                {
                    <tr>
                        <td class="text-muted small">@i</td>
                        <td class="fw-semibold">@bus.BusName</td>
                        <td><span class="badge bg-primary-subtle text-primary px-2 py-1">@bus.BusNumber</span></td>
                        <td>@(bus.RouteName ?? "–")</td>
                        <td>
                            @if (bus.DriverName is not null)
                            {
                                <span><i class="bi bi-person-circle me-1"></i>@bus.DriverName</span>
                            }
                            else { <span class="text-muted">Unassigned</span> }
                        </td>
                        <td>@(bus.Capacity?.ToString() ?? "–")</td>
                        <td>
                            <span class="badge @(bus.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                @(bus.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@bus.BusId" class="btn btn-sm btn-outline-info me-1" title="Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@bus.BusId" class="btn btn-sm btn-outline-warning me-1" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@bus.BusId" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this bus?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model is not null && Model.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center mb-0">
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@ViewBag.Search">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
