@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Standard.StandardDto>
@{
    ViewData["Title"] = "Classes / Standards";
    ViewData["Breadcrumb"] = "Classes / Standards";
    var searchFilter = ViewBag.Search as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-bookmark-star me-2 text-primary"></i>Classes / Standards</h4>
        <small class="text-muted">Manage classes and standards assigned to students</small>
    </div>
    <a asp-area="SuperAdmin" asp-controller="Standard" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Class
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3 px-4">
        <form asp-area="SuperAdmin" asp-action="Index" method="get" class="d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label class="form-label fw-semibold small mb-1">Search</label>
                <input type="text" name="search" value="@searchFilter" class="form-control form-control-sm"
                       style="width:240px" placeholder="Class name…" />
            </div>
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(searchFilter))
            {
                <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x me-1"></i>Clear search
                </a>
            }
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4">ID</th>
                        <th>Class / Standard Name</th>
                        <th>Status</th>
                        <th>Created At</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Items)
                    {
                        <tr id="row-@c.StandardId">
                            <td class="px-4">@c.StandardId</td>
                            <td>
                                <span class="fw-semibold">@c.StandardName</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill status-badge-@c.StandardId"
                                      style="@(c.IsActive ? "background:#e6f4ea;color:#1e8e3e" : "background:#fce8e6;color:#c5221f");font-size:.73rem">
                                    @(c.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td><span class="text-muted small">@c.CreatedAt.ToString("dd MMM yyyy")</span></td>
                            <td class="text-end px-4">
                                <a asp-area="SuperAdmin" asp-action="Details" asp-route-id="@c.StandardId"
                                   class="btn btn-sm btn-outline-info me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@c.StandardId"
                                   class="btn btn-sm btn-outline-warning me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-secondary me-1 btn-toggle-standard"
                                        data-id="@c.StandardId" title="Toggle Active">
                                    <i class="bi @(c.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off")"></i>
                                </button>
                                <form asp-area="SuperAdmin" asp-action="Delete" asp-route-id="@c.StandardId"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete class \'@c.StandardName\'? This cannot be undone.')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <i class="bi bi-bookmark-star fs-1 text-muted d-block mb-2"></i>
        <div class="text-muted">No classes/standards found. <a asp-area="SuperAdmin" asp-action="Create">Add the first one.</a></div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-2 px-4">
            @if (Model.TotalPages > 1)
            {
                <partial name="_Pagination" model="Model" />
            }
            else
            {
                <small class="text-muted">Showing all @Model.TotalCount result@(Model.TotalCount == 1 ? "" : "s")</small>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle-standard').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id  = this.dataset.id;
                const res = await fetch(`/SuperAdmin/Standard/Toggle/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' }
                });
                const data = await res.json();
                if (data.success) location.reload();
                else alert(data.message);
            });
        });
    </script>
}
