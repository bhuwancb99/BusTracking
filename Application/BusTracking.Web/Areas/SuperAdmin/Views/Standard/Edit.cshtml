@model BusTracking.Common.DTOs.Standard.UpdateStandardDto
@{
    ViewData["Title"] = "Edit Class / Standard";
    ViewData["Breadcrumb"] = "Edit Class";
    var standardId = ViewBag.StandardId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-pencil me-2 text-warning"></i>Edit Class / Standard</h4>
    <a asp-area="SuperAdmin" asp-controller="Standard" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <div asp-validation-summary="All" class="alert alert-danger border-0 small py-2 mb-3" style="display:none"></div>

                <form asp-area="SuperAdmin" asp-controller="Standard" asp-action="Edit" asp-route-id="@standardId" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="StandardName" class="form-label fw-semibold">
                            Class Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="StandardName" class="form-control"
                               placeholder="e.g. Class 5, Class 10" />
                        <div class="form-text text-muted">Enter standard/class name. Must be unique.</div>
                        <span asp-validation-for="StandardName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                            <div class="form-text text-muted">Inactive classes won't be shown when adding/editing students.</div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check2 me-1"></i>Save Changes
                        </button>
                        <a asp-area="SuperAdmin" asp-controller="Standard" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const vs = document.querySelector('[data-valmsg-summary]');
        if (vs && vs.querySelectorAll('li').length > 0) vs.style.display = '';
    </script>
}
