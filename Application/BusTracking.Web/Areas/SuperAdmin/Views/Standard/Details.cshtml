@model BusTracking.Common.DTOs.Standard.StandardDto
@{
    ViewData["Title"] = "Class Details";
    ViewData["Breadcrumb"] = "Class Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-eye me-2 text-info"></i>Class / Standard Details</h4>
    <div class="d-flex gap-2">
        <a asp-area="SuperAdmin" asp-controller="Standard" asp-action="Edit" asp-route-id="@Model.StandardId" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-area="SuperAdmin" asp-controller="Standard" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-0">
                        <tbody>
                            <tr>
                                <td class="fw-semibold text-muted" style="width: 30%">Standard ID</td>
                                <td class="font-monospace">@Model.StandardId</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Class Name</td>
                                <td class="fw-bold">@Model.StandardName</td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Status</td>
                                <td>
                                    <span class="badge rounded-pill"
                                          style="@(Model.IsActive ? "background:#e6f4ea;color:#1e8e3e" : "background:#fce8e6;color:#c5221f");font-size:.8rem">
                                        @(Model.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted">Created At</td>
                                <td>@Model.CreatedAt.ToString("g")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
