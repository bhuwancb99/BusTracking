@model BusTracking.Common.DTOs.Common.PagedResult<BusTracking.Common.DTOs.Student.StudentListDto>
@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard me-2 text-info"></i>Students</h4>
    <a asp-area="SuperAdmin" asp-controller="Student" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Student</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-4 d-flex align-items-center gap-4 flex-wrap">
        <span class="fw-semibold small text-muted">Filter:</span>
        <form asp-area="SuperAdmin" asp-action="Index" method="get" class="d-flex align-items-center gap-3 flex-wrap flex-grow-1">
            <div class="d-flex gap-3">
                @foreach (var s in new[] { ("Active", "Active"), ("Inactive", "Inactive"), ("", "Both") })
                {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="radio" name="status" value="@s.Item1" id="st_@s.Item1"
                        @(ViewBag.Status as string == s.Item1 ? "checked" : "") onchange="this.form.submit()" />
                        <label class="form-check-label small" for="st_@s.Item1">@s.Item2</label>
                    </div>
                }
            </div>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm ms-auto" style="max-width:260px" placeholder="Search name or code…" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>#</th><th>Code</th><th>Name</th><th>Email</th><th>Class</th><th>Bus</th><th>Stop</th><th>Status</th><th class="text-end pe-4">Actions</th></tr>
                </thead>
                <tbody>
                    @if (Model?.Items.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-5"><i class="bi bi-mortarboard fs-1 d-block mb-2"></i>No students found.</td></tr>
                    }
                    @foreach (var (s, i) in (Model?.Items ?? []).Select((x, i) => (x, i + 1 + (Model!.PageNumber - 1) * Model.PageSize)))
                    {
                        <tr>
                            <td class="ps-3 text-muted small">@i</td>
                            <td><code class="bg-light px-2 py-1 rounded">@s.StudentCode</code></td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td class="text-muted small">@s.Email</td>
                            <td class="small">@(s.Standard ?? "–")</td>
                            <td>
                                @if (s.BusNumber is not null)
                                {
                                    <span class="badge bg-primary-subtle text-primary">@s.BusNumber</span>
                                }
                                else
                                {

                                    <span class="text-muted small">–</span>
                                }
                            </td>
                            <td class="small">@(s.StopName ?? "–")</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                    @(s.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <a asp-area="SuperAdmin" asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
                                <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <a asp-area="SuperAdmin" asp-action="Availability" asp-route-studentId="@s.StudentId" class="btn btn-sm btn-outline-secondary me-1" title="Availability"><i class="bi bi-calendar-check"></i></a>
                                <button class="btn btn-sm @(s.IsActive ? "btn-outline-secondary" : "btn-outline-success") me-1 btn-toggle"
                                        data-id="@s.StudentId" data-url="/SuperAdmin/Student/Toggle">
                                    <i class="bi @(s.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-4 py-2"><partial name="_Pagination" model="Model" /></div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle').forEach(btn => {
            btn.addEventListener('click', async function() {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                const res = await fetch(`${this.dataset.url}?id=${this.dataset.id}`,{method:'POST',headers:{'RequestVerificationToken':token}});
                const data = await res.json();
                busTrack.showToast(data.message, data.success?'success':'danger');
                if (data.success) setTimeout(()=>location.reload(),700);
            });
        });
    </script>
}
