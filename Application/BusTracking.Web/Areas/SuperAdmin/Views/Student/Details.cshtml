@model BusTracking.Common.DTOs.Student.StudentListDto
@{
    ViewData["Title"] = "Student Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard me-2 text-info"></i>Student Profile</h4>
    <div class="d-flex gap-2">
        <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@Model?.StudentId" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-area="SuperAdmin" asp-action="Availability" asp-route-studentId="@Model?.StudentId" class="btn btn-outline-secondary btn-sm"><i class="bi bi-calendar-check me-1"></i>Availability</a>
        <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

@if (Model is not null)
{
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-xl bg-info-subtle text-info mx-auto rounded-circle d-flex align-items-center justify-content-center mb-3"
                             style="width:72px;height:72px;font-size:1.8rem;font-weight:700">
                            @Model.FullName.ToInitials()
                        </div>
                        <h5 class="fw-bold mb-1">@Model.FullName</h5>
                        <code class="small">@Model.StudentCode</code>
                        <div class="mt-1">
                            <span class="badge bg-info-subtle text-info me-1">Student</span>
                            <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@(Model.IsActive ? "Active" : "Inactive")</span>
                        </div>
                    </div>
                    <table class="table table-borderless small mb-0">
                        <tr><th class="text-muted w-40">Email</th><td>@Model.Email</td></tr>
                        <tr><th class="text-muted">Phone</th><td>@(Model.PhoneNumber ?? "–")</td></tr>
                        <tr><th class="text-muted">Class</th><td>@(Model.Standard ?? "–")</td></tr>
                        <tr><th class="text-muted">Stop</th><td>@(Model.StopName ?? "–")</td></tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-bus-front me-2 text-primary"></i>Assigned Bus</div>
                <div class="card-body p-4">
                    @if (Model.BusName is not null)
                    {
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="p-3 bg-primary-subtle rounded-circle"><i class="bi bi-bus-front text-primary fs-4"></i></div>
                            <div>
                                <div class="fw-semibold">@Model.BusName</div>
                                <span class="badge bg-primary-subtle text-primary">@Model.BusNumber</span>
                            </div>
                        </div>
                    }
                    else
                    {

                        <div class="text-muted small mb-3">No bus assigned.</div>
                    }

                    <div class="fw-semibold small mb-2">Quick Assign / Change Bus</div>
                    <div class="d-flex gap-2">
                        <div class="position-relative flex-grow-1">
                            <input type="text" id="quickBusSearch" class="form-control form-control-sm" placeholder="Type bus name…" autocomplete="off" />
                            <div id="quickBusSug" class="dropdown-menu w-100 shadow-sm"></div>
                        </div>
                        <button class="btn btn-sm btn-primary" id="btnAssignBus"><i class="bi bi-check2"></i> Assign</button>
                        <button class="btn btn-sm btn-outline-danger" id="btnRemoveBus"><i class="bi bi-x"></i> Remove</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const studentId = @Model?.StudentId;
        let selectedBusId = null;
        let t;
        document.getElementById('quickBusSearch').addEventListener('input',function(){clearTimeout(t);const q=this.value.trim();if(q.length<1){hideSug();return;}t=setTimeout(()=>fetchBuses(q),250);});
        document.addEventListener('click',e=>{if(!e.target.closest('#quickBusSearch,#quickBusSug'))hideSug();});
        async function fetchBuses(q){const res=await fetch(`/SuperAdmin/Student/SearchBuses?q=${encodeURIComponent(q)}`);const data=await res.json();const box=document.getElementById('quickBusSug');box.innerHTML='';data.forEach(b=>{const a=document.createElement('a');a.className='dropdown-item';a.href='#';a.textContent=b.display;a.addEventListener('click',e=>{e.preventDefault();selectedBusId=b.busId;document.getElementById('quickBusSearch').value=b.display;hideSug();});box.appendChild(a);});if(data.length)box.classList.add('show');}
        function hideSug(){document.getElementById('quickBusSug').classList.remove('show');}

        const token=()=>document.querySelector('input[name="__RequestVerificationToken"]')?.value||'';
        document.getElementById('btnAssignBus').addEventListener('click',async()=>{
            if(!selectedBusId){busTrack.showToast('Select a bus first','warning');return;}
            const res=await fetch('/SuperAdmin/Student/AssignBus',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':token()},body:JSON.stringify({studentId,busId:selectedBusId})});
            const data=await res.json();busTrack.showToast(data.message,data.success?'success':'danger');
            if(data.success)setTimeout(()=>location.reload(),800);
        });
        document.getElementById('btnRemoveBus').addEventListener('click',async()=>{
            if(!confirm('Remove bus assignment?'))return;
            const res=await fetch('/SuperAdmin/Student/AssignBus',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':token()},body:JSON.stringify({studentId,busId:null})});
            const data=await res.json();busTrack.showToast(data.message,data.success?'success':'danger');
            if(data.success)setTimeout(()=>location.reload(),800);
        });
    </script>
}
