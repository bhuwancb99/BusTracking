@model BusTracking.Common.DTOs.Student.UpdateStudentDto
@{
    ViewData["Title"] = "Edit Student";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-pencil me-2 text-warning"></i>Edit Student
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@ViewBag.StudentId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="UserName" class="form-control" id="usernameInput" autocomplete="off" />
                                <button type="button" class="btn btn-outline-secondary" id="btnCheckUsername" title="Check availability"><i class="bi bi-search"></i></button>
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div id="usernameMsg" class="small mt-1"></div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StudentCode" class="form-label fw-semibold">Student Code <span class="text-danger">*</span></label>
                            <input asp-for="StudentCode" class="form-control" />
                            <span asp-validation-for="StudentCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Standard" class="form-label fw-semibold">Class / Standard</label>
                            <input asp-for="Standard" class="form-control" />
                        </div>

                        <!-- Bus autocomplete -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Assign Bus</label>
                            <div class="position-relative">
                                <input type="text" id="busSearch" class="form-control"
                                       value="@(ViewBag.BusDisplay as string ?? "")"
                                       placeholder="Type bus name or number…" autocomplete="off" />
                                <input type="hidden" asp-for="BusId" id="busIdInput" />
                                <div id="busSuggestions" class="dropdown-menu w-100 shadow-sm"></div>
                            </div>
                            <div id="busSelected" class="mt-1">
                                @if (Model?.BusId.HasValue == true)
                                {
                                    <span class="badge bg-primary-subtle text-primary">
                                        <i class="bi bi-bus-front me-1"></i><span id="busLabel">@(ViewBag.BusDisplay as string ?? $"Bus ID: {Model.BusId}")</span>
                                    </span>
                                    <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-1" onclick="clearBus()">Remove</button>
                                }
                                else
                                {
                                    <span class="text-muted small" id="busLabel">No bus assigned.</span>
                                }
                            </div>
                        </div>

                        <!-- Stop dropdown -->
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label fw-semibold">New Password <span class="text-muted fw-normal">(leave blank to keep current)</span></label>
                            <div class="input-group">
                                <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" id="pwdInputNew" autocomplete="new-password" />
                                <button type="button" class="btn btn-outline-secondary" onclick="toggleNewPwd()"><i class="bi bi-eye" id="eyeIconNew"></i></button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StopId" class="form-label fw-semibold">
                                Assign Stop
                                <small class="text-muted fw-normal ms-1">(auto-loads from bus route)</small>
                            </label>
                            <select asp-for="StopId" id="stopSelect" class="form-select" disabled>
                                <option value="">-- Select a bus first --</option>
                            </select>
                            <div id="stopHint" class="mt-1 small">
                                @if (Model?.BusId.HasValue == true)
                                {
                                    <span class="text-muted"><i class="bi bi-arrow-clockwise me-1"></i>Loading stops…</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-info-circle me-1"></i>Select a bus to see available stops.</span>
                                }
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">Status</label>
                            <div class="d-flex gap-3 mt-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="IsActive" value="true"
                                           id="isActiveTrue" @(Model?.IsActive == true ? "checked" : "") />
                                    <label class="form-check-label text-success fw-semibold" for="isActiveTrue">
                                        <i class="bi bi-check-circle me-1"></i>Active
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="IsActive" value="false"
                                           id="isActiveFalse" @(Model?.IsActive == false ? "checked" : "") />
                                    <label class="form-check-label text-danger fw-semibold" for="isActiveFalse">
                                        <i class="bi bi-x-circle me-1"></i>Inactive
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning px-4"><i class="bi bi-check2 me-1"></i>Update Student</button>
                        <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                        <button type="button" class="btn btn-outline-danger px-4 ms-auto" onclick="confirmResetPassword()">
                            <i class="bi bi-key me-1"></i>Reset Password
                        </button>
                    </div>
                </form>

                <div id="pwdResult" class="mt-3" style="display:none;">
                    <div class="alert alert-success border-0 d-flex align-items-start gap-3">
                        <i class="bi bi-shield-check fs-4 text-success mt-1"></i>
                        <div>
                            <div class="fw-semibold mb-1">Password Reset Successfully</div>
                            <div class="mb-1 small text-muted">New password for <span id="pwdName" class="fw-semibold text-dark"></span></div>
                            <div class="d-flex align-items-center gap-2 mt-2">
                                <code id="pwdValue" class="fs-5 px-3 py-1 bg-white border rounded text-danger fw-bold"></code>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyPwd()" title="Copy">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                            <div class="text-muted small mt-2"><i class="bi bi-exclamation-triangle me-1 text-warning"></i>Copy this password now — it will not be shown again.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const AREA         = 'SuperAdmin';
        const currentBusId  = @Html.Raw(Model?.BusId?.ToString() ?? "null");
        const currentStopId = @Html.Raw(Model?.StopId?.ToString() ?? "null");

        // ── On page load: if bus already assigned, load stops ───────────────
        window.addEventListener('DOMContentLoaded', async () => {
            if (!currentBusId) return;
            await loadStops(currentBusId, currentStopId);
        });

        // ── Bus autocomplete ──────────────────────────────────────────────────
        let busTimer;
        document.getElementById('busSearch').addEventListener('input', function () {
            clearTimeout(busTimer);
            const q = this.value.trim();
            if (q.length < 1) { hideBusSug(); return; }
            busTimer = setTimeout(() => fetchBuses(q), 250);
        });
        document.addEventListener('click', e => {
            if (!e.target.closest('#busSearch,#busSuggestions')) hideBusSug();
        });

        async function fetchBuses(q) {
            const data = await (await fetch(`/SuperAdmin/Student/SearchBuses?q=${encodeURIComponent(q)}`)).json();
            const box  = document.getElementById('busSuggestions');
            box.innerHTML = '';
            if (!data.length) { hideBusSug(); return; }
            data.forEach(b => {
                const a = document.createElement('a');
                a.className = 'dropdown-item'; a.href = '#';
                a.textContent = b.display;
                a.addEventListener('click', e => { e.preventDefault(); selectBus(b); });
                box.appendChild(a);
            });
            box.classList.add('show');
        }

        function selectBus(b) {
            document.getElementById('busIdInput').value = b.busId;
            document.getElementById('busSearch').value  = b.display;
            document.getElementById('busSelected').innerHTML =
                `<span class="badge bg-primary-subtle text-primary">
                     <i class="bi bi-bus-front me-1"></i>${b.display}
                 </span>
                 <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-1"
                         onclick="clearBus()">Remove</button>`;
            hideBusSug();
            // Reset stop then reload
            document.getElementById('stopSelect').innerHTML = '<option value="">Loading stops…</option>';
            loadStops(b.busId, null);
        }

        function hideBusSug() { document.getElementById('busSuggestions').classList.remove('show'); }

        function clearBus() {
            document.getElementById('busIdInput').value = '';
            document.getElementById('busSearch').value  = '';
            document.getElementById('busSelected').innerHTML = '<span class="text-muted small">No bus assigned.</span>';
            const sel = document.getElementById('stopSelect');
            sel.innerHTML = '<option value="">-- Select a bus first --</option>';
            sel.disabled  = true;
            document.getElementById('stopHint').innerHTML =
                '<span class="text-muted"><i class="bi bi-info-circle me-1"></i>Select a bus to see available stops.</span>';
        }

        // ── Stop loader ───────────────────────────────────────────────────────
        async function loadStops(busId, preSelectId) {
            const sel  = document.getElementById('stopSelect');
            const hint = document.getElementById('stopHint');
            sel.innerHTML = '<option value="">Loading stops…</option>';
            sel.disabled  = false;

            try {
                const data = await (await fetch(`/SuperAdmin/Student/SearchStops?busId=${busId}`)).json();

                if (!data || data.length === 0) {
                    sel.innerHTML = '<option value="">No stops — this bus has no route assigned</option>';
                    sel.disabled  = true;
                    hint.innerHTML =
                        `<span class="text-warning">
                             <i class="bi bi-exclamation-triangle me-1"></i>
                             No stops found. <a href="/SuperAdmin/Bus/Edit/${busId}" target="_blank">Edit this bus</a>
                             to assign a route first.
                         </span>`;
                    return;
                }

                sel.innerHTML = '<option value="">-- No stop (optional) --</option>';
                data.forEach(s => {
                    const opt        = document.createElement('option');
                    opt.value        = s.stopId;
                    opt.textContent  = `Stop #${s.stopOrder} — ${s.stopName}`;
                    if (s.morningTime) opt.textContent += `  🌅 ${s.morningTime}`;
                    sel.appendChild(opt);
                });

                // Pre-select current stop
                if (preSelectId) {
                    sel.value = preSelectId;
                    if (!sel.value) {
                        // stopId not in list — add it as fallback
                        const opt = document.createElement('option');
                        opt.value = preSelectId; opt.textContent = `Stop ID: ${preSelectId}`;
                        opt.selected = true;
                        sel.appendChild(opt);
                    }
                }

                hint.innerHTML =
                    `<span class="text-success">
                         <i class="bi bi-check-circle me-1"></i>${data.length} stop(s) available on this route.
                     </span>`;
            } catch (err) {
                sel.innerHTML = '<option value="">Error loading stops</option>';
                sel.disabled  = true;
                hint.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>Could not load stops.</span>';
            }
        }

        function confirmResetPassword() {
            if (!confirm('Reset password for this student? A new password will be generated and shown once.')) return;
            doResetPassword();
        }
        async function doResetPassword() {
            const id = @ViewBag.StudentId;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const res = await fetch(`/SuperAdmin/Student/ResetPassword?id=${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('pwdName').textContent = data.fullName + ' (' + data.email + ')';
                document.getElementById('pwdValue').textContent = data.password;
                document.getElementById('pwdResult').style.display = '';
                document.getElementById('pwdResult').scrollIntoView({ behavior: 'smooth' });
            } else {
                alert('Error: ' + data.message);
            }
        }
        function copyPwd() {
            navigator.clipboard.writeText(document.getElementById('pwdValue').textContent);
        }
        // Username check
        const currentUserId = @ViewBag.StudentId;
        document.getElementById('btnCheckUsername').addEventListener('click', checkUsername);
        document.getElementById('usernameInput').addEventListener('input', () => document.getElementById('usernameMsg').innerHTML = '');
        async function checkUsername() {
            const val = document.getElementById('usernameInput').value.trim();
            if (!val) { showUsernameMsg('Enter a username first.', 'text-muted'); return; }
            const res = await fetch(`/api/auth/check-username?userName=${encodeURIComponent(val)}&excludeUserId=${currentUserId}`);
            const data = await res.json();
            if (!data.success) {
                showUsernameMsg('<i class="bi bi-x-circle me-1"></i>Username already exists', 'text-danger fw-semibold');
            } else {
                showUsernameMsg('<i class="bi bi-check-circle me-1"></i>Username is available', 'text-success fw-semibold');
            }
        }
        function showUsernameMsg(html, cls) { const el = document.getElementById('usernameMsg'); el.innerHTML = html; el.className = 'small mt-1 ' + cls; }
        function toggleNewPwd() { const inp = document.getElementById('pwdInputNew'); const icon = document.getElementById('eyeIconNew'); inp.type = inp.type === 'password' ? 'text' : 'password'; icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash'; }
    </script>
}
