@model BusTracking.Common.DTOs.Student.CreateStudentDto
@{
    ViewData["Title"] = "Add Student";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">
                <i class="bi bi-mortarboard me-2 text-info"></i>Add New Student
            </div>
            <div class="card-body p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 border-0"></div>
                }
                <form asp-area="SuperAdmin" asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Student full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Username <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="UserName" class="form-control" placeholder="unique_username" id="usernameInput" autocomplete="off" />
                            </div>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                            <div id="usernameMsg" class="small mt-1"></div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-muted fw-normal">(Optional)</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="student@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StudentCode" class="form-label fw-semibold">Student Code <span class="text-danger">*</span></label>
                            <input asp-for="StudentCode" class="form-control" placeholder="e.g. STD-001" />
                            <span asp-validation-for="StudentCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StandardId" class="form-label fw-semibold">Class / Standard</label>
                            <select asp-for="StandardId" class="form-select" asp-items="ViewBag.Standards">
                                <option value="">-- Select Class --</option>
                            </select>
                        </div>

                        <!-- ── Bus autocomplete ── -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Assign Bus (optional)</label>
                            <div class="position-relative">
                                <input type="text" id="busSearch" class="form-control"
                                       placeholder="Type bus name or number…" autocomplete="off" />
                                <input type="hidden" asp-for="BusId" id="busIdInput" />
                                <div id="busSuggestions" class="dropdown-menu w-100 shadow-sm"></div>
                            </div>
                            <div id="busSelected" class="mt-1 small text-muted">
                                No bus selected.
                            </div>
                        </div>

                        <!-- ── Stop dropdown — enabled after bus selected ── -->
                        <div class="col-md-6">
                            <label asp-for="StopId" class="form-label fw-semibold">
                                Assign Stop
                                <small class="text-muted fw-normal ms-1">(select bus first)</small>
                            </label>
                            <select asp-for="StopId" id="stopSelect" class="form-select" disabled>
                                <option value="">-- Select a bus first --</option>
                            </select>
                            <div id="stopHint" class="mt-1 small text-muted">
                                <i class="bi bi-info-circle me-1"></i>Select a bus to load available stops.
                            </div>
                        </div>

                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password <span class="text-muted fw-normal">(leave blank to auto-generate)</span></label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Set password or leave blank" id="pwdInput" autocomplete="new-password" />
                            <button type="button" class="btn btn-outline-secondary" onclick="togglePwd()"><i class="bi bi-eye" id="eyeIcon"></i></button>
                        </div>
                    </div>
                    <div class="form-check form-switch mt-3">
                        <input asp-for="SendEmail" class="form-check-input" type="checkbox" role="switch" id="sendEmailChk" />
                        <label class="form-check-label" for="sendEmailChk">
                            <i class="bi bi-envelope me-1"></i>Send welcome email with credentials
                            <span class="badge bg-secondary-subtle text-secondary ms-1">Optional</span>
                        </label>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check2 me-1"></i>Create Student
                        </button>
                        <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Bus autocomplete ──────────────────────────────────────────
        let busTimer;
        document.getElementById('busSearch').addEventListener('input', function() {
            clearTimeout(busTimer);
            const q = this.value.trim();
            if (q.length < 1) { hideBusSug(); return; }
            busTimer = setTimeout(() => fetchBuses(q), 250);
        });
        document.addEventListener('click', e => {
            if (!e.target.closest('#busSearch,#busSuggestions')) hideBusSug();
        });
        async function fetchBuses(q) {
            const data = await (await fetch(`/SuperAdmin/Student/SearchBuses?q=${encodeURIComponent(q)}`)).json();
            const box = document.getElementById('busSuggestions');
            box.innerHTML = '';
            if (!data.length) { hideBusSug(); return; }
            data.forEach(b => {
                const a = document.createElement('a');
                a.className = 'dropdown-item'; a.href = '#'; a.textContent = b.display;
                a.addEventListener('click', e => { e.preventDefault(); selectBus(b); });
                box.appendChild(a);
            });
            box.classList.add('show');
        }
        function selectBus(b) {
            document.getElementById('busIdInput').value = b.busId;
            document.getElementById('busSearch').value = b.display;
            document.getElementById('busSelected').innerHTML =
                `<span class="badge bg-primary-subtle text-primary">
                             <i class="bi bi-bus-front me-1"></i>${b.display}
                         </span>
                         <button type="button" class="btn btn-sm btn-link text-danger p-0 ms-1"
                                 onclick="clearBus()">Remove</button>`;
            hideBusSug();
            loadStops(b.busId, null);
        }
        function hideBusSug() { document.getElementById('busSuggestions').classList.remove('show'); }
        function clearBus() {
            document.getElementById('busIdInput').value = '';
            document.getElementById('busSearch').value = '';
            document.getElementById('busSelected').innerHTML = '<span class="text-muted">No bus selected.</span>';
            const sel = document.getElementById('stopSelect');
            sel.innerHTML = '<option value="">-- Select a bus first --</option>';
            sel.disabled = true;
            document.getElementById('stopHint').innerHTML =
                '<i class="bi bi-info-circle me-1"></i>Select a bus to load available stops.';
        }

        // ── Stop dropdown loader ──────────────────────────────────────
        async function loadStops(busId, preSelectId) {
            const sel = document.getElementById('stopSelect');
            const hint = document.getElementById('stopHint');
            sel.innerHTML = '<option value="">Loading stops…</option>';
            sel.disabled = false;
            try {
                const data = await (await fetch(`/SuperAdmin/Student/SearchStops?busId=${busId}`)).json();
                if (!data.length) {
                    sel.innerHTML = '<option value="">No stops — assign a route to this bus first</option>';
                    sel.disabled = true;
                    hint.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>This bus has no route assigned. Edit the bus to add a route.</span>';
                    return;
                }
                sel.innerHTML = '<option value="">-- Select stop (optional) --</option>';
                data.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.stopId;
                    opt.textContent = `Stop #${s.stopOrder} — ${s.stopName}${s.morningTime ? '  🌅 ' + s.morningTime : ''}`;
                    sel.appendChild(opt);
                });
                if (preSelectId) sel.value = preSelectId;
                hint.innerHTML = `<span class="text-success"><i class="bi bi-check-circle me-1"></i>${data.length} stops available.</span>`;
            } catch {
                sel.innerHTML = '<option value="">Error loading stops</option>';
                sel.disabled = true;
                hint.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>Could not load stops.</span>';
            }
        }
        function togglePwd() { const inp = document.getElementById('pwdInput'); const icon = document.getElementById('eyeIcon'); inp.type = inp.type === 'password' ? 'text' : 'password'; icon.className = inp.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash'; }
        // ── Username live-check (keyup, min 5 chars, no excludeUserId on create) ──
        const _unInput = document.getElementById('usernameInput');
        const _unMsg = document.getElementById('usernameMsg');
        let _unTimer = null;

        _unInput.addEventListener('keyup', () => {
            clearTimeout(_unTimer);
            _unTimer = setTimeout(liveCheckUsername, 350);
        });

        async function liveCheckUsername() {
            const val = _unInput.value.trim();
            _unMsg.innerHTML = '';
            _unMsg.className = 'small mt-1';
            if (val.length === 0) return;
            if (val.length < 5) {
                _unMsg.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>Username must have at least 5 characters';
                _unMsg.className = 'small mt-1 text-danger';
                return;
            }
            try {
                const res = await fetch(`/Auth/CheckUsername?userName=${encodeURIComponent(val)}`);
                if (!res.ok) return;
                const data = await res.json();
                if (!data.success) {
                    _unMsg.innerHTML = `<i class="bi bi-x-circle me-1"></i>The username <strong>${escHtml(val)}</strong> is already taken`;
                    _unMsg.className = 'small mt-1 text-danger';
                } else {
                    _unMsg.innerHTML = `<i class="bi bi-check-circle me-1"></i><strong>${escHtml(val)}</strong> is available`;
                    _unMsg.className = 'small mt-1 text-success fw-semibold';
                }
            } catch (_) { /* silent */ }
        }
        function escHtml(s) {
            return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
    </script>
}
