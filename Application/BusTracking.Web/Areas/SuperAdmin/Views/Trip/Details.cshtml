@model BusTracking.Common.DTOs.Trip.TripListDto
@using BusTracking.Common.DTOs.Trip
@using System.Text.Encodings.Web
@{
    ViewData["Title"] = $"Trip #{Model?.TripId}";
    var students = ViewBag.Students as List<StudentTripStatusDto> ?? [];
    var stops = ViewBag.Stops as List<TripStopEventDto> ?? [];
    var isLive = Model?.Status == "InProgress";
    var googleApiKey = ViewBag.GoogleMapApiKey as string ?? "";
    var statusStyle = Model?.Status switch
    {
        "Scheduled" => "background:#e8f0fe;color:#1a73e8",
        "InProgress" => "background:#e6f4ea;color:#1e8e3e",
        "Completed" => "background:#f1f3f4;color:#5f6368",
        "Cancelled" => "background:#fce8e6;color:#c5221f",
        _ => "background:#f1f3f4;color:#5f6368"
    };
}

<!-- ── Header ─────────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-bus-front me-2 text-primary"></i>
            Trip #@Model?.TripId — @Model?.BusNumber
        </h4>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge rounded-pill px-3 py-2" style="@statusStyle;font-size:.8rem">
                @Model?.Status
            </span>
            <span class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@Model?.TripDate</span>
            <span class="badge rounded-pill px-2"
                  style="@(Model?.TripType == "Morning" ? "background:#fff3e0;color:#e65100" : "background:#e8eaf6;color:#3949ab");font-size:.75rem">
                <i class="bi @(Model?.TripType == "Morning" ? "bi-sunrise" : "bi-sunset") me-1"></i>@Model?.TripType
            </span>
            <span class="text-muted small"><i class="bi bi-person-video2 me-1"></i>@Model?.DriverName</span>
            <span class="text-muted small"><i class="bi bi-map me-1"></i>@Model?.RouteName</span>
        </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @if (Model?.Status == "Scheduled")
        {
            <form asp-area="SuperAdmin" asp-controller="Trip" asp-action="Start" asp-route-id="@Model.TripId" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-success px-4"><i class="bi bi-play-fill me-1"></i>Start Trip</button>
            </form>
        }
        @if (Model?.Status == "InProgress")
        {
            <form asp-area="SuperAdmin" asp-controller="Trip" asp-action="End" asp-route-id="@Model.TripId" method="post"
                  onsubmit="return confirm('End this trip?')">
                @Html.AntiForgeryToken()
                <button class="btn btn-danger px-4"><i class="bi bi-stop-fill me-1"></i>End Trip</button>
            </form>
        }
        @if (Model?.Status is "Scheduled" or "InProgress")
        {
            <form asp-area="SuperAdmin" asp-controller="Trip" asp-action="Cancel" asp-route-id="@Model!.TripId" method="post"
                  onsubmit="return confirm('Cancel this trip?')">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-warning px-3"><i class="bi bi-x-lg me-1"></i>Cancel</button>
            </form>
        }
        <a asp-area="SuperAdmin" asp-controller="Trip" asp-action="Index" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- ══ LEFT COLUMN ════════════════════════════════════════════════ -->
    <div class="col-lg-5">

        <!-- ── Stop Timeline ──────────────────────────────────────── -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span class="fw-semibold">
                    <i class="bi bi-signpost-split me-2 text-primary"></i>Route Stops Timeline
                    <span class="badge bg-secondary-subtle text-secondary ms-2">@stops.Count stops</span>
                </span>
                @if (stops.Any())
                {
                    var originStop = stops.OrderBy(s => s.StopOrder).FirstOrDefault();
                    var destStop = stops.OrderBy(s => s.StopOrder).LastOrDefault();
                    <span class="small text-muted">
                        <span class="badge bg-danger-subtle text-danger"><i class="bi bi-geo-alt-fill me-1"></i>From: @originStop?.StopName</span>
                        <i class="bi bi-arrow-right mx-1"></i>
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-flag-fill me-1"></i>To: @destStop?.StopName</span>
                    </span>
                }
            </div>
            <div class="card-body p-4">
                @if (!stops.Any())
                {
                    <p class="text-muted small text-center py-2">No stops added to this trip.</p>
                }
                else
                {
                    var orderedStops = stops.OrderBy(s => s.StopOrder).ToList();
                    var firstStop = orderedStops.FirstOrDefault();
                    var lastStop = orderedStops.LastOrDefault();

                    <div class="stop-timeline">
                        @foreach (var stop in orderedStops)
                        {
                            var isFirst = stop.StopId == firstStop?.StopId;
                            var isLast = stop.StopId == lastStop?.StopId;
                            var dotColor = stop.Status switch { "Departed" => "#1e8e3e", "Reached" => "#1a73e8", _ => "#dadce0" };
                            var dotIcon = isFirst ? "bi-geo-alt-fill" : isLast ? "bi-flag-fill" : (stop.Status switch { "Departed" => "bi-check-circle-fill", "Reached" => "bi-geo-alt-fill", _ => "bi-circle" });
                            var iconColor = isFirst ? "#c5221f" : isLast ? "#1e8e3e" : dotColor;

                            <div class="d-flex gap-3 mb-3 align-items-start stop-row" data-stop-id="@stop.StopId">
                                <div class="flex-shrink-0 mt-1">
                                    <i class="bi @dotIcon" style="color:@iconColor;font-size:1.15rem"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <span class="fw-semibold small">@stop.StopName</span>
                                            @if (isFirst)
                                            {
                                                <span class="badge bg-danger-subtle text-danger ms-1" style="font-size:.65rem">FROM (START)</span>
                                            }
                                            @if (isLast)
                                            {
                                                <span class="badge bg-success-subtle text-success ms-1" style="font-size:.65rem">TO (DESTINATION)</span>
                                            }
                                            <span class="text-muted ms-2" style="font-size:.72rem">Stop #@stop.StopOrder</span>
                                        </div>
                                        <span class="badge rounded-pill px-2"
                                              style="font-size:.7rem;@(stop.Status == "Departed" ? "background:#e6f4ea;color:#1e8e3e" : stop.Status == "Reached" ? "background:#e8f0fe;color:#1a73e8" : "background:#f1f3f4;color:#5f6368")">
                                            @stop.Status
                                        </span>
                                    </div>
                                    <div class="d-flex gap-3 mt-1" style="font-size:.72rem;color:#5f6368">
                                        @if (stop.ReachedAt.HasValue)
                                        {
                                            <span><i class="bi bi-clock me-1"></i>Reached @stop.ReachedAt.Value.ToString("HH:mm")</span>
                                        }
                                        @if (stop.DepartedAt.HasValue)
                                        {
                                            <span><i class="bi bi-arrow-right me-1"></i>Departed @stop.DepartedAt.Value.ToString("HH:mm")</span>
                                        }
                                    </div>
                                    @if (isLive && stop.Status == "Pending")
                                    {
                                        <button class="btn btn-sm mt-2 btn-reach-stop"
                                                style="font-size:.75rem;background:#e8f0fe;color:#1a73e8;border:none;padding:3px 10px;border-radius:20px"
                                                data-trip-id="@Model!.TripId" data-stop-id="@stop.StopId">
                                            <i class="bi bi-geo-alt me-1"></i>Mark Reached
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ── Student List ───────────────────────────────────────── -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between">
                <span class="fw-semibold">
                    <i class="bi bi-mortarboard me-2 text-info"></i>Students
                    <span class="badge bg-info-subtle text-info ms-1">@students.Count</span>
                </span>
                @if (isLive)
                {
                    <small class="text-muted align-self-center">Select status to update</small>
                }
            </div>
            <div class="card-body p-0" style="max-height:380px;overflow-y:auto">
                @if (!students.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-mortarboard fs-2 d-block mb-1"></i>No students on this trip.
                    </div>
                }
                else
                {
                    @foreach (var s in students.OrderBy(x => x.StopOrder).ThenBy(x => x.StudentName))
                    {
                        var bsCss = s.BoardingStatus switch
                        {
                            "PickedUp" => "background:#e6f4ea;color:#1e8e3e",
                            "NoShow" => "background:#fce8e6;color:#c5221f",
                            "OnLeave" => "background:#fff3e0;color:#e65100",
                            _ => "background:#f1f3f4;color:#5f6368"
                        };
                        <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom student-row" id="srow-@s.StudentId">
                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-info-subtle text-info fw-bold flex-shrink-0"
                                 style="width:36px;height:36px;font-size:.8rem">
                                @s.StudentName.ToInitials()
                            </div>
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-semibold small text-truncate">@s.StudentName</div>
                                <div class="text-muted" style="font-size:.72rem">
                                    <i class="bi bi-geo-alt me-1"></i>@s.StopName
                                    <span class="ms-2"><i class="bi bi-hash me-1"></i>Stop @s.StopOrder</span>
                                </div>
                            </div>
                            @if (isLive)
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm dropdown-toggle sboarding-badge"
                                            style="@bsCss;border:none;font-size:.75rem;border-radius:20px;padding:4px 12px"
                                            data-bs-toggle="dropdown" id="sbtn-@s.StudentId">
                                        @s.BoardingStatus
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                        @foreach (var st in new[] { ("Pending", "bi-circle", "#5f6368"), ("PickedUp", "bi-check-circle-fill", "#1e8e3e"), ("NoShow", "bi-x-circle-fill", "#c5221f"), ("OnLeave", "bi-calendar-x", "#e65100") })
                                        {
                                            <li>
                                                <a class="dropdown-item small boarding-option" href="#"
                                                   data-trip-id="@Model!.TripId" data-student-id="@s.StudentId"
                                                   data-stop-id="@s.StopOrder" data-status="@st.Item1" data-btn-id="sbtn-@s.StudentId">
                                                    <i class="bi @st.Item2 me-2" style="color:@st.Item3"></i>@st.Item1
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <span class="badge rounded-pill px-3 py-2" style="@bsCss;font-size:.73rem">@s.BoardingStatus</span>
                            }
                        </div>
                    }
                }
            </div>
        </div>

    </div>

    <!-- ══ RIGHT COLUMN — LIVE GOOGLE MAP ═══════════════════════ -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm" style="overflow:hidden">

            <!-- Map header with live badge -->
            <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">
                    <i class="bi bi-map me-2 text-primary"></i>Live Google Map Tracking
                </span>
                @if (isLive)
                {
                    <span class="badge d-flex align-items-center gap-1" style="background:#e6f4ea;color:#1e8e3e;font-size:.75rem">
                        <span id="liveDot" style="display:inline-block;width:8px;height:8px;background:#1e8e3e;border-radius:50%;animation:livePulse 1.5s infinite"></span>
                        LIVE GPS
                    </span>
                }
                else
                {
                    <span class="text-muted small">Trip not in progress</span>
                }
            </div>

            <!-- Google Map Canvas -->
            <div class="card-body p-0 position-relative">
                <div id="tripMap" style="height:520px;width:100%"></div>

                <!-- Speed & Status overlay -->
                <div id="liveOverlay" class="position-absolute bottom-0 start-0 end-0 px-3 py-2"
                     style="background:linear-gradient(transparent,rgba(0,0,0,.65));pointer-events:none;z-index:500;display:none">
                    <div class="d-flex justify-content-between align-items-end text-white">
                        <div>
                            <div id="spdBig" style="font-size:2rem;font-weight:700;line-height:1">–</div>
                            <div style="font-size:.7rem;opacity:.8">km/h</div>
                        </div>
                        <div class="text-center">
                            <div id="busStatusLabel" style="font-size:.85rem;font-weight:600">–</div>
                            <div id="lastUpdLabel" style="font-size:.68rem;opacity:.75">–</div>
                        </div>
                        <div class="text-end">
                            <div id="coordLabel" style="font-size:.68rem;opacity:.75">–</div>
                            <div id="headingLabel" style="font-size:.75rem">–</div>
                        </div>
                    </div>
                </div>

                @if (!isLive)
                {
                    <div id="mapPlaceholder" class="position-absolute top-50 start-50 translate-middle text-center"
                         style="pointer-events:none;z-index:999">
                        <div style="background:rgba(255,255,255,.92);border-radius:12px;padding:16px 24px;box-shadow:0 4px 20px rgba(0,0,0,.15)">
                            <i class="bi bi-bus-front text-primary" style="font-size:2.5rem"></i>
                            <div class="fw-semibold mt-1" style="font-size:.9rem">@(Model?.Status == "Completed" ? "Trip completed" : "Trip not started yet")</div>
                            <div class="text-muted" style="font-size:.75rem">@(Model?.Status == "Completed" ? "Route summary shown" : "Start trip to activate live GPS map")</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Bottom info bar -->
            <div class="px-4 py-2 border-top d-flex gap-4 small text-muted flex-wrap" id="gpsInfoBar">
                <span><i class="bi bi-geo-alt me-1 text-danger"></i><span id="latVal">–</span></span>
                <span><i class="bi bi-geo me-1 text-primary"></i><span id="lngVal">–</span></span>
                <span><i class="bi bi-speedometer2 me-1 text-success"></i><span id="spdVal">–</span> km/h</span>
                <span><i class="bi bi-compass me-1 text-warning"></i><span id="hdgVal">–</span>°</span>
                <span><i class="bi bi-clock me-1"></i><span id="updVal">–</span></span>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const TRIP_ID = @Model?.TripId;
        const IS_LIVE = @(isLive ? "true" : "false");
        const TOKEN = () => document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        const STOPS = [
            @foreach (var stop in stops.OrderBy(s => s.StopOrder))
            {
                @:{ id: @stop.StopId, name: "@JavaScriptEncoder.Default.Encode(stop.StopName)", order: @stop.StopOrder, status: "@stop.Status" },
            }
        ];

        let map, busMarker, routePolyline;
        let stopMarkers = [];

        function initGoogleMap() {
            map = new google.maps.Map(document.getElementById('tripMap'), {
                zoom: 14,
                center: { lat: 28.6139, lng: 77.2090 },
                mapTypeId: 'roadmap',
                disableDefaultUI: false,
                zoomControl: true
            });

            busMarker = new google.maps.Marker({
                map: map,
                icon: {
                    path: google.maps.SymbolPath.FORWARD_CLOSED_ARROW,
                    scale: 7,
                    fillColor: '#1a73e8',
                    fillOpacity: 1,
                    strokeColor: '#ffffff',
                    strokeWeight: 2,
                    rotation: 0
                },
                title: 'School Bus',
                zIndex: 100
            });

            const bounds = new google.maps.LatLngBounds();

            STOPS.forEach(s => {
                const color = s.status === 'Departed' ? '#1e8e3e' : s.status === 'Reached' ? '#1a73e8' : '#9aa0a6';

                const marker = new google.maps.Marker({
                    map: map,
                    title: `Stop #${s.order}: ${s.name}`,
                    icon: {
                        path: google.maps.SymbolPath.CIRCLE,
                        scale: 9,
                        fillColor: color,
                        fillOpacity: 1,
                        strokeColor: '#ffffff',
                        strokeWeight: 2
                    },
                    label: { text: String(s.order), color: '#ffffff', fontSize: '10px', fontWeight: 'bold' }
                });

                const infoWin = new google.maps.InfoWindow({
                    content: `<div><b>Stop #${s.order}</b><br>${s.name}<br><span style="color:${color}">${s.status}</span></div>`
                });
                marker.addListener('click', () => infoWin.open(map, marker));
                stopMarkers.push(marker);
            });

            if (IS_LIVE) {
                fetchLocation();
                setInterval(fetchLocation, 5000);
            } else {
                loadHistory();
            }
        }

        async function fetchLocation() {
            try {
                const area = window.location.pathname.startsWith('/BusCoordinator') ? 'BusCoordinator' : 'SuperAdmin';
                const res = await fetch(`/${area}/Trip/LatestLocation?tripId=${TRIP_ID}`);
                const data = await res.json();
                if (!data.success || !data.data) return;

                const { latitude: lat, longitude: lng, speed, heading, recordedAt } = data.data;
                const pos = new google.maps.LatLng(Number(lat), Number(lng));

                busMarker.setPosition(pos);
                if (heading || heading === 0) {
                    const icon = busMarker.getIcon();
                    icon.rotation = Number(heading);
                    busMarker.setIcon(icon);
                }

                updateInfoBar(lat, lng, speed, heading, recordedAt);
                document.getElementById('mapPlaceholder')?.remove();
            } catch (e) { console.warn('Location fetch failed', e); }
        }

        async function loadHistory() {
            try {
                const area = window.location.pathname.startsWith('/BusCoordinator') ? 'BusCoordinator' : 'SuperAdmin';
                const res = await fetch(`/${area}/Trip/LocationHistory?tripId=${TRIP_ID}`);
                const data = await res.json();
                if (!data.success || !data.data?.length) return;

                const coords = data.data.map(d => ({ lat: Number(d.latitude), lng: Number(d.longitude) }));
                if (coords.length > 0) {
                    routePolyline = new google.maps.Polyline({
                        path: coords,
                        geodesic: true,
                        strokeColor: '#1a73e8',
                        strokeOpacity: 0.8,
                        strokeWeight: 5,
                        map: map
                    });

                    const bounds = new google.maps.LatLngBounds();
                    coords.forEach(c => bounds.extend(c));
                    map.fitBounds(bounds);

                    const last = coords[coords.length - 1];
                    const lastData = data.data[data.data.length - 1];
                    busMarker.setPosition(new google.maps.LatLng(last.lat, last.lng));
                    updateInfoBar(lastData.latitude, lastData.longitude, lastData.speed, lastData.heading, lastData.recordedAt);
                    document.getElementById('mapPlaceholder')?.remove();
                }
            } catch (e) { console.warn('History load failed', e); }
        }

        function updateInfoBar(lat, lng, speed, heading, recordedAt) {
            const spd = speed ? parseFloat(speed).toFixed(1) : '0';
            const hdg = heading ? Math.round(heading) : 0;

            document.getElementById('latVal').textContent = parseFloat(lat).toFixed(5);
            document.getElementById('lngVal').textContent = parseFloat(lng).toFixed(5);
            document.getElementById('spdVal').textContent = spd;
            document.getElementById('hdgVal').textContent = hdg;
            document.getElementById('updVal').textContent = new Date(recordedAt).toLocaleTimeString();

            document.getElementById('spdBig').textContent = spd;
            document.getElementById('coordLabel').textContent = `${parseFloat(lat).toFixed(4)}, ${parseFloat(lng).toFixed(4)}`;
            document.getElementById('headingLabel').textContent = headingToCompass(hdg);
            document.getElementById('lastUpdLabel').textContent = 'Updated ' + new Date(recordedAt).toLocaleTimeString();

            const moving = parseFloat(spd) > 2;
            document.getElementById('busStatusLabel').textContent = moving ? '🚌 Moving' : '🅿️ Stopped';
            document.getElementById('liveOverlay').style.display = '';
        }

        function headingToCompass(h) {
            const dirs = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW', 'N'];
            return dirs[Math.round(h / 45)] + ` ${h}°`;
        }

        // ── Mark stop reached ────────────────────────────────────────────────
        document.querySelectorAll('.btn-reach-stop').forEach(btn => {
            btn.addEventListener('click', async function() {
                const area = window.location.pathname.startsWith('/BusCoordinator') ? 'BusCoordinator' : 'SuperAdmin';
                const res = await fetch(`/${area}/Trip/ReachStop?tripId=${this.dataset.tripId}&stopId=${this.dataset.stopId}`, {
                    method: 'POST', headers: { 'RequestVerificationToken': TOKEN() }
                });
                const data = await res.json();
                busTrack.showToast(data.message, data.success ? 'success' : 'danger');
                if (data.success) setTimeout(() => location.reload(), 700);
            });
        });

        // ── Boarding status update ────────────────────────────────────────────
        document.querySelectorAll('.boarding-option').forEach(opt => {
            opt.addEventListener('click', async function(e) {
                e.preventDefault();
                const area = window.location.pathname.startsWith('/BusCoordinator') ? 'BusCoordinator' : 'SuperAdmin';
                const body = {
                    tripId: parseInt(this.dataset.tripId),
                    studentId: parseInt(this.dataset.studentId),
                    stopId: parseInt(this.dataset.stopId),
                    status: this.dataset.status
                };
                const res = await fetch(`/${area}/Trip/UpdateBoarding`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN() },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                busTrack.showToast(data.message, data.success ? 'success' : 'danger');
                if (data.success) {
                    setTimeout(() => location.reload(), 700);
                }
            });
        });
    </script>

    @if (!string.IsNullOrEmpty(googleApiKey))
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@googleApiKey&callback=initGoogleMap&libraries=geometry" async defer></script>
    }
}

<style>
    @@keyframes livePulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .2;
        }
    }

    .stop-timeline .stop-row:not(:last-child) {
        padding-bottom: 8px;
        border-left: 2px dashed #e8eaed;
        margin-left: 9px;
        padding-left: 16px;
    }

        .stop-timeline .stop-row:not(:last-child) .flex-shrink-0 {
            margin-left: -25px;
        }
</style>
