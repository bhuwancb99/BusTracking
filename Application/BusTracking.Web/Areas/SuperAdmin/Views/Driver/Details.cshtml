@model BusTracking.Common.DTOs.Driver.DriverListDto
@{
    ViewData["Title"] = "Driver Details"; ViewData["Breadcrumb"] = "Drivers / Details";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-person-video2 me-2 text-success"></i>Driver Profile</span>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model?.UserId" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
            <div class="card-body p-4">
                @if (Model is null)
                {
                    <p class="text-muted">Driver not found.</p>
                }
                else
                {
                    <div class="text-center mb-4">
                        <div class="avatar-lg bg-success-subtle text-success mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                             style="width:72px;height:72px;font-size:1.8rem;font-weight:700">
                            @Model.FullName.ToInitials()
                        </div>
                        <h5 class="fw-bold mb-0">@Model.FullName</h5>
                        <p class="text-muted small mb-1">@Model.Email</p>
                        <span class="badge @(Model.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>

                    <table class="table table-borderless">
                        <tbody>
                            <tr><th class="text-muted small w-40">Phone</th><td>@(Model.PhoneNumber ?? "–")</td></tr>
                            <tr>
                                <th class="text-muted small">Assigned Bus</th>
                                <td>
                                    @if (Model.BusName is not null)
                                    {
                                        <span><span class="badge bg-primary-subtle text-primary me-1">@Model.BusNumber</span>@Model.BusName</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                            </tr>
                            <tr><th class="text-muted small">License No.</th><td>@(Model.LicenseNumber ?? "–")</td></tr>
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
