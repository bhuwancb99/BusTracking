@model BusTracking.Common.DTOs.AppConfig.AppConfigDto
@{
    ViewData["Title"] = "Config Details";
    ViewData["Breadcrumb"] = "Config Details";
    var platformStyle = Model.Platform switch
    {
        "Mobile" => "background:#e8f0fe;color:#1a73e8",
        "Web" => "background:#e6f4ea;color:#1e8e3e",
        _ => "background:#f1f3f4;color:#5f6368"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-info-circle me-2 text-info"></i>Configuration Detail</h4>
    <div class="d-flex gap-2">
        <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@Model.ConfigId" class="btn btn-outline-warning">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 pb-2 px-4 d-flex align-items-center gap-3">
                <div class="rounded-2 d-flex align-items-center justify-content-center"
                     style="width:44px;height:44px;background:#eff6ff">
                    <i class="bi bi-key text-primary fs-5"></i>
                </div>
                <div>
                    <div class="fw-bold font-monospace" style="font-size:1rem;color:#1a73e8">@Model.ConfigKey</div>
                    <span class="badge rounded-pill" style="@platformStyle;font-size:.72rem">@Model.Platform</span>
                    <span class="badge rounded-pill ms-1" style="@(Model.IsActive ? "background:#e6f4ea;color:#1e8e3e" : "background:#fce8e6;color:#c5221f");font-size:.72rem">
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="mb-4">
                    <div class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing:.05em">Value</div>
                    <div class="p-3 rounded-2 font-monospace" style="background:#f8fafc;border:1px solid #e2e8f0;word-break:break-all;font-size:.9rem">
                        @Model.ConfigValue
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-4">
                        <div class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing:.05em">Description</div>
                        <div class="text-secondary">@Model.Description</div>
                    </div>
                }

                <hr class="my-3" />

                <div class="row g-3" style="font-size:.82rem">
                    <div class="col-6">
                        <div class="text-muted fw-semibold text-uppercase" style="letter-spacing:.04em;font-size:.72rem">Created By</div>
                        <div class="fw-semibold mt-1">@Model.CreatedByName</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted fw-semibold text-uppercase" style="letter-spacing:.04em;font-size:.72rem">Created At</div>
                        <div class="fw-semibold mt-1">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted fw-semibold text-uppercase" style="letter-spacing:.04em;font-size:.72rem">Last Updated</div>
                        <div class="fw-semibold mt-1">@Model.UpdatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted fw-semibold text-uppercase" style="letter-spacing:.04em;font-size:.72rem">Config ID</div>
                        <div class="fw-semibold mt-1">#@Model.ConfigId</div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <form asp-area="SuperAdmin" asp-action="Delete" asp-route-id="@Model.ConfigId" method="post"
                          onsubmit="return confirm('Delete \'@Model.ConfigKey\'? This cannot be undone.')">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-danger btn-sm px-3">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
