@model List<BusTracking.Common.DTOs.AppConfig.AppConfigDto>
@{
    ViewData["Title"] = "App Configuration";
    ViewData["Breadcrumb"] = "App Configuration";
    var platformFilter = ViewBag.Platform as string;
    var searchFilter = ViewBag.Search as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-sliders me-2 text-primary"></i>App Configuration</h4>
        <small class="text-muted">Manage system-wide settings for Web and Mobile platforms</small>
    </div>
    <a asp-area="SuperAdmin" asp-controller="AppConfig" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Config
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-3 px-4">
        <form asp-area="SuperAdmin" asp-action="Index" method="get" class="d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label class="form-label fw-semibold small mb-1">Platform</label>
                <select name="platform" class="form-select form-select-sm" style="width:160px">
                    <option value="">All Platforms</option>
                    <option value="Web" selected="@(platformFilter == "Web")">Web</option>
                    <option value="Mobile" selected="@(platformFilter == "Mobile")">Mobile</option>
                    <option value="Both" selected="@(platformFilter == "Both")">Both</option>
                </select>
            </div>
            <div>
                <label class="form-label fw-semibold small mb-1">Search</label>
                <input type="text" name="search" value="@searchFilter" class="form-control form-control-sm"
                       style="width:240px" placeholder="Key or value…" />
            </div>
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-search me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(platformFilter) || !string.IsNullOrEmpty(searchFilter))
            {
                <a asp-area="SuperAdmin" asp-action="Index" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-x me-1"></i>Clear
                </a>
            }
        </form>
    </div>
</div>

@{
    var grouped = Model.GroupBy(c => c.Platform).OrderBy(g => g.Key);
}

@foreach (var group in grouped)
{
    var badgeStyle = group.Key switch
    {
        "Mobile" => "background:#e8f0fe;color:#1a73e8",
        "Web" => "background:#e6f4ea;color:#1e8e3e",
        _ => "background:#f1f3f4;color:#5f6368"
    };
    var icon = group.Key switch
    {
        "Mobile" => "bi-phone",
        "Web" => "bi-globe",
        _ => "bi-layers"
    };

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-0 pt-3 pb-2 px-4 d-flex align-items-center gap-2">
            <i class="bi @icon" style="color:@(group.Key == "Mobile" ? "#1a73e8" : group.Key == "Web" ? "#1e8e3e" : "#5f6368")"></i>
            <span class="fw-semibold">@group.Key</span>
            <span class="badge ms-1" style="@badgeStyle;font-size:.72rem">@group.Count() keys</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4">Key</th>
                            <th>Value</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th class="text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in group.OrderBy(x => x.ConfigKey))
                        {
                            <tr id="row-@c.ConfigId">
                                <td class="px-4">
                                    <code class="fw-semibold" style="font-size:.85rem;color:#1a73e8">@c.ConfigKey</code>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border" style="font-size:.8rem;max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block"
                                          title="@c.ConfigValue">
                                        @(c.ConfigValue.Length > 40 ? c.ConfigValue[..40] + "…" : c.ConfigValue)
                                    </span>
                                </td>
                                <td><span class="text-muted small">@(c.Description ?? "–")</span></td>
                                <td>
                                    <span class="badge rounded-pill status-badge-@c.ConfigId"
                                          style="@(c.IsActive ? "background:#e6f4ea;color:#1e8e3e" : "background:#fce8e6;color:#c5221f");font-size:.73rem">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td><span class="text-muted small">@c.UpdatedAt.ToString("dd MMM yyyy")</span></td>
                                <td class="text-end px-4">
                                    <a asp-area="SuperAdmin" asp-action="Details" asp-route-id="@c.ConfigId"
                                       class="btn btn-sm btn-outline-info me-1" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-area="SuperAdmin" asp-action="Edit" asp-route-id="@c.ConfigId"
                                       class="btn btn-sm btn-outline-warning me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-sm btn-outline-secondary me-1 btn-toggle-config"
                                            data-id="@c.ConfigId" title="Toggle Active">
                                        <i class="bi @(c.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off")"></i>
                                    </button>
                                    <form asp-area="SuperAdmin" asp-action="Delete" asp-route-id="@c.ConfigId"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Delete config key \'@c.ConfigKey\'? This cannot be undone.')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <i class="bi bi-sliders fs-1 text-muted d-block mb-2"></i>
        <div class="text-muted">No configurations found. <a asp-area="SuperAdmin" asp-action="Create">Add the first one.</a></div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle-config').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id  = this.dataset.id;
                const res = await fetch(`/SuperAdmin/AppConfig/Toggle/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' }
                });
                const data = await res.json();
                if (data.success) location.reload();
                else alert(data.message);
            });
        });
    </script>
}
