@* Student/Tracking/Track.cshtml *@
@model List<BusTracking.Common.DTOs.Trip.StudentTripStatusDto>
@{
    ViewData["Title"] = "Track My Bus";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-geo-alt me-2 text-danger"></i>Track My Bus</h4>
    <span class="text-muted small" id="lastUpdated">Updates every 10s</span>
</div>
<div class="row g-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 px-4 fw-semibold"><i class="bi bi-map me-2"></i>Live Location</div>
            <div class="card-body p-0">
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                <div id="busMap" data-trip-id="@ViewBag.TripId" style="height:500px;border-radius:0 0 10px 10px"></div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
}
