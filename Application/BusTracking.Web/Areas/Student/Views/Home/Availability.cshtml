@* Student/Home/Availability.cshtml *@
@model List<BusTracking.Common.DTOs.Availability.AvailabilityDto>
@{
    ViewData["Title"] = "My Availability";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2 text-secondary"></i>My Availability</h4>
</div>
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">Mark Unavailability</div>
            <div class="card-body p-4">
                <form asp-area="Student" asp-controller="Home" asp-action="SetAvailability" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="StudentId" value="@ViewBag.StudentId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason</label>
                        <select name="AvailabilityType" class="form-select">
                            <option value="OnLeave">On Leave</option>
                            <option value="NotGoingToSchool">Not Going to School</option>
                            <option value="ParentPickup">Parent Pickup</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">From Date <span class="text-danger">*</span></label>
                        <input type="date" name="FromDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">To Date <span class="text-danger">*</span></label>
                        <input type="date" name="ToDate" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Remarks</label>
                        <textarea name="Remarks" class="form-control" rows="2"></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary w-100 text-white">Save</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4">Upcoming Records</div>
            <div class="card-body p-4">
                @if (Model is null || Model.Count == 0)
                {
                    <div class="text-center text-muted py-4"><i class="bi bi-calendar-check fs-1 d-block mb-2"></i>No upcoming records.</div>
                }
                else
                {
                    <table class="table align-middle table-hover">
                        <thead class="table-light">
                            <tr><th>Reason</th><th>From</th><th>To</th><th>Remarks</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-warning-subtle text-warning">@a.AvailabilityType</span></td>
                                    <td>@a.FromDate</td>
                                    <td>@a.ToDate</td>
                                    <td class="text-muted small">@(a.Remarks ?? "–")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

