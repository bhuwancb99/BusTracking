@model BusTracking.Common.DTOs.Feedback.CreateFeedbackDto
@{
    ViewData["Title"] = "Help & Support";
}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold border-0 pt-4 px-4"><i class="bi bi-headset me-2 text-primary"></i>Submit Inquiry or Complaint</div>
            <div class="card-body p-4">
                @if (TempData["SuccessMessage"] is string msg)
                {
                    <div class="alert alert-success py-2">@msg</div>
                }
                <form asp-area="Student" asp-controller="Feedback" asp-action="Submit" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3 d-flex gap-4">
                        <div class="form-check"><input class="form-check-input" type="radio" name="Category" value="Inquiry" id="ci" checked /><label class="form-check-label" for="ci">Inquiry</label></div>
                        <div class="form-check"><input class="form-check-input" type="radio" name="Category" value="Complaint" id="cc" /><label class="form-check-label" for="cc">Complaint</label></div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label><input asp-for="Email" type="email" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="PhoneNumber" class="form-label fw-semibold">Phone</label><input asp-for="PhoneNumber" class="form-control" /></div>
                        <div class="col-12"><label asp-for="Description" class="form-label fw-semibold">Message <span class="text-danger">*</span></label><textarea asp-for="Description" class="form-control" rows="5"></textarea></div>
                    </div>
                    <div class="mt-4"><button type="submit" class="btn btn-primary px-4"><i class="bi bi-send me-1"></i>Submit</button></div>
                </form>
            </div>
        </div>
    </div>
</div>
