<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  ══ SYNCFUSION HINT LABELS ════════════════════════════════════════  -->
    <Style x:Key="SfHintStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style x:Key="SfFocusedHintStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!--  ══ SHELL / NAVIGATION ════════════════════════════════════════════  -->
    <Style TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource NavBarBg}" />
        <Setter Property="Shell.ForegroundColor" Value="White" />
        <Setter Property="Shell.TitleColor" Value="White" />
        <Setter Property="Shell.DisabledColor" Value="#B4FFFFFF" />
        <Setter Property="Shell.UnselectedColor" Value="#60FFFFFF" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource NavBarBg}" />
        <Setter Property="BarTextColor" Value="White" />
    </Style>

    <!--  ══ PAGE DEFAULT ══════════════════════════════════════════════════  -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}" />
    </Style>

    <!--  ══ TYPOGRAPHY ════════════════════════════════════════════════════  -->
    <Style x:Key="DisplayLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>
    <Style x:Key="HeadingLabel" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>
    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>
    <Style x:Key="CardTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>
    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>
    <Style x:Key="SubLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>
    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>
    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="0.8" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!--  ══ ENTRY / PICKER DEFAULTS ═══════════════════════════════════════  -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InputText}, Dark={StaticResource InputTextDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource InputPlaceholder}, Dark={StaticResource InputPlaceholderDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>
    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InputText}, Dark={StaticResource InputTextDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource InputPlaceholder}, Dark={StaticResource InputPlaceholderDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InputText}, Dark={StaticResource InputTextDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource InputPlaceholder}, Dark={StaticResource InputPlaceholderDark}}" />
    </Style>
    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource InputText}, Dark={StaticResource InputTextDark}}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource Primary}" />
        <Setter Property="ThumbColor" Value="White" />
    </Style>
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <!--  ══ CARD BORDERS ══════════════════════════════════════════════════  -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
    </Style>
    <Style x:Key="StatCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
    </Style>
    <Style x:Key="ListItemBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style x:Key="InputCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource InputBorder}, Dark={StaticResource InputBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="16,12" />
    </Style>
    <Style x:Key="SearchBarBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>
    <Style x:Key="ErrorBannerBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style x:Key="QuickActionChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1.5" />
    </Style>
    <Style x:Key="IconTileBorder" TargetType="Border">
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Stroke" Value="Transparent" />
    </Style>

    <!--  ══ FORM FIELD CARD ════════════════════════════════════════════════  -->
    <Style x:Key="FormFieldCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <!--  ══ BUTTONS ════════════════════════════════════════════════════════  -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontSize" Value="15" />
    </Style>
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!--  ══ NAV ADD BUTTON (Icon pill in Shell header) ════════════════════  -->
    <!--  Used as wrapper — see NavAddBorder below for replacement  -->
    <Style x:Key="NavPillButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!--  Stylish icon-pill border used as Add button in Shell headers  -->
    <Style x:Key="NavAddBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="SearchGoButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="HeightRequest" Value="38" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>
    <Style x:Key="LoginSignInButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!--  ══ STATUS BADGE BORDERS ═══════════════════════════════════════════  -->
    <Style x:Key="StatusActiveBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource StatusActiveBg}, Dark={StaticResource StatusActiveBgDark}}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <Style x:Key="StatusInactiveBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!--  ══ LOGIN CARD / INPUT BORDERS ════════════════════════════════════  -->
    <Style x:Key="LoginCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LoginCardBgLight}, Dark={StaticResource LoginCardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 28" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="28,30" />
    </Style>
    <Style x:Key="LoginInputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LoginInputBgLight}, Dark={StaticResource LoginInputBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="16,4" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>
    <Style x:Key="LoginInputLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>
    <Style x:Key="SecureFooterBadge" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource LoginSecureBadgeBgLight}, Dark={StaticResource LoginSecureBadgeBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource LoginSecureBadgeBorderLight}, Dark={StaticResource LoginSecureBadgeBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,6" />
    </Style>
    <Style x:Key="SecurePillBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SecurePillBgLight}, Dark={StaticResource SecurePillBgDark}}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="14,6" />
    </Style>
    <Style x:Key="RoleBadgeBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource RoleBadgeBgLight}, Dark={StaticResource RoleBadgeBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource RoleBadgeBorderLight}, Dark={StaticResource RoleBadgeBorderDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <!--  ══ DRAWER MENU ITEM ═══════════════════════════════════════════════  -->
    <Style x:Key="DrawerItemBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="12,13" />
        <Setter Property="Margin" Value="8,2" />
    </Style>
    <Style x:Key="DrawerItemActiveBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource DrawerItemActive}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Padding" Value="12,13" />
        <Setter Property="Margin" Value="8,2" />
    </Style>

    <!--  ══ HERO CARD (dark banner used on Driver/Student/Parent pages) ══  -->
    <Style x:Key="HeroCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource HeroCardBgLight}, Dark={StaticResource HeroCardBgDark}}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!--  ══ DIVIDER ════════════════════════════════════════════════════════  -->
    <Style x:Key="DividerBox" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

</ResourceDictionary>
