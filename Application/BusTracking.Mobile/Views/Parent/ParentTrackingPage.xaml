<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Parent.ParentTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Parent"
    Title="Track Bus"
    x:DataType="vm:ParentTrackingViewModel"
    x:TypeArguments="vm:ParentTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <!--  ══ Shell header: title left + student picker pill right ══════════  -->
    <Shell.TitleView>
        <Grid
            Padding="0,0,12,0"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="10">

            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Track Bus"
                TextColor="White"
                VerticalOptions="Center" />

            <!--  Student selector pill  -->
            <Border
                Grid.Column="1"
                BackgroundColor="#1e2a3a"
                HorizontalOptions="End"
                MinimumWidthRequest="140"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Grid
                    Padding="8,0"
                    ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="6">

                    <!--  Initials circle  -->
                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="28"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        WidthRequest="28">
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            HorizontalOptions="Center"
                            Text="{Binding SelectedStudent.Initials, FallbackValue='?'}"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>

                    <!--  Picker  -->
                    <Picker
                        Title="Select child"
                        Grid.Column="1"
                        BackgroundColor="Transparent"
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalOptions="Fill"
                        ItemDisplayBinding="{Binding FullName}"
                        ItemsSource="{Binding Students}"
                        SelectedItem="{Binding SelectedStudent}"
                        TextColor="White"
                        TitleColor="#94a3b8"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="2"
                        FontSize="11"
                        Text="▾"
                        TextColor="#94a3b8"
                        VerticalOptions="Center" />

                </Grid>
            </Border>
        </Grid>
    </Shell.TitleView>

    <!--  ══ Page body ═════════════════════════════════════════════════════  -->
    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!--  Row 0 — Status banner  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,0"
            BackgroundColor="{AppThemeBinding Light={StaticResource NavBarBg},
                                              Dark={StaticResource DrawerBgDark}}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="0">
            <Grid
                Padding="16,14"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="12">

                <Border
                    Grid.Column="0"
                    BackgroundColor="#1e2a3a"
                    HeightRequest="42"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="42">
                    <Image
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        Source="bus.png"
                        VerticalOptions="Center"
                        WidthRequest="22">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Image.Behaviors>
                    </Image>
                </Border>

                <VerticalStackLayout
                    Grid.Column="1"
                    Margin="0"
                    Spacing="3"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding StatusLabel}"
                        TextColor="White" />
                    <Label
                        FontSize="12"
                        Text="{Binding Tracking.BoardingStatus, StringFormat='Boarding: {0}', FallbackValue='Boarding: —'}"
                        TextColor="{StaticResource HeroCardSubText}" />
                </VerticalStackLayout>

                <!--  Live / No Trip pill  -->
                <Border
                    Grid.Column="2"
                    Padding="10,5"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Border.Triggers>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="True">
                            <Setter Property="BackgroundColor" Value="#14532d" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="False">
                            <Setter Property="BackgroundColor" Value="#1e2a3a" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label FontAttributes="Bold" FontSize="12">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="● LIVE" />
                                <Setter Property="TextColor" Value="#4ade80" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="False">
                                <Setter Property="Text" Value="○ No Trip" />
                                <Setter Property="TextColor" Value="#64748b" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

            </Grid>
        </Border>

        <!--  Row 1 — Selected student info strip  -->
        <Border
            Grid.Row="1"
            Margin="12,8,12,0"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                              Dark={StaticResource CardBgDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                     Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1">
            <Grid
                Padding="14,10"
                ColumnDefinitions="Auto,*,Auto,Auto"
                ColumnSpacing="10">

                <!--  Avatar  -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                      Dark={StaticResource StatBusBgDark}}"
                    HeightRequest="36"
                    StrokeShape="RoundRectangle 18"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding SelectedStudent.Initials, FallbackValue='?'}"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center" />
                </Border>

                <!--  Name + class  -->
                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="1"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="{Binding SelectedStudent.FullName, FallbackValue='No student'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="11"
                        Text="{Binding SelectedStudent.Standard, StringFormat='Class: {0}', FallbackValue='—'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>

                <!--  Bus badge  -->
                <Border
                    Grid.Column="2"
                    Padding="8,4"
                    BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                      Dark={StaticResource StatBusBgDark}}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 8"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="11"
                        Text="{Binding SelectedStudent.BusDisplay}"
                        TextColor="{StaticResource Primary}" />
                </Border>

                <!--  Student code  -->
                <Label
                    Grid.Column="3"
                    FontSize="11"
                    Text="{Binding SelectedStudent.StudentCode}"
                    TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                Dark={StaticResource TextSecondaryDark}}"
                    VerticalOptions="Center" />

            </Grid>
        </Border>

        <!--  Row 2 — Map area  -->
        <Border
            Grid.Row="2"
            Margin="12,8"
            BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor},
                                              Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 20"
            StrokeThickness="0">
            <Grid>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="8"
                    VerticalOptions="Center">
                    <Label
                        FontSize="72"
                        HorizontalOptions="Center"
                        Text="🗺️" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="Live Map"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Label
                        FontSize="11"
                        HorizontalOptions="Center"
                        Text="Bus location updates every 10 seconds"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>

                <!--  Live bus marker  -->
                <Border
                    Padding="10,8"
                    BackgroundColor="{StaticResource Primary}"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsLive}"
                    Stroke="White"
                    StrokeShape="RoundRectangle 28"
                    StrokeThickness="2"
                    VerticalOptions="Center">
                    <Label FontSize="22" Text="🚌" />
                </Border>
            </Grid>
        </Border>

        <!--  Row 3 — Coordinates card  -->
        <Border
            Grid.Row="3"
            Margin="12,0,12,16"
            Style="{StaticResource CardBorder}">
            <Grid Padding="16,14" ColumnDefinitions="*,Auto,*,Auto,*">

                <VerticalStackLayout
                    Grid.Column="0"
                    HorizontalOptions="Center"
                    Spacing="3">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="{Binding BusLatitude, StringFormat='{0:F4}', FallbackValue='—'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource CaptionLabel}"
                        Text="Latitude" />
                </VerticalStackLayout>

                <BoxView
                    Grid.Column="1"
                    HeightRequest="32"
                    Style="{StaticResource DividerBox}"
                    VerticalOptions="Center"
                    WidthRequest="1" />

                <VerticalStackLayout
                    Grid.Column="2"
                    HorizontalOptions="Center"
                    Spacing="3">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="{Binding BusLongitude, StringFormat='{0:F4}', FallbackValue='—'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource CaptionLabel}"
                        Text="Longitude" />
                </VerticalStackLayout>

                <BoxView
                    Grid.Column="3"
                    HeightRequest="32"
                    Style="{StaticResource DividerBox}"
                    VerticalOptions="Center"
                    WidthRequest="1" />

                <VerticalStackLayout
                    Grid.Column="4"
                    HorizontalOptions="Center"
                    Spacing="3">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="{Binding Tracking.Location.SpeedDisplay, FallbackValue='— km/h'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        HorizontalOptions="Center"
                        Style="{StaticResource CaptionLabel}"
                        Text="Speed" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>

</views:ViewBase>
