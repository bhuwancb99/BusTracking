<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Parent.ParentDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Parent"
    Title="Parent Portal"
    x:DataType="vm:ParentDashboardViewModel"
    x:TypeArguments="vm:ParentDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,10,0">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Parent Portal"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="16,20,16,40" Spacing="20">

                <!--  Welcome Header  -->
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource HeadingLabel}" Text="{Binding WelcomeText}" />
                    <Label Style="{StaticResource SubLabel}" Text="{Binding TodayLabel}" />
                </VerticalStackLayout>

                <!--  Quick Action Cards - Bento Grid Design  -->
                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="10"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="10">

                    <!--  Track Bus Card (Hero Card, Span 2)  -->
                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Style="{StaticResource StatCardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTrackingCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DangerLight}, Dark=#4a070a}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid Padding="4,2" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="6"
                                VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Border
                                        Padding="6,3"
                                        BackgroundColor="{StaticResource Danger}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="9"
                                            Text="LIVE TRACKING"
                                            TextColor="White" />
                                    </Border>
                                    <Label
                                        Style="{StaticResource CaptionLabel}"
                                        Text="Track Bus"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    Text="Track Child's Bus"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark=White}" />
                                <Label
                                    FontSize="11"
                                    Text="See where your child's bus is right now."
                                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                Dark={StaticResource TextSecondaryDark}}" />
                            </VerticalStackLayout>
                            <Border
                                Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                                  Dark={StaticResource StatTripBgDark}}"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="56">
                                <Image
                                    HeightRequest="26"
                                    HorizontalOptions="Center"
                                    Source="map_pin.png"
                                    VerticalOptions="Center"
                                    WidthRequest="26">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                        </Grid>
                    </Border>

                    <!--  Manage Availability Card  -->
                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource StatCardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToAvailabilityCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DrawerItemActiveLight}, Dark=#0c1f4e}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Border
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                HeightRequest="44"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Image
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="calendar_check.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Availability"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                HorizontalOptions="Center"
                                Style="{StaticResource CaptionLabel}"
                                Text="Leaves &amp; Pickups" />
                            <Border
                                Padding="6,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    HorizontalOptions="Center"
                                    Text="Manage"
                                    TextColor="{StaticResource Primary}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!--  Help & Support Card  -->
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource StatCardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToFeedbackCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource StatStudentBg}, Dark=#0c1c3f}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Border
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatStudentBg},
                                                                  Dark={StaticResource StatStudentBgDark}}"
                                HeightRequest="44"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Image
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="headphones.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Purple}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Support"
                                TextColor="{StaticResource Purple}" />
                            <Label
                                HorizontalOptions="Center"
                                Style="{StaticResource CaptionLabel}"
                                Text="Get Help" />
                            <Border
                                Padding="6,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PurpleLight},
                                                                  Dark={StaticResource StatStudentBgDark}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    HorizontalOptions="Center"
                                    Text="Contact"
                                    TextColor="{StaticResource Purple}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!--  My Children Section  -->
                <Border Margin="0,10,0,0" Style="{StaticResource StatCardBorder}">
                    <VerticalStackLayout Spacing="14">

                        <!--  Section header  -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Image
                                Grid.Column="0"
                                HeightRequest="18"
                                Source="student.png"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label
                                Grid.Column="1"
                                Style="{StaticResource SectionLabel}"
                                Text="My Children"
                                VerticalOptions="Center" />
                            <Border
                                Grid.Column="2"
                                Padding="10,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding ChildrenCountLabel}"
                                    TextColor="{StaticResource Primary}" />
                            </Border>
                        </Grid>

                        <!--  Divider  -->
                        <BoxView Margin="0" Style="{StaticResource DividerBox}" />

                        <!--  Children CollectionView  -->
                        <CollectionView ItemsSource="{Binding Children}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout
                                    Padding="0,20"
                                    HorizontalOptions="Center"
                                    Spacing="10">
                                    <Image
                                        HeightRequest="48"
                                        HorizontalOptions="Center"
                                        Source="student.png"
                                        WidthRequest="48">
                                        <Image.Behaviors>
                                            <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label
                                        HorizontalOptions="Center"
                                        Style="{StaticResource SubLabel}"
                                        Text="No children linked to your account" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Parent.LinkedStudent">
                                    <Border
                                        Margin="0,0,0,10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                                                          Dark={StaticResource PageBgDark}}"
                                        Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                                 Dark={StaticResource BorderColorDark}}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="1">
                                        <VerticalStackLayout Padding="14" Spacing="12">

                                            <!--  Student info row  -->
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">

                                                <!--  Avatar circle  -->
                                                <Border
                                                    Grid.Column="0"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                                      Dark={StaticResource StatBusBgDark}}"
                                                    HeightRequest="48"
                                                    StrokeShape="RoundRectangle 24"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center"
                                                    WidthRequest="48">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="16"
                                                        HorizontalOptions="Center"
                                                        Text="{Binding Initials}"
                                                        TextColor="{StaticResource Primary}"
                                                        VerticalOptions="Center" />
                                                </Border>

                                                <!--  Name / code / class / bus  -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Spacing="3"
                                                    VerticalOptions="Center">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label
                                                            Grid.Column="0"
                                                            Style="{StaticResource CardTitleLabel}"
                                                            Text="{Binding FullName}"
                                                            VerticalOptions="Center" />
                                                        <Border
                                                            Grid.Column="1"
                                                            Padding="8,3"
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusActiveBg},
                                                                                              Dark={StaticResource StatusActiveBgDark}}"
                                                            Stroke="Transparent"
                                                            StrokeShape="RoundRectangle 8"
                                                            VerticalOptions="Center">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="11"
                                                                Text="Active"
                                                                TextColor="{AppThemeBinding Light={StaticResource StatusActiveText},
                                                                                            Dark={StaticResource StatusActiveTextDark}}" />
                                                        </Border>
                                                    </Grid>
                                                    <Label Style="{StaticResource CaptionLabel}" Text="{Binding StudentCode}" />
                                                    <Label Style="{StaticResource SubLabel}" Text="{Binding Standard, StringFormat='Class: {0}'}" />
                                                    <Border
                                                        Padding="8,3"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                                          Dark={StaticResource StatBusBgDark}}"
                                                        HorizontalOptions="Start"
                                                        Stroke="Transparent"
                                                        StrokeShape="RoundRectangle 8">
                                                        <Label
                                                            FontAttributes="Bold"
                                                            FontSize="11"
                                                            Text="{Binding BusDisplay}"
                                                            TextColor="{StaticResource Primary}" />
                                                    </Border>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <!--  Action buttons row  -->
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <!--  Track  -->
                                                <Button
                                                    Grid.Column="0"
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{StaticResource Danger}"
                                                    BorderWidth="1.5"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParentDashboardViewModel}}, Path=TrackChildCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="8"
                                                    FontAttributes="Bold"
                                                    FontSize="13"
                                                    HeightRequest="40"
                                                    Text="Track"
                                                    TextColor="{StaticResource Danger}" />
                                                <!--  Leave  -->
                                                <Button
                                                    Grid.Column="1"
                                                    BackgroundColor="Transparent"
                                                    BorderColor="{StaticResource Primary}"
                                                    BorderWidth="1.5"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParentDashboardViewModel}}, Path=LeaveChildCommand}"
                                                    CommandParameter="{Binding .}"
                                                    CornerRadius="8"
                                                    FontAttributes="Bold"
                                                    FontSize="13"
                                                    HeightRequest="40"
                                                    Text="Leave"
                                                    TextColor="{StaticResource Primary}" />
                                            </Grid>

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
