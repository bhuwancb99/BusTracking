<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Parent.ParentDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Parent"
    Title="My Dashboard"
    x:DataType="vm:ParentDashboardViewModel"
    x:TypeArguments="vm:ParentDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Parent Portal"
                TextColor="White"
                VerticalOptions="Center" />
            <ImageButton
                Grid.Column="1"
                BackgroundColor="Transparent"
                Command="{Binding LogoutCommand}"
                Source="logout.png"
                WidthRequest="22" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="16">

                <!--  Welcome  -->
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding WelcomeText}"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <Label
                    FontSize="13"
                    Text="Track your children's buses below"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />

                <!--  Children list  -->
                <Label
                    Margin="0,4,0,4"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="My Children"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

                <CollectionView ItemsSource="{Binding Children}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            Padding="0,32"
                            HorizontalOptions="Center"
                            Spacing="12">
                            <Label
                                FontSize="48"
                                HorizontalOptions="Center"
                                Text="👶" />
                            <Label
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="No children linked to your account"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Parent.LinkedStudent">
                            <Border
                                Margin="0,0,0,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" StrokeShape="RoundRectangle 16"
                                StrokeThickness="0">
                                <Grid
                                    Padding="16"
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="12">

                                    <!--  Avatar  -->
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg}, Dark={StaticResource StatBusBgDark}}"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 24"
                                        StrokeThickness="0"
                                        WidthRequest="48">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="18"
                                            HorizontalOptions="Center"
                                            Text="{Binding FullName}"
                                            TextColor="{StaticResource Primary}"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <!--  Info  -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="4"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding FullName}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding StudentCode}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding BusDisplay}"
                                            TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>

                                    <!--  Track button  -->
                                    <Button
                                        Grid.Column="2"
                                        Padding="14,8"
                                        BackgroundColor="{StaticResource Primary}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParentDashboardViewModel}}, Path=TrackChildCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="20"
                                        FontSize="12"
                                        Text="Track"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
