<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Shared.LiveTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:tracking="clr-namespace:BusTracking.Mobile.Models.Tracking"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Shared"
    x:DataType="vm:LiveTrackingViewModel"
    x:TypeArguments="vm:LiveTrackingViewModel">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="Transparent" StatusBarStyle="DarkContent" />
    </views:ViewBase.Behaviors>

    <!--  Full-screen stack: map fills screen, panels float on top  -->
    <Grid>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LAYER 1 — Google Maps WebView  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <WebView
            x:Name="MapWebView"
            HorizontalOptions="Fill"
            Source="tracking_map.html"
            VerticalOptions="Fill" />

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LAYER 2 — Top bar: back button + live pill + bus card  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Grid
            Padding="14,50,14,14"
            RowDefinitions="Auto,Auto"
            VerticalOptions="Start">

            <!--  Row 0: back + live pill  -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">

                <!--  Back button  -->
                <Border
                    Grid.Column="0"
                    Padding="0"
                    BackgroundColor="White"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    WidthRequest="40">
                    <Border.Shadow>
                        <Shadow
                            Brush="#20000000"
                            Radius="6"
                            Offset="0,2" />
                    </Border.Shadow>
                    <ImageButton
                        BackgroundColor="Transparent"
                        Command="{Binding GoBackCommand}"
                        HeightRequest="24"
                        HorizontalOptions="Center"
                        Source="back.png"
                        VerticalOptions="Center"
                        WidthRequest="24" />
                </Border>

                <!--  Live / Reconnecting pill  -->
                <Border
                    Grid.Column="2"
                    Padding="12,6"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0">
                    <Border.Triggers>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="True">
                            <Setter Property="BackgroundColor" Value="#16a34a" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="False">
                            <Setter Property="BackgroundColor" Value="#64748b" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.Shadow>
                        <Shadow
                            Brush="#20000000"
                            Radius="6"
                            Offset="0,2" />
                    </Border.Shadow>
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="{Binding ConnectionStatus}"
                        TextColor="White"
                        VerticalOptions="Center" />
                </Border>
            </Grid>

            <!--  Row 1: bus info card  -->
            <Border
                Grid.Row="1"
                Margin="0,10,0,0"
                Padding="14,12"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="0">
                <Border.Shadow>
                    <Shadow
                        Brush="#25000000"
                        Radius="10"
                        Offset="0,3" />
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <!--  Bus icon badge  -->
                    <Border
                        Grid.Column="0"
                        Padding="0"
                        BackgroundColor="#EEF2FF"
                        HeightRequest="46"
                        StrokeShape="RoundRectangle 8"
                        WidthRequest="46">
                        <Label
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="🚌"
                            VerticalOptions="Center" />
                    </Border>

                    <!--  Bus name + number  -->
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="{Binding BusName}"
                            TextColor="#1a1a2e" />
                        <Label
                            FontSize="12"
                            Text="{Binding BusNumber}"
                            TextColor="#666" />
                    </VerticalStackLayout>

                    <!--  Speed + last update  -->
                    <VerticalStackLayout
                        Grid.Column="2"
                        HorizontalOptions="End"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            HorizontalOptions="End"
                            Text="{Binding SpeedLabel}"
                            TextColor="#6366f1" />
                        <Label
                            FontSize="10"
                            HorizontalOptions="End"
                            Text="{Binding LastUpdateLabel}"
                            TextColor="#aaa" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LAYER 3 — Bottom sheet: route stops list  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border
            Padding="0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 24,24,0,0"
            StrokeThickness="0"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="#30000000"
                    Radius="16"
                    Offset="0,-4" />
            </Border.Shadow>
            <VerticalStackLayout>

                <!--  Drag handle  -->
                <BoxView
                    Margin="0,10,0,8"
                    BackgroundColor="#e5e7eb"
                    CornerRadius="3"
                    HeightRequest="4"
                    HorizontalOptions="Center"
                    WidthRequest="40" />

                <Label
                    Margin="18,4,18,10"
                    FontAttributes="Bold"
                    FontSize="15"
                    Text="Route Stops"
                    TextColor="#1a1a2e" />

                <!--  Empty state  -->
                <Label
                    Margin="18,0,18,20"
                    FontSize="13"
                    IsVisible="{Binding IsEmpty}"
                    Text="No stop data for this trip."
                    TextColor="#94a3b8" />

                <!--  Stops list  -->
                <CollectionView
                    Margin="0,0,0,24"
                    HeightRequest="200"
                    IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}"
                    ItemsSource="{Binding Stops}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="0" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="tracking:StopStatus">
                            <Grid
                                Padding="18,10"
                                ColumnDefinitions="28,12,*,Auto"
                                ColumnSpacing="0">

                                <!--  Numbered circle  -->
                                <Border
                                    Grid.Column="0"
                                    BackgroundColor="{Binding StatusColor}"
                                    HeightRequest="28"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    WidthRequest="28">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="11"
                                        HorizontalOptions="Center"
                                        Text="{Binding StopOrder}"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </Border>

                                <!--  Stop name  -->
                                <Label
                                    Grid.Column="2"
                                    FontSize="13"
                                    Text="{Binding StopName}"
                                    TextColor="#1a1a2e"
                                    VerticalOptions="Center" />

                                <!--  Status badge  -->
                                <Border
                                    Grid.Column="3"
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusColor}"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontSize="10"
                                        Text="{Binding Status}"
                                        TextColor="White" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LAYER 4 — Trip Ended overlay  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border
            BackgroundColor="#CC000000"
            IsVisible="{Binding TripEnded}"
            StrokeThickness="0">
            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="16"
                VerticalOptions="Center">
                <Label
                    FontSize="48"
                    HorizontalOptions="Center"
                    Text="🏁" />
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Center"
                    Text="Trip Completed!"
                    TextColor="White" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="The bus has reached the final stop."
                    TextColor="#ccc" />
                <Button
                    Margin="40,10"
                    BackgroundColor="#6366f1"
                    Command="{Binding GoBackCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    Text="OK, Go Back"
                    TextColor="White" />
            </VerticalStackLayout>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LAYER 5 — Connecting spinner  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border
            BackgroundColor="#99FFFFFF"
            IsVisible="{Binding IsBusy}"
            StrokeThickness="0">
            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="12"
                VerticalOptions="Center">
                <ActivityIndicator IsRunning="True" Color="#6366f1" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    Text="Connecting to live tracking…"
                    TextColor="#333" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</views:ViewBase>
