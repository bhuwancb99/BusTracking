<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BusTracking.Mobile.Views.Common.MaintenancePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    BackgroundColor="{AppThemeBinding Light={StaticResource NavBarBg},
                                      Dark={StaticResource DrawerBgDark}}"
    Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <VerticalStackLayout
        Padding="32"
        HorizontalOptions="Center"
        Spacing="20"
        VerticalOptions="Center">

        <Label
            FontSize="80"
            HorizontalOptions="Center"
            Text="🔧" />

        <Label
            FontAttributes="Bold"
            FontSize="24"
            HorizontalOptions="Center"
            Text="Under Maintenance"
            TextColor="White" />

        <Label
            x:Name="MessageLabel"
            FontSize="14"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            LineBreakMode="WordWrap"
            Text="We are under maintenance. Please check back soon."
            TextColor="{StaticResource HeroCardSubText}" />

        <Border
            Margin="0,10"
            Padding="16,12"
            BackgroundColor="#ffffff15"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="0">
            <Label
                FontSize="13"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Text="Our team is working hard to get things back up. Thank you for your patience."
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />
        </Border>

        <ActivityIndicator
            Margin="0,10"
            IsRunning="True"
            Color="White" />

    </VerticalStackLayout>

</ContentPage>
