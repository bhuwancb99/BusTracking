<?xml version="1.0" encoding="UTF-8" ?>
<!--
    AVATAR VISIBILITY
    ─────────────────────────────────────────────────────────────────────────
    ProfileImageUrl = null/empty  →  Initials circle visible   |  Photo circle hidden
    ProfileImageUrl = "https://…"  →  Initials circle hidden  |  Photo circle visible
    
    CAMERA BADGE  (bottom-right of avatar)
    ─────────────────────────────────────────────────────────────────────────
    IsVisible = CanUpdateImage  (IsMobileUpdateImage = 1 only)
    Tap → CaptureOrPickPhotoCommand → ActionSheet:
    "Take Photo"          → MediaPicker.CapturePhotoAsync
    "Choose from Gallery" → MediaPicker.PickPhotosAsync
-->
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Common.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Common"
    Title="{Binding Title}"
    x:DataType="vm:ProfileViewModel"
    x:TypeArguments="vm:ProfileViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="24,32,24,40" Spacing="0">

            <!--
                ══════════════════════════════════════════════════════════════
                AVATAR CARD
                ══════════════════════════════════════════════════════════════════
            -->
            <Border
                Padding="28,32"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                HorizontalOptions="Fill"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">

                <VerticalStackLayout HorizontalOptions="Center" Spacing="20">

                    <!--
                        ══ AVATAR + CAMERA BADGE ════════════════════════════
                        Grid 110×110 — extra 10 px so the 34×34 badge
                        doesn't get clipped at the edge of the 100×100 photo.
                        
                        All three children share cell [0,0].
                        Z-order (bottom → top): Initials | Photo | Camera badge
                        ═════════════════════════════════════════════════════════
                    -->
                    <Grid
                        HeightRequest="110"
                        HorizontalOptions="Center"
                        WidthRequest="110">

                        <!--
                            ── INITIALS CIRCLE ──────────────────────────────
                            Primary-colour background + Initials text.
                            Visible when ProfileImageUrl is null / empty.
                            ───────────────────────────────────────────────────
                        -->
                        <Border
                            BackgroundColor="{StaticResource Primary}"
                            HeightRequest="100"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ProfileImageUrl, Converter={StaticResource StringToInvertBool}}"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="100">
                            <Label
                                FontAttributes="Bold"
                                FontSize="36"
                                HorizontalOptions="Center"
                                Text="{Binding Initials}"
                                TextColor="White"
                                VerticalOptions="Center" />
                        </Border>

                        <!--
                            ── PHOTO CIRCLE ─────────────────────────────────
                            Circular crop via RoundRectangle 50.
                            Visible when ProfileImageUrl is non-empty.
                            UriImageSource caches 1 h; server returns a new
                            path/timestamp after upload so cache auto-busts.
                            ───────────────────────────────────────────────────
                        -->
                        <Border
                            HeightRequest="100"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ProfileImageUrl, Converter={StaticResource StringToBool}}"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="100">
                            <Image
                                Aspect="AspectFill"
                                HeightRequest="100"
                                WidthRequest="100">
                                <Image.Source>
                                    <UriImageSource
                                        CacheValidity="0:01:00:00"
                                        CachingEnabled="True"
                                        Uri="{Binding ProfileImageUrl}" />
                                </Image.Source>
                            </Image>
                        </Border>

                        <!--
                            ── CAMERA BADGE ─────────────────────────────────
                            Blue circle, white camera icon, bottom-right corner.
                            White stroke ring separates it from the photo/initials.
                            
                            IsVisible = CanUpdateImage
                            true  → IsMobileUpdateImage = 1 (upload allowed)
                            false → IsMobileUpdateImage = 0 (hidden, read-only)
                            
                            Tap → CaptureOrPickPhotoCommand
                            ActionSheet: "Take Photo" | "Choose from Gallery"
                            ───────────────────────────────────────────────────
                        -->
                        <Border
                            Padding="0"
                            BackgroundColor="{StaticResource Primary}"
                            HeightRequest="34"
                            HorizontalOptions="End"
                            IsVisible="{Binding CanUpdateImage}"
                            Stroke="White"
                            StrokeShape="RoundRectangle 17"
                            StrokeThickness="2"
                            VerticalOptions="End"
                            WidthRequest="34">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CaptureOrPickPhotoCommand}" />
                            </Border.GestureRecognizers>
                            <Image
                                HeightRequest="18"
                                HorizontalOptions="Center"
                                Source="camera.png"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="White" />
                                </Image.Behaviors>
                            </Image>
                        </Border>

                    </Grid>
                    <!--  ══ End AVATAR + CAMERA BADGE ════════════════════════  -->

                    <!--  Full name  -->
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="{Binding FullName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />

                    <!--  Role badge pill  -->
                    <Border
                        Padding="14,5"
                        BackgroundColor="{StaticResource Accent}"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="0">
                        <Label
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="{Binding RoleDisplay}"
                            TextColor="White" />
                    </Border>

                    <!--  Email (under role badge)  -->
                    <Label
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding Email}"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                    Dark={StaticResource TextMutedDark}}" />

                    <!--
                        ══ REMOVE PHOTO BUTTON ═══════════════════════════════
                        Visible ONLY when:
                        CanUpdateImage = true   (IsMobileUpdateImage = 1)
                        AND
                        HasPhoto = true          (a photo is currently set)
                        
                        Hidden when:
                        IsMobileUpdateImage = 0  → CanUpdateImage = false
                        No photo exists          → HasPhoto = false
                        ═════════════════════════════════════════════════════════
                    -->
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                          Dark={StaticResource CardBgDark}}"
                        HorizontalOptions="Fill"
                        Stroke="{StaticResource Danger}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1">
                        <Border.IsVisible>
                            <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                <Binding Path="CanUpdateImage" />
                                <Binding Path="HasPhoto" />
                            </MultiBinding>
                        </Border.IsVisible>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RemovePhotoCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout
                            Padding="20,14"
                            HorizontalOptions="Center"
                            Spacing="10">
                            <Image
                                HeightRequest="18"
                                Source="delete.png"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                </Image.Behaviors>
                            </Image>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="Remove Photo"
                                TextColor="{StaticResource Danger}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    <!--  ══ End REMOVE PHOTO BUTTON ═══════════════════════════  -->

                    <!--  Loading spinner (IsBusy from BaseViewModel)  -->
                    <ActivityIndicator
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="{StaticResource Primary}" />

                </VerticalStackLayout>
            </Border>
            <!--  ══ End AVATAR CARD ══════════════════════════════════════════  -->

            <!--
                ══════════════════════════════════════════════════════════════
                ACCOUNT DETAILS CARD
                ══════════════════════════════════════════════════════════════════
            -->
            <Border
                Margin="0,20,0,0"
                Padding="24,20"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                HorizontalOptions="Fill"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <VerticalStackLayout Spacing="16">

                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="Account Details"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />

                    <!--  Email row  -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            HeightRequest="38"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="38">
                            <Image
                                HeightRequest="18"
                                HorizontalOptions="Center"
                                Source="email.png"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                FontSize="11"
                                Text="Email"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextMutedDark}}" />
                            <Label
                                FontSize="14"
                                Text="{Binding Email}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Grid>

                    <!--  Role row  -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border
                            Grid.Column="0"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            HeightRequest="38"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="38">
                            <Image
                                HeightRequest="18"
                                HorizontalOptions="Center"
                                Source="role.png"
                                VerticalOptions="Center"
                                WidthRequest="18">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                FontSize="11"
                                Text="Role"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextMutedDark}}" />
                            <Label
                                FontSize="14"
                                Text="{Binding RoleDisplay}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>
            <!--  ══ End ACCOUNT DETAILS CARD ═════════════════════════════════  -->

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
