<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Auth"
    x:TypeArguments="vm:LoginViewModel"
    BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="*,Auto,*">

        <!--  ── Maintenance overlay ──  -->
        <Frame
            Grid.RowSpan="3"
            Padding="32"
            BackgroundColor="White"
            CornerRadius="0"
            IsVisible="{Binding IsMaintenanceMode}"
            ZIndex="99">
            <VerticalStackLayout Spacing="16" VerticalOptions="Center">
                <Label
                    FontSize="64"
                    HorizontalOptions="Center"
                    Text="🔧" />
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    HorizontalOptions="Center"
                    Text="Under Maintenance"
                    TextColor="#1e293b" />
                <Label
                    FontSize="14"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding MaintenanceMessage}"
                    TextColor="#64748b" />
            </VerticalStackLayout>
        </Frame>

        <!--  ── Top brand panel ──  -->
        <Grid
            Grid.Row="0"
            Padding="32,60,32,40"
            BackgroundColor="#1e3a5f">
            <VerticalStackLayout Spacing="8" VerticalOptions="End">
                <Label
                    FontSize="48"
                    HorizontalOptions="Center"
                    Text="🚌" />
                <Label
                    FontAttributes="Bold"
                    FontSize="28"
                    HorizontalOptions="Center"
                    Text="BusTrack"
                    TextColor="White" />
                <Label
                    FontSize="13"
                    HorizontalOptions="Center"
                    Text="Safe journeys, every day"
                    TextColor="#93c5fd" />
            </VerticalStackLayout>
        </Grid>

        <!--  ── Form card ──  -->
        <ScrollView Grid.Row="1">
            <Frame
                Margin="20,-24,20,0"
                Padding="28,24"
                BackgroundColor="White"
                CornerRadius="20"
                HasShadow="True">
                <VerticalStackLayout Spacing="20">

                    <Label
                        FontAttributes="Bold"
                        FontSize="22"
                        Text="Sign In"
                        TextColor="#1e293b" />

                    <!--  Error banner  -->
                    <Frame
                        Padding="12,8"
                        BackgroundColor="#fef2f2"
                        BorderColor="#fecaca"
                        CornerRadius="10"
                        IsVisible="{Binding HasError}">
                        <Label
                            FontSize="13"
                            Text="{Binding ErrorMessage}"
                            TextColor="#ef4444" />
                    </Frame>

                    <!--  Email  -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="Email"
                            TextColor="#374151" />
                        <Frame
                            Padding="14,0"
                            BackgroundColor="#f8fafc"
                            BorderColor="#e2e8f0"
                            CornerRadius="12">
                            <Entry
                                BackgroundColor="Transparent"
                                Keyboard="Email"
                                Placeholder="you@example.com"
                                PlaceholderColor="#94a3b8"
                                ReturnType="Next"
                                Text="{Binding Email}"
                                TextColor="#1e293b" />
                        </Frame>
                    </VerticalStackLayout>

                    <!--  Password  -->
                    <VerticalStackLayout Spacing="6">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="Password"
                            TextColor="#374151" />
                        <Frame
                            Padding="14,0"
                            BackgroundColor="#f8fafc"
                            BorderColor="#e2e8f0"
                            CornerRadius="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry
                                    Grid.Column="0"
                                    BackgroundColor="Transparent"
                                    IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertBool}}"
                                    Placeholder="••••••••"
                                    PlaceholderColor="#94a3b8"
                                    ReturnType="Done"
                                    Text="{Binding Password}"
                                    TextColor="#1e293b" />
                                <ImageButton
                                    Grid.Column="1"
                                    Padding="4"
                                    BackgroundColor="Transparent"
                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                    HeightRequest="22"
                                    Source="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIcon}}"
                                    WidthRequest="22" />
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!--  Forgot password  -->
                    <Label HorizontalOptions="End">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span
                                    FontSize="13"
                                    Text="Forgot password?"
                                    TextColor="#2563eb"
                                    TextDecorations="Underline">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <!--  Sign In Button  -->
                    <Button
                        BackgroundColor="#2563eb"
                        Command="{Binding LoginCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="52"
                        Text="Sign In"
                        TextColor="White">
                        <Button.Triggers>
                            <DataTrigger
                                Binding="{Binding IsBusy}"
                                TargetType="Button"
                                Value="True">
                                <Setter Property="Text" Value="Signing in…" />
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!--  Loading  -->
                    <ActivityIndicator
                        HorizontalOptions="Center"
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="#2563eb" />

                </VerticalStackLayout>
            </Frame>
        </ScrollView>

        <!--  ── Footer ──  -->
        <Label
            Grid.Row="2"
            FontSize="12"
            HorizontalOptions="Center"
            Text="🔒 End-to-end encrypted"
            TextColor="#94a3b8"
            VerticalOptions="Center" />

    </Grid>
</views:ViewBase>
