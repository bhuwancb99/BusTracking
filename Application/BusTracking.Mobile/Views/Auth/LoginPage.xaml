<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:sfIndicator="clr-namespace:Syncfusion.Maui.Toolkit.ProgressBar;assembly=Syncfusion.Maui.Toolkit"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Auth"
    x:DataType="vm:LoginViewModel"
    x:TypeArguments="vm:LoginViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource LoginCardBgLight}, Dark={StaticResource LoginCardBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <ScrollView>
        <Grid RowDefinitions="Auto,*">

            <!--  ══════ ROW 0 — Dark hero header ══════  -->
            <VerticalStackLayout
                Grid.Row="0"
                Padding="28,56,28,40"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}"
                Spacing="0">

                <!--  SECURE pill  -->
                <Border
                    Margin="0,0,0,24"
                    Padding="14,7"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecurePillBgLight}, Dark={StaticResource SecurePillBgDark}}"
                    HorizontalOptions="Center"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20">
                    <HorizontalStackLayout Spacing="6">
                        <Image
                            HeightRequest="14"
                            HorizontalOptions="Center"
                            Source="lock.png"
                            VerticalOptions="Center"
                            WidthRequest="14">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource SecurePillTextLight}, Dark={StaticResource SecurePillTextDark}}" />
                            </Image.Behaviors>
                        </Image>
                        <Label
                            CharacterSpacing="1.5"
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="SECURE LOGIN"
                            TextColor="{AppThemeBinding Light={StaticResource SecurePillTextLight}, Dark={StaticResource SecurePillTextDark}}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!--  Bus icon with glow rings  -->
                <Grid
                    Margin="0,0,0,24"
                    HeightRequest="88"
                    HorizontalOptions="Center"
                    WidthRequest="88">
                    <Ellipse
                        Fill="{StaticResource Primary}"
                        HeightRequest="88"
                        Opacity="0.12"
                        WidthRequest="88" />
                    <Ellipse
                        Fill="{StaticResource Primary}"
                        HeightRequest="68"
                        HorizontalOptions="Center"
                        Opacity="0.18"
                        VerticalOptions="Center"
                        WidthRequest="68" />
                    <Border
                        BackgroundColor="{StaticResource PrimaryDark}"
                        HeightRequest="56"
                        HorizontalOptions="Center"
                        Stroke="White"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1.5"
                        VerticalOptions="Center"
                        WidthRequest="56">
                        <Image
                            HeightRequest="28"
                            HorizontalOptions="Center"
                            Source="bus.png"
                            VerticalOptions="Center"
                            WidthRequest="28">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="White" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                </Grid>

                <!--  App name  -->
                <Label
                    CharacterSpacing="3"
                    FontAttributes="Bold"
                    FontSize="28"
                    HorizontalOptions="Center"
                    Text="BUSTRACK"
                    TextColor="White" />

                <!--  Tagline  -->
                <Label
                    Margin="0,8,0,0"
                    FontSize="13"
                    HorizontalOptions="Center"
                    Text="Safe journeys, every day"
                    TextColor="{StaticResource HeroCardSubText}" />

            </VerticalStackLayout>

            <!--  ══════ ROW 1 — Card panel ══════  -->
            <Border
                Grid.Row="1"
                Padding="24,28,24,32"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginCardBgLight}, Dark={StaticResource LoginCardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28,28,0,0" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.18"
                        Radius="24"
                        Offset="0,-6" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!--  Welcome + key badge  -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout
                            Grid.Column="0"
                            Spacing="3"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="22"
                                Text="Welcome back"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                FontSize="13"
                                Text="Sign in to continue"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>

                        <Border
                            Grid.Column="1"
                            Padding="12,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource RoleBadgeBgLight}, Dark={StaticResource RoleBadgeBgDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource RoleBadgeBorderLight}, Dark={StaticResource RoleBadgeBorderDark}}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5"
                            VerticalOptions="Center">
                            <Image
                                HeightRequest="22"
                                HorizontalOptions="Center"
                                Source="key.png"
                                WidthRequest="22">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource RoleBadgeTextLight}, Dark={StaticResource RoleBadgeTextDark}}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                    </Grid>

                    <BoxView
                        Margin="0,16,0,22"
                        BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                        HeightRequest="1" />

                    <!--  Maintenance overlay  -->
                    <VerticalStackLayout
                        Padding="0,8"
                        IsVisible="{Binding IsMaintenanceMode}"
                        Spacing="14">
                        <Image
                            HeightRequest="64"
                            HorizontalOptions="Center"
                            Source="config.png"
                            WidthRequest="64">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{StaticResource Accent}" />
                            </Image.Behaviors>
                        </Image>
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            HorizontalOptions="Center"
                            Text="Under Maintenance"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="14"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="{Binding MaintenanceMessage}"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>

                    <!--  Login form  -->
                    <VerticalStackLayout IsVisible="{Binding IsMaintenanceMode, Converter={StaticResource InvertBool}}" Spacing="0">

                        <!--  Error banner  -->
                        <Border
                            Margin="0,0,0,16"
                            Padding="14,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                            IsVisible="{Binding HasError}"
                            Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="notification.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                    </Image.Behaviors>
                                </Image>
                                <Label
                                    Grid.Column="1"
                                    FontSize="13"
                                    Text="{Binding ErrorMessage}"
                                    TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight}, Dark={StaticResource ErrorTextDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  USERNAME label  -->
                        <Label
                            Margin="0,0,0,6"
                            CharacterSpacing="1"
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="USERNAME"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />

                        <!--  Email Entry  -->
                        <Border
                            Margin="0,0,0,18"
                            Padding="16,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LoginInputBgLight}, Dark={StaticResource LoginInputBgDark}}"
                            HeightRequest="52"
                            Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="user.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Entry
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    Keyboard="Default"
                                    Placeholder="Enter your username"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                                    ReturnType="Next"
                                    Text="{Binding UserName}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  PASSWORD label  -->
                        <Label
                            Margin="0,0,0,6"
                            CharacterSpacing="1"
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="PASSWORD"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />

                        <!--  Password Entry with eye icon  -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="16,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LoginInputBgLight}, Dark={StaticResource LoginInputBgDark}}"
                            HeightRequest="52"
                            Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="lock.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Entry
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    IsPassword="True"
                                    Placeholder="••••••••"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                                    ReturnType="Done"
                                    Text="{Binding Password}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Forgot password  -->
                        <Label Margin="0,0,0,26" HorizontalOptions="End">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span
                                        FontSize="13"
                                        Text="Forgot password?"
                                        TextColor="{AppThemeBinding Light={StaticResource TextLink}, Dark={StaticResource TextLinkDark}}">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <!--  Sign In button  -->
                        <Button
                            Margin="0,0,0,12"
                            BackgroundColor="{StaticResource Primary}"
                            BorderWidth="0"
                            Command="{Binding LoginCommand}"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="54"
                            Text="Sign In  →"
                            TextColor="White">
                            <Button.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsBusy}"
                                    TargetType="Button"
                                    Value="True">
                                    <Setter Property="Text" Value="Signing in…" />
                                    <Setter Property="IsEnabled" Value="False" />
                                    <Setter Property="Opacity" Value="0.7" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <!--  Progress bar  -->
                        <sfIndicator:SfLinearProgressBar
                            HeightRequest="3"
                            IsIndeterminate="True"
                            IsVisible="{Binding IsBusy}"
                            ProgressFill="{StaticResource Primary}"
                            TrackCornerRadius="2"
                            TrackFill="{AppThemeBinding Light={StaticResource LoginInputBorderLight}, Dark={StaticResource LoginInputBorderDark}}" />

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>

</views:ViewBase>
