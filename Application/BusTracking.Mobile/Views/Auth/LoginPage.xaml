<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Auth"
    x:DataType="vm:LoginViewModel"
    x:TypeArguments="vm:LoginViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource LoginPageBgLight},
                                      Dark={StaticResource LoginPageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <ScrollView>
        <Grid RowDefinitions="Auto,*">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" />
                    <GradientStop Offset="0.75" Color="{AppThemeBinding Light={StaticResource LoginCardBgLight}, Dark={StaticResource LoginCardBgDark}}" />
                </LinearGradientBrush>
            </Grid.Background>

            <!--  ══════ ROW 0 — Hero Header ══════  -->
            <VerticalStackLayout
                Grid.Row="0"
                Padding="24,48,24,36"
                Spacing="0">

                <!--  SECURE pill badge  -->
                <Border
                    Margin="0,0,0,24"
                    Padding="12,6"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecurePillBgLight},
                                                      Dark={StaticResource SecurePillBgDark}}"
                    HorizontalOptions="Center"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20">
                    <HorizontalStackLayout Spacing="6">
                        <Image
                            HeightRequest="12"
                            HorizontalOptions="Center"
                            Source="lock.png"
                            VerticalOptions="Center"
                            WidthRequest="12">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource SecurePillTextLight}, Dark={StaticResource SecurePillTextDark}}" />
                            </Image.Behaviors>
                        </Image>
                        <Label
                            CharacterSpacing="1"
                            FontAttributes="Bold"
                            FontSize="10"
                            Text="SECURE LOGIN"
                            TextColor="{AppThemeBinding Light={StaticResource SecurePillTextLight},
                                                        Dark={StaticResource SecurePillTextDark}}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!--  Logo with glowing rings  -->
                <Grid
                    Margin="0,0,0,20"
                    HeightRequest="96"
                    HorizontalOptions="Center"
                    WidthRequest="96">
                    <Ellipse
                        Fill="{StaticResource Primary}"
                        HeightRequest="96"
                        Opacity="0.08"
                        WidthRequest="96" />
                    <Ellipse
                        Fill="{StaticResource Primary}"
                        HeightRequest="76"
                        HorizontalOptions="Center"
                        Opacity="0.14"
                        VerticalOptions="Center"
                        WidthRequest="76" />
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                          Dark={StaticResource PrimaryDark}}"
                        HeightRequest="60"
                        HorizontalOptions="Center"
                        Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                 Dark=White}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        VerticalOptions="Center"
                        WidthRequest="60">
                        <Border.Shadow>
                            <Shadow
                                Brush="{StaticResource Primary}"
                                Opacity="0.3"
                                Radius="8"
                                Offset="0,4" />
                        </Border.Shadow>
                        <Image
                            HeightRequest="30"
                            HorizontalOptions="Center"
                            Source="bus.png"
                            VerticalOptions="Center"
                            WidthRequest="30">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource PrimaryButtonTextLight}, Dark={StaticResource PrimaryButtonTextDark}}" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                </Grid>

                <!--  App Name with custom spacing  -->
                <Label
                    CharacterSpacing="3"
                    FontAttributes="Bold"
                    FontSize="28"
                    HorizontalOptions="Center"
                    Text="BUSTRACK"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                Dark=White}" />

                <!--  Tagline  -->
                <Label
                    Margin="0,6,0,0"
                    FontSize="13"
                    HorizontalOptions="Center"
                    Text="Safe journeys, every day"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                Dark={StaticResource TextSecondaryDark}}" />

            </VerticalStackLayout>

            <!--  ══════ ROW 1 — Main Card Panel ══════  -->
            <Border
                Grid.Row="1"
                Padding="24,32,24,36"
                BackgroundColor="{AppThemeBinding Light={StaticResource LoginCardBgLight},
                                                  Dark={StaticResource LoginCardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight},
                                         Dark={StaticResource LoginInputBorderDark}}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28,28,0,0" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.1"
                        Radius="16"
                        Offset="0,-4" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!--  Welcome & Header details  -->
                    <Grid Margin="0,0,0,24" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout
                            Grid.Column="0"
                            Spacing="4"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="22"
                                Text="Welcome back"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                            <Label
                                FontSize="13"
                                Text="Sign in to continue"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>

                        <Border
                            Grid.Column="1"
                            Padding="12,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource RoleBadgeBgLight},
                                                              Dark={StaticResource RoleBadgeBgDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource RoleBadgeBorderLight},
                                                     Dark={StaticResource RoleBadgeBorderDark}}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1.5"
                            VerticalOptions="Center">
                            <Image
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                Source="key.png"
                                WidthRequest="20">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource RoleBadgeTextLight}, Dark={StaticResource RoleBadgeTextDark}}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                    </Grid>

                    <!--  Maintenance Mode Panel  -->
                    <VerticalStackLayout
                        Padding="0,16"
                        IsVisible="{Binding IsMaintenanceMode}"
                        Spacing="16">
                        <Image
                            HeightRequest="60"
                            HorizontalOptions="Center"
                            Source="config.png"
                            WidthRequest="60">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{StaticResource Accent}" />
                            </Image.Behaviors>
                        </Image>
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalOptions="Center"
                            Text="Under Maintenance"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="13"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="{Binding MaintenanceMessage}"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>

                    <!--  Login Form Section  -->
                    <VerticalStackLayout IsVisible="{Binding IsMaintenanceMode, Converter={StaticResource InvertBool}}" Spacing="0">

                        <!--  Error display box  -->
                        <Border
                            Margin="0,0,0,20"
                            Padding="14,12"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                              Dark={StaticResource ErrorBannerBgDark}}"
                            IsVisible="{Binding HasError}"
                            Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                                     Dark={StaticResource ErrorBannerBorderDark}}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="notification.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                    </Image.Behaviors>
                                </Image>
                                <Label
                                    Grid.Column="1"
                                    FontSize="13"
                                    Text="{Binding ErrorMessage}"
                                    TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                                                Dark={StaticResource ErrorTextDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Username label  -->
                        <Label
                            Margin="0,0,0,6"
                            CharacterSpacing="0.8"
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="USERNAME"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />

                        <!--  Username Input Box  -->
                        <Border
                            Margin="0,0,0,20"
                            Padding="16,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LoginInputBgLight},
                                                              Dark={StaticResource LoginInputBgDark}}"
                            HeightRequest="52"
                            Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight},
                                                     Dark={StaticResource LoginInputBorderDark}}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="user.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Entry
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    Keyboard="Default"
                                    Placeholder="Enter your username"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                       Dark={StaticResource TextMutedDark}}"
                                    ReturnType="Next"
                                    Text="{Binding UserName}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Password label  -->
                        <Label
                            Margin="0,0,0,6"
                            CharacterSpacing="0.8"
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="PASSWORD"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />

                        <!--  Password Input Box with eye toggle  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="16,0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource LoginInputBgLight},
                                                              Dark={StaticResource LoginInputBgDark}}"
                            HeightRequest="52"
                            Stroke="{AppThemeBinding Light={StaticResource LoginInputBorderLight},
                                                     Dark={StaticResource LoginInputBorderDark}}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Image
                                    Grid.Column="0"
                                    HeightRequest="16"
                                    Source="lock.png"
                                    VerticalOptions="Center"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Entry
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    HeightRequest="52"
                                    IsPassword="{Binding IsPasswordHidden}"
                                    Placeholder="••••••••"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                       Dark={StaticResource TextMutedDark}}"
                                    ReturnType="Done"
                                    Text="{Binding Password}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}"
                                    VerticalOptions="Center" />

                                <!--  Custom beautiful Eye toggle image  -->
                                <Image
                                    Grid.Column="2"
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="20">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                                    </Image.GestureRecognizers>
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                    </Image.Behaviors>
                                    <Image.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsPasswordVisible}"
                                            TargetType="Image"
                                            Value="False">
                                            <Setter Property="Source" Value="eye.png" />
                                        </DataTrigger>
                                        <DataTrigger
                                            Binding="{Binding IsPasswordVisible}"
                                            TargetType="Image"
                                            Value="True">
                                            <Setter Property="Source" Value="eye_slash.png" />
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>
                            </Grid>
                        </Border>

                        <!--  Forgot password text  -->
                        <Label Margin="0,0,0,28" HorizontalOptions="End">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span
                                        FontSize="13"
                                        Text="Forgot password?"
                                        TextColor="{AppThemeBinding Light={StaticResource TextLink},
                                                                    Dark={StaticResource TextLinkDark}}">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <!--  Sign In button  -->
                        <Button
                            Margin="0,0,0,12"
                            Command="{Binding LoginCommand}"
                            CornerRadius="12"
                            Style="{StaticResource LoginSignInButton}"
                            Text="Sign In  →">
                            <Button.Shadow>
                                <Shadow
                                    Brush="{StaticResource Primary}"
                                    Opacity="0.2"
                                    Radius="6"
                                    Offset="0,4" />
                            </Button.Shadow>
                            <Button.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsBusy}"
                                    TargetType="Button"
                                    Value="True">
                                    <Setter Property="Text" Value="Signing In..." />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</views:ViewBase>
