<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Auth.ChangePasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Auth"
    Title="Change Password"
    x:DataType="vm:ChangePasswordViewModel"
    x:TypeArguments="vm:ChangePasswordViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="16,24,16,32" Spacing="14">

            <!--  Header  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource NavBarBg}, Dark={StaticResource DrawerBgDark}}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0">
                <VerticalStackLayout Padding="20,18" Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="🔑 Change Password"
                        TextColor="White" />
                    <Label
                        FontSize="13"
                        Text="Choose a strong password with at least 6 characters."
                        TextColor="{StaticResource HeroCardSubText}" />
                </VerticalStackLayout>
            </Border>

            <!--  Error  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="1">
                <Label
                    Padding="12,10"
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Current Password  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Current Password"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Enter current password"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding CurrentPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  New Password  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="New Password"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Min. 6 characters"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding NewPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Confirm Password  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Confirm New Password"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Re-enter new password"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding ConfirmPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Submit  -->
            <Button
                Margin="0,8,0,0"
                BackgroundColor="{StaticResource Primary}"
                Command="{Binding SubmitCommand}"
                CornerRadius="14"
                FontAttributes="Bold"
                FontSize="16"
                HeightRequest="52"
                Text="Update Password"
                TextColor="White">
                <Button.Triggers>
                    <DataTrigger
                        Binding="{Binding IsBusy}"
                        TargetType="Button"
                        Value="True">
                        <Setter Property="Text" Value="Updating…" />
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>

</views:ViewBase>
