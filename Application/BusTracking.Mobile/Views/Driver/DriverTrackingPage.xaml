<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:driver="clr-namespace:BusTracking.Mobile.Models.Driver"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:sfBottomSheet="clr-namespace:Syncfusion.Maui.Toolkit.BottomSheet;assembly=Syncfusion.Maui.Toolkit"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:Name="PageRoot"
    Title="Live Tracking"
    x:DataType="vm:DriverTrackingViewModel"
    x:TypeArguments="vm:DriverTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <!--  Match status bar UI with all other app pages  -->
    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light=White, Dark={StaticResource PageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <!--  Top Navigation Header  -->
    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="Auto,*,Auto">
            <ImageButton
                Grid.Column="0"
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                HeightRequest="22"
                Source="back.png"
                VerticalOptions="Center"
                WidthRequest="22" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="17"
                HorizontalOptions="Center"
                Text="Live Tracking"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />

            <Button
                Grid.Column="2"
                BackgroundColor="{StaticResource Danger}"
                Command="{Binding EndTripCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                FontSize="12"
                HeightRequest="34"
                Text="End Trip"
                TextColor="White"
                VerticalOptions="Center"
                WidthRequest="80" />
        </Grid>
    </Shell.TitleView>

    <!--  Full-Screen Layout: Map fills space between header and fixed bottom bar  -->
    <Grid RowDefinitions="*,Auto">

        <!--  ROW 0 — Map occupies full screen between header & bottom bar  -->
        <Grid Grid.Row="0">
            <!--  Map WebView  -->
            <WebView
                x:Name="MapWebView"
                HorizontalOptions="Fill"
                Source="tracking_map.html"
                VerticalOptions="Fill" />

            <!--  Floating Top Speed/GPS Pill  -->
            <Border
                Margin="0,10,0,0"
                Padding="14,6"
                BackgroundColor="White"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Start">
                <Border.Shadow>
                    <Shadow
                        Brush="#30000000"
                        Radius="6"
                        Offset="0,2" />
                </Border.Shadow>
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Live"
                        TextColor="#1a1a2e"
                        VerticalOptions="Center" />
                    <Label
                        FontSize="12"
                        Text="•"
                        TextColor="#22c55e"
                        VerticalOptions="Center" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="{Binding GpsStatus}"
                        TextColor="#22c55e"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <!--  LOCATION PERMISSION BANNER  -->
            <Border
                Padding="16,14"
                BackgroundColor="#1a1a2e"
                IsVisible="{Binding ShowLocationBanner}"
                StrokeShape="RoundRectangle 20,20,0,0"
                StrokeThickness="0"
                VerticalOptions="End">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border
                        Grid.Column="0"
                        Padding="0"
                        BackgroundColor="#FF6B35"
                        HeightRequest="40"
                        StrokeShape="RoundRectangle 20"
                        WidthRequest="40">
                        <Image
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            Source="map_pin.svg"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                    </Border>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="Location not enabled"
                            TextColor="White" />
                        <Label
                            FontSize="11"
                            Text="Parents cannot see the bus without your location."
                            TextColor="#AAAACC" />
                    </VerticalStackLayout>

                    <Button
                        Grid.Column="2"
                        Padding="12,0"
                        BackgroundColor="#FF6B35"
                        Command="{Binding RequestLocationCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="12"
                        HeightRequest="38"
                        Text="{Binding LocationBannerButtonText}"
                        TextColor="White" />
                </Grid>
            </Border>
        </Grid>

        <!--  ROW 1 — Fixed Bottom Button Bar (Pinned at bottom of page)  -->
        <Border
            Grid.Row="1"
            Padding="16,12"
            BackgroundColor="{AppThemeBinding Light=White,
                                              Dark={StaticResource CardBgDark}}"
            StrokeShape="RoundRectangle 24,24,0,0"
            StrokeThickness="0"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="#40000000"
                    Radius="16"
                    Offset="0,-4" />
            </Border.Shadow>

            <Grid
                ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="10"
                VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleSheetCommand}" />
                </Grid.GestureRecognizers>

                <Label
                    Grid.Column="0"
                    FontAttributes="Bold"
                    FontSize="15"
                    Text="Trip Stops &amp; Students"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                Dark={StaticResource TextPrimaryDark}}"
                    VerticalOptions="Center" />

                <Border
                    Grid.Column="1"
                    Padding="10,4"
                    BackgroundColor="{StaticResource PrimaryLight}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="11"
                        Text="{Binding Stops.Count, StringFormat='Stops: {0}'}"
                        TextColor="{StaticResource Primary}" />
                </Border>

                <Image
                    Grid.Column="2"
                    HeightRequest="20"
                    Source="chevron_up.svg"
                    VerticalOptions="Center"
                    WidthRequest="20" />
            </Grid>
        </Border>

        <!--  SYNCFUSION BOTTOM SHEET (White header background & rounded top corners)  -->
        <sfBottomSheet:SfBottomSheet
            x:Name="StopsBottomSheet"
            Grid.RowSpan="2"
            Background="{AppThemeBinding Light=White,
                                         Dark={StaticResource CardBgDark}}"
            CornerRadius="24"
            FullExpandedRatio="0.88"
            HalfExpandedRatio="0.65"
            IsModal="False"
            IsOpen="{Binding IsSheetExpanded, Mode=TwoWay}">
            <sfBottomSheet:SfBottomSheet.BottomSheetContent>
                <Grid BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBgDark}}" RowDefinitions="Auto,*">

                    <!--  Top Header with Title, Badge & Small Close (X) Button  -->
                    <Grid
                        Grid.Row="0"
                        Padding="16,14"
                        BackgroundColor="{AppThemeBinding Light=White,
                                                          Dark={StaticResource CardBgDark}}"
                        ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="10">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Trip Stops &amp; Students"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}"
                            VerticalOptions="Center" />

                        <Border
                            Grid.Column="1"
                            Padding="10,4"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="{Binding Stops.Count, StringFormat='Stops: {0}'}"
                                TextColor="{StaticResource Primary}" />
                        </Border>

                        <!--  Small, clean close button  -->
                        <Border
                            Grid.Column="2"
                            Padding="6"
                            BackgroundColor="{AppThemeBinding Light=#F1F5F9,
                                                              Dark=#1E293B}"
                            HeightRequest="32"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="32">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleSheetCommand}" />
                            </Border.GestureRecognizers>
                            <Image
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                Source="close.svg"
                                VerticalOptions="Center"
                                WidthRequest="16" />
                        </Border>
                    </Grid>

                    <!--  Scrollable Content Inside Bottom Sheet  -->
                    <ScrollView Grid.Row="1" Padding="16,4,16,16">
                        <VerticalStackLayout Spacing="12">

                            <!--  Stops & Students Collection  -->
                            <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label
                                        Margin="0,20,0,0"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        Text="No stops found for this trip"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="driver:DriverTripStop">
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                                              Dark={StaticResource CardBgDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                                     Dark={StaticResource BorderColorDark}}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="1">

                                            <!--  Card layout with left status accent stripe  -->
                                            <Grid ColumnDefinitions="4,*">
                                                <!--  Left Accent Stripe  -->
                                                <BoxView
                                                    Grid.Column="0"
                                                    BackgroundColor="{Binding StatusColor}"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="Fill" />

                                                <!--  Card Content  -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Padding="12"
                                                    Spacing="10">

                                                    <!--  Stop Header  -->
                                                    <Grid
                                                        ColumnDefinitions="28,*,Auto"
                                                        ColumnSpacing="10"
                                                        VerticalOptions="Center">
                                                        <Border
                                                            Grid.Column="0"
                                                            Padding="0"
                                                            BackgroundColor="{Binding StatusColor}"
                                                            HeightRequest="28"
                                                            StrokeShape="RoundRectangle 8"
                                                            WidthRequest="28">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="12"
                                                                HorizontalOptions="Center"
                                                                Text="{Binding StopOrder}"
                                                                TextColor="White"
                                                                VerticalOptions="Center" />
                                                        </Border>

                                                        <VerticalStackLayout
                                                            Grid.Column="1"
                                                            Spacing="1"
                                                            VerticalOptions="Center">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="14"
                                                                Text="{Binding StopName}"
                                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                            Dark={StaticResource TextPrimaryDark}}" />
                                                            <Label
                                                                FontSize="11"
                                                                Text="{Binding StatusLabel}"
                                                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                                            Dark={StaticResource TextSecondaryDark}}" />
                                                        </VerticalStackLayout>

                                                        <!--  Status Pill Badge  -->
                                                        <Border
                                                            Grid.Column="2"
                                                            Padding="8,3"
                                                            BackgroundColor="{Binding StatusColor}"
                                                            StrokeShape="RoundRectangle 10"
                                                            StrokeThickness="0"
                                                            VerticalOptions="Center">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="10"
                                                                Text="{Binding Status}"
                                                                TextColor="White" />
                                                        </Border>
                                                    </Grid>

                                                    <!--  Action Buttons: Reached & Departed with Sequential Rule Enablement  -->
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                        <!--  Reached Button (Enabled ONLY if previous stop is completed)  -->
                                                        <Border
                                                            Grid.Column="0"
                                                            BackgroundColor="{StaticResource Primary}"
                                                            HeightRequest="36"
                                                            IsEnabled="{Binding CanMarkReached}"
                                                            Opacity="{Binding ReachedOpacity}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding BindingContext.MarkReachedCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                            <HorizontalStackLayout
                                                                HorizontalOptions="Center"
                                                                Spacing="6"
                                                                VerticalOptions="Center">
                                                                <Image
                                                                    HeightRequest="15"
                                                                    Source="reached.svg"
                                                                    VerticalOptions="Center"
                                                                    WidthRequest="15" />
                                                                <Label
                                                                    FontAttributes="Bold"
                                                                    FontSize="11"
                                                                    Text="Reached"
                                                                    TextColor="White"
                                                                    VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                        </Border>

                                                        <!--  Departed Button (Enabled ONLY if stop is Reached)  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            BackgroundColor="{StaticResource Success}"
                                                            HeightRequest="36"
                                                            IsEnabled="{Binding CanMarkDeparted}"
                                                            Opacity="{Binding DepartedOpacity}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding BindingContext.MarkDepartedCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                            <HorizontalStackLayout
                                                                HorizontalOptions="Center"
                                                                Spacing="6"
                                                                VerticalOptions="Center">
                                                                <Image
                                                                    HeightRequest="15"
                                                                    Source="departed.svg"
                                                                    VerticalOptions="Center"
                                                                    WidthRequest="15" />
                                                                <Label
                                                                    FontAttributes="Bold"
                                                                    FontSize="11"
                                                                    Text="Departed"
                                                                    TextColor="White"
                                                                    VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                        </Border>
                                                    </Grid>

                                                    <!--  Divider line  -->
                                                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />

                                                    <!--  Students Section Header  -->
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label
                                                            Grid.Column="0"
                                                            FontAttributes="Bold"
                                                            FontSize="12"
                                                            Text="Students"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                        Dark={StaticResource TextPrimaryDark}}" />
                                                        <Label
                                                            Grid.Column="1"
                                                            FontSize="11"
                                                            Text="{Binding Students.Count, StringFormat='Count: {0}'}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                        Dark={StaticResource TextSecondaryDark}}" />
                                                    </Grid>

                                                    <!--  Students List  -->
                                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Students}" Spacing="6">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="driver:DriverStudentStatus">
                                                                <Border
                                                                    Padding="10,6"
                                                                    BackgroundColor="{AppThemeBinding Light=White,
                                                                                                      Dark={StaticResource CardBgDark}}"
                                                                    Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                                                             Dark={StaticResource BorderColorDark}}"
                                                                    StrokeShape="RoundRectangle 8"
                                                                    StrokeThickness="1">
                                                                    <Grid
                                                                        ColumnDefinitions="Auto,*,Auto"
                                                                        ColumnSpacing="10"
                                                                        VerticalOptions="Center">
                                                                        <Border
                                                                            Grid.Column="0"
                                                                            Padding="6"
                                                                            BackgroundColor="{Binding BoardingColor}"
                                                                            HeightRequest="28"
                                                                            StrokeShape="RoundRectangle 6"
                                                                            VerticalOptions="Center"
                                                                            WidthRequest="28">
                                                                            <Image
                                                                                HeightRequest="16"
                                                                                HorizontalOptions="Center"
                                                                                Source="{Binding BoardingIcon}"
                                                                                VerticalOptions="Center"
                                                                                WidthRequest="16" />
                                                                        </Border>

                                                                        <VerticalStackLayout
                                                                            Grid.Column="1"
                                                                            Spacing="1"
                                                                            VerticalOptions="Center">
                                                                            <Label
                                                                                FontAttributes="Bold"
                                                                                FontSize="13"
                                                                                Text="{Binding StudentName}"
                                                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                                            Dark={StaticResource TextPrimaryDark}}" />
                                                                            <Label
                                                                                FontSize="11"
                                                                                Text="{Binding StudentCode, StringFormat='ID: {0}'}"
                                                                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                                            Dark={StaticResource TextSecondaryDark}}" />
                                                                        </VerticalStackLayout>

                                                                        <!--  Student Status Picker Dropdown  -->
                                                                        <Border
                                                                            Grid.Column="2"
                                                                            Padding="8,0"
                                                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC,
                                                                                                              Dark=#1E293B}"
                                                                            HeightRequest="42"
                                                                            Stroke="{Binding BoardingColor}"
                                                                            StrokeShape="RoundRectangle 8"
                                                                            StrokeThickness="1.5"
                                                                            VerticalOptions="Center"
                                                                            WidthRequest="135">
                                                                            <Picker
                                                                                Title="Status"
                                                                                BackgroundColor="Transparent"
                                                                                FontAttributes="Bold"
                                                                                FontSize="12"
                                                                                HeightRequest="42"
                                                                                HorizontalOptions="Fill"
                                                                                ItemsSource="{x:Static driver:DriverStudentStatus.StatusOptions}"
                                                                                SelectedItem="{Binding BoardingStatus, Mode=TwoWay}"
                                                                                TextColor="{Binding BoardingColor}"
                                                                                VerticalOptions="Center" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </VerticalStackLayout>

                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </sfBottomSheet:SfBottomSheet.BottomSheetContent>
        </sfBottomSheet:SfBottomSheet>

    </Grid>
</views:ViewBase>
