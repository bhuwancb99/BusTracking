<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:driver="clr-namespace:BusTracking.Mobile.Models.Driver"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    Title="Live Tracking"
    x:DataType="vm:DriverTrackingViewModel"
    x:TypeArguments="vm:DriverTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="Auto,*,Auto">
            <ImageButton
                Grid.Column="0"
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                Source="back.png"
                WidthRequest="22" />
            <VerticalStackLayout
                Grid.Column="1"
                HorizontalOptions="Center"
                Spacing="0"
                VerticalOptions="Center">
                <Label
                    FontAttributes="Bold"
                    FontSize="17"
                    HorizontalOptions="Center"
                    Text="Live Tracking"
                    TextColor="White" />
                <!--  GPS live status pill — hidden when location is not granted  -->
                <Label
                    FontSize="10"
                    HorizontalOptions="Center"
                    IsVisible="{Binding LocationGranted}"
                    Text="{Binding GpsStatus}"
                    TextColor="#90FFFFFF" />
            </VerticalStackLayout>
            <Button
                Grid.Column="2"
                BackgroundColor="{StaticResource DangerDark}"
                Command="{Binding EndTripCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                FontSize="12"
                HeightRequest="34"
                Text="End Trip"
                TextColor="White"
                WidthRequest="80" />
        </Grid>
    </Shell.TitleView>

    <!--  Root grid: rows = error banner | content | location banner  -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!--  Error banner  -->
        <Border
            Grid.Row="0"
            Margin="16,10,16,0"
            Padding="12,8"
            BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                              Dark={StaticResource ErrorBannerBgDark}}"
            IsVisible="{Binding HasError}"
            Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                     Dark={StaticResource ErrorBannerBorderDark}}"
            StrokeShape="RoundRectangle 10">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{StaticResource Danger}" />
        </Border>

        <!--  Stops + students list  -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadStopsCommand}"
            IsRefreshing="{Binding IsBusy}">
            <CollectionView
                Margin="16,12,16,32"
                ItemsSource="{Binding Stops}"
                SelectionMode="None">

                <CollectionView.EmptyView>
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No stops found for this trip"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                    Dark={StaticResource TextSecondaryDark}}"
                        VerticalOptions="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="driver:DriverTripStop">
                        <Border
                            Margin="0,0,0,14"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                              Dark={StaticResource CardBgDark}}"
                            StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Spacing="12">

                                <!--  Stop header  -->
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border
                                        Grid.Column="0"
                                        Padding="8"
                                        BackgroundColor="{Binding StatusColor}"
                                        HeightRequest="36"
                                        StrokeShape="RoundRectangle 10"
                                        WidthRequest="36">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            HorizontalOptions="Center"
                                            Text="{Binding StopOrder}"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Margin="10,0"
                                        Spacing="2">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding StopName}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                        Dark={StaticResource TextPrimaryDark}}" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding StatusLabel}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                        Dark={StaticResource TextSecondaryDark}}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!--  Stop action buttons  -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button
                                        Grid.Column="0"
                                        BackgroundColor="{StaticResource Primary}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=MarkReachedCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        HeightRequest="38"
                                        IsEnabled="{Binding Status, Converter={StaticResource EqualsToPending}}"
                                        Text="✅ Reached"
                                        TextColor="White" />
                                    <Button
                                        Grid.Column="1"
                                        BackgroundColor="{StaticResource Success}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=MarkDepartedCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        HeightRequest="38"
                                        IsEnabled="{Binding Status, Converter={StaticResource EqualsToReached}}"
                                        Text="🚌 Departed"
                                        TextColor="White" />
                                </Grid>

                                <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />

                                <!--  Student list  -->
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="Students"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}" />

                                <CollectionView
                                    HeightRequest="{Binding Students.Count, Converter={StaticResource CountToHeight}, ConverterParameter=60}"
                                    ItemsSource="{Binding Students}"
                                    SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="driver:DriverStudentStatus">
                                            <Grid
                                                Margin="0,0,0,8"
                                                ColumnDefinitions="Auto,*,Auto,Auto"
                                                ColumnSpacing="8">

                                                <Border
                                                    Grid.Column="0"
                                                    Padding="6"
                                                    BackgroundColor="{Binding BoardingColor}"
                                                    HeightRequest="32"
                                                    StrokeShape="RoundRectangle 8"
                                                    WidthRequest="32">
                                                    <Label
                                                        FontSize="14"
                                                        HorizontalOptions="Center"
                                                        Text="{Binding BoardingIcon}"
                                                        VerticalOptions="Center" />
                                                </Border>

                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Spacing="1"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="13"
                                                        Text="{Binding StudentName}"
                                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                    Dark={StaticResource TextPrimaryDark}}" />
                                                    <Label
                                                        FontSize="11"
                                                        Text="{Binding StudentCode}"
                                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                                </VerticalStackLayout>

                                                <Button
                                                    Grid.Column="2"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource StatusActiveBg},
                                                                                      Dark={StaticResource StatusActiveBgDark}}"
                                                    BorderColor="{StaticResource SuccessDark}"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=UpdateBoardingCommand}"
                                                    CommandParameter="{Binding ., Converter={StaticResource StudentPickedUpTuple}}"
                                                    CornerRadius="8"
                                                    FontSize="11"
                                                    HeightRequest="32"
                                                    IsVisible="{Binding IsUnavailable, Converter={StaticResource Invert}}"
                                                    Text="✅"
                                                    TextColor="{StaticResource Success}"
                                                    WidthRequest="40" />

                                                <Button
                                                    Grid.Column="3"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                                                      Dark={StaticResource ErrorBannerBgDark}}"
                                                    BorderColor="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                                                                  Dark={StaticResource ErrorBannerBorderDark}}"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=UpdateBoardingCommand}"
                                                    CommandParameter="{Binding ., Converter={StaticResource StudentNoShowTuple}}"
                                                    CornerRadius="8"
                                                    FontSize="11"
                                                    HeightRequest="32"
                                                    IsVisible="{Binding IsUnavailable, Converter={StaticResource Invert}}"
                                                    Text="❌"
                                                    TextColor="{StaticResource Danger}"
                                                    WidthRequest="40" />

                                                <Border
                                                    Grid.Column="2"
                                                    Grid.ColumnSpan="2"
                                                    Padding="8,4"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource WarningLight},
                                                                                      Dark={StaticResource StatCoordBgDark}}"
                                                    IsVisible="{Binding IsUnavailable}"
                                                    StrokeShape="RoundRectangle 8">
                                                    <Label
                                                        FontSize="11"
                                                        Text="📅 On Leave"
                                                        TextColor="{StaticResource AccentDark}" />
                                                </Border>

                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!--
            ═══════════════════════════════════════════════════════════════
            LOCATION PERMISSION BANNER — bottom of screen
            Visible whenever location is not granted.
            Same UX as Google Maps / Uber when location is off.
            ═══════════════════════════════════════════════════════════════
        -->
        <Border
            Grid.Row="2"
            Padding="16,14"
            BackgroundColor="#1a1a2e"
            IsVisible="{Binding ShowLocationBanner}"
            StrokeShape="RoundRectangle 20,20,0,0"
            StrokeThickness="0">
            <Border.Shadow>
                <Shadow
                    Brush="#40000000"
                    Radius="16"
                    Offset="0,-4" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                <!--  Warning icon  -->
                <Border
                    Grid.Column="0"
                    Padding="0"
                    BackgroundColor="#FF6B35"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    WidthRequest="40">
                    <Label
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="📍"
                        VerticalOptions="Center" />
                </Border>

                <!--  Message  -->
                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="2"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Location not enabled"
                        TextColor="White" />
                    <Label
                        FontSize="11"
                        Text="Parents cannot see the bus without your location."
                        TextColor="#AAAACC" />
                </VerticalStackLayout>

                <!--  Enable / Open Settings button  -->
                <Button
                    Grid.Column="2"
                    Padding="12,0"
                    BackgroundColor="#FF6B35"
                    Command="{Binding RequestLocationCommand}"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    FontSize="12"
                    HeightRequest="38"
                    Text="{Binding LocationBannerButtonText}"
                    TextColor="White" />
            </Grid>
        </Border>

    </Grid>
</views:ViewBase>
