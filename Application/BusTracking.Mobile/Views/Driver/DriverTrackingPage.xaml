<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:driver="clr-namespace:BusTracking.Mobile.Models.Driver"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:Name="PageRoot"
    Title="Live Tracking"
    x:DataType="vm:DriverTrackingViewModel"
    x:TypeArguments="vm:DriverTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <!--  Match status bar UI with all other app pages (White header background, Dark icons)  -->
    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light=White, Dark={StaticResource PageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <!--  Top Navigation Header: Live Tracking title center, End Trip button on far right end  -->
    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="Auto,*,Auto">
            <ImageButton
                Grid.Column="0"
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                HeightRequest="22"
                Source="back.png"
                VerticalOptions="Center"
                WidthRequest="22" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="17"
                HorizontalOptions="Center"
                Text="Live Tracking"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />

            <Button
                Grid.Column="2"
                BackgroundColor="{StaticResource Danger}"
                Command="{Binding EndTripCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                FontSize="12"
                HeightRequest="34"
                Text="End Trip"
                TextColor="White"
                VerticalOptions="Center"
                WidthRequest="80" />
        </Grid>
    </Shell.TitleView>

    <!--  Full-Screen Layered Grid  -->
    <Grid>

        <!--  ==============================================================  -->
        <!--  LAYER 1 — Full Screen Google Maps WebView  -->
        <!--  ==============================================================  -->
        <WebView
            x:Name="MapWebView"
            HorizontalOptions="Fill"
            Source="tracking_map.html"
            VerticalOptions="Fill" />

        <!--  ==============================================================  -->
        <!--  LAYER 2 — Floating Top Speed/GPS Pill (Positioned higher up)  -->
        <!--  ==============================================================  -->
        <Border
            Margin="0,10,0,0"
            Padding="14,6"
            BackgroundColor="White"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 20"
            StrokeThickness="0"
            VerticalOptions="Start">
            <Border.Shadow>
                <Shadow
                    Brush="#30000000"
                    Radius="6"
                    Offset="0,2" />
            </Border.Shadow>
            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="Live"
                    TextColor="#1a1a2e"
                    VerticalOptions="Center" />
                <Label
                    FontSize="12"
                    Text="•"
                    TextColor="#22c55e"
                    VerticalOptions="Center" />
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="{Binding GpsStatus}"
                    TextColor="#22c55e"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!--  ==============================================================  -->
        <!--  LAYER 3 — Bottom Flyout Sheet (Collapsible / Expandable)  -->
        <!--  Default: Collapsed at bottom. Tap header to expand.  -->
        <!--  ==============================================================  -->
        <Border
            Padding="0"
            BackgroundColor="{AppThemeBinding Light=White,
                                              Dark={StaticResource CardBgDark}}"
            StrokeShape="RoundRectangle 24,24,0,0"
            StrokeThickness="0"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="#40000000"
                    Radius="16"
                    Offset="0,-4" />
            </Border.Shadow>

            <VerticalStackLayout Padding="16,10,16,16" Spacing="8">

                <!--  Collapsible Header & Drag Handle Bar (Tapping toggles expand/collapse)  -->
                <VerticalStackLayout Spacing="6">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleSheetCommand}" />
                    </VerticalStackLayout.GestureRecognizers>

                    <!--  Drag Handle Bar  -->
                    <BoxView
                        Margin="0,0,0,4"
                        BackgroundColor="#cbd5e1"
                        CornerRadius="2"
                        HeightRequest="4"
                        HorizontalOptions="Center"
                        WidthRequest="40" />

                    <!--  Flyout Header: Title, Count Badge, Expand Toggle Icon  -->
                    <Grid
                        Margin="4,0"
                        ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="8">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Trip Stops &amp; Students"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}"
                            VerticalOptions="Center" />

                        <Border
                            Grid.Column="1"
                            Padding="8,3"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="{Binding Stops.Count, StringFormat='Stops: {0}'}"
                                TextColor="{StaticResource Primary}" />
                        </Border>

                        <!--  Expand / Collapse Indicator Icon  -->
                        <Border
                            Grid.Column="2"
                            Padding="8,3"
                            BackgroundColor="#EEF2FF"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="{Binding IsSheetExpanded, Converter={StaticResource StringToBool}, FallbackValue='▲ View Stops'}"
                                TextColor="{StaticResource Primary}">
                                <Label.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsSheetExpanded}"
                                        TargetType="Label"
                                        Value="True">
                                        <Setter Property="Text" Value="▼ Close" />
                                    </DataTrigger>
                                    <DataTrigger
                                        Binding="{Binding IsSheetExpanded}"
                                        TargetType="Label"
                                        Value="False">
                                        <Setter Property="Text" Value="▲ View Stops" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!--  Expanded Details Section (Visible ONLY when IsSheetExpanded is True)  -->
                <VerticalStackLayout
                    Margin="0,4,0,0"
                    IsVisible="{Binding IsSheetExpanded}"
                    Spacing="10">

                    <ScrollView HeightRequest="340">
                        <VerticalStackLayout Spacing="12">

                            <!--  Stops & Students Collection  -->
                            <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                                <CollectionView.EmptyView>
                                    <Label
                                        Margin="0,20,0,0"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        Text="No stops found for this trip"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="driver:DriverTripStop">
                                        <Border
                                            Margin="0,0,0,12"
                                            Padding="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                                              Dark={StaticResource CardBgDark}}"
                                            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                                     Dark={StaticResource BorderColorDark}}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="1">

                                            <!--  Card layout with left status accent stripe  -->
                                            <Grid ColumnDefinitions="4,*">
                                                <!--  Left Accent Stripe  -->
                                                <BoxView
                                                    Grid.Column="0"
                                                    BackgroundColor="{Binding StatusColor}"
                                                    HorizontalOptions="Fill"
                                                    VerticalOptions="Fill" />

                                                <!--  Card Content  -->
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Padding="12"
                                                    Spacing="10">

                                                    <!--  Stop Header  -->
                                                    <Grid
                                                        ColumnDefinitions="28,*,Auto"
                                                        ColumnSpacing="10"
                                                        VerticalOptions="Center">
                                                        <Border
                                                            Grid.Column="0"
                                                            Padding="0"
                                                            BackgroundColor="{Binding StatusColor}"
                                                            HeightRequest="28"
                                                            StrokeShape="RoundRectangle 8"
                                                            WidthRequest="28">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="12"
                                                                HorizontalOptions="Center"
                                                                Text="{Binding StopOrder}"
                                                                TextColor="White"
                                                                VerticalOptions="Center" />
                                                        </Border>

                                                        <VerticalStackLayout
                                                            Grid.Column="1"
                                                            Spacing="1"
                                                            VerticalOptions="Center">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="14"
                                                                Text="{Binding StopName}"
                                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                            Dark={StaticResource TextPrimaryDark}}" />
                                                            <Label
                                                                FontSize="11"
                                                                Text="{Binding StatusLabel}"
                                                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                                            Dark={StaticResource TextSecondaryDark}}" />
                                                        </VerticalStackLayout>

                                                        <!--  Status Pill Badge  -->
                                                        <Border
                                                            Grid.Column="2"
                                                            Padding="8,3"
                                                            BackgroundColor="{Binding StatusColor}"
                                                            StrokeShape="RoundRectangle 10"
                                                            StrokeThickness="0"
                                                            VerticalOptions="Center">
                                                            <Label
                                                                FontAttributes="Bold"
                                                                FontSize="10"
                                                                Text="{Binding Status}"
                                                                TextColor="White" />
                                                        </Border>
                                                    </Grid>

                                                    <!--  Action Buttons using SVG vector icons: Reached & Departed  -->
                                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                        <!--  Reached Button with reached.svg  -->
                                                        <Border
                                                            Grid.Column="0"
                                                            BackgroundColor="{StaticResource Primary}"
                                                            HeightRequest="36"
                                                            IsEnabled="{Binding Status, Converter={StaticResource EqualsToPending}}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding BindingContext.MarkReachedCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                            <HorizontalStackLayout
                                                                HorizontalOptions="Center"
                                                                Spacing="6"
                                                                VerticalOptions="Center">
                                                                <Image
                                                                    HeightRequest="15"
                                                                    Source="reached.svg"
                                                                    VerticalOptions="Center"
                                                                    WidthRequest="15" />
                                                                <Label
                                                                    FontAttributes="Bold"
                                                                    FontSize="11"
                                                                    Text="Reached"
                                                                    TextColor="White"
                                                                    VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                        </Border>

                                                        <!--  Departed Button with departed.svg  -->
                                                        <Border
                                                            Grid.Column="1"
                                                            BackgroundColor="{StaticResource Success}"
                                                            HeightRequest="36"
                                                            IsEnabled="{Binding Status, Converter={StaticResource EqualsToReached}}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding BindingContext.MarkDepartedCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                            </Border.GestureRecognizers>
                                                            <HorizontalStackLayout
                                                                HorizontalOptions="Center"
                                                                Spacing="6"
                                                                VerticalOptions="Center">
                                                                <Image
                                                                    HeightRequest="15"
                                                                    Source="departed.svg"
                                                                    VerticalOptions="Center"
                                                                    WidthRequest="15" />
                                                                <Label
                                                                    FontAttributes="Bold"
                                                                    FontSize="11"
                                                                    Text="Departed"
                                                                    TextColor="White"
                                                                    VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                        </Border>
                                                    </Grid>

                                                    <!--  Divider line  -->
                                                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />

                                                    <!--  Students Section Header  -->
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label
                                                            Grid.Column="0"
                                                            FontAttributes="Bold"
                                                            FontSize="12"
                                                            Text="Students"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                        Dark={StaticResource TextPrimaryDark}}" />
                                                        <Label
                                                            Grid.Column="1"
                                                            FontSize="11"
                                                            Text="{Binding Students.Count, StringFormat='Count: {0}'}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                        Dark={StaticResource TextSecondaryDark}}" />
                                                    </Grid>

                                                    <!--  Students List  -->
                                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Students}" Spacing="6">
                                                        <BindableLayout.ItemTemplate>
                                                            <DataTemplate x:DataType="driver:DriverStudentStatus">
                                                                <Border
                                                                    Padding="10,6"
                                                                    BackgroundColor="{AppThemeBinding Light=White,
                                                                                                      Dark={StaticResource CardBgDark}}"
                                                                    Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                                                             Dark={StaticResource BorderColorDark}}"
                                                                    StrokeShape="RoundRectangle 8"
                                                                    StrokeThickness="1">
                                                                    <Grid
                                                                        ColumnDefinitions="Auto,*,Auto"
                                                                        ColumnSpacing="10"
                                                                        VerticalOptions="Center">
                                                                        <Border
                                                                            Grid.Column="0"
                                                                            Padding="6"
                                                                            BackgroundColor="{Binding BoardingColor}"
                                                                            HeightRequest="28"
                                                                            StrokeShape="RoundRectangle 6"
                                                                            VerticalOptions="Center"
                                                                            WidthRequest="28">
                                                                            <Image
                                                                                HeightRequest="16"
                                                                                HorizontalOptions="Center"
                                                                                Source="{Binding BoardingIcon}"
                                                                                VerticalOptions="Center"
                                                                                WidthRequest="16" />
                                                                        </Border>

                                                                        <VerticalStackLayout
                                                                            Grid.Column="1"
                                                                            Spacing="1"
                                                                            VerticalOptions="Center">
                                                                            <Label
                                                                                FontAttributes="Bold"
                                                                                FontSize="13"
                                                                                Text="{Binding StudentName}"
                                                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                                            Dark={StaticResource TextPrimaryDark}}" />
                                                                            <Label
                                                                                FontSize="11"
                                                                                Text="{Binding StudentCode, StringFormat='ID: {0}'}"
                                                                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                                            Dark={StaticResource TextSecondaryDark}}" />
                                                                        </VerticalStackLayout>

                                                                        <!--  Student Status Picker Dropdown (matching website dropdown options: Pending, PickedUp, NoShow, OnLeave)  -->
                                                                        <Border
                                                                            Grid.Column="2"
                                                                            Padding="8,0"
                                                                            BackgroundColor="{AppThemeBinding Light=#F8FAFC,
                                                                                                              Dark=#1E293B}"
                                                                            HeightRequest="42"
                                                                            Stroke="{Binding BoardingColor}"
                                                                            StrokeShape="RoundRectangle 8"
                                                                            StrokeThickness="1.5"
                                                                            VerticalOptions="Center"
                                                                            WidthRequest="135">
                                                                            <Picker
                                                                                Title="Status"
                                                                                BackgroundColor="Transparent"
                                                                                FontAttributes="Bold"
                                                                                FontSize="12"
                                                                                HeightRequest="42"
                                                                                HorizontalOptions="Fill"
                                                                                ItemsSource="{x:Static driver:DriverStudentStatus.StatusOptions}"
                                                                                SelectedItem="{Binding BoardingStatus, Mode=TwoWay}"
                                                                                TextColor="{Binding BoardingColor}"
                                                                                VerticalOptions="Center" />
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </BindableLayout.ItemTemplate>
                                                    </VerticalStackLayout>

                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!--  ==============================================================  -->
        <!--  LOCATION PERMISSION BANNER  -->
        <!--  ==============================================================  -->
        <Border
            Padding="16,14"
            BackgroundColor="#1a1a2e"
            IsVisible="{Binding ShowLocationBanner}"
            StrokeShape="RoundRectangle 20,20,0,0"
            StrokeThickness="0"
            VerticalOptions="End">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border
                    Grid.Column="0"
                    Padding="0"
                    BackgroundColor="#FF6B35"
                    HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    WidthRequest="40">
                    <Image
                        HeightRequest="20"
                        HorizontalOptions="Center"
                        Source="map_pin.svg"
                        VerticalOptions="Center"
                        WidthRequest="20" />
                </Border>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="2"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Location not enabled"
                        TextColor="White" />
                    <Label
                        FontSize="11"
                        Text="Parents cannot see the bus without your location."
                        TextColor="#AAAACC" />
                </VerticalStackLayout>

                <Button
                    Grid.Column="2"
                    Padding="12,0"
                    BackgroundColor="#FF6B35"
                    Command="{Binding RequestLocationCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontSize="12"
                    HeightRequest="38"
                    Text="{Binding LocationBannerButtonText}"
                    TextColor="White" />
            </Grid>
        </Border>

    </Grid>
</views:ViewBase>
