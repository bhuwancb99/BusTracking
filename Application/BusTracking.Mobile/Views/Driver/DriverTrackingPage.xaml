<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:driver="clr-namespace:BusTracking.Mobile.Models.Driver"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    Title="Live Tracking"
    x:DataType="vm:DriverTrackingViewModel"
    x:TypeArguments="vm:DriverTrackingViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="Auto,*,Auto">
            <ImageButton
                Grid.Column="0"
                BackgroundColor="Transparent"
                Command="{Binding GoBackCommand}"
                Source="back.png"
                WidthRequest="22" />
            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="17"
                HorizontalOptions="Center"
                Text="Live Tracking"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="2"
                BackgroundColor="#dc2626"
                Command="{Binding EndTripCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                FontSize="12"
                HeightRequest="34"
                Text="End Trip"
                TextColor="White"
                WidthRequest="80" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!--  Error banner  -->
        <Border
            Grid.Row="0"
            Margin="16,10,16,0"
            Padding="12,8"
            BackgroundColor="#fef2f2"
            IsVisible="{Binding HasError}"
            Stroke="#fecaca"
            StrokeShape="RoundRectangle 10">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="#ef4444" />
        </Border>

        <!--  Stops + students  -->
        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadStopsCommand}"
            IsRefreshing="{Binding IsBusy}">

            <CollectionView
                Margin="16,12,16,32"
                ItemsSource="{Binding Stops}"
                SelectionMode="None">

                <CollectionView.EmptyView>
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No stops found for this trip"
                        TextColor="#94a3b8"
                        VerticalOptions="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="driver:DriverTripStop">
                        <Border
                            Margin="0,0,0,14"
                            Padding="16"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Spacing="12">

                                <!--  Stop header  -->
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border
                                        Grid.Column="0"
                                        Padding="8"
                                        BackgroundColor="{Binding StatusColor}"
                                        HeightRequest="36"
                                        StrokeShape="RoundRectangle 10"
                                        WidthRequest="36">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            HorizontalOptions="Center"
                                            Text="{Binding StopOrder}"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Margin="10,0"
                                        Spacing="2">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            Text="{Binding StopName}"
                                            TextColor="#1e293b" />
                                        <Label
                                            FontSize="12"
                                            Text="{Binding StatusLabel}"
                                            TextColor="#64748b" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!--  Stop action buttons  -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button
                                        Grid.Column="0"
                                        BackgroundColor="#1a73e8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=MarkReachedCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        HeightRequest="38"
                                        IsEnabled="{Binding Status, Converter={StaticResource EqualsToPending}}"
                                        Text="✅ Reached"
                                        TextColor="White" />
                                    <Button
                                        Grid.Column="1"
                                        BackgroundColor="#1e8e3e"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=MarkDepartedCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="10"
                                        FontAttributes="Bold"
                                        FontSize="12"
                                        HeightRequest="38"
                                        IsEnabled="{Binding Status, Converter={StaticResource EqualsToReached}}"
                                        Text="🚌 Departed"
                                        TextColor="White" />
                                </Grid>

                                <BoxView BackgroundColor="#f1f5f9" HeightRequest="1" />

                                <!--  Student list  -->
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="Students"
                                    TextColor="#374151" />

                                <CollectionView
                                    HeightRequest="{Binding Students.Count, Converter={StaticResource CountToHeight}, ConverterParameter=60}"
                                    ItemsSource="{Binding Students}"
                                    SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="driver:DriverStudentStatus">
                                            <Grid
                                                Margin="0,0,0,8"
                                                ColumnDefinitions="Auto,*,Auto,Auto"
                                                ColumnSpacing="8">

                                                <Border
                                                    Grid.Column="0"
                                                    Padding="6"
                                                    BackgroundColor="{Binding BoardingColor}"
                                                    HeightRequest="32"
                                                    StrokeShape="RoundRectangle 8"
                                                    WidthRequest="32">
                                                    <Label
                                                        FontSize="14"
                                                        HorizontalOptions="Center"
                                                        Text="{Binding BoardingIcon}"
                                                        VerticalOptions="Center" />
                                                </Border>

                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Spacing="1"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontSize="13"
                                                        Text="{Binding StudentName}"
                                                        TextColor="#1e293b" />
                                                    <Label
                                                        FontSize="11"
                                                        Text="{Binding StudentCode}"
                                                        TextColor="#94a3b8" />
                                                </VerticalStackLayout>

                                                <!--  PickedUp  -->
                                                <Button
                                                    Grid.Column="2"
                                                    BackgroundColor="#dcfce7"
                                                    BorderColor="#86efac"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=UpdateBoardingCommand}"
                                                    CommandParameter="{Binding ., Converter={StaticResource StudentPickedUpTuple}}"
                                                    CornerRadius="8"
                                                    FontSize="11"
                                                    HeightRequest="32"
                                                    IsVisible="{Binding IsUnavailable, Converter={StaticResource Invert}}"
                                                    Text="✅"
                                                    TextColor="#16a34a"
                                                    WidthRequest="40" />

                                                <!--  NoShow  -->
                                                <Button
                                                    Grid.Column="3"
                                                    BackgroundColor="#fef2f2"
                                                    BorderColor="#fecaca"
                                                    BorderWidth="1"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTrackingViewModel}}, Path=UpdateBoardingCommand}"
                                                    CommandParameter="{Binding ., Converter={StaticResource StudentNoShowTuple}}"
                                                    CornerRadius="8"
                                                    FontSize="11"
                                                    HeightRequest="32"
                                                    IsVisible="{Binding IsUnavailable, Converter={StaticResource Invert}}"
                                                    Text="❌"
                                                    TextColor="#ef4444"
                                                    WidthRequest="40" />

                                                <!--  On leave badge  -->
                                                <Border
                                                    Grid.Column="2"
                                                    Grid.ColumnSpan="2"
                                                    Padding="8,4"
                                                    BackgroundColor="#fff7ed"
                                                    IsVisible="{Binding IsUnavailable}"
                                                    StrokeShape="RoundRectangle 8">
                                                    <Label
                                                        FontSize="11"
                                                        Text="📅 On Leave"
                                                        TextColor="#d97706" />
                                                </Border>

                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>

</views:ViewBase>
