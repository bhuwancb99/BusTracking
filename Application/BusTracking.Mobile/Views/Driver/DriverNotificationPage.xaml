<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverNotificationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models.Driver"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:DataType="vm:DriverNotificationViewModel"
    x:TypeArguments="vm:DriverNotificationViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,10,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Notifications"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Command="{Binding MarkAllReadCommand}"
                FontSize="12"
                IsVisible="{Binding HasUnread}"
                Style="{StaticResource OutlineButtonSmall}"
                Text="Mark All Read"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!--  Error Banner  -->
        <Border
            Grid.Row="0"
            Margin="5,8"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>

        <!--  Busy / Empty / List  -->
        

        <!--  Empty State  -->
        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="12"
            VerticalOptions="Center">
            <Image
                HeightRequest="72"
                HorizontalOptions="Center"
                Source="bell.png"
                WidthRequest="72">
                <Image.Behaviors>
                    <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                </Image.Behaviors>
            </Image>
            <Label
                FontSize="15"
                HorizontalOptions="Center"
                Text="No notifications"
                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                            Dark={StaticResource TextMutedDark}}" />
        </VerticalStackLayout>

        <!--  Notification List  -->
        <CollectionView
            Grid.Row="1"
            IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}"
            ItemsSource="{Binding Items}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout ItemSpacing="0" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:DriverNotificationItem">
                    <Grid>
                        <Border
                            Margin="5,2.5"
                            Padding="14,12"
                            BackgroundColor="{Binding BgColor}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow
                                    Brush="{AppThemeBinding Light=#0F000000,
                                                            Dark=#3F000000}"
                                    Radius="4"
                                    Offset="0,1" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                <!--  Unread dot  -->
                                <Ellipse
                                    Grid.Column="0"
                                    Fill="{StaticResource Primary}"
                                    HeightRequest="8"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding IsRead, Converter={StaticResource InvertBoolConverter}}"
                                    VerticalOptions="Center"
                                    WidthRequest="8" />

                                <!--  Content  -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="{Binding Title}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                    Dark={StaticResource TextPrimaryDark}}" />
                                    <Label
                                        FontSize="13"
                                        MaxLines="2"
                                        Text="{Binding Body}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextMutedDark}}" />
                                    <Label
                                        FontSize="11"
                                        Text="{Binding TimeDisplay}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextMutedDark}}" />
                                </VerticalStackLayout>

                                <!--  Mark Read button  -->
                                <ImageButton
                                    Grid.Column="2"
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverNotificationViewModel}}, Path=MarkReadCommand}"
                                    CommandParameter="{Binding .}"
                                    HeightRequest="30"
                                    IsVisible="{Binding IsRead, Converter={StaticResource InvertBoolConverter}}"
                                    Source="check.png"
                                    VerticalOptions="Start"
                                    WidthRequest="30">
                                    <ImageButton.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </ImageButton.Behaviors>
                                </ImageButton>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</views:ViewBase>
