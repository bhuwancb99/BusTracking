<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTripDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:DataType="vm:DriverTripDetailViewModel"
    x:TypeArguments="vm:DriverTripDetailViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">
        

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

                <!--  Error  -->
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                    IsVisible="{Binding HasError}"
                    Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                    StrokeShape="RoundRectangle 8">
                    <Label
                        Padding="12,10"
                        FontSize="13"
                        Text="{Binding ErrorMessage}"
                        TextColor="{StaticResource Danger}" />
                </Border>

                <!--  Trip Summary Card  -->
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1">
                    <VerticalStackLayout Padding="16" Spacing="6">
                        <Label
                            Margin="0,0,0,8"
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Trip Information"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Trip ID"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripId, StringFormat='#{0}'}"
                                TextColor="{StaticResource Primary}" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Type"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripType}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Date"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripDate}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Bus"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.BusName}"
                                TextColor="{StaticResource Info}" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Route"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.RouteName}"
                                TextColor="{StaticResource Purple}" />
                        </Grid>
                        <!--  Status badge  -->
                        <Border
                            Margin="0,8,0,0"
                            Padding="10,5"
                            BackgroundColor="{Binding Trip.StatusColor}"
                            HorizontalOptions="Start"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0">
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="{Binding Trip.Status}"
                                TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!--  Action Buttons  -->
                <Grid
                    Margin="0,4,0,0"
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Success}"
                        Command="{Binding StartTripCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="? Start"
                        TextColor="White" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{StaticResource Danger}"
                        Command="{Binding CancelTripCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="? Cancel"
                        TextColor="White" />
                    <Button
                        Grid.Column="2"
                        BackgroundColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                        Command="{Binding EndTripCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="¦ End"
                        TextColor="White" />
                </Grid>

                <!--  Stops & Students  -->
                <Label
                    Margin="0,8,0,4"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Stops &amp; Students"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label
                            Margin="0,20"
                            HorizontalOptions="Center"
                            Text="No stops loaded"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Driver.DriverTripStop">
                            <Border
                                Margin="0,0,0,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="10">
                                    <!--  Stop header  -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Border
                                            BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg}, Dark={StaticResource StatBusBgDark}}"
                                            HeightRequest="32"
                                            StrokeShape="RoundRectangle 16"
                                            StrokeThickness="0"
                                            WidthRequest="32">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                HorizontalOptions="Center"
                                                Text="{Binding StopOrder}"
                                                TextColor="{StaticResource Primary}"
                                                VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                Text="{Binding StopName}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                            <Label
                                                FontSize="11"
                                                Text="{Binding PickupTime}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                    <!--  Student row  -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                Text="{Binding StudentName}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                            <Label
                                                FontSize="11"
                                                Text="{Binding StudentCode}"
                                                TextColor="{StaticResource Purple}" />
                                        </VerticalStackLayout>
                                        <Border
                                            Grid.Column="1"
                                            Padding="10,6"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="0">
                                            <Border.BackgroundColor>
                                                <Binding Path="IsBoarded">
                                                    <Binding.Converter>
                                                        <StaticResource Key="BoolToStatusColor" />
                                                    </Binding.Converter>
                                                </Binding>
                                            </Border.BackgroundColor>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTripDetailViewModel}}, Path=ToggleBoardingCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="11"
                                                Text="{Binding BoardingLabel}"
                                                TextColor="White" />
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</views:ViewBase>
