<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTripDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:DataType="vm:DriverTripDetailViewModel"
    x:TypeArguments="vm:DriverTripDetailViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">
        <ActivityIndicator
            Grid.Row="0"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="#2563eb" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

                <!--  Error  -->
                <Border
                    BackgroundColor="#fef2f2"
                    IsVisible="{Binding HasError}"
                    Stroke="#fecaca"
                    StrokeShape="RoundRectangle 10">
                    <Label
                        Padding="12,10"
                        FontSize="13"
                        Text="{Binding ErrorMessage}"
                        TextColor="#ef4444" />
                </Border>

                <!--  Trip Summary Card  -->
                <Border
                    BackgroundColor="White"
                    Stroke="#e2e8f0"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1">
                    <VerticalStackLayout Padding="16" Spacing="6">
                        <Label
                            Margin="0,0,0,8"
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Trip Information"
                            TextColor="#1e293b" />
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Trip ID"
                                TextColor="#64748b" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripId, StringFormat='#{0}'}"
                                TextColor="#2563eb" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Type"
                                TextColor="#64748b" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripType}"
                                TextColor="#1e293b" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Date"
                                TextColor="#64748b" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.TripDate}"
                                TextColor="#1e293b" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Bus"
                                TextColor="#64748b" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.BusName}"
                                TextColor="#0891b2" />
                        </Grid>
                        <Grid Padding="0,5" ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="Route"
                                TextColor="#64748b" />
                            <Label
                                Grid.Column="1"
                                FontSize="13"
                                Text="{Binding Trip.RouteName}"
                                TextColor="#7c3aed" />
                        </Grid>
                        <!--  Status badge  -->
                        <Border
                            Margin="0,8,0,0"
                            Padding="10,5"
                            BackgroundColor="{Binding Trip.StatusColor}"
                            HorizontalOptions="Start"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0">
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="{Binding Trip.Status}"
                                TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!--  Action Buttons  -->
                <Grid
                    Margin="0,4,0,0"
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="#059669"
                        Command="{Binding StartTripCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="▶ Start"
                        TextColor="White" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="#ef4444"
                        Command="{Binding CancelTripCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="✕ Cancel"
                        TextColor="White" />
                    <Button
                        Grid.Column="2"
                        BackgroundColor="#64748b"
                        Command="{Binding EndTripCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Text="■ End"
                        TextColor="White" />
                </Grid>

                <!--  Stops & Students  -->
                <Label
                    Margin="0,8,0,4"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Stops &amp; Students"
                    TextColor="#1e293b" />
                <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label
                            Margin="0,20"
                            HorizontalOptions="Center"
                            Text="No stops loaded"
                            TextColor="#94a3b8" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Driver.DriverTripStop">
                            <Border
                                Margin="0,0,0,10"
                                BackgroundColor="White"
                                Stroke="#e2e8f0"
                                StrokeShape="RoundRectangle 14"
                                StrokeThickness="1">
                                <VerticalStackLayout Padding="16" Spacing="10">
                                    <!--  Stop header  -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Border
                                            BackgroundColor="#eff6ff"
                                            HeightRequest="32"
                                            StrokeShape="RoundRectangle 16"
                                            StrokeThickness="0"
                                            WidthRequest="32">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                HorizontalOptions="Center"
                                                Text="{Binding StopOrder}"
                                                TextColor="#2563eb"
                                                VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Spacing="2">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="14"
                                                Text="{Binding StopName}"
                                                TextColor="#1e293b" />
                                            <Label
                                                FontSize="11"
                                                Text="{Binding PickupTime}"
                                                TextColor="#64748b" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                    <!--  Student row  -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                Text="{Binding StudentName}"
                                                TextColor="#1e293b" />
                                            <Label
                                                FontSize="11"
                                                Text="{Binding StudentCode}"
                                                TextColor="#7c3aed" />
                                        </VerticalStackLayout>
                                        <Border
                                            Grid.Column="1"
                                            Padding="10,6"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="0">
                                            <Border.BackgroundColor>
                                                <Binding Path="IsBoarded">
                                                    <Binding.Converter>
                                                        <StaticResource Key="BoolToStatusColor" />
                                                    </Binding.Converter>
                                                </Binding>
                                            </Border.BackgroundColor>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTripDetailViewModel}}, Path=ToggleBoardingCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="11"
                                                Text="{Binding BoardingLabel}"
                                                TextColor="White" />
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</views:ViewBase>
