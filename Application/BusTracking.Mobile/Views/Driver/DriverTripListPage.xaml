<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverTripListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    x:DataType="vm:DriverTripListViewModel"
    x:TypeArguments="vm:DriverTripListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,10,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="My Trips"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!--  Header & Search Bar  -->
        <VerticalStackLayout Grid.Row="0" Spacing="0">
            <Border
                Margin="12,12,12,6"
                Style="{StaticResource SearchBarBorder}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                    <Image
                        Grid.Column="0"
                        HeightRequest="18"
                        Source="search.png"
                        VerticalOptions="Center"
                        WidthRequest="18">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                        </Image.Behaviors>
                    </Image>
                    <Entry
                        Grid.Column="1"
                        Placeholder="{Binding SearchPlaceholder}"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                           Dark={StaticResource TextMutedDark}}"
                        ReturnCommand="{Binding SearchCommand}"
                        Text="{Binding SearchText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <ImageButton
                        Grid.Column="2"
                        Padding="8"
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding SearchCommand}"
                        CornerRadius="8"
                        HeightRequest="36"
                        HorizontalOptions="End"
                        Source="search.png"
                        WidthRequest="36">
                        <ImageButton.Behaviors>
                            <mct:IconTintColorBehavior TintColor="White" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </Grid>
            </Border>

            <!--  Error Banner  -->
            <Border
                Margin="12,0,12,6"
                IsVisible="{Binding HasError}"
                Style="{StaticResource ErrorBannerBorder}">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                                Dark={StaticResource ErrorTextDark}}" />
            </Border>
        </VerticalStackLayout>

        <!--  Content Area (List or Empty State)  -->
        <Grid Grid.Row="1">

            <!--  Empty View  -->
            <VerticalStackLayout
                HorizontalOptions="Center"
                IsVisible="{Binding IsEmpty}"
                Spacing="14"
                VerticalOptions="Center">
                <Border
                    BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                      Dark={StaticResource StatTripBgDark}}"
                    HeightRequest="72"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 36"
                    StrokeThickness="0"
                    WidthRequest="72">
                    <Image
                        HeightRequest="36"
                        HorizontalOptions="Center"
                        Source="trip.png"
                        VerticalOptions="Center"
                        WidthRequest="36">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                        </Image.Behaviors>
                    </Image>
                </Border>
                <Label
                    FontSize="16"
                    HorizontalOptions="Center"
                    Text="No trips assigned"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                Dark={StaticResource TextSecondaryDark}}" />
            </VerticalStackLayout>

            <!--  Trips List  -->
            <RefreshView
                Margin="12,0,12,12"
                Command="{Binding RefreshCommand}"
                IsRefreshing="{Binding IsRefreshing}">
                <CollectionView
                    ItemsSource="{Binding Items}"
                    RemainingItemsThreshold="3"
                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                    SelectionMode="None"
                    VerticalOptions="Start">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout ItemSpacing="10" Orientation="Vertical" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Driver.DriverTripItem">
                            <Border Style="{StaticResource ListItemBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverTripListViewModel}}, Path=ViewCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid
                                    Padding="14"
                                    ColumnDefinitions="Auto,*,Auto"
                                    ColumnSpacing="12">
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                                          Dark={StaticResource StatTripBgDark}}"
                                        Style="{StaticResource IconTileBorder}"
                                        VerticalOptions="Center">
                                        <Image
                                            HeightRequest="22"
                                            HorizontalOptions="Center"
                                            Source="trip.png"
                                            VerticalOptions="Center"
                                            WidthRequest="22">
                                            <Image.Behaviors>
                                                <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                            </Image.Behaviors>
                                        </Image>
                                    </Border>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="4"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="15"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                        Dark={StaticResource TextPrimaryDark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding TripTypeIcon}" />
                                                    <Span Text=" " />
                                                    <Span FontAttributes="Bold" Text="{Binding TripType}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label
                                            FontSize="12"
                                            Text="{Binding TripDate}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                        Dark={StaticResource TextSecondaryDark}}" />
                                        <Label FontSize="11" TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span
                                                        FontAttributes="Bold"
                                                        Text="{Binding BusName}"
                                                        TextColor="{StaticResource Primary}" />
                                                    <Span Text=" · " />
                                                    <Span Text="{Binding RouteName}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>
                                    <Border
                                        Grid.Column="2"
                                        Padding="8,4"
                                        BackgroundColor="{Binding StatusColor, Converter={StaticResource ColorToTranslucentConverter}}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 20"
                                        VerticalOptions="Start">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="10"
                                            Text="{Binding Status}"
                                            TextColor="{Binding StatusColor}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.Footer>
                        <ActivityIndicator
                            Margin="0,8"
                            IsRunning="{Binding CanLoadMore}"
                            IsVisible="{Binding CanLoadMore}" />
                    </CollectionView.Footer>
                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</views:ViewBase>