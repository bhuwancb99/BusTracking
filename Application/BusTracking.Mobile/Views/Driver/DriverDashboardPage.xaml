<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    Title="Driver Dashboard"
    x:DataType="vm:DriverDashboardViewModel"
    x:TypeArguments="vm:DriverDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,10,0">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="Driver Portal"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="16,20,16,40" Spacing="20">

                <!--  Welcome  -->
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource HeadingLabel}" Text="{Binding WelcomeText}" />
                    <Label Style="{StaticResource SubLabel}" Text="{Binding TodayDate}" />
                </VerticalStackLayout>

                <!--  Bus / Route card  -->
                <Border Style="{StaticResource StatCardBorder}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DrawerItemActiveLight}, Dark=#0c1f4e}" />
                            <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Padding="4,2" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout
                            Grid.Column="0"
                            Spacing="6"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="MY BUS"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                Text="{Binding BusDisplay}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark=White}" />
                            <Label
                                FontSize="13"
                                Text="{Binding RouteDisplay, StringFormat='Route: {0}'}"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                            <BoxView
                                Margin="0,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor},
                                                                  Dark={StaticResource BorderColorDark}}"
                                HeightRequest="1" />
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Image
                                    HeightRequest="16"
                                    Source="student.png"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </Image.Behaviors>
                                </Image>
                                <Label FontSize="12" TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span
                                                FontAttributes="Bold"
                                                Text="{Binding TotalStudents}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                            Dark=White}" />
                                            <Span Text=" students on route" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Border
                            Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                              Dark={StaticResource StatBusBgDark}}"
                            HeightRequest="56"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="56">
                            <Image
                                HeightRequest="26"
                                HorizontalOptions="Center"
                                Source="bus.png"
                                VerticalOptions="Center"
                                WidthRequest="26">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                    </Grid>
                </Border>

                <!--  Active trip card  -->
                <Border IsVisible="{Binding ActiveTrip}" Style="{StaticResource StatCardBorder}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource SuccessLight}, Dark=#032314}" />
                            <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="12">
                        <Grid Padding="4,2" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="6"
                                VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Border
                                        Padding="6,3"
                                        BackgroundColor="{StaticResource Success}"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="9"
                                            Text="ASSIGNED TRIP"
                                            TextColor="White" />
                                    </Border>
                                    <Label
                                        Style="{StaticResource CaptionLabel}"
                                        Text="Today's Trip"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding ActiveTrip.TripType, StringFormat='Type: {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark=White}" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding ActiveTrip.TripDate, StringFormat='Date: {0}'}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                Dark={StaticResource TextSecondaryDark}}" />
                            </VerticalStackLayout>
                            <Border
                                Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                                  Dark={StaticResource StatTripBgDark}}"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="56">
                                <Image
                                    HeightRequest="26"
                                    HorizontalOptions="Center"
                                    Source="trip.png"
                                    VerticalOptions="Center"
                                    WidthRequest="26">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Success}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                        </Grid>

                        <!--  Error banner  -->
                        <Border
                            Padding="12,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                              Dark={StaticResource ErrorBannerBgDark}}"
                            IsVisible="{Binding HasError}"
                            Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                                     Dark={StaticResource ErrorBannerBorderDark}}"
                            StrokeShape="RoundRectangle 8">
                            <Label
                                FontSize="12"
                                Text="{Binding ErrorMessage}"
                                TextColor="{StaticResource Danger}" />
                        </Border>

                        <!--  Start button  -->
                        <Button
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding StartActiveTripCommand}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            IsVisible="{Binding ActiveTrip.CanStart}"
                            Text="Start Trip"
                            TextColor="White" />

                        <!--  Go to tracking button  -->
                        <Button
                            BackgroundColor="{StaticResource Success}"
                            Command="{Binding GoToActiveTrackingCommand}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            IsVisible="{Binding HasActiveTrip}"
                            Text="Live Tracking"
                            TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!--  No trip placeholder  -->
                <Border IsVisible="{Binding ActiveTrip, Converter={StaticResource NullToVisible}}" Style="{StaticResource StatCardBorder}">
                    <VerticalStackLayout
                        Padding="10"
                        HorizontalOptions="Center"
                        Spacing="10">
                        <Border
                            BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                                              Dark={StaticResource PageBgDark}}"
                            HeightRequest="48"
                            HorizontalOptions="Center"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            WidthRequest="48">
                            <Image
                                HeightRequest="22"
                                HorizontalOptions="Center"
                                Source="trip.png"
                                VerticalOptions="Center"
                                WidthRequest="22">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                        <Label
                            FontAttributes="Italic"
                            FontSize="14"
                            HorizontalOptions="Center"
                            Text="No trip scheduled for today"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </Border>

                <!--  View all trips  -->
                <Button
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                      Dark={StaticResource CardBgDark}}"
                    BorderColor="{StaticResource Primary}"
                    BorderWidth="1.5"
                    Command="{Binding ViewTripsCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="View All Trips"
                    TextColor="{StaticResource Primary}" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
