<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Driver.DriverDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Driver"
    Title="Driver Dashboard"
    x:DataType="vm:DriverDashboardViewModel"
    x:TypeArguments="vm:DriverDashboardViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Driver Portal"
                TextColor="White"
                VerticalOptions="Center" />
            <ImageButton
                Grid.Column="1"
                BackgroundColor="Transparent"
                Command="{Binding LogoutCommand}"
                Source="logout.png"
                WidthRequest="22" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="16">

                <!--  Welcome  -->
                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding WelcomeText}"
                    TextColor="#1e293b" />

                <!--  Bus / Route card  -->
                <Border
                    Padding="20"
                    BackgroundColor="#1e3a5f"
                    Shadow="True"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="MY BUS"
                            TextColor="#93c5fd" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="{Binding BusDisplay}"
                            TextColor="White" />
                        <Label
                            FontSize="14"
                            Text="{Binding RouteDisplay}"
                            TextColor="#93c5fd" />
                        <BoxView
                            Margin="0,4"
                            BackgroundColor="#ffffff22"
                            HeightRequest="1" />
                        <Label FontSize="13" TextColor="#cbd5e1">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="👥 " />
                                    <Span
                                        FontAttributes="Bold"
                                        Text="{Binding TotalStudents}"
                                        TextColor="White" />
                                    <Span Text=" students on route" TextColor="#cbd5e1" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!--  Active trip card  -->
                <Border
                    Padding="20"
                    BackgroundColor="White"
                    IsVisible="{Binding ActiveTrip, Converter={StaticResource NotNull}}"
                    Shadow="True"
                    StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="🚌 Today's Trip"
                            TextColor="#1e293b" />

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label
                                    FontSize="13"
                                    Text="{Binding ActiveTrip.TripType, StringFormat='Type: {0}'}"
                                    TextColor="#64748b" />
                                <Label
                                    FontSize="13"
                                    Text="{Binding ActiveTrip.TripDate, StringFormat='Date: {0}'}"
                                    TextColor="#64748b" />
                            </VerticalStackLayout>
                            <Border
                                Grid.Column="1"
                                Padding="10,4"
                                BackgroundColor="{Binding ActiveTrip.StatusColor}"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding ActiveTrip.Status}"
                                    TextColor="White" />
                            </Border>
                        </Grid>

                        <!--  Error banner  -->
                        <Border
                            Padding="10,6"
                            BackgroundColor="#fef2f2"
                            IsVisible="{Binding HasError}"
                            Stroke="#fecaca"
                            StrokeShape="RoundRectangle 8">
                            <Label
                                FontSize="12"
                                Text="{Binding ErrorMessage}"
                                TextColor="#ef4444" />
                        </Border>

                        <!--  Start button  -->
                        <Button
                            BackgroundColor="#2563eb"
                            Command="{Binding StartActiveTripCommand}"
                            CornerRadius="12"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            IsVisible="{Binding ActiveTrip.CanStart}"
                            Text="▶  Start Trip"
                            TextColor="White" />

                        <!--  Go to tracking button  -->
                        <Button
                            BackgroundColor="#16a34a"
                            Command="{Binding GoToActiveTrackingCommand}"
                            CornerRadius="12"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            IsVisible="{Binding HasActiveTrip}"
                            Text="📍 Live Tracking"
                            TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!--  No trip placeholder  -->
                <Border
                    Padding="20"
                    BackgroundColor="White"
                    IsVisible="{Binding ActiveTrip, Converter={StaticResource IsNull}}"
                    StrokeShape="RoundRectangle 16">
                    <Label
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="No trip scheduled for today"
                        TextColor="#94a3b8" />
                </Border>

                <!--  View all trips  -->
                <Button
                    BackgroundColor="White"
                    BorderColor="#2563eb"
                    BorderWidth="1.5"
                    Command="{Binding ViewTripsCommand}"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="📋 View All Trips"
                    TextColor="#2563eb" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
