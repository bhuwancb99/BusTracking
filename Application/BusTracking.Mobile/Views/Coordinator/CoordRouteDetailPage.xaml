<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordRouteDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordRouteDetailViewModel"
    x:TypeArguments="vm:CoordRouteDetailViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>


    <Shell.TitleView>
        <Grid
            Padding="0,0,8,0"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="8">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Route Details"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="12,6"
                BackgroundColor="White"
                Command="{Binding EditCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanEdit}"
                Text="Edit"
                TextColor="{StaticResource Primary}" />
            <Button
                Grid.Column="2"
                Padding="12,6"
                BackgroundColor="{StaticResource Danger}"
                Command="{Binding DeleteCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanDelete}"
                Text="Delete"
                TextColor="White" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                Color="{StaticResource Primary}" />

            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        Padding="14"
                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg}, Dark={StaticResource StatBusBgDark}}"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="60">
                        <Label
                            FontSize="26"
                            HorizontalOptions="Center"
                            Text="🗺️"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Route.RouteName}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="13"
                            Text="{Binding Route.RouteCode}"
                            TextColor="{StaticResource Primary}" />
                        <Label
                            FontSize="12"
                            Text="{Binding Route.TimingDisplay}"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Stops  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Label>
                        <Label.FormattedText>
                            <FormattedString>
                                <Span
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="Stops  "
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                <Span
                                    FontSize="13"
                                    Text="{Binding Route.StopCount, StringFormat='({0})'}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                FontSize="13"
                                HorizontalOptions="Center"
                                Text="No stops"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Route.StopItem">
                                <Grid
                                    Padding="0,8"
                                    ColumnDefinitions="32,*,Auto"
                                    ColumnSpacing="10">
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{StaticResource Primary}"
                                        HeightRequest="28"
                                        StrokeShape="RoundRectangle 14"
                                        WidthRequest="28">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            HorizontalOptions="Center"
                                            Text="{Binding StopOrder}"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </Border>
                                    <Label
                                        Grid.Column="1"
                                        FontSize="14"
                                        Text="{Binding StopName}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="2"
                                        FontSize="12"
                                        Text="{Binding MorningTime}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
