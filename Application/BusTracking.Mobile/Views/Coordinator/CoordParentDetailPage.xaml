<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordParentDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordParentDetailViewModel"
    x:TypeArguments="vm:CoordParentDetailViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid
            Padding="0,0,8,0"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="8">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Parent Details"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="7"
                BackgroundColor="White"
                IsVisible="{Binding CanEdit}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="edit.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Border
                Grid.Column="2"
                Padding="7"
                BackgroundColor="{StaticResource Danger}"
                IsVisible="{Binding CanDelete}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="delete.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="White" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            

            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                  Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                         Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 8">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Success}"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 30"
                        WidthRequest="60">
                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="{Binding Parent.InitialsDisplay}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryButtonTextLight}, Dark={StaticResource PrimaryButtonTextDark}}"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Parent.FullName}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="13"
                            Text="{Binding Parent.Email}"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                        <Label
                            FontSize="13"
                            Text="{Binding Parent.ChildrenLabel}"
                            TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Info  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Contact"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontSize="11"
                            Text="PHONE"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="{Binding Parent.PhoneNumber}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Linked students  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Linked Students"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <CollectionView ItemsSource="{Binding Parent.Students}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                FontSize="13"
                                HorizontalOptions="Center"
                                Text="No students linked"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Parent.LinkedStudent">
                                <Border
                                    Margin="0,3"
                                    Padding="12,8"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                                                      Dark={StaticResource CardBgDark}}"
                                    Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                             Dark={StaticResource BorderColorDark}}"
                                    StrokeShape="RoundRectangle 8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Grid.Column="0"
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            Text="{Binding FullName}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                        Dark={StaticResource TextPrimaryDark}}" />
                                        <Label
                                            Grid.Column="1"
                                            FontSize="12"
                                            Text="{Binding StudentCode}"
                                            TextColor="{StaticResource Primary}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
