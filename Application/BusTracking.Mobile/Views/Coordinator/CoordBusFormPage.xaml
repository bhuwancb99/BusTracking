<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordBusFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordBusFormViewModel"
    x:TypeArguments="vm:CoordBusFormViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

            <!--  Error  -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Bus Name  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Bus Name *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="e.g. Red Falcon"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding BusName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Bus Number  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Bus Number *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="e.g. MH-01-1234"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding BusNumber}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Capacity  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Capacity"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Numeric"
                        Placeholder="e.g. 40"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding Capacity}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Route  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Route"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding RouteName}"
                        ItemsSource="{Binding RouteOptions}"
                        SelectedItem="{Binding SelectedRoute}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                        TitleColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Active toggle  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14">
                <Grid Padding="16" ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Active"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                        VerticalOptions="Center" />
                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsActive}"
                        OnColor="{StaticResource Primary}" />
                </Grid>
            </Border>

            <!--  Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="White"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SaveCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Saving…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Update Bus" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Add Bus" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
