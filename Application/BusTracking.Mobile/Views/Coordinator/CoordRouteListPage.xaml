<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordRouteListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordRouteListViewModel"
    x:TypeArguments="vm:CoordRouteListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Routes"
                TextColor="White"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8"
                BackgroundColor="White"
                IsVisible="{Binding CanAdd}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="20"
                    Source="add.png"
                    WidthRequest="20">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Status filter + Search (one row)  -->
        <Grid
            Grid.Row="0"
            Margin="14,12,14,4"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">

            <!--  Status filter, bordered  -->
            <Border
                Grid.Column="0"
                Padding="10,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                HeightRequest="52"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="1.5"
                VerticalOptions="Center"
                WidthRequest="118">
                <Picker
                    Title="Status"
                    BackgroundColor="Transparent"
                    FontSize="13"
                    ItemsSource="{Binding StatusOptions}"
                    SelectedItem="{Binding SelectedStatus}"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                Dark={StaticResource TextPrimaryDark}}"
                    VerticalOptions="Center" />
            </Border>

            <!--  Search  -->
            <Border Grid.Column="1" Style="{StaticResource SearchBarBorder}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                    <Image
                        Grid.Column="0"
                        HeightRequest="18"
                        Source="search.png"
                        VerticalOptions="Center"
                        WidthRequest="18">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                        </Image.Behaviors>
                    </Image>
                    <Entry
                        Grid.Column="1"
                        Placeholder="{Binding SearchPlaceholder}"
                        ReturnCommand="{Binding SearchCommand}"
                        Text="{Binding SearchText}" />
                    <ImageButton
                        Grid.Column="2"
                        Padding="8"
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding SearchCommand}"
                        CornerRadius="10"
                        HeightRequest="36"
                        HorizontalOptions="End"
                        Source="search.png"
                        WidthRequest="36">
                        <ImageButton.Behaviors>
                            <mct:IconTintColorBehavior TintColor="White" />
                        </ImageButton.Behaviors>
                    </ImageButton>
                </Grid>
            </Border>
        </Grid>

        <!--  Error  -->
        <Border
            Grid.Row="1"
            Margin="14,0"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>
        <!--  Busy  -->
        <ActivityIndicator
            Grid.Row="2"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />

        <!--  Empty  -->
        <VerticalStackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="14"
            VerticalOptions="Center">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                  Dark={StaticResource StatBusBgDark}}"
                HeightRequest="72"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 36"
                StrokeThickness="0"
                WidthRequest="72">
                <Image
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Source="route.png"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No routes found"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />
            <Button
                Padding="24,0"
                Command="{Binding AddCommand}"
                HorizontalOptions="Center"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource PrimaryButton}"
                Text="+ Add Route" />
        </VerticalStackLayout>

        <!--  List  -->
        <CollectionView
            Grid.Row="2"
            Margin="14,4,14,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,60"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="🗺️" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No routes found"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Route.RouteItem">
                    <Border Style="{StaticResource ListItemBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordRouteListViewModel}}, Path=DetailCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                Style="{StaticResource IconTileBorder}"
                                VerticalOptions="Center">
                                <Image
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="route.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="4"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    Text="{Binding RouteName}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}" />
                                <Label FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span
                                                FontAttributes="Bold"
                                                Text="{Binding RouteCode}"
                                                TextColor="{StaticResource Primary}" />
                                            <Span Text=" · " TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            <Span Text="{Binding TimingDisplay}" TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label
                                    FontSize="11"
                                    Text="{Binding StopCount}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="8"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusBgColor}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding StatusLabel}"
                                        TextColor="{Binding StatusTextColor}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <ActivityIndicator
                    Margin="0,8"
                    IsRunning="{Binding CanLoadMore}"
                    IsVisible="{Binding CanLoadMore}" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</views:ViewBase>