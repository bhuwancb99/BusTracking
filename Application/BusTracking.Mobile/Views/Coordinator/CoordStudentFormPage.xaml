<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordStudentFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordStudentFormViewModel"
    x:TypeArguments="vm:CoordStudentFormViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 8">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Full Name  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Full Name *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="Student's full name"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding FullName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Username (required, used for login)  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Username *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                        Keyboard="Default"
                        Placeholder="Enter unique username"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding UserName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontAttributes="Italic"
                        FontSize="12"
                        IsVisible="{Binding UsernameMessage, Converter={StaticResource StringToBool}}"
                        Text="{Binding UsernameMessage}"
                        TextColor="{Binding UsernameMessageColor}" />
                </VerticalStackLayout>
            </Border>

            <!--  Password (Add only)  -->
            <Border
                BackgroundColor="White"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Password *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Initial password"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding Password}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  EMAIL (Optional)  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="EMAIL (Optional)"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Email"
                        Placeholder="Enter email address"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                        Text="{Binding Email}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  NEW PASSWORD  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                IsVisible="{Binding IsEditMode}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="NEW PASSWORD"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Default"
                        Placeholder="Leave blank to keep current password"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                        IsPassword="True"
                        Text="{Binding NewPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontAttributes="Italic"
                        FontSize="11"
                        Text="Leave blank to keep current password"
                        TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Border>

            <!--  Phone  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Phone"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Telephone"
                        Placeholder="+91 00000 00000"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding PhoneNumber}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Standard/Class  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Standard / Class"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="e.g. Grade 5"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding Standard}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Bus  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Bus"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding BusName}"
                        ItemsSource="{Binding BusOptions}"
                        SelectedItem="{Binding SelectedBus}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                        TitleColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Stop  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Stop"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding StopName}"
                        ItemsSource="{Binding StopOptions}"
                        SelectedItem="{Binding SelectedStop}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                        TitleColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Active  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 8">
                <Grid Padding="16" ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Active"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                        VerticalOptions="Center" />
                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsActive}"
                        OnColor="{StaticResource Primary}" />
                </Grid>
            </Border>

            <!--  Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="White"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SaveCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Saving…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Update Student" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Add Student" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
