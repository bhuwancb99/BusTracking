<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordinatorDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordinatorDashboardViewModel"
    x:TypeArguments="vm:CoordinatorDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="Bus Coordinator"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="0">

                <!--  Welcome  -->
                <Label
                    Margin="0,0,0,4"
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding WelcomeText}"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                <Label
                    Margin="0,0,0,20"
                    FontSize="13"
                    Text="Coordinator Dashboard"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />

                <!--  Stats (only show if user has permission to view that data)  -->
                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="12"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="12">

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowBuses}"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToBusesCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="🚌" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="26"
                                Text="{Binding Summary.TotalBuses}"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                FontSize="12"
                                Text="Buses"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowStudents}"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToStudentsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="🎒" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="26"
                                Text="{Binding Summary.TotalStudents}"
                                TextColor="{StaticResource Purple}" />
                            <Label
                                FontSize="12"
                                Text="Students"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowTrips}"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTripsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="📍" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="26"
                                Text="{Binding Summary.ActiveTrips}"
                                TextColor="{StaticResource DangerDark}" />
                            <Label
                                FontSize="12"
                                Text="Active Trips"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowParents}"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToParentsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="👨‍👩‍👧" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="26"
                                Text="{Binding Summary.TotalParents}"
                                TextColor="{StaticResource Success}" />
                            <Label
                                FontSize="12"
                                Text="Parents"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!--  Permission-gated nav menu  -->
                <Label
                    Margin="0,24,0,12"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Manage"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

                <FlexLayout
                    AlignItems="Start"
                    JustifyContent="Start"
                    Wrap="Wrap">

                    <Border
                        Margin="0,0,10,10"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowRoutes}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRoutesCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label FontSize="18" Text="🗺️" />
                            <Label
                                FontSize="14"
                                Text="Routes"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border
                        Margin="0,0,10,10"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowDrivers}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToDriversCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label FontSize="18" Text="🧑‍✈️" />
                            <Label
                                FontSize="14"
                                Text="Drivers"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border
                        Margin="0,0,10,10"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowStudents}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToStudentsCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label FontSize="18" Text="🎒" />
                            <Label
                                FontSize="14"
                                Text="Students"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border
                        Margin="0,0,10,10"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowParents}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToParentsCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label FontSize="18" Text="👨‍👩‍👧" />
                            <Label
                                FontSize="14"
                                Text="Parents"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border
                        Margin="0,0,10,10"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        IsVisible="{Binding ShowTrips}"
                        StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTripsCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label FontSize="18" Text="📍" />
                            <Label
                                FontSize="14"
                                Text="Trips"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </FlexLayout>

                <!--  Quick Actions  -->
                <Label
                    Margin="0,8,0,12"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Quick Actions"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

                <VerticalStackLayout Spacing="10">
                    <Button
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding GoToTripsCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        IsVisible="{Binding CanCreateTrip}"
                        Text="+ Create Trip"
                        TextColor="White" />
                    <Button
                        BackgroundColor="{StaticResource Purple}"
                        Command="{Binding GoToStudentsCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        IsVisible="{Binding CanAddStudent}"
                        Text="+ Add Student"
                        TextColor="White" />
                    <Button
                        BackgroundColor="{StaticResource Success}"
                        Command="{Binding GoToBusesCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        IsVisible="{Binding CanAddBus}"
                        Text="+ Add Bus"
                        TextColor="White" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
