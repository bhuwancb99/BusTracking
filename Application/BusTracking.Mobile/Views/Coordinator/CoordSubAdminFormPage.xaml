<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordSubAdminFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordSubAdminFormViewModel"
    x:TypeArguments="vm:CoordSubAdminFormViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

            <!--  Error  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                  Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                         Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="1">
                <Label
                    Padding="12,10"
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Full Name  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Full Name *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="Enter full name"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                           Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding FullName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Email (create only)  -->
            <Border
                BackgroundColor="White"
                
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Username *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Default"
                        Placeholder="Enter unique username"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                           Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding UserName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontAttributes="Italic"
                        FontSize="12"
                        IsVisible="{Binding UsernameMessage, Converter={StaticResource StringToBool}}"
                        Text="{Binding UsernameMessage}"
                        TextColor="{Binding UsernameMessageColor}" />
                </VerticalStackLayout>
            </Border>

            <!--  EMAIL (Optional)  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="EMAIL (Optional)"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Email"
                        Placeholder="Enter email address"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                        Text="{Binding Email}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  NEW PASSWORD  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                IsVisible="{Binding IsEditMode}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="NEW PASSWORD"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Default"
                        Placeholder="Leave blank to keep current password"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}"
                        IsPassword="True"
                        Text="{Binding NewPassword}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontAttributes="Italic"
                        FontSize="11"
                        Text="Leave blank to keep current password"
                        TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Border>

            <!--  Password (create only)  -->
            <Border
                BackgroundColor="White"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertBool}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Password *"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Min. 6 characters"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                           Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding Password}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Phone  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Phone Number"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Telephone"
                        Placeholder="+91 XXXXX XXXXX"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                           Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding PhoneNumber}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Is Active  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <Grid Padding="16" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Active Account"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="12"
                            Text="Inactive coordinators cannot login"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsActive}"
                        OnColor="{StaticResource Primary}"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--  Permissions  -->
            <Label
                Margin="0,8,0,0"
                FontAttributes="Bold"
                FontSize="16"
                Text="Assign Permissions"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark={StaticResource TextPrimaryDark}}" />
            <Label
                Margin="0,0,0,4"
                FontSize="13"
                Text="Select what this bus coordinators can access and manage."
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />

            <CollectionView ItemsSource="{Binding PermissionGroups}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Permission.PermissionGroup">
                        <Border
                            Margin="0,0,0,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                              Dark={StaticResource CardBgDark}}"
                            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                                     Dark={StaticResource BorderColorDark}}"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1">
                            <VerticalStackLayout Padding="16" Spacing="0">

                                <!--  Module header  -->
                                <Grid Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                                    <Label
                                        Grid.Column="0"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="{Binding ModuleName}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                    Dark={StaticResource TextPrimaryDark}}"
                                        VerticalOptions="Center" />
                                    <Button
                                        Grid.Column="1"
                                        Padding="12,4"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                          Dark={StaticResource StatBusBgDark}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordSubAdminFormViewModel}}, Path=ToggleAllInGroupCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="8"
                                        FontSize="12"
                                        HeightRequest="32"
                                        Text="All"
                                        TextColor="{StaticResource Primary}" />
                                </Grid>

                                <BoxView
                                    Margin="0,0,0,10"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg},
                                                                      Dark={StaticResource StatusInactiveBgDark}}"
                                    HeightRequest="1" />

                                <CollectionView ItemsSource="{Binding Permissions}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Coordinator.PermissionItem">
                                            <Grid
                                                Padding="0,6"
                                                ColumnDefinitions="Auto,*"
                                                ColumnSpacing="12">
                                                <CheckBox
                                                    Grid.Column="0"
                                                    IsChecked="{Binding IsSelected}"
                                                    Color="{StaticResource Primary}" />
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Spacing="2"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontSize="13"
                                                        Text="{Binding Description}"
                                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                    Dark={StaticResource TextPrimaryDark}}" />
                                                    <Label
                                                        FontFamily="Monospace"
                                                        FontSize="10"
                                                        Text="{Binding Key}"
                                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--  New password (after reset)  -->
            <Border
                BackgroundColor="#fffbeb"
                IsVisible="{Binding ShowNewPassword}"
                Stroke="#fde68a"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="1">
                <VerticalStackLayout Padding="14" Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="New Password — copy now"
                        TextColor="#92400e" />
                    <Label
                        FontAttributes="Bold"
                        FontFamily="Monospace"
                        FontSize="18"
                        Text="{Binding NewPassword}"
                        TextColor="#b45309" />
                    <Label
                        FontSize="11"
                        Text="This password will not be shown again."
                        TextColor="#92400e" />
                </VerticalStackLayout>
            </Border>

            <!--  Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="White"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderColor},
                                                  Dark={StaticResource BorderColorDark}}"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                Dark={StaticResource TextSecondaryDark}}" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SaveCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Saving…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Update" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Create" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <!--  Reset Password (edit only)  -->
            <Button
                BackgroundColor="Transparent"
                BorderColor="{StaticResource Danger}"
                BorderWidth="1.5"
                Command="{Binding ResetPasswordCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="46"
                IsVisible="{Binding IsEditMode}"
                Text="Reset Password"
                TextColor="{StaticResource Danger}" />

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
