<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordSubAdminListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordSubAdminListViewModel"
    x:TypeArguments="vm:CoordSubAdminListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Bus Coordinators"
                TextColor="White"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8"
                BackgroundColor="White"
                IsVisible="{Binding CanAdd}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="20"
                    Source="add.png"
                    WidthRequest="20">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Search  -->
        <Border
            Grid.Row="0"
            Margin="14,12,14,4"
            Style="{StaticResource SearchBarBorder}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <Image
                    Grid.Column="0"
                    HeightRequest="18"
                    Source="search.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                    </Image.Behaviors>
                </Image>
                <Entry
                    Grid.Column="1"
                    Placeholder="{Binding SearchPlaceholder}"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}" />
                <ImageButton
                    Grid.Column="2"
                    Padding="8"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SearchCommand}"
                    CornerRadius="10"
                    HeightRequest="36"
                    HorizontalOptions="End"
                    Source="search.png"
                    WidthRequest="36">
                    <ImageButton.Behaviors>
                        <mct:IconTintColorBehavior TintColor="White" />
                    </ImageButton.Behaviors>
                </ImageButton>
            </Grid>
        </Border>

        <!--  Error  -->
        <Border
            Grid.Row="1"
            Margin="14,0"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>

        <ActivityIndicator
            Grid.Row="2"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />

        <!--  Empty state  -->
        <VerticalStackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="14"
            VerticalOptions="Center">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                  Dark={StaticResource StatBusBgDark}}"
                HeightRequest="72"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 36"
                StrokeThickness="0"
                WidthRequest="72">
                <Image
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Source="coordinator.png"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No bus coordinators found"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />
            <Button
                Padding="24,0"
                Command="{Binding AddCommand}"
                HorizontalOptions="Center"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource PrimaryButton}"
                Text="+ Add Bus Coordinator" />
        </VerticalStackLayout>

        <!--  List  -->
        <CollectionView
            Grid.Row="2"
            Margin="14,4,14,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Coordinator.CoordinatorItem">
                    <Border Style="{StaticResource ListItemBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordSubAdminListViewModel}}, Path=DetailCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <!--  Avatar  -->
                            <Border
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                Style="{StaticResource IconTileBorder}"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding InitialsDisplay}"
                                    TextColor="{StaticResource Primary}"
                                    VerticalOptions="Center" />
                            </Border>

                            <!--  Info  -->
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding FullName}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}" />
                                <Label Style="{StaticResource SubLabel}" Text="{Binding Email}" />
                                <Label Style="{StaticResource SubLabel}" Text="{Binding PermCount}" />
                            </VerticalStackLayout>

                            <!--  Status badge  -->
                            <Border
                                Grid.Column="2"
                                Padding="8,3"
                                BackgroundColor="{Binding StatusBgColor}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="{Binding StatusLabel}"
                                    TextColor="{Binding StatusTextColor}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</views:ViewBase>
