<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordConfigListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordConfigListViewModel"
    x:TypeArguments="vm:CoordConfigListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="App Config"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8"
                BackgroundColor="White"
                IsVisible="{Binding CanAdd}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="20"
                    Source="add.png"
                    WidthRequest="20">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Search Section Card (Separated from list)  -->
        <Border
            Grid.Row="0"
            Margin="5,14,5,8"
            Padding="14,12"
            Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}">
            <VerticalStackLayout Spacing="10">
                <Border Style="{StaticResource SearchBarBorder}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                        <Image
                            Grid.Column="0"
                            HeightRequest="18"
                            Source="search.png"
                            VerticalOptions="Center"
                            WidthRequest="18">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                            </Image.Behaviors>
                        </Image>
                        <Entry
                            Grid.Column="1"
                            Placeholder="{Binding SearchPlaceholder}"
                            ReturnCommand="{Binding SearchCommand}"
                            Text="{Binding SearchText}" />
                        <ImageButton
                            Grid.Column="2"
                            Padding="8"
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding SearchCommand}"
                            CornerRadius="8"
                            HeightRequest="36"
                            HorizontalOptions="End"
                            Source="search.png"
                            WidthRequest="36">
                            <ImageButton.Behaviors>
                                <mct:IconTintColorBehavior TintColor="White" />
                            </ImageButton.Behaviors>
                        </ImageButton>
                    </Grid>
                </Border>

                <!--  Platform filter chips  -->
                <HorizontalStackLayout Spacing="8">
                    <Border
                        Padding="14,6"
                        BackgroundColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Web'}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Web" />
                        </Border.GestureRecognizers>
                        <Label
                            FontSize="12"
                            Text="Web"
                            TextColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Web'}" />
                    </Border>
                    <Border
                        Padding="14,6"
                        BackgroundColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Mobile'}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Mobile" />
                        </Border.GestureRecognizers>
                        <Label
                            FontSize="12"
                            Text="Mobile"
                            TextColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Mobile'}" />
                    </Border>
                    <Border
                        Padding="14,6"
                        BackgroundColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Both'}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Both" />
                        </Border.GestureRecognizers>
                        <Label
                            FontSize="12"
                            Text="Both"
                            TextColor="{Binding SelectedPlatform, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Both'}" />
                    </Border>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!--  Error  -->
        <Border
            Grid.Row="1"
            Margin="14,4"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>

        

        <!--  Empty State (Row 2)  -->
        <VerticalStackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="14"
            VerticalOptions="Center">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource StatBusBgDark}}"
                HeightRequest="72"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 36"
                StrokeThickness="0"
                WidthRequest="72">
                <Image
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Source="config.png"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No configs found"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
            <Button
                Padding="24,0"
                Command="{Binding AddCommand}"
                HorizontalOptions="Center"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource PrimaryButton}"
                Text="+ Add Config" />
        </VerticalStackLayout>

        <!--  Collection List (Row 2)  -->
        <CollectionView
            Grid.Row="2"
            Margin="5,4,5,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AppConfig.AppConfigItem">
                    <Border Style="{StaticResource ListItemBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordConfigListViewModel}}, Path=DetailCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="14">
                            
                            <!--  Platform-colored Squircle Badge  -->
                            <Border
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource DrawerBgDark}}"
                                HeightRequest="44"
                                Stroke="{Binding Platform, Converter={StaticResource PlatformToColorConverter}}"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="1.5"
                                VerticalOptions="Center"
                                WidthRequest="44">
                                <Image
                                    HeightRequest="20"
                                    HorizontalOptions="Center"
                                    Source="config.png"
                                    VerticalOptions="Center"
                                    WidthRequest="20">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{Binding Platform, Converter={StaticResource PlatformToColorConverter}}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            
                            <!--  Config Details  -->
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding ConfigKey}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                <Label
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1"
                                    Style="{StaticResource SubLabel}"
                                    Text="{Binding ConfigValue}" />
                                <Label
                                    FontSize="10"
                                    FontAttributes="Bold"
                                    Text="{Binding Platform, StringFormat='Platform: {0}'}"
                                    TextColor="{Binding Platform, Converter={StaticResource PlatformToColorConverter}}" />
                            </VerticalStackLayout>
                            
                            <!--  Status Badge  -->
                            <Border
                                Grid.Column="2"
                                Padding="8,3"
                                BackgroundColor="{Binding StatusBgColor}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="{Binding StatusLabel}"
                                    TextColor="{Binding StatusTextColor}" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <ActivityIndicator
                    Margin="0,8"
                    IsRunning="{Binding CanLoadMore}"
                    IsVisible="{Binding CanLoadMore}" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</views:ViewBase>
