<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordParentListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    Title="Parents"
    x:DataType="vm:CoordParentListViewModel"
    x:TypeArguments="vm:CoordParentListViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Parents"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="White"
                Command="{Binding AddCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanAdd}"
                Text="+ Add"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            BackgroundColor="White"
            Stroke="#e2e8f0"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1">
            <Grid Padding="14,0" ColumnDefinitions="Auto,*,Auto">
                <Label
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Text="🔍"
                    VerticalOptions="Center" />
                <Entry
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Placeholder="Search parents…"
                    PlaceholderColor="#94a3b8"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}"
                    TextColor="#1e293b" />
                <Button
                    Grid.Column="2"
                    Padding="10,4"
                    BackgroundColor="#2563eb"
                    Command="{Binding SearchCommand}"
                    CornerRadius="8"
                    FontSize="12"
                    Text="Search"
                    TextColor="White" />
            </Grid>
        </Border>

        <ActivityIndicator
            Grid.Row="1"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="#2563eb" />

        <CollectionView
            Grid.Row="1"
            Margin="12,4,12,0"
            ItemsSource="{Binding Items}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,60"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="👨‍👩‍👧" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No parents found"
                        TextColor="#64748b" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Parent.ParentItem">
                    <Border
                        Margin="0,0,0,10"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0">
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="#eff6ff"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding InitialsDisplay}"
                                    TextColor="#2563eb"
                                    VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding FullName}"
                                    TextColor="#1e293b" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding Email}"
                                    TextColor="#64748b" />
                                <Label
                                    FontSize="11"
                                    Text="{Binding ChildrenLabel}"
                                    TextColor="#2563eb" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="6"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusColor}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding StatusLabel}"
                                        TextColor="White" />
                                </Border>
                                <ImageButton
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordParentListViewModel}}, Path=ViewCommand}"
                                    CommandParameter="{Binding .}"
                                    HeightRequest="20"
                                    HorizontalOptions="End"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CoordParentListViewModel}}, Path=CanView}"
                                    Source="view.png"
                                    WidthRequest="20" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</views:ViewBase>
