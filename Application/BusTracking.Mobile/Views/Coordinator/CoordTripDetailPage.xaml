<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordTripDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordTripDetailViewModel"
    x:TypeArguments="vm:CoordTripDetailViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="Trip Details"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                Color="#2563eb" />

            <Border
                Padding="12,10"
                BackgroundColor="#fef2f2"
                IsVisible="{Binding HasError}"
                Stroke="#fecaca"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="#ef4444" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        Padding="14"
                        BackgroundColor="#eff6ff"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="60">
                        <Label
                            FontSize="26"
                            HorizontalOptions="Center"
                            Text="{Binding Trip.TripTypeIcon}"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="17"
                            Text="{Binding Trip.RouteName}"
                            TextColor="#1e293b" />
                        <Label
                            FontSize="13"
                            Text="{Binding Trip.BusNumber}"
                            TextColor="#2563eb" />
                        <Border
                            Padding="8,3"
                            BackgroundColor="#f1f5f9"
                            HorizontalOptions="Start"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                            <Label
                                FontSize="11"
                                Text="{Binding Trip.Status}"
                                TextColor="{Binding Trip.StatusColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Info  -->
            <Border
                Padding="16"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Trip Info"
                        TextColor="#374151" />
                    <BoxView BackgroundColor="#f1f5f9" HeightRequest="1" />
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="14">
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="DRIVER"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Trip.DriverName}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="TYPE"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Trip.TripType}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="DATE"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Trip.TripDate}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="STARTED"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="{Binding Trip.StartedAt, StringFormat='{0:HH:mm}'}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!--  Actions  -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="#22c55e"
                    Command="{Binding StartCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Start Trip"
                    TextColor="White" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="#ef4444"
                    Command="{Binding CancelTripCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel Trip"
                    TextColor="White" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
