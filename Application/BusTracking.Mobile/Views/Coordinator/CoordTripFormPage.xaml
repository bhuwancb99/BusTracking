<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordTripFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordTripFormViewModel"
    x:TypeArguments="vm:CoordTripFormViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="Create Trip"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

            <Border
                Padding="12,10"
                BackgroundColor="#fef2f2"
                IsVisible="{Binding HasError}"
                Stroke="#fecaca"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="#ef4444" />
            </Border>

            <!--  Bus  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Bus *"
                        TextColor="#374151" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding BusName}"
                        ItemsSource="{Binding BusOptions}"
                        SelectedItem="{Binding SelectedBus}"
                        TextColor="#1e293b"
                        TitleColor="#94a3b8" />
                </VerticalStackLayout>
            </Border>

            <!--  Route  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Route *"
                        TextColor="#374151" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding RouteName}"
                        ItemsSource="{Binding RouteOptions}"
                        SelectedItem="{Binding SelectedRoute}"
                        TextColor="#1e293b"
                        TitleColor="#94a3b8" />
                </VerticalStackLayout>
            </Border>

            <!--  Trip Type  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Trip Type *"
                        TextColor="#374151" />
                    <Picker
                        BackgroundColor="Transparent"
                        ItemsSource="{Binding TripTypes}"
                        SelectedItem="{Binding TripType}"
                        TextColor="#1e293b"
                        TitleColor="#94a3b8" />
                </VerticalStackLayout>
            </Border>

            <!--  Trip Date  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Trip Date *"
                        TextColor="#374151" />
                    <DatePicker
                        BackgroundColor="Transparent"
                        Date="{Binding TripDate}"
                        MinimumDate="{x:Static sys:DateTime.Today}"
                        TextColor="#1e293b" />
                </VerticalStackLayout>
            </Border>

            <!--  Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="White"
                    BorderColor="#e2e8f0"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="#64748b" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="#2563eb"
                    Command="{Binding SaveCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Creating…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Create Trip" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
