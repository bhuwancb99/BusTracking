<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Coordinator.CoordStudentDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Coordinator"
    x:DataType="vm:CoordStudentDetailViewModel"
    x:TypeArguments="vm:CoordStudentDetailViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Student Details"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="12,6"
                BackgroundColor="White"
                Command="{Binding EditCommand}"
                CornerRadius="20"
                FontSize="13"
                Text="Edit"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                Color="#2563eb" />

            <Border
                Padding="12,10"
                BackgroundColor="#fef2f2"
                IsVisible="{Binding HasError}"
                Stroke="#fecaca"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="#ef4444" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        BackgroundColor="#0ea5e9"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 30"
                        WidthRequest="60">
                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="{Binding Student.InitialsDisplay}"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Student.FullName}"
                            TextColor="#1e293b" />
                        <Label
                            FontSize="13"
                            Text="{Binding Student.Email}"
                            TextColor="#64748b" />
                        <Label
                            FontSize="12"
                            Text="{Binding Student.StudentCode}"
                            TextColor="#2563eb" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Details  -->
            <Border
                Padding="16"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Details"
                        TextColor="#374151" />
                    <BoxView BackgroundColor="#f1f5f9" HeightRequest="1" />
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto,Auto"
                        RowSpacing="14">
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="STANDARD"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Student.Standard}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="STATUS"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Student.StatusLabel}"
                                TextColor="{Binding Student.StatusColor}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="BUS"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="{Binding Student.BusDisplay}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="STOP"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Student.StopName}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="2"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="PHONE"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Student.PhoneNumber}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
