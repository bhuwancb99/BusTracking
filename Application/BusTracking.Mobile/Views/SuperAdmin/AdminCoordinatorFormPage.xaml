<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminCoordinatorFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminCoordinatorFormViewModel"
    x:TypeArguments="vm:AdminCoordinatorFormViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">

            <!--  Error  -->
            <Border
                BackgroundColor="#fef2f2"
                IsVisible="{Binding HasError}"
                Stroke="#fecaca"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="1">
                <Label
                    Padding="12,10"
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="#ef4444" />
            </Border>

            <!--  Full Name  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Full Name *"
                        TextColor="#374151" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="Enter coordinator's full name"
                        PlaceholderColor="#94a3b8"
                        Text="{Binding FullName}"
                        TextColor="#1e293b" />
                </VerticalStackLayout>
            </Border>

            <!--  Email (create only)  -->
            <Border
                BackgroundColor="White"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertBool}}"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Email *"
                        TextColor="#374151" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Email"
                        Placeholder="coordinator@school.com"
                        PlaceholderColor="#94a3b8"
                        Text="{Binding Email}"
                        TextColor="#1e293b" />
                </VerticalStackLayout>
            </Border>

            <!--  Phone  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Phone Number"
                        TextColor="#374151" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Telephone"
                        Placeholder="+91 XXXXX XXXXX"
                        PlaceholderColor="#94a3b8"
                        Text="{Binding PhoneNumber}"
                        TextColor="#1e293b" />
                </VerticalStackLayout>
            </Border>

            <!--  Password (create only)  -->
            <Border
                BackgroundColor="White"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertBool}}"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Password *"
                        TextColor="#374151" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Min. 6 characters"
                        PlaceholderColor="#94a3b8"
                        Text="{Binding Password}"
                        TextColor="#1e293b" />
                </VerticalStackLayout>
            </Border>

            <!--  Is Active  -->
            <Border
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <Grid Padding="16" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Active Account"
                            TextColor="#1e293b" />
                        <Label
                            FontSize="12"
                            Text="Inactive coordinators cannot login"
                            TextColor="#64748b" />
                    </VerticalStackLayout>
                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsActive}"
                        OnColor="#2563eb"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--  Permissions section  -->
            <Label
                Margin="0,8,0,0"
                FontAttributes="Bold"
                FontSize="16"
                Text="Assign Permissions"
                TextColor="#1e293b" />
            <Label
                Margin="0,0,0,4"
                FontSize="13"
                Text="Select what this coordinator can access and manage."
                TextColor="#64748b" />

            <!--  Permission groups  -->
            <CollectionView ItemsSource="{Binding PermissionGroups}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PermissionGroup">
                        <Border
                            Margin="0,0,0,10"
                            BackgroundColor="White"
                            Stroke="#e2e8f0"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1">
                            <VerticalStackLayout Padding="16" Spacing="0">

                                <!--  Module header  -->
                                <Grid Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                                    <Label
                                        Grid.Column="0"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="{Binding ModuleName}"
                                        TextColor="#1e293b"
                                        VerticalOptions="Center" />
                                    <Button
                                        Grid.Column="1"
                                        Padding="12,4"
                                        BackgroundColor="#eff6ff"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminCoordinatorFormViewModel}}, Path=ToggleAllInGroupCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="8"
                                        FontSize="12"
                                        HeightRequest="32"
                                        Text="All"
                                        TextColor="#2563eb" />
                                </Grid>

                                <BoxView
                                    Margin="0,0,0,10"
                                    BackgroundColor="#f1f5f9"
                                    HeightRequest="1" />

                                <!--  Permissions in this module  -->
                                <CollectionView ItemsSource="{Binding Permissions}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Coordinator.PermissionItem">
                                            <Grid
                                                Padding="0,6"
                                                ColumnDefinitions="Auto,*"
                                                ColumnSpacing="12">
                                                <CheckBox
                                                    Grid.Column="0"
                                                    IsChecked="{Binding IsSelected}"
                                                    Color="#2563eb" />
                                                <VerticalStackLayout
                                                    Grid.Column="1"
                                                    Spacing="2"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontSize="13"
                                                        Text="{Binding Description}"
                                                        TextColor="#1e293b" />
                                                    <Label
                                                        FontFamily="Monospace"
                                                        FontSize="10"
                                                        Text="{Binding Key}"
                                                        TextColor="#94a3b8" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--  Action Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="White"
                    BorderColor="#e2e8f0"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="#64748b" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="#2563eb"
                    Command="{Binding SaveCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Saving…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Update" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Create" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#2563eb" />

        </VerticalStackLayout>
    </ScrollView>

</views:ViewBase>
