<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminBusListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    Title="Buses"
    x:DataType="vm:AdminBusListViewModel"
    x:TypeArguments="vm:AdminBusListViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Buses"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="White"
                Command="{Binding AddCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanAdd}"
                Text="+ Add"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!--  Search bar  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            Padding="12,0"
            BackgroundColor="White"
            Shadow="False"
            Stroke="#e2e8f0"
            StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Text="🔍"
                    VerticalOptions="Center" />
                <Entry
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Placeholder="Search buses…"
                    PlaceholderColor="#94a3b8"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}"
                    TextColor="#1e293b" />
                <Button
                    Grid.Column="2"
                    Padding="10,4"
                    BackgroundColor="#2563eb"
                    Command="{Binding SearchCommand}"
                    CornerRadius="8"
                    FontSize="12"
                    Text="Go"
                    TextColor="White" />
            </Grid>
        </Border>

        <!--  Error  -->
        <Border
            Grid.Row="0"
            Margin="12,0"
            Padding="12,8"
            BackgroundColor="#fef2f2"
            IsVisible="{Binding HasError}"
            Stroke="#fecaca"
            StrokeShape="RoundRectangle 10">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="#ef4444" />
        </Border>

        <!--  Loading  -->
        <ActivityIndicator
            Grid.Row="1"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="#2563eb" />

        <!--  Empty state  -->
        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="12"
            VerticalOptions="Center">
            <Label
                FontSize="48"
                HorizontalOptions="Center"
                Text="🚌" />
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No buses found"
                TextColor="#64748b" />
        </VerticalStackLayout>

        <!--  List  -->
        <CollectionView
            Grid.Row="1"
            Margin="12,4,12,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Bus.BusItem">
                    <Border
                        Margin="0,4"
                        Padding="16"
                        BackgroundColor="White"
                        Shadow="True"
                        StrokeShape="RoundRectangle 0">
                        <Grid
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12"
                            RowDefinitions="Auto,Auto">

                            <!--  Icon  -->
                            <Border
                                Grid.RowSpan="2"
                                Grid.Column="0"
                                Padding="10"
                                BackgroundColor="#eff6ff"
                                HeightRequest="48"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center"
                                WidthRequest="48">
                                <Label
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="🚌"
                                    VerticalOptions="Center" />
                            </Border>

                            <!--  Info  -->
                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                FontAttributes="Bold"
                                FontSize="15"
                                Text="{Binding BusName}"
                                TextColor="#1e293b" />
                            <Label
                                Grid.Row="1"
                                Grid.Column="1"
                                FontSize="12"
                                TextColor="#64748b">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span
                                            FontAttributes="Bold"
                                            Text="{Binding BusNumber}"
                                            TextColor="#2563eb" />
                                        <Span Text=" · " />
                                        <Span Text="{Binding DriverDisplay}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!--  Status + Actions  -->
                            <VerticalStackLayout
                                Grid.RowSpan="2"
                                Grid.Column="2"
                                Spacing="6"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="#f1f5f9"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20">
                                    <Label
                                        FontSize="11"
                                        Text="{Binding StatusLabel}"
                                        TextColor="{Binding StatusColor}" />
                                </Border>
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="6">
                                    <!--  Edit button — bound to CanEdit on parent ViewModel via ancestor binding  -->
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminBusListViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        Source="edit.png"
                                        WidthRequest="20" />
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminBusListViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        Source="delete.png"
                                        WidthRequest="20" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <ActivityIndicator
                    Margin="0,8"
                    IsRunning="{Binding CanLoadMore}"
                    IsVisible="{Binding CanLoadMore}"
                    Color="#2563eb" />
            </CollectionView.Footer>
        </CollectionView>

    </Grid>

</views:ViewBase>
