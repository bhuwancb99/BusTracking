<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminDashboardViewModel"
    x:TypeArguments="vm:AdminDashboardViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Super Admin"
                TextColor="White"
                VerticalOptions="Center" />
            <ImageButton
                Grid.Column="1"
                BackgroundColor="Transparent"
                Command="{Binding LogoutCommand}"
                Source="logout.png"
                WidthRequest="22" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="0">

                <!--  Welcome  -->
                <Label
                    Margin="0,0,0,4"
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding WelcomeText}"
                    TextColor="#1e293b" />
                <Label
                    Margin="0,0,0,20"
                    FontSize="13"
                    Text="Here's your system overview"
                    TextColor="#64748b" />

                <!--  Stat Cards Grid  -->
                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="12"
                    RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="12">

                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToBusesCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="🚌" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.TotalBuses}"
                                TextColor="#2563eb" />
                            <Label
                                FontSize="12"
                                Text="Buses"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToDriversCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="🧑‍✈️" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.TotalDrivers}"
                                TextColor="#0891b2" />
                            <Label
                                FontSize="12"
                                Text="Drivers"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToStudentsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="🎒" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.TotalStudents}"
                                TextColor="#7c3aed" />
                            <Label
                                FontSize="12"
                                Text="Students"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToParentsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="👨‍👩‍👧" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.TotalParents}"
                                TextColor="#059669" />
                            <Label
                                FontSize="12"
                                Text="Parents"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTripsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="📍" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.ActiveTrips}"
                                TextColor="#dc2626" />
                            <Label
                                FontSize="12"
                                Text="Active Trips"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Row="2"
                        Grid.Column="1"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCoordinatorsCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="28" Text="📋" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="28"
                                Text="{Binding Summary.TotalBusCoordinators}"
                                TextColor="#d97706" />
                            <Label
                                FontSize="12"
                                Text="Coordinators"
                                TextColor="#64748b" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!--  Quick actions  -->
                <Label
                    Margin="0,24,0,12"
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="Quick Actions"
                    TextColor="#1e293b" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="#eff6ff"
                        Command="{Binding GoToRoutesCommand}"
                        CornerRadius="12"
                        FontSize="13"
                        HeightRequest="44"
                        Text="Routes"
                        TextColor="#2563eb" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="#f0fdf4"
                        Command="{Binding GoToConfigCommand}"
                        CornerRadius="12"
                        FontSize="13"
                        HeightRequest="44"
                        Text="Config"
                        TextColor="#059669" />
                    <Button
                        Grid.Column="2"
                        BackgroundColor="#fef2f2"
                        Command="{Binding GoToTripsCommand}"
                        CornerRadius="12"
                        FontSize="13"
                        HeightRequest="44"
                        Text="Trips"
                        TextColor="#dc2626" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
