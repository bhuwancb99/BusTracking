<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminRouteDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminRouteDetailViewModel"
    x:TypeArguments="vm:AdminRouteDetailViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>


    <Shell.TitleView>
        <Grid
            Padding="0,0,8,0"
            ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="8">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Route Details"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="7"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="edit.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Border
                Grid.Column="2"
                Padding="7"
                BackgroundColor="{StaticResource Danger}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="delete.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="White" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">



            <!--  Error  -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                  Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                         Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 8">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        Padding="14"
                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                          Dark={StaticResource StatBusBgDark}}"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 16"
                        WidthRequest="60">
                        <Image
                            HeightRequest="28"
                            HorizontalOptions="Center"
                            Source="route.png"
                            VerticalOptions="Center"
                            WidthRequest="28">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Route.RouteName}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="13"
                            Text="{Binding Route.RouteCode}"
                            TextColor="{StaticResource Primary}" />
                        <Border
                            Padding="8,3"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg},
                                                              Dark={StaticResource StatusInactiveBgDark}}"
                            HorizontalOptions="Start"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                            <Label
                                FontSize="11"
                                Text="{Binding Route.StatusLabel}"
                                TextColor="{Binding Route.IsActive, Converter={StaticResource BoolToStatusColor}}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Timing  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <Grid
                    ColumnDefinitions="*,*"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="14">
                    <Label
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Timing"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <VerticalStackLayout
                        Grid.Row="1"
                        Grid.Column="0"
                        Spacing="3">
                        <Label
                            FontSize="11"
                            Text="MORNING"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="{Binding Route.MorningTime}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        Grid.Row="1"
                        Grid.Column="1"
                        Spacing="3">
                        <Label
                            FontSize="11"
                            Text="EVENING"
                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="{Binding Route.EveningTime}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Description  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                IsVisible="{Binding Route.Description, Converter={StaticResource StringToBool}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Description"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="13"
                        Text="{Binding Route.Description}"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Add Stop  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Add Stop"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Padding="14,6"
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding ToggleAddStopCommand}"
                            CornerRadius="8"
                            FontSize="12"
                            Text="+ Add"
                            TextColor="White">
                            <Button.Triggers>
                                <DataTrigger
                                    Binding="{Binding IsAddStopVisible}"
                                    TargetType="Button"
                                    Value="True">
                                    <Setter Property="Text" Value="Close" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsAddStopVisible}" Spacing="10">
                        <Entry Placeholder="Stop name *" Text="{Binding NewStopName}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label FontSize="11" Text="Morning" />
                                <TimePicker Format="hh:mm tt" Time="{Binding NewStopMorningTime, Converter={StaticResource NullableTimeSpan}}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label FontSize="11" Text="Evening" />
                                <TimePicker Format="hh:mm tt" Time="{Binding NewStopEveningTime, Converter={StaticResource NullableTimeSpan}}" />
                            </VerticalStackLayout>
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Entry
                                Grid.Column="0"
                                Keyboard="Numeric"
                                Placeholder="Latitude"
                                Text="{Binding NewStopLatitude}" />
                            <Entry
                                Grid.Column="1"
                                Keyboard="Numeric"
                                Placeholder="Longitude"
                                Text="{Binding NewStopLongitude}" />
                        </Grid>
                        <Button
                            BackgroundColor="{StaticResource Primary}"
                            Command="{Binding AddStopCommand}"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            HeightRequest="46"
                            Text="Add Stop"
                            TextColor="White" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Stops  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="Stops  "
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                    Dark={StaticResource TextPrimaryDark}}" />
                                    <Span
                                        FontSize="13"
                                        Text="{Binding Route.StopCount, StringFormat='({0})'}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Button
                            Grid.Column="1"
                            Padding="12,6"
                            BackgroundColor="{StaticResource Success}"
                            Command="{Binding UpdateOrderCommand}"
                            CornerRadius="8"
                            FontSize="12"
                            IsVisible="{Binding HasStops}"
                            Text="Update Order"
                            TextColor="White" />
                    </Grid>
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                FontSize="13"
                                HorizontalOptions="Center"
                                Text="No stops loaded"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Route.StopItem">
                                <Grid
                                    Padding="0,8"
                                    ColumnDefinitions="48,*,Auto,Auto"
                                    ColumnSpacing="10">
                                    <Entry
                                        Grid.Column="0"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        HorizontalTextAlignment="Center"
                                        Keyboard="Numeric"
                                        Text="{Binding OrderText}"
                                        WidthRequest="48" />
                                    <Label
                                        Grid.Column="1"
                                        FontSize="14"
                                        Text="{Binding StopName}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                    Dark={StaticResource TextPrimaryDark}}"
                                        VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="2"
                                        FontSize="12"
                                        Text="{Binding MorningTime}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextSecondaryDark}}"
                                        VerticalOptions="Center" />
                                    <Border
                                        Grid.Column="3"
                                        Padding="6"
                                        BackgroundColor="Transparent"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteDetailViewModel}}, Path=DeleteStopCommand}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Image
                                            HeightRequest="18"
                                            HorizontalOptions="Center"
                                            Source="delete.png"
                                            VerticalOptions="Center"
                                            WidthRequest="18">
                                            <Image.Behaviors>
                                                <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                            </Image.Behaviors>
                                        </Image>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
