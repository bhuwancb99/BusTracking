<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminCoordinatorDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminCoordinatorDetailViewModel"
    x:TypeArguments="vm:AdminCoordinatorDetailViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid
            Padding="0,0,8,0"
            ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="8">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Coordinator"
                TextColor="White"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="7"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="edit.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Border
                Grid.Column="2"
                Padding="7"
                BackgroundColor="{StaticResource Accent}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ResetPasswordCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="key.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="White" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Border
                Grid.Column="3"
                Padding="7"
                BackgroundColor="{StaticResource Danger}"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="18"
                    HorizontalOptions="Center"
                    Source="delete.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="White" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                Color="{StaticResource Primary}" />

            <!--  Error  -->
            <Border
                Padding="12,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                  Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                         Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Purple}"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 30"
                        WidthRequest="60">
                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="{Binding Coordinator.InitialsDisplay}"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Coordinator.FullName}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="13"
                            Text="{Binding Coordinator.Email}"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                        Dark={StaticResource TextSecondaryDark}}" />
                        <Border
                            Padding="8,3"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg},
                                                              Dark={StaticResource StatusInactiveBgDark}}"
                            HorizontalOptions="Start"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                            <Label
                                FontSize="11"
                                Text="{Binding Coordinator.StatusLabel}"
                                TextColor="{Binding Coordinator.StatusColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Info  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Info"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="14">
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="PHONE"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Coordinator.PhoneNumber}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="PERMISSIONS"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Coordinator.PermCount}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="JOINED"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="{Binding Coordinator.CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark={StaticResource TextPrimaryDark}}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!--  Permissions grouped by module  -->
            <Border
                Padding="16"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Permissions"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource StatusInactiveBg}, Dark={StaticResource StatusInactiveBgDark}}" HeightRequest="1" />
                    <CollectionView ItemsSource="{Binding PermissionGroups}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PermissionGroup">
                                <VerticalStackLayout Margin="0,0,0,12" Spacing="6">
                                    <!--  Module header  -->
                                    <Border
                                        Padding="10,6"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                          Dark={StaticResource StatBusBgDark}}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 8">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="12"
                                            Text="{Binding ModuleName}"
                                            TextColor="{StaticResource Primary}" />
                                    </Border>
                                    <!--  Permissions in this module  -->
                                    <CollectionView ItemsSource="{Binding Permissions}" SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:Coordinator.PermissionItem">
                                                <Grid
                                                    Padding="4,5"
                                                    ColumnDefinitions="Auto,*"
                                                    ColumnSpacing="10">
                                                    <Border
                                                        Grid.Column="0"
                                                        Padding="5"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight},
                                                                                          Dark={StaticResource StatParentBgDark}}"
                                                        StrokeShape="RoundRectangle 6"
                                                        StrokeThickness="0">
                                                        <Image
                                                            HeightRequest="12"
                                                            Source="check.png"
                                                            WidthRequest="12">
                                                            <Image.Behaviors>
                                                                <mct:IconTintColorBehavior TintColor="{StaticResource Success}" />
                                                            </Image.Behaviors>
                                                        </Image>
                                                    </Border>
                                                    <VerticalStackLayout
                                                        Grid.Column="1"
                                                        Spacing="1"
                                                        VerticalOptions="Center">
                                                        <Label
                                                            FontSize="13"
                                                            Text="{Binding Description}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                        Dark={StaticResource TextPrimaryDark}}" />
                                                        <Label
                                                            FontFamily="Monospace"
                                                            FontSize="10"
                                                            Text="{Binding Key}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                                        Dark={StaticResource TextSecondaryDark}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Button
                BackgroundColor="{StaticResource Accent}"
                Command="{Binding ToggleCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="50"
                Text="Toggle Active / Inactive"
                TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
