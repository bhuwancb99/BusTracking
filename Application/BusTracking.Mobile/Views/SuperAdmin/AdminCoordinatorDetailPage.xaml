<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminCoordinatorDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminCoordinatorDetailViewModel"
    x:TypeArguments="vm:AdminCoordinatorDetailViewModel"
    BackgroundColor="#F4F6FB">

    <Shell.TitleView>
        <Grid
            Padding="0,0,8,0"
            ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="8">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Coordinator"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="12,6"
                BackgroundColor="White"
                Command="{Binding EditCommand}"
                CornerRadius="20"
                FontSize="13"
                Text="Edit"
                TextColor="#2563eb" />
            <Button
                Grid.Column="2"
                Padding="12,6"
                BackgroundColor="#f59e0b"
                Command="{Binding ResetPasswordCommand}"
                CornerRadius="20"
                FontSize="13"
                Text="Reset"
                TextColor="White" />
            <Button
                Grid.Column="3"
                Padding="12,6"
                BackgroundColor="#ef4444"
                Command="{Binding DeleteCommand}"
                CornerRadius="20"
                FontSize="13"
                Text="Delete"
                TextColor="White" />
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                Color="#2563eb" />

            <!--  Error  -->
            <Border
                Padding="12,10"
                BackgroundColor="#fef2f2"
                IsVisible="{Binding HasError}"
                Stroke="#fecaca"
                StrokeShape="RoundRectangle 10">
                <Label
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="#ef4444" />
            </Border>

            <!--  Header  -->
            <Border
                Padding="20"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        Grid.Column="0"
                        BackgroundColor="#7c3aed"
                        HeightRequest="60"
                        StrokeShape="RoundRectangle 30"
                        WidthRequest="60">
                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalOptions="Center"
                            Text="{Binding Coordinator.InitialsDisplay}"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Coordinator.FullName}"
                            TextColor="#1e293b" />
                        <Label
                            FontSize="13"
                            Text="{Binding Coordinator.Email}"
                            TextColor="#64748b" />
                        <Border
                            Padding="8,3"
                            BackgroundColor="#f1f5f9"
                            HorizontalOptions="Start"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                            <Label
                                FontSize="11"
                                Text="{Binding Coordinator.StatusLabel}"
                                TextColor="{Binding Coordinator.StatusColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Info  -->
            <Border
                Padding="16"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Info"
                        TextColor="#374151" />
                    <BoxView BackgroundColor="#f1f5f9" HeightRequest="1" />
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="14">
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="PHONE"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Coordinator.PhoneNumber}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="0"
                            Grid.Column="1"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="PERMISSIONS"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding Coordinator.PermCount}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                        <VerticalStackLayout
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="3">
                            <Label
                                FontSize="11"
                                Text="JOINED"
                                TextColor="#94a3b8" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                Text="{Binding Coordinator.CreatedAt, StringFormat='{0:dd MMM yyyy}'}"
                                TextColor="#1e293b" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!--  Permissions list  -->
            <Border
                Padding="16"
                BackgroundColor="White"
                Stroke="#e2e8f0"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Permissions"
                        TextColor="#374151" />
                    <BoxView BackgroundColor="#f1f5f9" HeightRequest="1" />
                    <CollectionView ItemsSource="{Binding Coordinator.Permissions}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Margin="0,3"
                                    Padding="10,6"
                                    BackgroundColor="#f8fafc"
                                    Stroke="#e2e8f0"
                                    StrokeShape="RoundRectangle 8">
                                    <Label
                                        FontSize="13"
                                        Text="{Binding .}"
                                        TextColor="#374151" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Button
                BackgroundColor="#f59e0b"
                Command="{Binding ToggleCommand}"
                CornerRadius="12"
                FontAttributes="Bold"
                HeightRequest="50"
                Text="Toggle Active / Inactive"
                TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>
