<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminRouteListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    Title="Routes"
    x:DataType="vm:AdminRouteListViewModel"
    x:TypeArguments="vm:AdminRouteListViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Routes"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="White"
                Command="{Binding AddCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanAdd}"
                Text="+ Add"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!--  Search  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            Padding="12,0"
            BackgroundColor="White"
            Stroke="#e2e8f0"
            StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Text="🔍"
                    VerticalOptions="Center" />
                <Entry
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Placeholder="Search routes…"
                    PlaceholderColor="#94a3b8"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}"
                    TextColor="#1e293b" />
                <Button
                    Grid.Column="2"
                    Padding="10,4"
                    BackgroundColor="#2563eb"
                    Command="{Binding SearchCommand}"
                    CornerRadius="8"
                    FontSize="12"
                    Text="Go"
                    TextColor="White" />
            </Grid>
        </Border>

        <ActivityIndicator
            Grid.Row="1"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="#2563eb" />

        <CollectionView
            Grid.Row="1"
            Margin="12,4,12,0"
            ItemsSource="{Binding Items}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,60"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="🗺️" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No routes found"
                        TextColor="#64748b" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Route.RouteItem">
                    <Border
                        Margin="0,0,0,10"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0">
                        <!--  Tap whole row → detail  -->
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteListViewModel}}, Path=TapCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="16"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <Border
                                Grid.Column="0"
                                Padding="10"
                                BackgroundColor="#eff6ff"
                                HeightRequest="48"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center"
                                WidthRequest="48">
                                <Label
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="🗺️"
                                    VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding RouteName}"
                                    TextColor="#1e293b" />
                                <Label FontSize="12" TextColor="#64748b">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span
                                                FontAttributes="Bold"
                                                Text="{Binding RouteCode}"
                                                TextColor="#2563eb" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding StopCount, StringFormat='{0} stops'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label
                                    FontSize="11"
                                    Text="{Binding TimingDisplay}"
                                    TextColor="#94a3b8" />
                            </VerticalStackLayout>

                            <!--  Actions: Edit + Delete only  -->
                            <HorizontalStackLayout
                                Grid.Column="2"
                                Spacing="10"
                                VerticalOptions="Center">
                                <ImageButton
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteListViewModel}}, Path=EditCommand}"
                                    CommandParameter="{Binding .}"
                                    HeightRequest="20"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteListViewModel}}, Path=CanEdit}"
                                    Source="edit.png"
                                    WidthRequest="20" />
                                <ImageButton
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteListViewModel}}, Path=DeleteCommand}"
                                    CommandParameter="{Binding .}"
                                    HeightRequest="20"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminRouteListViewModel}}, Path=CanDelete}"
                                    Source="delete.png"
                                    WidthRequest="20" />
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</views:ViewBase>
