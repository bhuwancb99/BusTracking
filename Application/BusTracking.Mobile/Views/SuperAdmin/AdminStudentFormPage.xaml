<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminStudentFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminStudentFormViewModel"
    x:TypeArguments="vm:AdminStudentFormViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">


    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>
    <Shell.TitleView>
        <Label
            FontAttributes="Bold"
            FontSize="17"
            Text="{Binding Title}"
            TextColor="White"
            VerticalOptions="Center" />
    </Shell.TitleView>
    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="14">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight},
                                                  Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight},
                                         Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="1">
                <Label
                    Padding="12,10"
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                                Dark={StaticResource ErrorTextDark}}" />
            </Border>
            <!--  Full Name  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Full Name *"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="Student full name"
                        Text="{Binding FullName}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Email (Add only)  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertBool}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Email *"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Email"
                        Placeholder="student@example.com"
                        Text="{Binding Email}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Password (Add only)  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertBool}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Password *"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        IsPassword="True"
                        Placeholder="Min 6 characters"
                        Text="{Binding Password}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Phone  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Phone"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Keyboard="Telephone"
                        Placeholder="Optional"
                        Text="{Binding PhoneNumber}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Standard/Class  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Class / Standard"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Entry
                        BackgroundColor="Transparent"
                        Placeholder="e.g. Grade 8"
                        Text="{Binding Standard}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Assign Bus  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Assign Bus"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Picker
                        Title="Select a bus…"
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding BusName}"
                        ItemsSource="{Binding BusOptions}"
                        SelectedItem="{Binding SelectedBus}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Assign Stop  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="12"
                        Text="Assign Stop"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Picker
                        Title="Select a stop…"
                        BackgroundColor="Transparent"
                        ItemDisplayBinding="{Binding StopName}"
                        ItemsSource="{Binding StopOptions}"
                        SelectedItem="{Binding SelectedStop}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>
            <!--  Active  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                  Dark={StaticResource CardBgDark}}"
                Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                         Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <Grid Padding="16" ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        FontSize="14"
                        Text="Active"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}"
                        VerticalOptions="Center" />
                    <Switch
                        Grid.Column="1"
                        IsToggled="{Binding IsActive}"
                        OnColor="{StaticResource Primary}"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>
            <!--  Buttons  -->
            <Grid
                Margin="0,8,0,0"
                ColumnDefinitions="*,*"
                ColumnSpacing="12">
                <Button
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                                      Dark={StaticResource CardBgDark}}"
                    BorderColor="{AppThemeBinding Light={StaticResource BorderColor},
                                                  Dark={StaticResource BorderColorDark}}"
                    BorderWidth="1.5"
                    Command="{Binding CancelCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Text="Cancel"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                Dark={StaticResource TextSecondaryDark}}" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource Primary}"
                    Command="{Binding SaveCommand}"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    TextColor="White">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding IsBusy}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Saving…" />
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="True">
                            <Setter Property="Text" Value="Update Student" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsEditMode}"
                            TargetType="Button"
                            Value="False">
                            <Setter Property="Text" Value="Add Student" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</views:ViewBase>