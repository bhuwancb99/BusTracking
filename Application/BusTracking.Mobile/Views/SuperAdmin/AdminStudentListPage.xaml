<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminStudentListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    Title="Students"
    x:DataType="vm:AdminStudentListViewModel"
    x:TypeArguments="vm:AdminStudentListViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Students"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="White"
                Command="{Binding AddCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanAdd}"
                Text="+ Add"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Search  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            Padding="12,0"
            BackgroundColor="White"
            Stroke="#e2e8f0"
            StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    Text="🔍"
                    VerticalOptions="Center" />
                <Entry
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Placeholder="Search students…"
                    PlaceholderColor="#94a3b8"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}"
                    TextColor="#1e293b" />
                <Button
                    Grid.Column="2"
                    Padding="10,4"
                    BackgroundColor="#2563eb"
                    Command="{Binding SearchCommand}"
                    CornerRadius="8"
                    FontSize="12"
                    Text="Go"
                    TextColor="White" />
            </Grid>
        </Border>

        <!--  Filter chips  -->
        <HorizontalStackLayout
            Grid.Row="1"
            Margin="12,4,12,4"
            Spacing="8">
            <Border
                Padding="12,6"
                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Active'}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Active" />
                </Border.GestureRecognizers>
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="Active"
                    TextColor="{Binding SelectedFilter, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Active'}" />
            </Border>
            <Border
                Padding="12,6"
                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Inactive'}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Inactive" />
                </Border.GestureRecognizers>
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="Inactive"
                    TextColor="{Binding SelectedFilter, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Inactive'}" />
            </Border>
            <Border
                Padding="12,6"
                BackgroundColor="{Binding SelectedFilter, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Both'}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Both" />
                </Border.GestureRecognizers>
                <Label
                    FontAttributes="Bold"
                    FontSize="12"
                    Text="Both"
                    TextColor="{Binding SelectedFilter, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Both'}" />
            </Border>
        </HorizontalStackLayout>

        <ActivityIndicator
            Grid.Row="2"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="#2563eb" />

        <CollectionView
            Grid.Row="2"
            Margin="12,4,12,0"
            ItemsSource="{Binding Items}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,60"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="🎒" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No students found"
                        TextColor="#64748b" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student.StudentItem">
                    <Border
                        Margin="0,0,0,10"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=TapCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="#fef3c7"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding InitialsDisplay}"
                                    TextColor="#d97706"
                                    VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding FullName}"
                                    TextColor="#1e293b" />
                                <Label
                                    FontSize="12"
                                    Text="{Binding StudentCode}"
                                    TextColor="#2563eb" />
                                <Label
                                    FontSize="11"
                                    Text="{Binding BusDisplay}"
                                    TextColor="#64748b" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="8"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusColor}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding StatusLabel}"
                                        TextColor="White" />
                                </Border>
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=CanEdit}"
                                        Source="edit.png"
                                        WidthRequest="20" />
                                    <!--  Delete only shown for active students  -->
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        IsVisible="{Binding IsActive}"
                                        Source="delete.png"
                                        WidthRequest="20" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</views:ViewBase>
