<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminStudentListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    Title="Students"
    x:DataType="vm:AdminStudentListViewModel"
    x:TypeArguments="vm:AdminStudentListViewModel"
    BackgroundColor="#F4F6FB">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Students"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="White"
                Command="{Binding AddCommand}"
                CornerRadius="20"
                FontSize="13"
                IsVisible="{Binding CanAdd}"
                Text="+ Add"
                TextColor="#2563eb" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            BackgroundColor="White"
            Stroke="#e2e8f0"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1">
            <Grid Padding="14,0" ColumnDefinitions="Auto,*,Auto">
                <Image
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    HeightRequest="18"
                    Source="search.png"
                    VerticalOptions="Center"
                    WidthRequest="18" />
                <Entry
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Placeholder="Search by name or code…"
                    PlaceholderColor="#94a3b8"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}"
                    TextColor="#1e293b" />
                <Button
                    Grid.Column="2"
                    Padding="10,4"
                    BackgroundColor="#2563eb"
                    Command="{Binding SearchCommand}"
                    CornerRadius="8"
                    FontSize="12"
                    Text="Go"
                    TextColor="White" />
            </Grid>
        </Border>

        <ActivityIndicator
            Grid.Row="1"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            Color="#2563eb" />

        <CollectionView
            Grid.Row="1"
            Margin="12,4,12,0"
            ItemsSource="{Binding Items}"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,60"
                    HorizontalOptions="Center"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Label
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="🎒" />
                    <Label
                        FontSize="15"
                        HorizontalOptions="Center"
                        Text="No students found"
                        TextColor="#64748b" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student.StudentItem">
                    <Border
                        Margin="0,0,0,10"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="0">
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">

                            <Border
                                Grid.Column="0"
                                BackgroundColor="#f5f3ff"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding InitialsDisplay}"
                                    TextColor="#7c3aed"
                                    VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="3"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    Text="{Binding FullName}"
                                    TextColor="#1e293b" />
                                <Label FontSize="12" TextColor="#64748b">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span
                                                FontAttributes="Bold"
                                                Text="{Binding StudentCode}"
                                                TextColor="#7c3aed" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding Standard, FallbackValue='–'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label
                                    FontSize="11"
                                    Text="{Binding BusDisplay}"
                                    TextColor="#2563eb" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="8"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusColor}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding StatusLabel}"
                                        TextColor="White" />
                                </Border>
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=ViewCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=CanEdit}"
                                        Source="view.png"
                                        WidthRequest="20" />
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=CanEdit}"
                                        Source="edit.png"
                                        WidthRequest="20" />
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="20"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=CanDelete}"
                                        Source="delete.png"
                                        WidthRequest="20" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</views:ViewBase>
