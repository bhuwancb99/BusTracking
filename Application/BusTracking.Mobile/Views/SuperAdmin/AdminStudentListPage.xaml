<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminStudentListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminStudentListViewModel"
    x:TypeArguments="vm:AdminStudentListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,10,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Students"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Command="{Binding AddCommand}"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource NavPillButton}"
                Text="+ Add" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!--  Search  -->
        <Border
            Grid.Row="0"
            Margin="14,12,14,4"
            Style="{StaticResource SearchBarBorder}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Image
                    Grid.Column="0"
                    HeightRequest="18"
                    Source="search.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                    </Image.Behaviors>
                </Image>
                <Entry
                    Grid.Column="1"
                    Placeholder="{Binding SearchPlaceholder}"
                    ReturnCommand="{Binding SearchCommand}"
                    Text="{Binding SearchText}" />
                <Button
                    Grid.Column="2"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchGoButton}"
                    Text="Go" />
            </Grid>
        </Border>

        <!--  Error  -->
        <Border
            Grid.Row="1"
            Margin="14,0"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>
        <!--  Busy  -->
        <ActivityIndicator
            Grid.Row="2"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />

        <!--  Empty  -->
        <VerticalStackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="14"
            VerticalOptions="Center">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource StatStudentBg},
                                                  Dark={StaticResource StatStudentBgDark}}"
                HeightRequest="72"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 36"
                StrokeThickness="0"
                WidthRequest="72">
                <Image
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Source="student.png"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Purple}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No students found"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />
            <Button
                Padding="24,0"
                Command="{Binding AddCommand}"
                HorizontalOptions="Center"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource PrimaryButton}"
                Text="+ Add Student" />
        </VerticalStackLayout>

        <!--  List  -->
        <CollectionView
            Grid.Row="2"
            Margin="14,4,14,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Student.StudentItem">
                    <Border Style="{StaticResource ListItemBorder}">
                        <Grid
                            Padding="14"
                            ColumnDefinitions="Auto,*,Auto"
                            ColumnSpacing="12">
                            <Border
                                Grid.Column="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatStudentBg},
                                                                  Dark={StaticResource StatStudentBgDark}}"
                                HeightRequest="44"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="44">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    Text="{Binding InitialsDisplay}"
                                    TextColor="{StaticResource Purple}"
                                    VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="4"
                                VerticalOptions="Center">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    Text="{Binding FullName}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                Dark={StaticResource TextPrimaryDark}}" />
                                <Label FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span
                                                FontAttributes="Bold"
                                                Text="{Binding StudentCode}"
                                                TextColor="{StaticResource Purple}" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding Standard}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label
                                    FontSize="11"
                                    Text="{Binding BusDisplay}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                Dark={StaticResource TextMutedDark}}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="8"
                                VerticalOptions="Center">
                                <Border
                                    Padding="8,3"
                                    BackgroundColor="{Binding StatusBgColor}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding StatusLabel}"
                                        TextColor="{Binding StatusTextColor}" />
                                </Border>
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="22"
                                        Source="edit.png"
                                        WidthRequest="22">
                                        <ImageButton.Behaviors>
                                            <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                        </ImageButton.Behaviors>
                                    </ImageButton>
                                    <ImageButton
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminStudentListViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="22"
                                        Source="delete.png"
                                        WidthRequest="22">
                                        <ImageButton.Behaviors>
                                            <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                        </ImageButton.Behaviors>
                                    </ImageButton>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <ActivityIndicator
                    Margin="0,8"
                    IsRunning="{Binding CanLoadMore}"
                    IsVisible="{Binding CanLoadMore}" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</views:ViewBase>