<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.SuperAdmin.AdminTripListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.SuperAdmin"
    x:DataType="vm:AdminTripListViewModel"
    x:TypeArguments="vm:AdminTripListViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid Padding="0,0,8,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="18"
                Text="Trips"
                TextColor="White"
                VerticalOptions="Center" />
            <Border
                Grid.Column="1"
                Padding="8"
                BackgroundColor="White"
                IsVisible="{Binding CanAdd}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddCommand}" />
                </Border.GestureRecognizers>
                <Image
                    HeightRequest="20"
                    Source="add.png"
                    WidthRequest="20">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                    </Image.Behaviors>
                </Image>
            </Border>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!--  Date filter  -->
        <Border
            Grid.Row="0"
            Margin="14,12,14,4"
            Style="{StaticResource SearchBarBorder}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Image
                    Grid.Column="0"
                    HeightRequest="18"
                    Source="calendar_check.png"
                    VerticalOptions="Center"
                    WidthRequest="18">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextMutedDark}}" />
                    </Image.Behaviors>
                </Image>
                <DatePicker
                    Grid.Column="1"
                    Date="{Binding SelectedDate}"
                    FontSize="15"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                Dark={StaticResource TextPrimaryDark}}" />
            </Grid>
        </Border>

        <!--  Status filter chips  -->
        <ScrollView
            Grid.Row="1"
            Margin="14,0,14,4"
            HorizontalScrollBarVisibility="Never"
            Orientation="Horizontal">
            <HorizontalStackLayout Spacing="8">
                <Border
                    Padding="14,6"
                    BackgroundColor="{Binding SelectedStatus, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='All'}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="All" />
                    </Border.GestureRecognizers>
                    <Label
                        FontSize="12"
                        Text="All"
                        TextColor="{Binding SelectedStatus, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='All'}" />
                </Border>
                <Border
                    Padding="14,6"
                    BackgroundColor="{Binding SelectedStatus, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Scheduled'}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Scheduled" />
                    </Border.GestureRecognizers>
                    <Label
                        FontSize="12"
                        Text="Scheduled"
                        TextColor="{Binding SelectedStatus, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Scheduled'}" />
                </Border>
                <Border
                    Padding="14,6"
                    BackgroundColor="{Binding SelectedStatus, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='InProgress'}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="InProgress" />
                    </Border.GestureRecognizers>
                    <Label
                        FontSize="12"
                        Text="In Progress"
                        TextColor="{Binding SelectedStatus, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='InProgress'}" />
                </Border>
                <Border
                    Padding="14,6"
                    BackgroundColor="{Binding SelectedStatus, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Completed'}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Completed" />
                    </Border.GestureRecognizers>
                    <Label
                        FontSize="12"
                        Text="Completed"
                        TextColor="{Binding SelectedStatus, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Completed'}" />
                </Border>
                <Border
                    Padding="14,6"
                    BackgroundColor="{Binding SelectedStatus, Converter={StaticResource FilterChipColorConverter}, ConverterParameter='Cancelled'}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Cancelled" />
                    </Border.GestureRecognizers>
                    <Label
                        FontSize="12"
                        Text="Cancelled"
                        TextColor="{Binding SelectedStatus, Converter={StaticResource FilterChipTextConverter}, ConverterParameter='Cancelled'}" />
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!--  Error  -->
        <Border
            Grid.Row="3"
            Margin="14,0"
            IsVisible="{Binding HasError}"
            Style="{StaticResource ErrorBannerBorder}">
            <Label
                FontSize="13"
                Text="{Binding ErrorMessage}"
                TextColor="{AppThemeBinding Light={StaticResource ErrorTextLight},
                                            Dark={StaticResource ErrorTextDark}}" />
        </Border>
        <!--  Busy  -->
        <ActivityIndicator
            Grid.Row="3"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />

        <!--  Empty  -->
        <VerticalStackLayout
            Grid.Row="3"
            HorizontalOptions="Center"
            IsVisible="{Binding IsEmpty}"
            Spacing="14"
            VerticalOptions="Center">
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                  Dark={StaticResource StatTripBgDark}}"
                HeightRequest="72"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 36"
                StrokeThickness="0"
                WidthRequest="72">
                <Image
                    HeightRequest="36"
                    HorizontalOptions="Center"
                    Source="trip.png"
                    VerticalOptions="Center"
                    WidthRequest="36">
                    <Image.Behaviors>
                        <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                    </Image.Behaviors>
                </Image>
            </Border>
            <Label
                FontSize="16"
                HorizontalOptions="Center"
                Text="No trips found"
                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                            Dark={StaticResource TextSecondaryDark}}" />
            <Button
                Padding="24,0"
                Command="{Binding AddCommand}"
                HorizontalOptions="Center"
                IsVisible="{Binding CanAdd}"
                Style="{StaticResource PrimaryButton}"
                Text="+ New Trip" />
        </VerticalStackLayout>

        <!--  List  -->
        <CollectionView
            Grid.Row="3"
            Margin="14,4,14,0"
            ItemsSource="{Binding Items}"
            RemainingItemsThreshold="3"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Trip.TripItem">
                    <Border Style="{StaticResource ListItemBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminTripListViewModel}}, Path=DetailCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid
                            Padding="14"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="10">

                            <!--  Row 0: trip info  -->
                            <Grid
                                Grid.Row="0"
                                ColumnDefinitions="Auto,*,Auto"
                                ColumnSpacing="12">
                                <Border
                                    Grid.Column="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                                      Dark={StaticResource StatTripBgDark}}"
                                    Style="{StaticResource IconTileBorder}"
                                    VerticalOptions="Center">
                                    <Image
                                        HeightRequest="22"
                                        HorizontalOptions="Center"
                                        Source="trip.png"
                                        VerticalOptions="Center"
                                        WidthRequest="22">
                                        <Image.Behaviors>
                                            <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                        </Image.Behaviors>
                                    </Image>
                                </Border>
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="4"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                    Dark={StaticResource TextPrimaryDark}}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding TripTypeIcon}" />
                                                <Span Text=" " />
                                                <Span FontAttributes="Bold" Text="{Binding TripType}" />
                                                <Span Text=" – " />
                                                <Span Text="{Binding TripDate}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="12">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span
                                                    FontAttributes="Bold"
                                                    Text="{Binding BusNumber}"
                                                    TextColor="{StaticResource Primary}" />
                                                <Span Text=" · " TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                                <Span Text="{Binding DriverName}" TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label
                                        FontSize="11"
                                        Text="{Binding RouteName}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextMutedDark}}" />
                                </VerticalStackLayout>
                                <Border
                                    Grid.Column="2"
                                    Padding="8,4"
                                    BackgroundColor="{Binding StatusColor, Converter={StaticResource ColorToTranslucentConverter}}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 20"
                                    VerticalOptions="Start">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="10"
                                        Text="{Binding Status}"
                                        TextColor="{Binding StatusColor}" />
                                </Border>
                            </Grid>

                            <!--  Row 1: 📍 Track Live button — only when InProgress  -->
                            <Button
                                Grid.Row="1"
                                BackgroundColor="#6366f1"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminTripListViewModel}}, Path=TrackLiveCommand}"
                                CommandParameter="{Binding .}"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="38"
                                HorizontalOptions="Fill"
                                IsVisible="{Binding Status, Converter={StaticResource StatusToEndVisible}}"
                                Text="📍 Track Live"
                                TextColor="White" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <ActivityIndicator
                    Margin="0,8"
                    IsRunning="{Binding CanLoadMore}"
                    IsVisible="{Binding CanLoadMore}" />
            </CollectionView.Footer>
        </CollectionView>
    </Grid>
</views:ViewBase>