<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Student.StudentAvailabilityPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Student"
    Title="My Availability"
    x:DataType="vm:StudentAvailabilityViewModel"
    x:TypeArguments="vm:StudentAvailabilityViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>


    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,32" Spacing="16">

            <!--  Header card  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource NavBarBg}, Dark={StaticResource DrawerBgDark}}"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0">
                <VerticalStackLayout Padding="20" Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="📅 Set Availability"
                        TextColor="White" />
                    <Label
                        FontSize="13"
                        Text="Let your coordinator know when you'll be travelling."
                        TextColor="{StaticResource HeroCardSubText}" />
                </VerticalStackLayout>
            </Border>

            <!--  Date picker  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Date"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <DatePicker
                        BackgroundColor="Transparent"
                        Date="{Binding SelectedDate}"
                        FontSize="15"
                        MinimumDate="{Binding MinimumDate}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Morning toggle  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <Grid Padding="16" ColumnDefinitions="Auto,*,Auto">
                    <Label
                        Grid.Column="0"
                        FontSize="24"
                        Text="🌅"
                        VerticalOptions="Center" />
                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="12,0"
                        Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Morning Trip"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="12"
                            Text="Available for pickup"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                    <Switch
                        Grid.Column="2"
                        IsToggled="{Binding MorningAvailable}"
                        OnColor="{StaticResource Primary}"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--  Evening toggle  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <Grid Padding="16" ColumnDefinitions="Auto,*,Auto">
                    <Label
                        Grid.Column="0"
                        FontSize="24"
                        Text="🌆"
                        VerticalOptions="Center" />
                    <VerticalStackLayout
                        Grid.Column="1"
                        Margin="12,0"
                        Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="Evening Trip"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label
                            FontSize="12"
                            Text="Available for drop-off"
                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                    <Switch
                        Grid.Column="2"
                        IsToggled="{Binding EveningAvailable}"
                        OnColor="{StaticResource Primary}"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

            <!--  Reason  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="1">
                <VerticalStackLayout Padding="16" Spacing="8">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="Reason (optional)"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Editor
                        AutoSize="TextChanges"
                        BackgroundColor="Transparent"
                        MinimumHeightRequest="80"
                        Placeholder="e.g. School holiday, sick leave…"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}"
                        Text="{Binding Reason}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                </VerticalStackLayout>
            </Border>

            <!--  Error  -->
            <Border
                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBgLight}, Dark={StaticResource ErrorBannerBgDark}}"
                IsVisible="{Binding HasError}"
                Stroke="{AppThemeBinding Light={StaticResource ErrorBannerBorderLight}, Dark={StaticResource ErrorBannerBorderDark}}"
                StrokeShape="RoundRectangle 10"
                StrokeThickness="1">
                <Label
                    Padding="12,8"
                    FontSize="13"
                    Text="{Binding ErrorMessage}"
                    TextColor="{StaticResource Danger}" />
            </Border>

            <!--  Save button  -->
            <Button
                BackgroundColor="{StaticResource Primary}"
                Command="{Binding SaveCommand}"
                CornerRadius="14"
                FontAttributes="Bold"
                FontSize="16"
                HeightRequest="52"
                Text="Save Availability"
                TextColor="White">
                <Button.Triggers>
                    <DataTrigger
                        Binding="{Binding IsBusy}"
                        TargetType="Button"
                        Value="True">
                        <Setter Property="Text" Value="Saving…" />
                        <Setter Property="IsEnabled" Value="False" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <ActivityIndicator
                HorizontalOptions="Center"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>

</views:ViewBase>
