<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Student.StudentTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Student"
    Title="Track My Bus"
    x:DataType="vm:StudentTrackingViewModel"
    x:TypeArguments="vm:StudentTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="17"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Track My Bus"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!--  Live status bar  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,4"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                              Dark={StaticResource CardBgDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                     Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="1">
            <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg}, Dark={StaticResource StatTripBgDark}}"
                    HeightRequest="42"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="42">
                    <Image
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        Source="bus.png"
                        VerticalOptions="Center"
                        WidthRequest="22">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Image.Behaviors>
                    </Image>
                </Border>
                <VerticalStackLayout
                    Grid.Column="1"
                    Margin="0"
                    Spacing="3"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding StatusText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="12"
                        Text="{Binding SpeedText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                <Border
                    Grid.Column="2"
                    Padding="10,5"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Border.Triggers>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="True">
                            <Setter Property="BackgroundColor" Value="#14532d" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource StatTripBgDark}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label FontAttributes="Bold" FontSize="12">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="&#x25CF; LIVE" />
                                <Setter Property="TextColor" Value="#4ade80" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="False">
                                <Setter Property="Text" Value="Offline" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <!--  Map placeholder  -->
        <Border
            Grid.Row="1"
            Margin="12,4"
            BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
            HeightRequest="220"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenLiveMapCommand}" />
            </Border.GestureRecognizers>
            <Grid>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="8"
                    VerticalOptions="Center">
                    <Border
                        BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg}, Dark={StaticResource StatTripBgDark}}"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 36"
                        StrokeThickness="0"
                        WidthRequest="72">
                        <Image
                            HeightRequest="36"
                            HorizontalOptions="Center"
                            Source="map_pin.png"
                            VerticalOptions="Center"
                            WidthRequest="36">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                    <Label
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="Live Map"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                    <Label
                        FontSize="11"
                        HorizontalOptions="Center"
                        Text="Bus location updates every 10 seconds"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                <!--  Bus marker overlay  -->
                <Border
                    Padding="10"
                    BackgroundColor="{StaticResource Primary}"
                    HorizontalOptions="Center"
                    IsVisible="{Binding IsLive}"
                    Stroke="White"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="2"
                    VerticalOptions="Center"
                    HeightRequest="48"
                    WidthRequest="48">
                    <Image
                        HeightRequest="20"
                        Source="bus.png"
                        WidthRequest="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="White" />
                        </Image.Behaviors>
                    </Image>
                </Border>
            </Grid>
        </Border>

        <!--  Stop timeline  -->
        <Border
            Grid.Row="2"
            Margin="12,4"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="0">
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="0">
                    <Label
                        Margin="0,0,0,12"
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="Route Stops"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

                    <CollectionView ItemsSource="{Binding Stops}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                Margin="0,12"
                                FontSize="13"
                                HorizontalOptions="Center"
                                Text="No stop data yet"
                                TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Tracking.StopStatus">
                                <Grid
                                    Margin="0,0,0,4"
                                    ColumnDefinitions="Auto,12,*"
                                    RowDefinitions="Auto,Auto">

                                    <!--  Timeline dot  -->
                                    <Border
                                        Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        BackgroundColor="{Binding StatusColor}"
                                        HeightRequest="28"
                                        HorizontalOptions="Center"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        VerticalOptions="Start"
                                        WidthRequest="28">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="11"
                                            HorizontalOptions="Center"
                                            Text="{Binding StopOrder}"
                                            TextColor="White"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <!--  Connector line  -->
                                    <BoxView
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
                                        HeightRequest="14"
                                        HorizontalOptions="Center"
                                        WidthRequest="2" />

                                    <!--  Stop info  -->
                                    <Label
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Margin="0,2,0,0"
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="{Binding StopName}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        FontSize="11"
                                        Text="{Binding Status}"
                                        TextColor="{Binding StatusColor}" />

                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <!--  Bottom info bar  -->
        <Border
            Grid.Row="3"
            Margin="12,4,12,12"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">
            <Grid Padding="16,12" ColumnDefinitions="*,*,*">
                <VerticalStackLayout
                    Grid.Column="0"
                    HorizontalOptions="Center"
                    Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding BusLat, StringFormat='{0:F4}'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="10"
                        HorizontalOptions="Center"
                        Text="Latitude"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                <VerticalStackLayout
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding BusLng, StringFormat='{0:F4}'}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="10"
                        HorizontalOptions="Center"
                        Text="Longitude"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                <VerticalStackLayout
                    Grid.Column="2"
                    HorizontalOptions="Center"
                    Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding SpeedText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="10"
                        HorizontalOptions="Center"
                        Text="Speed"
                        TextColor="{AppThemeBinding Light={StaticResource TextMuted}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>

</views:ViewBase>
