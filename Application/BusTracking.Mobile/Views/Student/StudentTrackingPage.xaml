<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Student.StudentTrackingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:models="clr-namespace:BusTracking.Mobile.Models"
    xmlns:sfBottomSheet="clr-namespace:Syncfusion.Maui.Toolkit.BottomSheet;assembly=Syncfusion.Maui.Toolkit"
    xmlns:tracking="clr-namespace:BusTracking.Mobile.Models.Tracking"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Student"
    Title="Track My Bus"
    x:DataType="vm:StudentTrackingViewModel"
    x:TypeArguments="vm:StudentTrackingViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="17"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Track My Bus"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <!--  Full-screen layout: Top status bar + Map fills middle + BottomSheet for Route Stops  -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!--  Row 0 - Live status bar  -->
        <Border
            Grid.Row="0"
            Margin="12,12,12,6"
            BackgroundColor="{AppThemeBinding Light={StaticResource CardBg},
                                              Dark={StaticResource CardBgDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderColor},
                                     Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="1">
            <Grid
                Padding="14,12"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="12">
                <Border
                    Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                      Dark={StaticResource StatTripBgDark}}"
                    HeightRequest="42"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="42">
                    <Image
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        Source="bus.png"
                        VerticalOptions="Center"
                        WidthRequest="22">
                        <Image.Behaviors>
                            <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                        </Image.Behaviors>
                    </Image>
                </Border>
                <VerticalStackLayout
                    Grid.Column="1"
                    Margin="0"
                    Spacing="3"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="15"
                        Text="{Binding StatusText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                    Dark={StaticResource TextPrimaryDark}}" />
                    <Label
                        FontSize="12"
                        Text="{Binding SpeedText}"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                    Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
                <Border
                    Grid.Column="2"
                    Padding="10,5"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Border.Triggers>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="True">
                            <Setter Property="BackgroundColor" Value="#14532d" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding IsLive}"
                            TargetType="Border"
                            Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource StatTripBgDark}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label FontAttributes="Bold" FontSize="12">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="Text" Value="&#x25CF; LIVE" />
                                <Setter Property="TextColor" Value="#4ade80" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{Binding IsLive}"
                                TargetType="Label"
                                Value="False">
                                <Setter Property="Text" Value="Offline" />
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <!--  Row 1 - Full Height Interactive Map  -->
        <Border
            Grid.Row="1"
            Margin="12,2"
            BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor},
                                              Dark={StaticResource BorderColorDark}}"
            StrokeShape="RoundRectangle 20"
            StrokeThickness="0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenLiveMapCommand}" />
            </Border.GestureRecognizers>
            <Grid>
                <WebView
                    x:Name="MapWebView"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Grid>
        </Border>

        <!--  Row 2 - Bottom Bar handle to expand Route Stops  -->
        <Border
            Grid.Row="2"
            Margin="12,4,12,12"
            Padding="16,12"
            BackgroundColor="{AppThemeBinding Light=White,
                                              Dark={StaticResource CardBgDark}}"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="0"
            VerticalOptions="End">
            <Border.Shadow>
                <Shadow
                    Brush="#30000000"
                    Radius="12"
                    Offset="0,-2" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleSheetCommand}" />
                </Grid.GestureRecognizers>
                <Label
                    Grid.Column="0"
                    FontAttributes="Bold"
                    FontSize="15"
                    Text="Route Stops"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                Dark={StaticResource TextPrimaryDark}}"
                    VerticalOptions="Center" />
                <Border
                    Grid.Column="1"
                    Padding="10,4"
                    BackgroundColor="{StaticResource PrimaryLight}"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="11"
                        Text="{Binding Stops.Count, StringFormat='Stops: {0}'}"
                        TextColor="{StaticResource Primary}" />
                </Border>
                <Image
                    Grid.Column="2"
                    HeightRequest="20"
                    Source="chevron_up.png"
                    VerticalOptions="Center"
                    WidthRequest="20" />
            </Grid>
        </Border>

        <!--  SYNCFUSION BOTTOM SHEET for Route Stops  -->
        <sfBottomSheet:SfBottomSheet
            x:Name="StopsBottomSheet"
            Grid.RowSpan="3"
            Background="{AppThemeBinding Light=White,
                                         Dark={StaticResource CardBgDark}}"
            CornerRadius="24"
            FullExpandedRatio="0.85"
            HalfExpandedRatio="0.60"
            IsModal="False"
            IsOpen="{Binding IsSheetExpanded, Mode=TwoWay}">
            <sfBottomSheet:SfBottomSheet.BottomSheetContent>
                <Grid BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBgDark}}" RowDefinitions="Auto,*">

                    <!--  Top Header with Title, Badge & Close (X) Button  -->
                    <Grid
                        Grid.Row="0"
                        Padding="16,14"
                        BackgroundColor="{AppThemeBinding Light=White,
                                                          Dark={StaticResource CardBgDark}}"
                        ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="10">
                        <Label
                            Grid.Column="0"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="Route Stops"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                        Dark={StaticResource TextPrimaryDark}}"
                            VerticalOptions="Center" />

                        <Border
                            Grid.Column="1"
                            Padding="10,4"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="{Binding Stops.Count, StringFormat='Stops: {0}'}"
                                TextColor="{StaticResource Primary}" />
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="6"
                            BackgroundColor="{AppThemeBinding Light=#F1F5F9,
                                                              Dark=#1E293B}"
                            HeightRequest="32"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="32">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleSheetCommand}" />
                            </Border.GestureRecognizers>
                            <Image
                                HeightRequest="16"
                                HorizontalOptions="Center"
                                Source="close.png"
                                VerticalOptions="Center"
                                WidthRequest="16" />
                        </Border>
                    </Grid>

                    <!--  Scrollable Route Stops Timeline  -->
                    <ScrollView Grid.Row="1" Padding="16,4,16,16">
                        <VerticalStackLayout Spacing="12">
                            <CollectionView ItemsSource="{Binding Stops}">
                                <CollectionView.EmptyView>
                                    <Label
                                        Margin="0,12"
                                        FontSize="13"
                                        HorizontalOptions="Center"
                                        Text="No stop data available for this trip."
                                        TextColor="{AppThemeBinding Light={StaticResource TextMuted},
                                                                    Dark={StaticResource TextSecondaryDark}}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout ItemSpacing="0" Orientation="Vertical" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="tracking:StopStatus">
                                        <Grid Padding="14,10" ColumnDefinitions="28,12,*,Auto">
                                            <Border
                                                Grid.Column="0"
                                                BackgroundColor="{Binding StatusColor}"
                                                HeightRequest="28"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                WidthRequest="28">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="11"
                                                    HorizontalOptions="Center"
                                                    Text="{Binding StopOrder}"
                                                    TextColor="White"
                                                    VerticalOptions="Center" />
                                            </Border>
                                            <Label
                                                Grid.Column="2"
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                Text="{Binding StopName}"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                            Dark={StaticResource TextPrimaryDark}}"
                                                VerticalOptions="Center" />
                                            <Border
                                                Grid.Column="3"
                                                Padding="8,3"
                                                BackgroundColor="{Binding StatusColor}"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                VerticalOptions="Center">
                                                <Label
                                                    FontSize="10"
                                                    Text="{Binding Status}"
                                                    TextColor="White" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </sfBottomSheet:SfBottomSheet.BottomSheetContent>
        </sfBottomSheet:SfBottomSheet>

    </Grid>

</views:ViewBase>
