<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Student.StudentDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Student"
    Title="My Dashboard"
    x:DataType="vm:StudentDashboardViewModel"
    x:TypeArguments="vm:StudentDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="LightContent" />
    </views:ViewBase.Behaviors>


    <Shell.TitleView>
        <Grid Padding="0,0,12,0" ColumnDefinitions="*,Auto">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="17"
                Text="Student Portal"
                TextColor="White"
                VerticalOptions="Center" />
            <ImageButton
                Grid.Column="1"
                BackgroundColor="Transparent"
                Command="{Binding LogoutCommand}"
                Source="logout.png"
                WidthRequest="22" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,32" Spacing="16">

                <Label
                    FontAttributes="Bold"
                    FontSize="22"
                    Text="{Binding WelcomeText}"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

                <!--  Bus info card  -->
                <Border
                    Padding="20"
                    BackgroundColor="{AppThemeBinding Light={StaticResource HeroCardBgLight}, Dark={StaticResource HeroCardBgDark}}"
                    StrokeShape="RoundRectangle 20">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="My Bus"
                            TextColor="{StaticResource HeroCardSubText}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="20"
                            Text="{Binding BusDisplay}"
                            TextColor="White" />
                        <Label
                            FontSize="13"
                            Text="{Binding StopDisplay}"
                            TextColor="{StaticResource HeroCardSubText}" />
                        <BoxView
                            Margin="0,4"
                            BackgroundColor="#ffffff22"
                            HeightRequest="1" />
                        <Label
                            FontSize="14"
                            Text="{Binding TripStatus}"
                            TextColor="White" />
                    </VerticalStackLayout>
                </Border>

                <!--  Action buttons  -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="{StaticResource Primary}"
                        Command="{Binding TrackBusCommand}"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        HeightRequest="54"
                        Text="🚌 Track Bus"
                        TextColor="White" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1.5"
                        Command="{Binding ViewAvailabilityCommand}"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        HeightRequest="54"
                        Text="📅 Availability"
                        TextColor="{StaticResource Primary}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
