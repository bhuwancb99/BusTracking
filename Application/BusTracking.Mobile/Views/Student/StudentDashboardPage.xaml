<?xml version="1.0" encoding="utf-8" ?>
<views:ViewBase
    x:Class="BusTracking.Mobile.Views.Student.StudentDashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:views="clr-namespace:BusTracking.Mobile.Views"
    xmlns:vm="clr-namespace:BusTracking.Mobile.Viewmodels.Student"
    Title="My Dashboard"
    x:DataType="vm:StudentDashboardViewModel"
    x:TypeArguments="vm:StudentDashboardViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBg},
                                      Dark={StaticResource PageBgDark}}">

    <views:ViewBase.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource LoginPageBgLight}, Dark={StaticResource LoginPageBgDark}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </views:ViewBase.Behaviors>

    <Shell.TitleView>
        <Grid HorizontalOptions="Center" VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="Student Portal"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                            Dark=White}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="16,20,16,40" Spacing="20">

                <!--  Welcome Header  -->
                <VerticalStackLayout Spacing="4">
                    <Label Style="{StaticResource HeadingLabel}" Text="{Binding WelcomeText}" />
                    <Label Style="{StaticResource SubLabel}" Text="Welcome back to your school bus portal" />
                </VerticalStackLayout>

                <!--  Bus info card  -->
                <Border Style="{StaticResource StatCardBorder}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DrawerItemActiveLight}, Dark=#0c1f4e}" />
                            <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Padding="4,2" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout
                            Grid.Column="0"
                            Spacing="6"
                            VerticalOptions="Center">
                            <Border
                                Padding="6,3"
                                BackgroundColor="{StaticResource Primary}"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="0">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="9"
                                    Text="MY BUS"
                                    TextColor="White" />
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="20"
                                Text="{Binding BusDisplay}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark=White}" />
                            <Label
                                FontSize="13"
                                Text="{Binding StopDisplay}"
                                TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                            Dark={StaticResource TextSecondaryDark}}" />
                            <BoxView
                                Margin="0,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource BorderColor},
                                                                  Dark=#ffffff22}"
                                HeightRequest="1" />
                            <Label
                                FontAttributes="Italic"
                                FontSize="13"
                                Text="{Binding TripStatus}"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                            Dark=White}" />
                        </VerticalStackLayout>
                        <Border
                            Grid.Column="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                              Dark={StaticResource StatBusBgDark}}"
                            HeightRequest="56"
                            StrokeShape="RoundRectangle 28"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="56">
                            <Image
                                HeightRequest="26"
                                HorizontalOptions="Center"
                                Source="bus.png"
                                VerticalOptions="Center"
                                WidthRequest="26">
                                <Image.Behaviors>
                                    <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                    </Grid>
                </Border>

                <!--  Bento Grid Action Cards  -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                    <!--  Track Bus Card  -->
                    <Border Grid.Column="0" Style="{StaticResource StatCardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TrackBusCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DangerLight}, Dark=#4a070a}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Border
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatTripBg},
                                                                  Dark={StaticResource StatTripBgDark}}"
                                HeightRequest="44"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Image
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="map_pin.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Track Bus"
                                TextColor="{StaticResource Danger}" />
                            <Label
                                HorizontalOptions="Center"
                                Style="{StaticResource CaptionLabel}"
                                Text="Live Location" />
                            <Border
                                Padding="6,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                                  Dark={StaticResource StatTripBgDark}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    HorizontalOptions="Center"
                                    Text="Track"
                                    TextColor="{StaticResource Danger}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!--  My Availability Card  -->
                    <Border Grid.Column="1" Style="{StaticResource StatCardBorder}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAvailabilityCommand}" />
                        </Border.GestureRecognizers>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0.0" Color="{AppThemeBinding Light={StaticResource DrawerItemActiveLight}, Dark=#0c1f4e}" />
                                <GradientStop Offset="1.0" Color="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Border
                                BackgroundColor="{AppThemeBinding Light={StaticResource StatBusBg},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                HeightRequest="44"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 22"
                                StrokeThickness="0"
                                WidthRequest="44">
                                <Image
                                    HeightRequest="22"
                                    HorizontalOptions="Center"
                                    Source="calendar_check.png"
                                    VerticalOptions="Center"
                                    WidthRequest="22">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Availability"
                                TextColor="{StaticResource Primary}" />
                            <Label
                                HorizontalOptions="Center"
                                Style="{StaticResource CaptionLabel}"
                                Text="Leaves &amp; Trips" />
                            <Border
                                Padding="6,2"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight},
                                                                  Dark={StaticResource StatBusBgDark}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 8">
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    HorizontalOptions="Center"
                                    Text="Manage"
                                    TextColor="{StaticResource Primary}" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</views:ViewBase>
