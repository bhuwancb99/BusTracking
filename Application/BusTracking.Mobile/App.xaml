<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="BusTracking.Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:BusTracking.Mobile.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!--  ── Converters ───────────────────────────────────────  -->
            <converters:InvertBoolConverter x:Key="InvertBool" />
            <converters:NullToBoolConverter x:Key="NullToBool" />
            <converters:NullToVisibleConverter x:Key="NullToVisible" />
            <converters:BoolToEyeIconConverter x:Key="BoolToEyeIcon" />
            <converters:StatusToStartVisibleConverter x:Key="StatusToStartVisible" />
            <converters:StatusToEndVisibleConverter x:Key="StatusToEndVisible" />
            <converters:BoolToStatusColorConverter x:Key="BoolToStatusColor" />
            <converters:PlatformToColorConverter x:Key="PlatformToColor" />
            <converters:StringToBoolConverter x:Key="StringToBool" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/BusTrackingAppColors.xaml" />
                <ResourceDictionary Source="Resources/Styles/BusTrackingAppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>

</Application>
