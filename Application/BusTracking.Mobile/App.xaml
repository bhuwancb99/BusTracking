<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="BusTracking.Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:BusTracking.Mobile.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!--  ── Converters ─────────────────────────────────────────  -->
            <converters:InvertBoolConverter x:Key="InvertBool" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:InvertBoolConverter x:Key="Invert" />
            <converters:NullToBoolConverter x:Key="NullToBool" />
            <converters:NullToVisibleConverter x:Key="NullToVisible" />
            <converters:BoolToEyeIconConverter x:Key="BoolToEyeIcon" />
            <converters:StatusToStartVisibleConverter x:Key="StatusToStartVisible" />
            <converters:StatusToEndVisibleConverter x:Key="StatusToEndVisible" />
            <converters:BoolToStatusColorConverter x:Key="BoolToStatusColor" />
            <converters:PlatformToColorConverter x:Key="PlatformToColor" />
            <converters:PlatformToColorConverter x:Key="PlatformToColorConverter" />
            <converters:StringToBoolConverter x:Key="StringToBool" />
            <converters:FilterChipColorConverter x:Key="FilterChipColorConverter" />
            <converters:FilterChipTextConverter x:Key="FilterChipTextConverter" />
            <converters:ColorToTranslucentConverter x:Key="ColorToTranslucentConverter" />
            <converters:DrawerItemBgConverter x:Key="DrawerItemBgConverter" />
            <converters:DrawerIconColorConverter x:Key="DrawerIconColorConverter" />
            <converters:DrawerIconTintConverter x:Key="DrawerIconTintConverter" />
            <converters:DrawerTextColorConverter x:Key="DrawerTextColorConverter" />
            <converters:DrawerFontAttribConverter x:Key="DrawerFontAttribConverter" />
            <converters:AllTrueMultiConverter x:Key="AllTrueConverter" />
            <converters:StringToInvertBoolConverter x:Key="StringToInvertBool" />
            <converters:NullableTimeSpanConverter x:Key="NullableTimeSpan" />
            <converters:EqualsToPendingConverter x:Key="EqualsToPending" />
            <converters:EqualsToReachedConverter x:Key="EqualsToReached" />
            <converters:CountToHeightConverter x:Key="CountToHeight" />
            <converters:StudentPickedUpTupleConverter x:Key="StudentPickedUpTuple" />
            <converters:StudentNoShowTupleConverter x:Key="StudentNoShowTuple" />


            <ResourceDictionary.MergedDictionaries>
                <!--  1. MAUI default platform colors (Gray*, White, Black, etc.)  -->
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />

                <!--  2. BusTrack brand colors — overrides Primary, PageBg, NavBarBg, etc.  -->
                <ResourceDictionary Source="Resources/Styles/BusTrackingAppColors.xaml" />

                <!--  3. MAUI control styles — depends on Colors and BusTrackingAppColors  -->
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />

                <!--  4. BusTrack named styles — depends on BusTrackingAppColors  -->
                <ResourceDictionary Source="Resources/Styles/BusTrackingAppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>

</Application>
