<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BusTracking.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:admin="clr-namespace:BusTracking.Mobile.Views.SuperAdmin"
    xmlns:auth="clr-namespace:BusTracking.Mobile.Views.Auth"
    xmlns:common="clr-namespace:BusTracking.Mobile.Views.Common"
    xmlns:coord="clr-namespace:BusTracking.Mobile.Views.Coordinator"
    xmlns:driver="clr-namespace:BusTracking.Mobile.Views.Driver"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
    xmlns:model="clr-namespace:BusTracking.Mobile.Models"
    xmlns:parent="clr-namespace:BusTracking.Mobile.Views.Parent"
    xmlns:student="clr-namespace:BusTracking.Mobile.Views.Student"
    FlyoutBehavior="Flyout"
    FlyoutWidth="270"
    Shell.BackgroundColor="{AppThemeBinding Light={StaticResource LoginPageBgLight},
                                            Dark={StaticResource LoginPageBgDark}}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#94a3b8">

    <!--
        ══════════════════════════════════════════════════════════
        CUSTOM FLYOUT CONTENT
        Using Shell.FlyoutContent instead of dynamic FlyoutItems
        because MAUI's dynamic FlyoutItem API requires ShellContent
        children wired at XAML-parse time — adding them at runtime
        leaves them invisible and navigation crashes.
        Here we own the entire drawer UI and call GoToAsync directly.
        ══════════════════════════════════════════════════════════
    -->
    <Shell.FlyoutContent>
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource DrawerBg}, Dark={StaticResource DrawerBgDark}}" RowDefinitions="Auto,*,Auto">

            <!--  ══ HEADER ══════════════════════════════════════════════════  -->
            <Grid
                Grid.Row="0"
                Padding="20,52,20,0"
                RowDefinitions="Auto,Auto,Auto">

                <!--  Brand row  -->
                <HorizontalStackLayout Grid.Row="0" Spacing="10">
                    <Border
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="36"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        WidthRequest="36">
                        <Image
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            Source="bus.png"
                            VerticalOptions="Center"
                            WidthRequest="20">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="White" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                    <Label VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span
                                    FontAttributes="Bold"
                                    FontSize="19"
                                    Text="BusTrack "
                                    TextColor="White" />
                                <Span
                                    FontSize="19"
                                    Text="Admin"
                                    TextColor="{StaticResource DrawerTextMuted}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>

                <!--  User avatar + info  -->
                <HorizontalStackLayout
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    Spacing="12">
                    <!--  Initials circle  -->
                    <Border
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="46"
                        StrokeShape="RoundRectangle 23"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        WidthRequest="46">
                        <Label
                            x:Name="LblInitials"
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalOptions="Center"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label
                            x:Name="LblUserName"
                            FontAttributes="Bold"
                            FontSize="14"
                            TextColor="White" />
                        <Border
                            Padding="8,3"
                            BackgroundColor="{StaticResource Accent}"
                            HorizontalOptions="Start"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0">
                            <Label
                                x:Name="LblRoleLabel"
                                FontAttributes="Bold"
                                FontSize="10"
                                TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!--  Divider  -->
                <BoxView
                    Grid.Row="2"
                    Margin="0,18,0,0"
                    BackgroundColor="{StaticResource DrawerDivider}"
                    HeightRequest="1" />
            </Grid>

            <!--  ══ NAV ITEMS ═══════════════════════════════════════════════  -->
            <CollectionView
                x:Name="MenuList"
                Grid.Row="1"
                Margin="0,6,0,0"
                SelectionChanged="OnMenuItemSelected"
                SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Common.FlyoutMenuItem">
                        <Border
                            Margin="10,2"
                            Padding="14,13"
                            BackgroundColor="{Binding IsActive, Converter={StaticResource DrawerItemBgConverter}}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="24,*" ColumnSpacing="14">
                                <Image
                                    x:Name="menuImage"
                                    Grid.Column="0"
                                    HeightRequest="20"
                                    Source="{Binding IconSvg}"
                                    VerticalOptions="Center"
                                    WidthRequest="20">
                                    <Image.Behaviors>
                                        <mct:IconTintColorBehavior BindingContext="{Binding Source={x:Reference menuImage}, Path=BindingContext}" TintColor="{Binding ., Converter={StaticResource DrawerIconTintConverter}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="{Binding IsActive, Converter={StaticResource DrawerFontAttribConverter}}"
                                    FontSize="14"
                                    Text="{Binding Title}"
                                    TextColor="{Binding IsActive, Converter={StaticResource DrawerTextColorConverter}}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--  ══ FOOTER / LOGOUT ══════════════════════════════════════════  -->
            <Grid
                Grid.Row="2"
                Padding="14,0,14,44"
                RowDefinitions="Auto,Auto">
                <BoxView
                    Grid.Row="0"
                    Margin="0,0,0,14"
                    BackgroundColor="{StaticResource DrawerDivider}"
                    HeightRequest="1" />
                <Border
                    Grid.Row="1"
                    Padding="16,14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight},
                                                      Dark={StaticResource CardBgDark}}"
                    Stroke="{StaticResource Danger}"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Image
                            HeightRequest="18"
                            Source="logout.png"
                            VerticalOptions="Center"
                            WidthRequest="18">
                            <Image.Behaviors>
                                <mct:IconTintColorBehavior TintColor="{StaticResource Danger}" />
                            </Image.Behaviors>
                        </Image>
                        <Label
                            FontAttributes="Bold"
                            FontSize="14"
                            Text="Logout"
                            TextColor="{StaticResource Danger}"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>

        </Grid>
    </Shell.FlyoutContent>

    <!--
        ══════════════════════════════════════════════════════════
        AUTH — never shown in flyout, no navbar
        ══════════════════════════════════════════════════════════
    -->
    <ShellContent
        ContentTemplate="{DataTemplate auth:LoginPage}"
        FlyoutItemIsVisible="False"
        Route="Login"
        Shell.FlyoutBehavior="Disabled"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate common:MaintenancePage}"
        FlyoutItemIsVisible="False"
        Route="Maintenance"
        Shell.FlyoutBehavior="Disabled"
        Shell.NavBarIsVisible="False" />

    <!--
        ══════════════════════════════════════════════════════════
        TOP-LEVEL PAGES — reachable via //RouteName from flyout menu.
        ONLY dashboards and list pages belong here.
        All detail/form pages are global routes in MauiProgram.cs
        and must NOT also appear here — double-registration breaks
        the back stack (back button stops working, GoBack crashes).
        ══════════════════════════════════════════════════════════
    -->

    <!--  Super Admin  -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate admin:AdminDashboardPage}"
        FlyoutItemIsVisible="False"
        Route="AdminDashboard" />
    <ShellContent
        Title="App Config"
        ContentTemplate="{DataTemplate admin:AdminConfigListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminConfigList" />
    <ShellContent
        Title="Bus Coordinators"
        ContentTemplate="{DataTemplate admin:AdminCoordinatorListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminCoordinatorList" />
    <ShellContent
        Title="Routes"
        ContentTemplate="{DataTemplate admin:AdminRouteListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminRouteList" />
    <ShellContent
        Title="Buses"
        ContentTemplate="{DataTemplate admin:AdminBusListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminBusList" />
    <ShellContent
        Title="Drivers"
        ContentTemplate="{DataTemplate admin:AdminDriverListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminDriverList" />
    <ShellContent
        Title="Parents"
        ContentTemplate="{DataTemplate admin:AdminParentListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminParentList" />
    <ShellContent
        Title="Students"
        ContentTemplate="{DataTemplate admin:AdminStudentListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminStudentList" />
    <ShellContent
        Title="Trips"
        ContentTemplate="{DataTemplate admin:AdminTripListPage}"
        FlyoutItemIsVisible="False"
        Route="AdminTripList" />

    <!--  Coordinator  -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate coord:CoordinatorDashboardPage}"
        FlyoutItemIsVisible="False"
        Route="CoordinatorDashboard" />
    <ShellContent
        Title="App Config"
        ContentTemplate="{DataTemplate coord:CoordConfigListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordConfigList" />
    <ShellContent
        Title="Bus Coordinators"
        ContentTemplate="{DataTemplate coord:CoordSubAdminListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordSubAdminList" />
    <ShellContent
        Title="Routes"
        ContentTemplate="{DataTemplate coord:CoordRouteListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordRouteList" />
    <ShellContent
        Title="Buses"
        ContentTemplate="{DataTemplate coord:CoordBusListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordBusList" />
    <ShellContent
        Title="Drivers"
        ContentTemplate="{DataTemplate coord:CoordDriverListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordDriverList" />
    <ShellContent
        Title="Parents"
        ContentTemplate="{DataTemplate coord:CoordParentListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordParentList" />
    <ShellContent
        Title="Students"
        ContentTemplate="{DataTemplate coord:CoordStudentListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordStudentList" />
    <ShellContent
        Title="Trips"
        ContentTemplate="{DataTemplate coord:CoordTripListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordTripList" />
    <ShellContent
        Title="Notifications"
        ContentTemplate="{DataTemplate coord:CoordNotificationListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordNotificationList" />
    <ShellContent
        Title="Help &amp; Support"
        ContentTemplate="{DataTemplate coord:CoordFeedbackListPage}"
        FlyoutItemIsVisible="False"
        Route="CoordFeedbackList" />

    <!--  Driver  -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate driver:DriverDashboardPage}"
        FlyoutItemIsVisible="False"
        Route="DriverDashboard" />
    <ShellContent
        Title="My Trips"
        ContentTemplate="{DataTemplate driver:DriverTripListPage}"
        FlyoutItemIsVisible="False"
        Route="DriverTripList" />
    <ShellContent
        Title="Live Tracking"
        ContentTemplate="{DataTemplate driver:DriverTrackingPage}"
        FlyoutItemIsVisible="False"
        Route="DriverTracking" />

    <!--  Parent  -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate parent:ParentDashboardPage}"
        FlyoutItemIsVisible="False"
        Route="ParentDashboard" />
    <ShellContent
        Title="Track Bus"
        ContentTemplate="{DataTemplate parent:ParentTrackingPage}"
        FlyoutItemIsVisible="False"
        Route="ParentTracking" />
    <ShellContent
        Title="Availability"
        ContentTemplate="{DataTemplate parent:ParentAvailabilityPage}"
        FlyoutItemIsVisible="False"
        Route="ParentAvailability" />
    <ShellContent
        Title="Help &amp; Support"
        ContentTemplate="{DataTemplate parent:ParentFeedbackPage}"
        FlyoutItemIsVisible="False"
        Route="ParentFeedback" />

    <!--  Student  -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate student:StudentDashboardPage}"
        FlyoutItemIsVisible="False"
        Route="StudentDashboard" />
    <ShellContent
        Title="Track My Bus"
        ContentTemplate="{DataTemplate student:StudentTrackingPage}"
        FlyoutItemIsVisible="False"
        Route="StudentTracking" />
    <ShellContent
        Title="My Availability"
        ContentTemplate="{DataTemplate student:StudentAvailabilityPage}"
        FlyoutItemIsVisible="False"
        Route="StudentAvailability" />

</Shell>
